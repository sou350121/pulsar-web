---
/**
 * src/pages/vla-deepdive/index.astro
 * VLA Deep Dive — 統一文章庫 + 方法族趨勢金融終端看板 + SOTA 排行。
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadVLASOTA, loadVLATheory, loadVLAGitHubArticles, loadLatestFieldState, loadFieldStateHistory, COMPETITION_PAIRS, loadEmergingTerms } from '../../utils/data';
import type { FamilyTimeSeries, EmergingTerm } from '../../utils/data';

const theory   = loadVLATheory(50);
const sota     = loadVLASOTA(30);
const ghAll    = loadVLAGitHubArticles(100);
const fieldState = loadLatestFieldState();
const history  = loadFieldStateHistory();
const emergingData = loadEmergingTerms();

const GITHUB_REPO         = 'https://github.com/sou350121/VLA-Handbook';
const GITHUB_THEORY_PATH  = `${GITHUB_REPO}/tree/main/theory`;
const GITHUB_SOTA_PATH    = 'https://sota.evomind-tech.com';

// 14-day cutoff
const cutoff = new Date(Date.now() - 14 * 86400000).toISOString().slice(0, 10);

// Deduplicate GitHub articles against theory articles (by title, case-insensitive)
const theoryTitles = new Set(theory.map(a => a.title.toLowerCase().trim()));
const dedupedGh = ghAll.filter(a => !theoryTitles.has(a.title.toLowerCase().trim()));

// Unified combined list (single data source)
const allCombined = [
  ...theory.map(a => ({
    title:    a.title,
    date:     a.date,
    html_url: a.html_url || a.url,
    topic:    a.target_dir?.replace('theory/', '') ?? 'general',
    source:   'pipeline' as const,
  })),
  ...dedupedGh.map(a => ({
    title:    a.title,
    date:     a.date,
    html_url: a.html_url || a.url,
    topic:    a.topic,
    source:   'github' as const,
  })),
].sort((a, b) => b.date.localeCompare(a.date));

// Split into recent (cards) and older (topic-grouped list)
const recentAll = allCombined.filter(a => a.date >= cutoff);
const olderAll  = allCombined.filter(a => a.date < cutoff);
const byTopicAll: Record<string, typeof olderAll> = {};
for (const a of olderAll) { (byTopicAll[a.topic] ??= []).push(a); }
const topics = Object.keys(byTopicAll).sort();

function dotDate(iso: string) {
  const [y, m, d] = iso.split('-');
  return `${y}.${m}.${d}`;
}

function vddRecency(dateStr: string): string {
  const now  = new Date();
  const d    = new Date(dateStr + 'T00:00:00+08:00');
  const diff = Math.floor((now.getTime() - d.getTime()) / 86400000);
  if (diff <= 0)  return '今天';
  if (diff === 1) return '昨天';
  return `${diff} 天前`;
}

// Group SOTA by benchmark
const sotaByBenchmark: Record<string, typeof sota> = {};
for (const s of sota) { (sotaByBenchmark[s.benchmark] ??= []).push(s); }
const benchmarks = Object.keys(sotaByBenchmark).sort();

// Method family display names (15 families)
const FAMILY_NAMES: Record<string, string> = {
  diffusion_policy:     'Diffusion Policy',
  flow_matching:        'Flow Matching',
  rl_finetuning:        'RL Fine-tuning',
  instruction_tuning:   'Instr. Tuning',
  world_model:          'World Model',
  tactile:              'Tactile',
  dexterous_hand:       'Dexterous Hand',
  cross_embodiment:     'Cross-Embodiment',
  sim_to_real:          'Sim-to-Real',
  long_horizon:         'Long Horizon',
  multi_task:           'Multi-Task',
  mobile_manipulation:  'Mobile Manip.',
  human_robot:          'Human-Robot',
  '3d_representation':  '3D Repr.',
  language_grounding:   'Lang. Grounding',
};

// Short names for competition pairs
const FAMILY_SHORT: Record<string, string> = {
  diffusion_policy:     'Diffusion Pol.',
  flow_matching:        'Flow Matching',
  rl_finetuning:        'RL Fine-tune',
  instruction_tuning:   'Instr. Tuning',
  world_model:          'World Model',
  tactile:              'Tactile',
  dexterous_hand:       'Dext. Hand',
  cross_embodiment:     'Cross-Embod.',
  sim_to_real:          'Sim2Real',
  long_horizon:         'Long Horizon',
  multi_task:           'Multi-Task',
  mobile_manipulation:  'Mobile Man.',
  human_robot:          'Human-Robot',
  '3d_representation':  '3D Repr.',
  language_grounding:   'Lang. Ground.',
};

// Build saturated benchmark set from field-state (prefix match: BENCHMARK/SPLIT → BENCHMARK)
const saturatedBenchmarks = new Set<string>();
if (fieldState?.benchmark_health) {
  for (const bh of fieldState.benchmark_health) {
    if (bh.status === 'saturated') {
      saturatedBenchmarks.add(bh.benchmark.split('/')[0]);
    }
  }
}

// --- Financial terminal helpers ---

// Adaptive sparkline dimensions — fixed total width, bars narrow as days grow
const SPARK_TOTAL_W = 140;  // fixed SVG width in px
const SPARK_H = 32;
function sparkDims(n: number) {
  const gap = n > 20 ? 1 : n > 14 ? 2 : 3;
  const barW = Math.max(2, Math.floor((SPARK_TOTAL_W - (n - 1) * gap) / n));
  return { barW, gap };
}

function buildSparkBars(shares: number[]): { x: number; y: number; h: number; up: boolean }[] {
  if (shares.length < 2) return [];
  const { barW, gap } = sparkDims(shares.length);
  const min = Math.min(...shares);
  const max = Math.max(...shares);
  const range = max - min || 0.001;
  const pad = 2;
  const usableH = SPARK_H - pad * 2;
  return shares.map((s, i) => {
    const norm = (s - min) / range;
    const h = Math.max(2, norm * usableH);
    return { x: i * (barW + gap), y: SPARK_H - pad - h, h, up: i === 0 ? true : s >= shares[i - 1] };
  });
}

function buildMALine(shares: number[], window: number = 3): { x: number; y: number }[] {
  if (shares.length < window) return [];
  const { barW, gap } = sparkDims(shares.length);
  const min = Math.min(...shares);
  const max = Math.max(...shares);
  const range = max - min || 0.001;
  const pad = 2;
  const usableH = SPARK_H - pad * 2;
  const points: { x: number; y: number }[] = [];
  for (let i = 0; i < shares.length; i++) {
    const start = Math.max(0, i - window + 1);
    const slice = shares.slice(start, i + 1);
    const avg = slice.reduce((a, b) => a + b, 0) / slice.length;
    const norm = (avg - min) / range;
    points.push({ x: i * (barW + gap) + barW / 2, y: SPARK_H - pad - norm * usableH });
  }
  return points;
}

function sparkWidth(n: number): number {
  const { barW, gap } = sparkDims(n);
  return n * barW + (n - 1) * gap;
}

// Status dot and label
function statusInfo(accel: number, status: string, isNew: boolean): { dot: string; label: string; cls: string } {
  if (isNew) return { dot: '◇', label: 'NEW', cls: 'fin-new-dot' };
  if (status === 'accelerating' || accel >= 1.5) return { dot: '◉', label: 'SURGE', cls: 'fin-surge' };
  if (accel >= 1.15) return { dot: '●', label: 'ACCEL', cls: 'fin-accel-dot' };
  if (!(accel > 0.85)) return { dot: '●', label: 'DECEL', cls: 'fin-decel-dot' };
  return { dot: '●', label: 'STABLE', cls: 'fin-stable-dot' };
}

// Format share as percentage
function fmtPct(v: number): string {
  return (v * 100).toFixed(1) + '%';
}

// Format delta (pp change)
function fmtDelta(v: number): string {
  const pp = v * 100;
  return (pp >= 0 ? '+' : '') + pp.toFixed(1);
}

// Sort families by latest 7d count desc (primary sort)
const sortedFamilies = (history?.families ?? []).slice().sort((a, b) => b.latest.count - a.latest.count);

// Helpers to avoid <= in JSX templates (Astro compiler treats < as tag)
function accelCls(val: number): string {
  if (val >= 1.15) return 'fin-up';
  if (val >= 0.86) return 'fin-flat';  // > 0.85
  return 'fin-down';
}

// Summary stats
const accelFamilies = sortedFamilies.filter(f => !f.latest.isNew && f.latest.accel >= 1.15).length;
const declFamilies = sortedFamilies.filter(f => !f.latest.isNew && f.latest.accel < 0.71).length;
const newFamilies = sortedFamilies.filter(f => f.latest.isNew).length;
const totalCoverage = history ? (sortedFamilies.reduce((s, f) => s + f.latest.count, 0)) : 0;

// Inline momentum gauge (6 segments, each = 0.5x accel)
function gaugeSegments(accel: number, isNew: boolean): { filled: number; color: string } {
  if (isNew) return { filled: 0, color: 'var(--accent-cyan)' };
  const filled = Math.min(6, Math.round(accel / 0.5));
  const color = accel >= 2.0 ? 'var(--fin-up)' : accel >= 1.0 ? 'var(--accent-amber)' : 'var(--fin-down)';
  return { filled, color };
}

// Competition pair context descriptions (short, shown inline)
const PAIR_DESC: Record<string, string> = {
  'ACTION HEAD ROUTE':      'Continuous action generation: denoising vs optimal transport',
  'POST-TRAINING ROUTE':    'Model adaptation: supervised tuning vs reward optimization',
  'LEARNING SIGNAL':        'Training paradigm: imagination-based vs reward-based',
  'MANIPULATION SENSING':   'Manipulation approach: tactile feedback vs dexterous control',
  'TRANSFER APPROACH':      'Domain bridging: simulation transfer vs cross-embodiment',
};

// Detailed hover explanations for each family and why they compete
const FAMILY_EXPLAIN: Record<string, string> = {
  diffusion_policy:     'Diffusion Policy: iterative denoising process (DDPM) to generate continuous robot actions; strong on multi-modal action distributions',
  flow_matching:        'Flow Matching: optimal-transport-based generative model (e.g. Pi0); faster inference than diffusion with comparable quality',
  rl_finetuning:        'RL Fine-tuning: post-training with PPO/DPO/GRPO reward signals; enables online improvement beyond demonstration data',
  instruction_tuning:   'Instruction Tuning: supervised fine-tuning (SFT) on language-action pairs; simpler but limited to offline data distribution',
  world_model:          'World Model: learned environment simulator (Dreamer, UniSim); enables planning via imagination without real-world interaction',
  tactile:              'Tactile Sensing: force/torque and GelSight contact sensors; provides direct manipulation feedback for delicate tasks',
  dexterous_hand:       'Dexterous Hand: multi-finger manipulation control; achieves fine-grained object interaction without dedicated sensors',
  cross_embodiment:     'Cross-Embodiment: transfer policies across different robot morphologies; aims for universal robot foundation models',
  sim_to_real:          'Sim-to-Real: train in simulation, deploy on real hardware; uses domain randomization to bridge the reality gap',
  long_horizon:         'Long Horizon: multi-step task planning with temporal abstraction; decomposes complex goals into executable sub-tasks',
  multi_task:           'Multi-Task: generalist robot models trained on diverse tasks; pursues open-vocabulary, general-purpose capability',
  mobile_manipulation:  'Mobile Manipulation: combined navigation + arm control; whole-body coordination for household/warehouse tasks',
  human_robot:          'Human-Robot Interaction: teleoperation and learning from demonstration; shared autonomy between human and robot',
  '3d_representation':  '3D Representation: point clouds, NeRF, Gaussian splatting for scene understanding; spatial awareness for manipulation',
  language_grounding:   'Language Grounding: connecting natural language instructions to robot actions; vision-language-action alignment',
};

const PAIR_EXPLAIN: Record<string, string> = {
  'ACTION HEAD ROUTE':      'Both generate continuous actions from the same VLA backbone but take different mathematical routes: diffusion iteratively denoises random noise into actions (slow, expressive), while flow matching uses optimal transport for a direct trajectory (fast, efficient). If flow matching matches diffusion quality, it could replace it as the default action head.',
  'POST-TRAINING ROUTE':    'After pretraining a VLA, two competing strategies exist: SFT directly imitates expert demonstrations (simple, stable), while RL fine-tuning (GRPO/DPO) optimizes a reward signal to go beyond the demonstration distribution. RL can discover novel strategies but is harder to stabilize.',
  'LEARNING SIGNAL':        'World models learn by predicting the future (imagination-based planning), while RL learns from reward feedback. If world models become accurate enough, they could reduce the need for expensive real-world RL exploration.',
  'MANIPULATION SENSING':   'Two approaches to dexterous manipulation: tactile sensing adds explicit touch feedback (hardware cost, rich signal), while dexterous hand control relies on proprioception and vision alone (simpler hardware, harder control). The winner depends on sensor cost-to-performance ratio.',
  'TRANSFER APPROACH':      'Sim-to-Real trains one robot in simulation then transfers (cheap data, reality gap risk), while Cross-Embodiment trains across multiple real robots directly (expensive data, natural generalization). The approaches represent different bets on where generalization should happen.',
};


// Competition pairs data
const pairsData = history ? COMPETITION_PAIRS.map(pair => {
  const a = history.families.find(f => f.family === pair.familyA);
  const b = history.families.find(f => f.family === pair.familyB);
  if (!a || !b) return null;
  const total = a.latest.share + b.latest.share;
  const pctA = total > 0 ? (a.latest.share / total) * 100 : 50;
  const ratio = b.latest.share > 0 ? (a.latest.share / b.latest.share).toFixed(2) : '—';
  return { ...pair, a, b, pctA, ratio };
}).filter(Boolean) : [];

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="VLA 深度追蹤"
  description="Vision-Language-Action 理論深挖與 SOTA 排行 — VLA-Handbook 庫"
>
  <div class="vdd-page page-container">

    <!-- ── Breadcrumb ── -->
    <nav class="dd-breadcrumb" aria-label="麵包屑">
      <a href={`${base}/`} class="bc-link"><span data-tc>首頁</span><span data-sc>首页</span></a>
      <span class="bc-sep">›</span>
      <span class="bc-current"><span data-tc>VLA 深度追蹤</span><span data-sc>VLA 深度追踪</span></span>
    </nav>

    <!-- ── Masthead (slim) ── -->
    <header class="vdd-masthead">
      <div class="vdd-overline"><span data-tc>VLA 線 · DEEP DIVE ARCHIVE</span><span data-sc>VLA 线 · DEEP DIVE ARCHIVE</span></div>
      <h1 class="vdd-title"><span data-tc>VLA 深度追蹤</span><span data-sc>VLA 深度追踪</span></h1>
      <div class="vdd-accent-bar"></div>
      <p class="vdd-desc"><span data-tc>Vision-Language-Action：讓機器人看→想→做的端到端模型</span><span data-sc>Vision-Language-Action：让机器人看→想→做的端到端模型</span></p>

      <!-- GitHub CTA row -->
      <div class="vdd-cta-row">
        <a href={GITHUB_THEORY_PATH} target="_blank" rel="noopener noreferrer" class="vdd-github-btn">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
              0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
              -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87
              2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95
              0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12
              0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27
              1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12
              .51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95
              .29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2
              0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          <span data-tc>VLA-Handbook 庫</span><span data-sc>VLA-Handbook 库</span>
          <span class="vdd-github-sub"><span data-tc>theory/ 目錄</span><span data-sc>theory/ 目录</span></span>
          <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M2 6h8M6 2l4 4-4 4"/>
          </svg>
        </a>
        <a href={GITHUB_SOTA_PATH} target="_blank" rel="noopener noreferrer" class="vdd-github-secondary">
          Evo-SOTA 排行榜 →
        </a>
        <div class="vdd-stats-row">
          <span class="vdd-stat">
            <span class="vdd-stat-num">{allCombined.length}</span>
            <span class="vdd-stat-lbl"><span data-tc>理論文章</span><span data-sc>理论文章</span></span>
          </span>
          <span class="vdd-stat-sep">·</span>
          <span class="vdd-stat">
            <span class="vdd-stat-num vdd-stat-num--cyan">{sota.length}</span>
            <span class="vdd-stat-lbl"><span data-tc>SOTA 記錄</span><span data-sc>SOTA 记录</span></span>
          </span>
        </div>
      </div>
    </header>

    <!-- ══════════════════════════════════════════
         FINANCIAL TERMINAL: Method Family Trends
    ══════════════════════════════════════════ -->
    {history && (
      <section class="fin-panel" aria-label="方法族趨勢看板">

        <!-- Header -->
        <div class="fin-header">
          <div class="fin-header-left">
            <h2 class="fin-title">METHOD FAMILY TRENDS</h2>
            <span class="fin-meta">
              {history.latestDate} · {history.totalPapers} papers · {history.dates.length}d window · {sortedFamilies.length} families
            </span>
          </div>
          <span class={`fin-confidence fin-confidence--${history.confidence}`}>
            {history.confidence}
          </span>
        </div>

        <!-- Summary line -->
        <div class="fin-summary-line">
          {accelFamilies > 0 && <span class="fin-summary-tag fin-up">&#9650; {accelFamilies} accelerating</span>}
          {declFamilies > 0 && <span class="fin-summary-tag fin-down">&#9660; {declFamilies} declining</span>}
          {newFamilies > 0 && <span class="fin-summary-tag fin-new-tag">&#9671; {newFamilies} new</span>}
          <span class="fin-summary-stat">{sortedFamilies.length} families</span>
          <span class="fin-summary-sep">&middot;</span>
          <span class="fin-summary-stat">{totalCoverage} papers covered</span>
        </div>

        <!-- Unified ticker table (gauge merged in) -->
        <div class="fin-ticker-wrap">
          <div class="fin-ticker-header fin-ticker-grid-v3">
            <span class="fin-th fin-th-name">FAMILY</span>
            <span class="fin-th fin-th-gauge">MOM</span>
            <span class="fin-th fin-th-vol">7d</span>
            <span class="fin-th fin-th-accel">&Delta;7d</span>
            <span class="fin-th fin-th-chart">CHART</span>
            <span class="fin-th fin-th-status">ST</span>
          </div>
          <div class="fin-ticker">
            {sortedFamilies.map(fam => {
              const bars = buildSparkBars(fam.shares);
              const maLine = buildMALine(fam.shares);
              const { barW } = sparkDims(fam.shares.length);
              const maPath = maLine.length > 1
                ? 'M' + maLine.map(p => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join('L')
                : '';
              const svgW = Math.max(sparkWidth(fam.shares.length), 90);
              const si = statusInfo(fam.latest.accel, fam.latest.status, fam.latest.isNew);
              const accelClsVal = fam.latest.isNew ? 'fin-new-text' : accelCls(fam.latest.accel);
              const gs = gaugeSegments(fam.latest.accel, fam.latest.isNew);
              return (
                <div class={`fin-row fin-ticker-grid-v3 ${fam.latest.isNew ? 'fin-row-new' : ''}`}>
                  <span class="fin-name" title={fam.family}>{FAMILY_NAMES[fam.family] ?? fam.family}</span>
                  <span class="fin-mini-gauge" aria-label={`momentum ${fam.latest.accel.toFixed(2)}x`}>
                    {[0,1,2,3,4,5].map(i => (
                      <span
                        class={`fin-gauge-seg ${i < gs.filled ? 'fin-gauge-seg-on' : ''}`}
                        style={i < gs.filled ? `background:${gs.color}` : ''}
                      />
                    ))}
                  </span>
                  <span class="fin-vol tabular-nums">{fam.latest.count}</span>
                  <span class={`fin-accel tabular-nums ${accelClsVal}`}>
                    {fam.latest.isNew ? 'NEW' : fam.latest.accel.toFixed(2) + 'x'}
                  </span>
                  <svg class="fin-spark" viewBox={`0 0 ${svgW} ${SPARK_H}`} width={svgW} height={SPARK_H} aria-hidden="true">
                    {bars.map(b => (
                      <rect
                        x={b.x} y={b.y} width={barW} height={b.h} rx="1"
                        fill={b.up ? 'var(--fin-up)' : 'var(--fin-down)'}
                        opacity="0.85"
                      />
                    ))}
                    {maPath && (
                      <path d={maPath} fill="none" stroke="var(--text-tertiary)" stroke-width="1"
                        stroke-dasharray="3,2" opacity="0.5" />
                    )}
                  </svg>
                  <span class={`fin-status-dot ${si.cls}`} title={si.label}>{si.dot}</span>
                </div>
              );
            })}
          </div>
        </div>

        <!-- Competition Pairs with hover explanations -->
        {pairsData.length > 0 && (
          <div class="fin-competition">
            <h3 class="fin-sub-title">COMPETITION PAIRS
              <span class="fin-gauge-range-label">{pairsData.length} matchups · hover for details</span>
            </h3>
            <div class="fin-pairs-grid">
            {pairsData.map(pair => pair && (
              <div class="fin-pair fin-pair-hover-wrap">
                <div class="fin-pair-label">{pair.label}</div>
                {PAIR_DESC[pair.label] && (
                  <div class="fin-pair-desc">{PAIR_DESC[pair.label]}</div>
                )}
                <div class="fin-pair-names">
                  <span class="fin-pair-name-left" title={FAMILY_EXPLAIN[pair.familyA] ?? ''}>{FAMILY_SHORT[pair.familyA] ?? pair.familyA}</span>
                  <span class="fin-pair-vs">vs</span>
                  <span class="fin-pair-name-right" title={FAMILY_EXPLAIN[pair.familyB] ?? ''}>{FAMILY_SHORT[pair.familyB] ?? pair.familyB}</span>
                </div>
                <div class="fin-pair-bar">
                  <div class="fin-pair-left" style={`width:${pair.pctA}%`}>
                    <span class="fin-pair-pct">{pair.pctA.toFixed(0)}%</span>
                  </div>
                  <div class="fin-pair-right" style={`width:${100 - pair.pctA}%`}>
                    <span class="fin-pair-pct">{(100 - pair.pctA).toFixed(0)}%</span>
                  </div>
                </div>
                <div class="fin-pair-stats">
                  <span class="fin-pair-stat">{fmtPct(pair.a.latest.share)} · x{pair.a.latest.accel.toFixed(2)}</span>
                  <span class="fin-pair-ratio">ratio {pair.ratio}</span>
                  <span class="fin-pair-stat">{fmtPct(pair.b.latest.share)} · x{pair.b.latest.accel.toFixed(2)}</span>
                </div>
                <!-- Hover tooltip with detailed explanation -->
                <div class="fin-pair-tooltip">
                  <div class="fin-pair-tooltip-section">
                    <strong>{FAMILY_NAMES[pair.familyA] ?? pair.familyA}</strong>
                    <p>{FAMILY_EXPLAIN[pair.familyA] ?? ''}</p>
                  </div>
                  <div class="fin-pair-tooltip-section">
                    <strong>{FAMILY_NAMES[pair.familyB] ?? pair.familyB}</strong>
                    <p>{FAMILY_EXPLAIN[pair.familyB] ?? ''}</p>
                  </div>
                  <div class="fin-pair-tooltip-why">
                    <strong>Why they compete</strong>
                    <p>{PAIR_EXPLAIN[pair.label] ?? PAIR_DESC[pair.label] ?? ''}</p>
                  </div>
                </div>
              </div>
            ))}
            </div>
          </div>
        )}
      </section>
    )}

    <!-- ══════════════════════════════════════════
         EMERGING SIGNALS: Emerging Method Terms
    ══════════════════════════════════════════ -->
    {emergingData && emergingData.candidates.length > 0 && (
      <section class="fin-panel fin-emerging-panel" aria-label="新興方法訊號">
        <div class="fin-header">
          <div class="fin-header-left">
            <h2 class="fin-title">EMERGING SIGNALS</h2>
            <span class="fin-meta">
              {emergingData.date} · {emergingData.unmatched_papers}/{emergingData.total_papers_scanned} unmatched · {emergingData.window_days}d window
            </span>
          </div>
          <span class="fin-emerging-badge">
            {emergingData.candidates.length} candidates
          </span>
        </div>

        <!-- Emerging terms table -->
        <div class="fin-emerging-grid-header fin-emerging-grid">
          <span class="fin-th">TERM</span>
          <span class="fin-th" style="text-align:right">COUNT</span>
          <span class="fin-th" style="text-align:right">DAYS</span>
          <span class="fin-th" style="text-align:center">VELOCITY</span>
          <span class="fin-th" style="text-align:center">STATUS</span>
          <span class="fin-th">SAMPLE</span>
        </div>
        <div class="fin-emerging-rows">
          {emergingData.candidates
            .sort((a, b) => b.acceleration - a.acceleration)
            .map((term) => {
              const statusCls = term.status === 'rising' ? 'fin-es-rising'
                : term.status === 'new' ? 'fin-es-new'
                : term.status === 'candidate' ? 'fin-es-candidate'
                : 'fin-es-promoted';
              const velArrow = term.velocity > 0.5 ? '++' : term.velocity > 0 ? '+' : term.velocity < -0.3 ? '--' : term.velocity < 0 ? '-' : '~';
              const velCls = term.velocity > 0.5 ? 'fin-up' : term.velocity > 0 ? 'fin-up' : term.velocity < 0 ? 'fin-down' : 'fin-flat';
              // Mini spark: daily counts as tiny bars
              const dailyEntries = Object.entries(term.daily_counts).sort(([a],[b]) => a.localeCompare(b));
              const maxDay = Math.max(...dailyEntries.map(([,v]) => v), 1);
              return (
                <div class="fin-emerging-row fin-emerging-grid">
                  <div class="fin-emerging-term">
                    <span class="fin-emerging-term-text">{term.term}</span>
                    <svg class="fin-emerging-spark" width={dailyEntries.length * 6} height="14" viewBox={`0 0 ${dailyEntries.length * 6} 14`}>
                      {dailyEntries.map(([, count], i) => (
                        <rect
                          x={i * 6}
                          y={14 - (count / maxDay) * 12}
                          width="4"
                          height={Math.max(1, (count / maxDay) * 12)}
                          fill={i === dailyEntries.length - 1 ? 'var(--accent-cyan)' : 'rgba(255,255,255,0.15)'}
                          rx="1"
                        />
                      ))}
                    </svg>
                  </div>
                  <span class="fin-emerging-count">{term.total_count}</span>
                  <span class="fin-emerging-days">{term.days_active}d</span>
                  <span class={`fin-emerging-vel ${velCls}`}>{velArrow} x{term.acceleration.toFixed(1)}</span>
                  <span class={`fin-emerging-status ${statusCls}`}>{term.status.toUpperCase()}</span>
                  <span class="fin-emerging-sample" title={term.sample_titles.join(' · ')}>
                    {term.sample_titles[0]?.substring(0, 50)}{(term.sample_titles[0]?.length ?? 0) > 50 ? '...' : ''}
                  </span>
                </div>
              );
            })}
        </div>

        <!-- Coverage stats footer -->
        <div class="fin-emerging-footer">
          <span class="fin-emerging-stat">
            {emergingData.stats.total_ngrams_extracted} n-grams
            <span class="fin-emerging-stat-sep">|</span>
            {emergingData.stats.after_stopword_filter} after filter
            <span class="fin-emerging-stat-sep">|</span>
            coverage gap: {((emergingData.unmatched_papers / emergingData.total_papers_scanned) * 100).toFixed(0)}%
          </span>
        </div>
      </section>
    )}

    <!-- ══════════════════════════════════════════
         UNIFIED: Theory Articles (merged)
    ══════════════════════════════════════════ -->
    <section class="vdd-section" aria-label="VLA 理論文章庫">
      <div class="vdd-section-header">
        <h2 class="vdd-section-title"><span data-tc>📐 理論文章庫</span><span data-sc>📐 理论文章库</span></h2>
        <a href={GITHUB_THEORY_PATH} target="_blank" rel="noopener noreferrer" class="vdd-section-link">
          <span data-tc>查看 GitHub 全庫</span><span data-sc>查看 GitHub 全库</span> →
        </a>
      </div>

      {allCombined.length === 0 ? (
        <p class="vdd-empty"><span data-tc>尚無理論文章資料</span><span data-sc>尚无理论文章资料</span></p>
      ) : (
        <>
          {/* --- Recent cards with NEW badge --- */}
          {recentAll.length > 0 && (
            <div class="vdd-subsection">
              <div class="vdd-subsection-label">
                <span class="vdd-sublabel"><span data-tc>最近 2 週</span><span data-sc>最近 2 周</span></span>
                <span class="vdd-sublabel-count">{recentAll.length} 篇</span>
              </div>
              <div class="vdd-card-grid">
                {recentAll.map((article) => (
                  <article class="vdd-card">
                    <div class="vdd-card-top">
                      <time class="vdd-card-date">{dotDate(article.date)}</time>
                      <span class="vdd-card-recency">{vddRecency(article.date)}</span>
                      <span class="vdd-card-tag vdd-card-tag--cyan">
                        {article.topic.replace(/-/g, ' ')}
                      </span>
                    </div>
                    <h3 class="vdd-card-title">{article.title}</h3>
                    <a
                      href={article.html_url || article.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="vdd-card-cta"
                    >
                      <span data-tc>在 GitHub 閱讀</span><span data-sc>在 GitHub 阅读</span>
                      <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M2 6h8M6 2l4 4-4 4"/>
                      </svg>
                    </a>
                  </article>
                ))}
              </div>
            </div>
          )}

          {/* --- Older articles grouped by topic --- */}
          {olderAll.length > 0 && (
            <div class="vdd-subsection">
              {recentAll.length > 0 && (
                <div class="vdd-subsection-label">
                  <span class="vdd-sublabel">更多文章 · 全部在 GitHub</span>
                  <span class="vdd-sublabel-count">{olderAll.length} 篇</span>
                </div>
              )}
              <div class="vdd-topics">
                {topics.map(topic => (
                  <div class="vdd-topic-group">
                    <div class="vdd-topic-label">
                      {topic.replace(/-/g, ' ')} &nbsp;·&nbsp; {byTopicAll[topic].length} 篇
                    </div>
                    <div class="vdd-art-list">
                      {byTopicAll[topic].map((article, i) => (
                        <a
                          href={article.html_url || article.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="vdd-art-row"
                          style={`animation-delay:${i * 0.03}s`}
                        >
                          <time class="vdd-art-date">{dotDate(article.date)}</time>
                          <span class="vdd-art-title">{article.title}</span>
                          <span class="vdd-art-ext" aria-label="在 GitHub 閱讀">
                            <svg width="11" height="11" viewBox="0 0 12 12" fill="none"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round">
                              <path d="M5 2H2a1 1 0 00-1 1v7a1 1 0 001 1h7a1 1 0 001-1V7"/>
                              <path d="M8 1h3v3M11 1L6 6"/>
                            </svg>
                          </span>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </>
      )}
    </section>

    <!-- ══════════════════════════════════════════
         SOTA Leaderboard
    ══════════════════════════════════════════ -->
    <section class="vdd-section" aria-label="SOTA 排行">
      <div class="vdd-section-header">
        <h2 class="vdd-section-title">🏆 SOTA 排行</h2>
        <a href={GITHUB_SOTA_PATH} target="_blank" rel="noopener noreferrer" class="vdd-section-link">
          Evo-SOTA 完整榜 →
        </a>
      </div>

      {sota.length === 0 ? (
        <p class="vdd-empty"><span data-tc>尚無 SOTA 數據</span><span data-sc>尚无 SOTA 数据</span></p>
      ) : (
        <div class="vdd-sota-groups">
          {benchmarks.map(bench => {
            const entries = sotaByBenchmark[bench].sort((a, b) => b.value - a.value);
            const top = entries[0];
            const isSaturated = saturatedBenchmarks.has(bench);
            return (
              <div class="sota-bench-block">
                <div class="sota-bench-header">
                  <div class="sota-bench-left">
                    <span class="sota-bench-name">
                      {top.leaderboard_url
                        ? <a href={top.leaderboard_url} target="_blank" rel="noopener noreferrer">{bench}</a>
                        : bench
                      }
                    </span>
                    {top.split && <span class="sota-bench-split">{top.split}</span>}
                    {isSaturated && <span class="sota-saturated-badge">飽和</span>}
                  </div>
                  <span class="sota-bench-metric">{top.metric}</span>
                </div>
                <div class="sota-table-wrap">
                  <table class="sota-table">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Model</th>
                        <th>Score</th>
                        <th>vs Prev</th>
                        <th>Date</th>
                        <th>Paper</th>
                      </tr>
                    </thead>
                    <tbody>
                      {entries.map((e, rank) => (
                        <tr class:list={['sota-row', rank === 0 && 'sota-row--top']}>
                          <td class="sota-rank">{rank + 1}</td>
                          <td class="sota-model">{e.model}</td>
                          <td class="sota-score">{e.value}</td>
                          <td class="sota-baseline">{e.baseline ?? '—'}</td>
                          <td class="sota-date">{e.date}</td>
                          <td class="sota-paper">
                            {e.paper_url
                              ? <a href={e.paper_url} target="_blank" rel="noopener noreferrer">arxiv →</a>
                              : '—'
                            }
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </section>

    <!-- ── Cross-domain navigation ── -->
    <nav class="xdomain-nav">
      <a href={`${base}/ai-deepdive/`} class="xdomain-link">
        <span data-tc>AI Agent 領域的工程實戰文章庫</span><span data-sc>AI Agent 领域的工程实战文章库</span>
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4"/>
        </svg>
      </a>
    </nav>

  </div>
</BaseLayout>

