            </div>
            <div>
              <div class="spark-label">AI App</div>
              <div class="spark-value">{spark7.length > 0 ? spark7[spark7.length-1].ai + ' 條' : '—'}</div>
            </div>
            <div style="text-align:right;">
              <div class="spark-label"><span data-tc>漂移狀態</span><span data-sc>漂移状态</span></div>
