---
/**
 * src/pages/talent/index.astro
 * Stage 4 — Talent Radar landing (v2 revamp).
 *
 * IA inversion from v1:
 *   v1: Subdirections → Labs → People → HR Queue (browse-first)
 *   v2: Weekly Brief → HR Shortlist → Velocity Board → Labs → Watchlist
 *       (signal-first, narrative-led, HR-actionable up top)
 *
 * No new utils — everything computed from the existing loaders.
 */
import BaseLayout        from '../../layouts/BaseLayout.astro';
import SubdirectionCard  from '../../components/SubdirectionCard.astro';
import LabCard           from '../../components/LabCard.astro';
import PersonCard        from '../../components/PersonCard.astro';
import RatingBadge       from '../../components/RatingBadge.astro';
import {
  loadSubdirections,
  loadLabs,
  loadPeople,
  loadHRScout,
  loadTalentStats,
  slugifyName,
  topMethodsForEvidence,
} from '../../utils/talent';

const base = import.meta.env.BASE_URL;

const stats     = loadTalentStats();
const allSubs   = loadSubdirections({ domain: 'all' });
const allLabs   = loadLabs({ minSignals: 3 });
const allPeople = loadPeople({ minPaperCount90d: 1 });
const scout     = loadHRScout();
const allHR     = scout.hot;   // back-compat for downstream brief card

// ── Trustworthy subset for ranking ─────────────────────────────────────────
// A family with prior_volume = 0 produces a clamped acceleration value
// (often +999%) that is mathematically meaningless. Separate those from the
// signal-bearing population and surface them under a distinct "Emerging"
// label instead of letting them dominate the velocity board.
const rankedSubs   = allSubs.filter(s => s.status !== 'insufficient_data');
const emergingSubs = allSubs
  .filter(s => s.status === 'insufficient_data' && s.velocity7d > 0)
  .sort((a, b) => b.velocity7d - a.velocity7d);

// ── Weekly Brief: 3 lead facts ─────────────────────────────────────────────
const topMover  = rankedSubs.find(s => s.acceleration > 0) ?? rankedSubs[0];
const topLab    = allLabs[0];
const topEmerge = emergingSubs[0];   // new card 3: "emerging on the radar"

// ── Velocity board: top 8 by abs acceleration, excluding insufficient_data ─
const velocityBoard = [...rankedSubs]
  .sort((a, b) => Math.abs(b.acceleration) - Math.abs(a.acceleration))
  .slice(0, 8);
const velocityMaxAbs = Math.max(0.01, ...velocityBoard.map(s => Math.abs(s.acceleration)));

// ── HR scout funnel ────────────────────────────────────────────────────────
//   HOT   — full gate passers
//   WARM  — missing one criterion (rising star / prolific-no-aff / social)
//   WATCH — ⚡ outliers without durable signal
const featuredHR = scout.hot[0];
const restHot    = scout.hot.slice(1);
const warmShown  = scout.warm.slice(0, 8);
const warmRest   = Math.max(0, scout.warm.length - warmShown.length);
const watchShown = scout.watch.slice(0, 12);

// Featured candidate gets enriched method tags for the hero card
const featuredMethods = featuredHR
  ? topMethodsForEvidence(featuredHR.evidence, 3)
  : [];

// ── Labs showcase: 6 with non-zero recent OR top by 90d signals ─────────────
const labsShowcase = allLabs.slice(0, 6);

// ── Researcher watchlist: prefer ⚡ + linked, then top by paperCount ─────────
const watchlistRaw = allPeople.filter(p =>
  p.topRating === '⚡' && p.contactStatus !== 'not_linked');
const watchlist = (watchlistRaw.length >= 6
  ? watchlistRaw
  : [...watchlistRaw, ...allPeople.filter(p => !watchlistRaw.includes(p) && p.contactStatus !== 'not_linked')]
).slice(0, 6);

// ── Freshness ──────────────────────────────────────────────────────────────
const dataDate = Date.parse(stats.dataAsOf + 'T00:00:00Z');
const daysOld = Number.isNaN(dataDate)
  ? null
  : Math.max(0, Math.floor((Date.now() - dataDate) / 86_400_000));
const freshnessTone =
  daysOld === null ? 'muted' :
  daysOld <= 1     ? 'fresh' :
  daysOld <= 3     ? 'ok'    :
  'stale';

// ── Format helpers ─────────────────────────────────────────────────────────
function fmtAccel(a: number): string {
  // Cap displayed magnitude at 500% — anything beyond that is a small-
  // baseline artefact, not signal. Caller is responsible for excluding
  // insufficient_data rows before formatting.
  const pct = Math.round(a * 100);
  if (pct >= 500)  return '+500%↑';
  if (pct <= -500) return '−500%↓';
  return `${pct > 0 ? '+' : ''}${pct}%`;
}
---

<BaseLayout
  title="人才雷達 Talent Radar"
  description="Stage 4 — 信號優先的人才雷達：本週簡報 → HR 候選人 → 方法族速度 → 活躍實驗室 → 觀察名單。從不儲存或顯示電子郵件。"
>
  <main class="talent-v2">
    <!-- ══ Hero ════════════════════════════════════════════════════════════ -->
    <header class="tv2-hero">
      <div class="tv2-hero-meta">
        <span class="tv2-stage">
          <span class="tv2-stage-dot" aria-hidden="true"></span>
          STAGE 04 · TALENT RADAR
        </span>
        <span class={`tv2-fresh tv2-fresh--${freshnessTone}`} title={`Data snapshot ${stats.dataAsOf}`}>
          <span class="tv2-fresh-dot" aria-hidden="true"></span>
          <span data-tc>資料 {stats.dataAsOf}</span>
          <span data-sc>数据 {stats.dataAsOf}</span>
          {daysOld !== null && <span class="tv2-fresh-age">· {daysOld === 0 ? 'today' : `${daysOld}d ago`}</span>}
        </span>
      </div>

      <div class="tv2-title-row">
        <h1 class="tv2-title">
          <span data-tc>人才雷達</span>
          <span data-sc>人才雷达</span>
        </h1>
        <p class="tv2-title-en">Talent Radar</p>
      </div>

      <p class="tv2-lede">
        <span data-tc>從論文池反推 — <strong>誰該聘</strong> · <strong>哪些方向在加速</strong> · <strong>哪些組織在攻頂</strong>。</span>
        <span data-sc>从论文池反推 — <strong>谁该聘</strong> · <strong>哪些方向在加速</strong> · <strong>哪些组织在攻顶</strong>。</span>
      </p>

      <p class="tv2-promise">
        <span class="tv2-promise-icon" aria-hidden="true">⏚</span>
        <span data-tc>每項推薦皆附論文級佐證。系統 <strong>從不儲存或顯示電子郵件</strong>。</span>
        <span data-sc>每项推荐皆附论文级佐证。系统 <strong>从不存储或显示邮箱</strong>。</span>
      </p>
    </header>

    <!-- ══ Weekly Brief — 3 narrative cards ═══════════════════════════════ -->
    <section class="tv2-brief" aria-label="Weekly brief">
      <h2 class="tv2-brief-label">
        <span data-tc>本週簡報</span>
        <span data-sc>本周简报</span>
        <span class="tv2-brief-en">/ This Week</span>
      </h2>

      <div class="tv2-brief-grid">
        <!-- 1. Top accelerating method -->
        {topMover && (
          <a class="tv2-brief-card" href={`${base}/talent/subdirections/#fam-${topMover.family}`}>
            <span class="tv2-brief-kicker">
              <span data-tc>加速最快的方向</span>
              <span data-sc>加速最快的方向</span>
            </span>
            <div class="tv2-brief-main">
              <span class="tv2-brief-head">{topMover.displayName}</span>
              <span class="tv2-brief-delta" data-pos={topMover.acceleration >= 0}>
                {fmtAccel(topMover.acceleration)}
              </span>
            </div>
            <div class="tv2-brief-sub">
              <span class="tv2-brief-domain">
                {topMover.domain === 'vla' ? 'VLA' : 'AI App'}
              </span>
              <span class="tv2-brief-meta">7d {topMover.velocity7d} · prior {topMover.velocityPrior7d}</span>
            </div>
          </a>
        )}

        <!-- 2. Top active lab -->
        {topLab && (
          <a class="tv2-brief-card" href={`${base}/talent/labs/#lab-${slugifyName(topLab.name)}`}>
            <span class="tv2-brief-kicker">
              <span data-tc>產能最高的實驗室</span>
              <span data-sc>产能最高的实验室</span>
            </span>
            <div class="tv2-brief-main">
              <span class="tv2-brief-head">{topLab.name}</span>
              <RatingBadge rating={topLab.topRating} size="sm" />
            </div>
            <div class="tv2-brief-sub">
              <span class="tv2-brief-meta">
                <span data-tc>{topLab.signalCount90d} 篇 · 90d · {topLab.methodFocus.slice(0, 2).join(' · ')}</span>
                <span data-sc>{topLab.signalCount90d} 篇 · 90d · {topLab.methodFocus.slice(0, 2).join(' · ')}</span>
              </span>
            </div>
          </a>
        )}

        <!-- 3. Emerging family (or, if none, fall back to top HR pick) -->
        {topEmerge ? (
          <a class="tv2-brief-card tv2-brief-card--accent" href={`${base}/talent/subdirections/#fam-${topEmerge.family}`}>
            <span class="tv2-brief-kicker">
              <span data-tc>新冒頭的方向</span>
              <span data-sc>新冒头的方向</span>
            </span>
            <div class="tv2-brief-main">
              <span class="tv2-brief-head">{topEmerge.displayName}</span>
              <span class="tv2-brief-emerge-badge">NEW</span>
            </div>
            <div class="tv2-brief-sub">
              <span class="tv2-brief-domain">
                {topEmerge.domain === 'vla' ? 'VLA' : 'AI App'}
              </span>
              <span class="tv2-brief-meta">
                <span data-tc>本週首見 · {topEmerge.velocity7d} 篇</span>
                <span data-sc>本周首见 · {topEmerge.velocity7d} 篇</span>
              </span>
            </div>
          </a>
        ) : topHR && (
          <a class="tv2-brief-card tv2-brief-card--accent" href="#hr-shortlist">
            <span class="tv2-brief-kicker">
              <span data-tc>首推候選人</span>
              <span data-sc>首推候选人</span>
            </span>
            <div class="tv2-brief-main">
              <span class="tv2-brief-head">{topHR.name}</span>
              <RatingBadge rating={topHR.topRating} size="sm" />
            </div>
            <div class="tv2-brief-sub">
              {topHR.affiliation && (
                <span class="tv2-brief-meta tv2-brief-affil">{topHR.affiliation}</span>
              )}
              <span class="tv2-brief-meta">· {topHR.paperCount90d} 篇 · 90d</span>
            </div>
          </a>
        )}
      </div>
    </section>

    <!-- ══ Section 01 · HR SCOUT FUNNEL ═══════════════════════════════════
         A real shortlist is a funnel, not a one-tier gate. We expose:
           HOT   = gate passers (interview-ready)
           WARM  = close-to-gate (need follow-up or affiliation lookup)
           WATCH = ⚡ flashes (one-paper outliers, curiosity tier)
         Each entry carries top method tags so HR knows what to interview on.
    ══════════════════════════════════════════════════════════════════════ -->
    <section class="tv2-section" id="hr-shortlist">
      <header class="tv2-section-header">
        <div class="tv2-section-titlewrap">
          <span class="tv2-section-num">01</span>
          <h2 class="tv2-section-h2">
            <span data-tc>HR 候選人短名單</span>
            <span data-sc>HR 候选人短名单</span>
          </h2>
          <span class="tv2-section-en">/ HR Scout · {scout.totals.pool}</span>
        </div>
        <a class="tv2-more" href={`${base}/talent/hr-queue/`}>
          <span data-tc>完整隊列 →</span>
          <span data-sc>完整队列 →</span>
        </a>
      </header>

      <p class="tv2-section-lede">
        <span data-tc>從 {stats.peopleCount} 名研究員中漏出 <strong>{scout.totals.pool}</strong> 位進入候選池 ·
          <span class="tv2-tier-tag tv2-tier-tag--hot">HOT {scout.totals.hot}</span> 通過完整門檻 ·
          <span class="tv2-tier-tag tv2-tier-tag--warm">WARM {scout.totals.warm}</span> 缺一道門檻 ·
          <span class="tv2-tier-tag tv2-tier-tag--watch">WATCH {scout.totals.watch}</span> ⚡ 異常爆點</span>
        <span data-sc>从 {stats.peopleCount} 名研究员中漏出 <strong>{scout.totals.pool}</strong> 位进入候选池 ·
          <span class="tv2-tier-tag tv2-tier-tag--hot">HOT {scout.totals.hot}</span> 通过完整门槛 ·
          <span class="tv2-tier-tag tv2-tier-tag--warm">WARM {scout.totals.warm}</span> 缺一道门槛 ·
          <span class="tv2-tier-tag tv2-tier-tag--watch">WATCH {scout.totals.watch}</span> ⚡ 异常爆点</span>
      </p>

      {scout.totals.pool === 0 ? (
        <div class="tv2-empty">
          <p class="tv2-empty-title">
            <span data-tc>本週無候選人</span>
            <span data-sc>本周无候选人</span>
          </p>
          <p class="tv2-empty-sub">
            <span data-tc>掃描了 {stats.peopleCount} 位研究員，無人達到候選池閾值。等待下一輪 entity-tracker。</span>
            <span data-sc>扫描了 {stats.peopleCount} 位研究员，无人达到候选池阈值。等待下一轮 entity-tracker。</span>
          </p>
        </div>
      ) : (
        <div class="tv2-scout">
          {/* ── Featured top candidate ──────────────────────────────── */}
          {featuredHR && (
            <article class="tv2-hr-featured">
              <div class="tv2-hr-featured-stripe" aria-hidden="true"></div>
              <div class="tv2-hr-featured-body">
                <div class="tv2-hr-featured-head">
                  <span class="tv2-hr-featured-kicker">
                    <span data-tc>首推 · </span><span data-sc>首推 · </span>HOT #1
                  </span>
                  <div class="tv2-hr-featured-title">
                    <h3>{featuredHR.name}</h3>
                    <RatingBadge rating={featuredHR.topRating} size="sm" />
                  </div>
                  <div class="tv2-hr-featured-meta">
                    {featuredHR.affiliation && (
                      <a class="tv2-hr-featured-affil"
                         href={`${base}/talent/labs/#lab-${slugifyName(featuredHR.affiliation)}`}>
                        {featuredHR.affiliation}
                      </a>
                    )}
                    {featuredMethods.length > 0 && (
                      <span class="tv2-method-tags">
                        {featuredMethods.map(m => (
                          <span class="tv2-method-tag">{m}</span>
                        ))}
                      </span>
                    )}
                  </div>
                </div>

                <p class="tv2-hr-featured-why">
                  <span class="tv2-hr-why-tag">WHY NOW</span>
                  {featuredHR.whyNow}
                </p>

                <div class="tv2-hr-featured-stats">
                  <div class="tv2-hr-stat">
                    <span class="tv2-hr-stat-num">{featuredHR.paperCount90d}</span>
                    <span class="tv2-hr-stat-lbl">
                      <span data-tc>篇 · 90d</span><span data-sc>篇 · 90d</span>
                    </span>
                  </div>
                  <div class="tv2-hr-stat">
                    <span class="tv2-hr-stat-num">{featuredHR.gateHits.length}/4</span>
                    <span class="tv2-hr-stat-lbl">
                      <span data-tc>門檻命中</span><span data-sc>门槛命中</span>
                    </span>
                  </div>
                  <div class="tv2-hr-stat">
                    <span class="tv2-hr-stat-pill" data-status={featuredHR.contactStatus}>
                      {featuredHR.contactStatus === 'linked_via_lab' ? '機構已關聯' :
                       featuredHR.contactStatus === 'social_mention' ? '社交提及' : '僅署名'}
                    </span>
                    <span class="tv2-hr-stat-lbl">NO-EMAIL</span>
                  </div>
                </div>

                {featuredHR.evidence.length > 0 && (
                  <ul class="tv2-hr-featured-papers">
                    {featuredHR.evidence.slice(0, 3).map(ev => (
                      <li>
                        <a href={ev.url} target="_blank" rel="noopener noreferrer">
                          <RatingBadge rating={ev.rating} size="sm" />
                          <span class="tv2-paper-title">{ev.title}</span>
                          <span class="tv2-paper-date">{ev.date}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          )}

          {/* ── HOT table (remaining gate-passers, compact rows) ────── */}
          {restHot.length > 0 && (
            <div class="tv2-tier tv2-tier--hot">
              <div class="tv2-tier-head">
                <span class="tv2-tier-dot" data-tier="hot" aria-hidden="true"></span>
                <span class="tv2-tier-label">
                  <span data-tc>HOT · 通過完整門檻</span>
                  <span data-sc>HOT · 通过完整门槛</span>
                </span>
                <span class="tv2-tier-count">{scout.totals.hot}</span>
              </div>
              <table class="tv2-scout-table">
                <tbody>
                  {restHot.map((c, i) => (
                    <tr>
                      <td class="tv2-scout-rank">#{i + 2}</td>
                      <td class="tv2-scout-rating"><RatingBadge rating={c.topRating} size="sm" /></td>
                      <td class="tv2-scout-name">{c.name}</td>
                      <td class="tv2-scout-aff">
                        {c.affiliation && (
                          <a href={`${base}/talent/labs/#lab-${slugifyName(c.affiliation)}`}>
                            {c.affiliation}
                          </a>
                        )}
                      </td>
                      <td class="tv2-scout-methods">
                        {c.topMethods.map(m => <span class="tv2-method-tag">{m}</span>)}
                      </td>
                      <td class="tv2-scout-papers">{c.paperCount90d}<span class="tv2-scout-unit"> · 90d</span></td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}

          {/* ── WARM grid (close-to-gate, 8 cards with gate-missed line) ─ */}
          {warmShown.length > 0 && (
            <div class="tv2-tier tv2-tier--warm">
              <div class="tv2-tier-head">
                <span class="tv2-tier-dot" data-tier="warm" aria-hidden="true"></span>
                <span class="tv2-tier-label">
                  <span data-tc>WARM · 缺一道門檻</span>
                  <span data-sc>WARM · 缺一道门槛</span>
                </span>
                <span class="tv2-tier-count">{scout.totals.warm}</span>
                {warmRest > 0 && (
                  <a class="tv2-tier-more" href={`${base}/talent/hr-queue/`}>+{warmRest} →</a>
                )}
              </div>
              <p class="tv2-tier-lede">
                <span data-tc>補上隸屬機構或下一篇高評論文後即進入 HOT。</span>
                <span data-sc>补上隶属机构或下一篇高评论文后即进入 HOT。</span>
              </p>
              <div class="tv2-warm-grid">
                {warmShown.map(c => (
                  <article class="tv2-warm-card">
                    <div class="tv2-warm-head">
                      <RatingBadge rating={c.topRating} size="sm" />
                      <span class="tv2-warm-name">{c.name}</span>
                      <span class="tv2-warm-papers">{c.paperCount90d}<span class="tv2-warm-unit"> 篇</span></span>
                    </div>
                    <div class="tv2-warm-affil">
                      {c.affiliation ? (
                        <a href={`${base}/talent/labs/#lab-${slugifyName(c.affiliation)}`}>{c.affiliation}</a>
                      ) : (
                        <span class="tv2-warm-noaff">org: unknown</span>
                      )}
                    </div>
                    {c.topMethods.length > 0 && (
                      <div class="tv2-method-tags tv2-method-tags--warm">
                        {c.topMethods.map(m => <span class="tv2-method-tag">{m}</span>)}
                      </div>
                    )}
                    {c.gateMissed && (
                      <p class="tv2-warm-missed">
                        <span class="tv2-warm-missed-tag">MISSING</span>
                        {c.gateMissed}
                      </p>
                    )}
                  </article>
                ))}
              </div>
            </div>
          )}

          {/* ── WATCH list (⚡ flashes, collapsible) ─────────────────── */}
          {watchShown.length > 0 && (
            <details class="tv2-tier tv2-tier--watch">
              <summary class="tv2-tier-head tv2-tier-head--clickable">
                <span class="tv2-tier-dot" data-tier="watch" aria-hidden="true"></span>
                <span class="tv2-tier-label">
                  <span data-tc>WATCH · ⚡ 異常爆點 · 單篇高評</span>
                  <span data-sc>WATCH · ⚡ 异常爆点 · 单篇高评</span>
                </span>
                <span class="tv2-tier-count">{scout.totals.watch}</span>
                <span class="tv2-tier-cue">click to expand →</span>
              </summary>
              <p class="tv2-tier-lede">
                <span data-tc>單篇 ⚡ 評級的作者，無已知機構。可能是新生力量，也可能是匿名/化名。</span>
                <span data-sc>单篇 ⚡ 评级的作者，无已知机构。可能是新生力量，也可能是匿名/化名。</span>
              </p>
              <table class="tv2-scout-table">
                <tbody>
                  {watchShown.map((c, i) => (
                    <tr>
                      <td class="tv2-scout-rank">#{i + 1}</td>
                      <td class="tv2-scout-rating"><RatingBadge rating={c.topRating} size="sm" /></td>
                      <td class="tv2-scout-name">{c.name}</td>
                      <td class="tv2-scout-methods">
                        {c.topMethods.map(m => <span class="tv2-method-tag">{m}</span>)}
                      </td>
                      <td class="tv2-scout-papers">{c.paperCount90d}<span class="tv2-scout-unit"> · 90d</span></td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </details>
          )}
        </div>
      )}
    </section>

    <!-- ══ Section 02 · VELOCITY BOARD ═════════════════════════════════════ -->
    <section class="tv2-section">
      <header class="tv2-section-header">
        <div class="tv2-section-titlewrap">
          <span class="tv2-section-num">02</span>
          <h2 class="tv2-section-h2">
            <span data-tc>方法族速度榜</span>
            <span data-sc>方法族速度榜</span>
          </h2>
          <span class="tv2-section-en">/ Velocity Board</span>
        </div>
        <a class="tv2-more" href={`${base}/talent/subdirections/`}>
          <span data-tc>全部 {stats.subdirectionCount} →</span>
          <span data-sc>全部 {stats.subdirectionCount} →</span>
        </a>
      </header>

      <p class="tv2-section-lede">
        <span data-tc>每行為一個方法族。<em>長條長度</em> = |加速度| 相對最大值；<em>顏色</em> = 加速（琥珀）/ 衰退（紅）。資料來自 <code>field-state-*.json</code>（機械化，零 LLM）。</span>
        <span data-sc>每行为一个方法族。<em>条形长度</em> = |加速度| 相对最大值；<em>颜色</em> = 加速（琥珀）/ 衰退（红）。数据来自 <code>field-state-*.json</code>（机械化，零 LLM）。</span>
      </p>

      <ol class="tv2-velocity-board">
        {velocityBoard.map((s, i) => {
          const pct = Math.abs(s.acceleration) / velocityMaxAbs * 100;
          const isUp = s.acceleration >= 0;
          return (
            <li class="tv2-vel-row" style={`--vel-pct: ${pct.toFixed(1)}%`}>
              <a href={`${base}/talent/subdirections/#fam-${s.family}`} class="tv2-vel-link">
                <span class="tv2-vel-rank">{String(i + 1).padStart(2, '0')}</span>
                <span class={`tv2-vel-domain ${s.domain === 'vla' ? 'tag-vla' : 'tag-ai'}`}>
                  {s.domain === 'vla' ? 'VLA' : 'AI'}
                </span>
                <span class="tv2-vel-name">{s.displayName}</span>
                <span class="tv2-vel-track">
                  <span class={`tv2-vel-bar ${isUp ? 'tv2-vel-bar--up' : 'tv2-vel-bar--down'}`}></span>
                </span>
                <span class={`tv2-vel-pct ${isUp ? 'tv2-vel-pct--up' : 'tv2-vel-pct--down'}`}>
                  {fmtAccel(s.acceleration)}
                </span>
                <span class="tv2-vel-vol">{s.velocity7d}/{s.velocityPrior7d}</span>
              </a>
            </li>
          );
        })}
      </ol>

      {/* Emerging families (zero prior volume — surfaced separately so they
          don't inflate the main board with clamped 999% values) */}
      {emergingSubs.length > 0 && (
        <div class="tv2-emerging">
          <span class="tv2-emerging-label">
            <span data-tc>新冒頭</span><span data-sc>新冒头</span>
            <span class="tv2-emerging-en">· EMERGING · prior volume = 0</span>
          </span>
          <ul class="tv2-emerging-list">
            {emergingSubs.slice(0, 4).map(s => (
              <li>
                <a href={`${base}/talent/subdirections/#fam-${s.family}`}>
                  <span class={`tv2-vel-domain ${s.domain === 'vla' ? 'tag-vla' : 'tag-ai'}`}>
                    {s.domain === 'vla' ? 'VLA' : 'AI'}
                  </span>
                  <span class="tv2-emerging-name">{s.displayName}</span>
                  <span class="tv2-emerging-count">{s.velocity7d}<span class="tv2-emerging-unit"> 篇 · 7d</span></span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>

    <!-- ══ Section 03 · ACTIVE LABS ════════════════════════════════════════ -->
    <section class="tv2-section">
      <header class="tv2-section-header">
        <div class="tv2-section-titlewrap">
