      border: 1px solid var(--border);
    }
    .tv2-tier--hot   .tv2-tier-count { color: var(--accent-amber); border-color: var(--accent-amber); }
    .tv2-tier--warm  .tv2-tier-count { color: var(--accent-cyan);  border-color: var(--accent-cyan); }
    .tv2-tier--watch .tv2-tier-count { color: var(--text-secondary); }
    .tv2-tier-dot {
      width: 9px; height: 9px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .tv2-tier-dot[data-tier="hot"]   { background: var(--accent-amber); box-shadow: 0 0 0 3px var(--accent-amber-bg); }
    .tv2-tier-dot[data-tier="warm"]  { background: var(--accent-cyan);  box-shadow: 0 0 0 3px var(--accent-cyan-bg); }
    .tv2-tier-dot[data-tier="watch"] { background: var(--text-tertiary); }
    .tv2-tier-more {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem;
      color: var(--accent-cyan);
      text-decoration: none;
      letter-spacing: 0.05em;
    }
    .tv2-tier-more:hover { text-decoration: underline; }
    .tv2-tier-cue {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.68rem; font-weight: 400;
      color: var(--accent-cyan);
      letter-spacing: 0.05em;
    }
    details[open] .tv2-tier-cue::before { content: '↓ '; }
    details[open] .tv2-tier-cue { color: var(--text-tertiary); }
    .tv2-tier-lede {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.55;
      margin: 0;
      padding: 0.75rem 1rem 0;
    }

    /* Inline tier tags inside the section lede */
    .tv2-tier-tag {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.1em;
      padding: 0.1rem 0.45rem;
      border-radius: 4px;
      margin-right: 0.15rem;
    }
    .tv2-tier-tag--hot   { background: var(--accent-amber-bg); color: var(--accent-amber); }
    .tv2-tier-tag--warm  { background: var(--accent-cyan-bg);  color: var(--accent-cyan); }
    .tv2-tier-tag--watch { background: var(--surface-2);       color: var(--text-secondary); border: 1px solid var(--border); }

    /* Method tag chips — used on featured card + tables + warm cards */
    .tv2-method-tags {
      display: inline-flex; flex-wrap: wrap; gap: 0.3rem;
    }
    .tv2-method-tag {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.65rem; font-weight: 600;
      letter-spacing: 0.04em;
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      background: var(--accent-cyan-bg);
      color: var(--accent-cyan);
      border: 1px solid color-mix(in srgb, var(--accent-cyan) 30%, transparent);
      white-space: nowrap;
    }

    /* HOT compact scout table */
    .tv2-scout-table {
      width: 100%;
      border-collapse: collapse;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem;
    }
    .tv2-scout-table td {
      padding: 0.6rem 0.75rem;
      border-bottom: 1px solid var(--border-subtle);
      vertical-align: middle;
    }
    .tv2-scout-table tr:last-child td { border-bottom: none; }
    .tv2-scout-table tr:hover td { background: var(--surface-2); }
    .tv2-scout-rank {
      width: 38px;
      color: var(--text-tertiary);
      font-weight: 700;
    }
    .tv2-scout-rating { width: 36px; }
    .tv2-scout-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-primary);
      white-space: nowrap;
    }
    .tv2-scout-aff a {
      color: var(--accent-amber);
      text-decoration: none;
      font-weight: 600;
    }
    .tv2-scout-aff a:hover { text-decoration: underline; }
    .tv2-scout-methods { display: flex; flex-wrap: wrap; gap: 0.3rem; }
    .tv2-scout-papers {
      text-align: right;
      color: var(--text-primary);
      font-weight: 700;
      white-space: nowrap;
    }
    .tv2-scout-unit {
      color: var(--text-tertiary); font-weight: 400; font-size: 0.7rem;
    }

    /* WARM grid */
    .tv2-warm-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
      padding: 0.75rem 1rem 1rem;
    }
    .tv2-warm-card {
      display: flex; flex-direction: column; gap: 0.4rem;
      padding: 0.75rem 0.85rem;
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent-cyan);
      border-radius: 8px;
      background: var(--surface-2);
      transition: transform 0.12s, box-shadow 0.12s;
    }
    .tv2-warm-card:hover {
      transform: translateY(-1px);
      box-shadow: var(--shadow-card);
    }
    .tv2-warm-head {
      display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
    }
    .tv2-warm-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 1.02rem; font-weight: 600;
      color: var(--text-primary);
      flex: 1; min-width: 0;
    }
    .tv2-warm-papers {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem; font-weight: 700;
      color: var(--text-primary);
    }
    .tv2-warm-unit {
      font-weight: 400; color: var(--text-tertiary); font-size: 0.7rem;
    }
    .tv2-warm-affil {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.78rem;
    }
    .tv2-warm-affil a {
      color: var(--accent-amber);
      text-decoration: none;
      font-weight: 600;
    }
    .tv2-warm-affil a:hover { text-decoration: underline; }
    .tv2-warm-noaff {
      color: var(--text-tertiary);
      font-style: italic;
      letter-spacing: 0.04em;
    }
    .tv2-method-tags--warm { margin-top: 0.1rem; }
    .tv2-warm-missed {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem;
      color: var(--text-secondary);
      margin: 0;
      padding-top: 0.3rem;
      border-top: 1px dashed var(--border);
    }
    .tv2-warm-missed-tag {
      font-weight: 700;
      letter-spacing: 0.14em;
      color: var(--accent-cyan);
      margin-right: 0.4rem;
    }

    /* ── EMERGING (zero-prior families) ──────────────────────────────── */
    .tv2-emerging {
      margin-top: 0.75rem;
      padding: 0.75rem 1rem;
      background: var(--surface-2);
      border: 1px dashed var(--border);
      border-radius: 8px;
    }
    .tv2-emerging-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.65rem; font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent-cyan);
      display: block; margin-bottom: 0.5rem;
    }
    .tv2-emerging-en {
      color: var(--text-tertiary); font-weight: 400; margin-left: 0.35rem;
    }
    .tv2-emerging-list {
      list-style: none; padding: 0; margin: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.4rem 1rem;
    }
    .tv2-emerging-list li a {
      display: flex; align-items: center; gap: 0.6rem;
      padding: 0.35rem 0.5rem;
      text-decoration: none;
      border-radius: 4px;
      color: var(--text-primary);
      transition: background 0.12s;
    }
    .tv2-emerging-list li a:hover { background: var(--surface); }
    .tv2-emerging-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.9rem; flex: 1;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .tv2-emerging-count {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem; font-weight: 700;
      color: var(--accent-cyan);
    }
    .tv2-emerging-unit {
      font-weight: 400; color: var(--text-tertiary); font-size: 0.7rem;
    }
    .tv2-brief-emerge-badge {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.6rem; font-weight: 700;
      letter-spacing: 0.16em;
      padding: 0.18rem 0.45rem;
      border-radius: 4px;
      background: var(--accent-cyan-bg);
      color: var(--accent-cyan);
      border: 1px solid var(--accent-cyan);
    }

    /* ── RESPONSIVE ──────────────────────────────────────────────────── */
    @media (max-width: 900px) {
      .tv2-brief-grid { grid-template-columns: 1fr; }
      .tv2-hr-rest    { grid-template-columns: 1fr; }
      .tv2-vel-link {
        grid-template-columns: 24px 44px 1fr 56px;
        gap: 0.5rem;
      }
      .tv2-vel-track { grid-column: 1 / -1; }
      .tv2-vel-vol   { display: none; }
      .tv2-emerging-list { grid-template-columns: 1fr; }
      .tv2-warm-grid     { grid-template-columns: 1fr; }
      .tv2-scout-aff     { display: none; }
      .tv2-scout-name    { font-size: 0.88rem; }
    }
    @media (max-width: 600px) {
      .tv2-scout-methods { display: none; }
    }
    @media (max-width: 600px) {
      .tv2-hr-featured-body { padding: 1rem 1.15rem; }
      .tv2-hr-featured-title h3 { font-size: 1.4rem; }
      .tv2-hr-featured-stats { gap: 1.25rem; }
    }

    /* ─── Section 04 · Lab Cluster Network (chart A) ─────────────────── */
    .tv2-labnet {
      margin: 1rem 0 1.5rem;
      padding: 0;
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent-amber);
      border-radius: 12px;
      overflow: hidden;
    }
    .tv2-labnet-title {
      display: flex;
      align-items: baseline;
      gap: 0.65rem;
      padding: 0.7rem 1rem 0.55rem;
      border-bottom: 1px solid var(--border-subtle);
      background: linear-gradient(90deg,
        color-mix(in srgb, var(--accent-amber) 8%, transparent),
        transparent 65%);
    }
    .tv2-labnet-title-num {
      display: inline-flex;
      align-items: center; justify-content: center;
      width: 22px; height: 22px;
      border-radius: 50%;
      background: var(--accent-amber);
      color: #fff;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem;
      font-weight: 700;
    }
    .tv2-labnet-title-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.92rem;
      font-weight: 600;
      color: var(--text-primary);
    }
    .tv2-labnet-title-en {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.65rem;
      color: var(--text-tertiary);
      letter-spacing: 0.06em;
    }
    .tv2-labnet-svg {
      display: block;
      width: 100%;
      height: auto;
      background:
        radial-gradient(ellipse at center, color-mix(in srgb, var(--accent-amber) 4%, transparent) 0%, transparent 70%),
        var(--surface);
    }
    .tv2-labnet-bubble {
      transition: stroke-width 0.15s, filter 0.15s;
    }
    .tv2-labnet-node:hover .tv2-labnet-bubble {
      stroke-width: 3;
      filter: drop-shadow(0 0 6px color-mix(in srgb, var(--accent-cyan) 60%, transparent));
    }
    .tv2-labnet-bubble-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 13px;
      font-weight: 600;
      fill: var(--text-primary);
    }
    .tv2-labnet-bubble-count {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 10px;
      font-weight: 500;
      fill: var(--text-tertiary);
    }
    .tv2-labnet-bubble-method {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 10px;
      font-weight: 600;
      fill: var(--accent-cyan);
      letter-spacing: 0.02em;
    }
    .tv2-labnet-foot {
      display: flex;
      flex-wrap: wrap;
      gap: 0.85rem 1.5rem;
      align-items: flex-start;
      justify-content: space-between;
      padding: 0.7rem 1rem 0.85rem;
      border-top: 1px solid var(--border-subtle);
      background: var(--surface-2);
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem;
    }
    .tv2-labnet-stats {
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      color: var(--text-secondary);
    }
    .tv2-labnet-stats strong {
      color: var(--text-primary);
      font-weight: 700;
    }
    .tv2-labnet-stats-sep {
      color: var(--text-tertiary);
      opacity: 0.5;
    }
    .tv2-labnet-isolated {
      color: var(--accent-amber);
    }
    .tv2-labnet-hubs {
      flex: 1;
      min-width: 280px;
    }
    .tv2-labnet-hubs-label {
      display: block;
      font-size: 0.68rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent-cyan);
      margin-bottom: 0.35rem;
    }
    .tv2-labnet-hubs-en {
      color: var(--text-tertiary);
      font-weight: 400;
      margin-left: 0.3rem;
    }
    .tv2-labnet-hubs-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.25rem 0.85rem;
    }
    .tv2-labnet-hubs-list li {
      display: flex;
      justify-content: space-between;
      gap: 0.4rem;
      padding: 0.2rem 0.4rem;
      border-radius: 4px;
      background: var(--surface);
      border-left: 2px solid var(--accent-cyan);
    }
    .tv2-labnet-hub-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.78rem;
      color: var(--text-primary);
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .tv2-labnet-hub-meta {
      color: var(--text-secondary);
      font-size: 0.66rem;
      white-space: nowrap;
    }
    .tv2-labnet-hub-meta strong {
      color: var(--accent-cyan);
      font-weight: 700;
    }
    .tv2-labnet-hub-sep {
      color: var(--text-tertiary);
      opacity: 0.6;
      padding: 0 0.2rem;
    }

    /* Title row for chart B (existing constellation) */
    .tv2-const-title {
      display: flex;
      align-items: baseline;
      gap: 0.65rem;
      margin: 0 0 0.45rem;
    }
    .tv2-const-title-num {
      display: inline-flex;
      align-items: center; justify-content: center;
      width: 22px; height: 22px;
      border-radius: 50%;
      background: var(--accent-cyan);
      color: #fff;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem;
      font-weight: 700;
    }
    .tv2-const-title-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.92rem;
      font-weight: 600;
      color: var(--text-primary);
    }
    .tv2-const-title-en {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.65rem;
      color: var(--text-tertiary);
      letter-spacing: 0.06em;
    }
    @media (max-width: 700px) {
      .tv2-labnet-bubble-name   { font-size: 11px; }
      .tv2-labnet-bubble-count  { font-size: 9px; }
      .tv2-labnet-bubble-method { font-size: 9px; }
      .tv2-labnet-hubs-list     { grid-template-columns: 1fr; }
    }

    /* ─── Section 04 · Researcher Constellation ─────────────────────── */
    .tv2-const {
      margin: 1rem 0 1.25rem;
      padding: 0;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
    }
    .tv2-const-svg {
      display: block;
      width: 100%;
      height: auto;
      background:
        radial-gradient(ellipse at center, color-mix(in srgb, var(--accent-cyan) 4%, transparent) 0%, transparent 65%),
        var(--surface);
    }
    .tv2-const-bridgehint {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.18em;
      fill: var(--accent-cyan);
      opacity: 0.6;
    }
    .tv2-const-method-count {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 12px;
      font-weight: 700;
      fill: var(--text-primary);
    }
    .tv2-const-method-label {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 13px;
      font-weight: 600;
      fill: var(--text-primary);
    }
    .tv2-const-dot {
      transition: r 0.15s ease, stroke-width 0.15s ease;
      cursor: pointer;
    }
    .tv2-const-dot-link:hover .tv2-const-dot {
      r: 7;
      stroke-width: 2;
    }
    .tv2-const-dot--bridge {
      filter: drop-shadow(0 0 3px color-mix(in srgb, var(--accent-cyan) 60%, transparent));
    }
    .tv2-const-caption {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      padding: 0.65rem 1rem 0.75rem;
      border-top: 1px solid var(--border-subtle);
      background: var(--surface-2);
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem;
      color: var(--text-secondary);
    }
    .tv2-const-legend {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
    }
    .tv2-const-leg-dot {
      display: inline-block;
      width: 9px; height: 9px;
      border-radius: 50%;
    }
    .tv2-const-leg-bridge {
      background: var(--accent-cyan);
      box-shadow: 0 0 6px color-mix(in srgb, var(--accent-cyan) 80%, transparent);
    }
    .tv2-const-coverage {
      color: var(--text-tertiary);
      letter-spacing: 0.04em;
    }

    .tv2-const-methodbar {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 0.5rem;
      margin: 0 0 1.25rem;
    }
    .tv2-const-methodchip {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0.55rem 0.75rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--text-tertiary);
      border-radius: 6px;
      text-decoration: none;
      color: var(--text-primary);
      transition: background 0.12s, border-color 0.12s;
    }
    .tv2-const-methodchip:hover {
      background: var(--surface-2);
    }
    .tv2-const-methodchip--vla { border-left-color: var(--accent-amber); }
    .tv2-const-methodchip--ai  { border-left-color: var(--accent-cyan); }
    .tv2-const-methodchip-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.85rem;
      font-weight: 500;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .tv2-const-methodchip-stats {
      display: inline-flex;
      gap: 0.45rem;
      align-items: baseline;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem;
    }
    .tv2-const-methodchip-count {
      color: var(--text-tertiary);
      font-weight: 700;
    }
    .tv2-const-methodchip-flash  { color: var(--accent-amber); font-weight: 700; }
    .tv2-const-methodchip-polish { color: var(--accent-cyan);  font-weight: 700; }

    .tv2-bridges {
      margin: 0 0 1.5rem;
      padding: 0.85rem 1rem 1rem;
      background: color-mix(in srgb, var(--accent-cyan) 5%, var(--surface));
      border: 1px solid color-mix(in srgb, var(--accent-cyan) 30%, var(--border));
      border-left: 3px solid var(--accent-cyan);
      border-radius: 8px;
    }
    .tv2-bridges-header {
      display: flex;
      flex-wrap: wrap;
      align-items: baseline;
      gap: 0.65rem 1rem;
      margin-bottom: 0.6rem;
    }
    .tv2-bridges-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent-cyan);
    }
    .tv2-bridges-en {
      color: var(--text-tertiary);
      font-weight: 400;
      margin-left: 0.3rem;
    }
    .tv2-bridges-hint {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.78rem;
      color: var(--text-secondary);
      font-style: italic;
    }
    .tv2-bridges-list {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.4rem 1rem;
    }
    .tv2-bridges-list li a {
      display: grid;
      grid-template-columns: 22px 1fr 1.2fr;
      gap: 0.55rem;
      align-items: center;
      padding: 0.45rem 0.55rem;
      text-decoration: none;
      color: var(--text-primary);
      border-radius: 4px;
      border-bottom: 1px solid transparent;
      transition: background 0.12s, border-color 0.12s;
    }
    .tv2-bridges-list li a:hover {
      background: var(--surface);
      border-bottom-color: var(--accent-cyan);
    }
    .tv2-bridges-rating {
      font-size: 0.95rem;
      text-align: center;
      line-height: 1;
    }
    .tv2-bridges-rating--flash  { filter: drop-shadow(0 0 2px var(--accent-amber)); }
    .tv2-bridges-rating--polish { opacity: 0.85; }
    .tv2-bridges-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.92rem;
      font-weight: 500;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
    }
    .tv2-bridges-aff {
      grid-column: 2 / -1;
      font-family: 'IBM Plex Mono', monospace;
