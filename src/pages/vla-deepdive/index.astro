---
/**
 * src/pages/vla-deepdive/index.astro
 * VLA Deep Dive — 理論深挖文章庫 + SOTA 排行 + VLA-Handbook 全庫。
 * Articles from the last 7 days render as visual cards; older ones as list rows.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadVLASOTA, loadVLATheory, loadVLAGitHubArticles } from '../../utils/data';

const theory   = loadVLATheory(50);
const sota     = loadVLASOTA(30);
const ghAll    = loadVLAGitHubArticles(100);

const GITHUB_REPO         = 'https://github.com/sou350121/VLA-Handbook';
const GITHUB_THEORY_PATH  = `${GITHUB_REPO}/tree/main/theory`;
const GITHUB_SOTA_PATH    = 'https://sota.evomind-tech.com';

// 14-day (2-week) cutoff
const cutoff = new Date(Date.now() - 14 * 86400000).toISOString().slice(0, 10);

// Theory split
const recentTheory = theory.filter(a => a.date >= cutoff);
const olderTheory  = theory.filter(a => a.date < cutoff);

// Group older theory by topic
const byTopic: Record<string, typeof olderTheory> = {};
for (const a of olderTheory) {
  const topic = a.target_dir?.replace('theory/', '') ?? 'general';
  (byTopic[topic] ??= []).push(a);
}
const topics = Object.keys(byTopic).sort();

function dotDate(iso: string) {
  const [y, m, d] = iso.split('-');
  return `${y}.${m}.${d}`;
}

// Group SOTA by benchmark
const sotaByBenchmark: Record<string, typeof sota> = {};
for (const s of sota) {
  (sotaByBenchmark[s.benchmark] ??= []).push(s);
}
const benchmarks = Object.keys(sotaByBenchmark).sort();

// Deduplicate GitHub articles against theory articles (by title, case-insensitive)
const theoryTitles = new Set(theory.map(a => a.title.toLowerCase().trim()));
const dedupedGh = ghAll.filter(a => !theoryTitles.has(a.title.toLowerCase().trim()));

// Combine: theory items + deduplicated github items, deduplicated by title
const allCombined = [
  ...theory.map(a => ({
    title:    a.title,
    date:     a.date,
    html_url: a.html_url ?? a.url,
    topic:    a.target_dir?.replace('theory/', '') ?? 'general',
    source:   'pipeline',
  })),
  ...dedupedGh.map(a => ({
    title:    a.title,
    date:     a.date,
    html_url: a.html_url,
    topic:    a.topic,
    source:   'github',
  })),
].sort((a, b) => b.date.localeCompare(a.date));

// Split combined library into 7-day cards and older list
const recentGhLibrary = allCombined.filter(a => a.date >= cutoff);
const olderGhLibrary  = allCombined.filter(a => a.date < cutoff);
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="VLA 深度追蹤"
  description="Vision-Language-Action 理論深挖與 SOTA 排行 — VLA-Handbook 庫"
>
  <div class="vdd-page page-container">

    <!-- ── Breadcrumb ── -->
    <nav class="dd-breadcrumb" aria-label="麵包屑">
      <a href={`${base}/`} class="bc-link"><span data-tc>首頁</span><span data-sc>首页</span></a>
      <span class="bc-sep">›</span>
      <span class="bc-current"><span data-tc>VLA 深度追蹤</span><span data-sc>VLA 深度追踪</span></span>
    </nav>

    <!-- ── Masthead ── -->
    <header class="vdd-masthead">
      <div class="vdd-overline"><span data-tc>VLA 線 · DEEP DIVE ARCHIVE</span><span data-sc>VLA 线 · DEEP DIVE ARCHIVE</span></div>
      <h1 class="vdd-title"><span data-tc>VLA 深度追蹤</span><span data-sc>VLA 深度追踪</span></h1>
      <div class="vdd-accent-bar"></div>

      <p class="vdd-desc">
        <span data-tc>Vision-Language-Action 系統的理論深挖與 SOTA 排行追蹤。
        Theory 文章由 pipeline 解析 arxiv 並存入 </span><span data-sc>Vision-Language-Action 系统的理论深挖与 SOTA 排行追踪。
        Theory 文章由 pipeline 解析 arxiv 并存入 </span><strong>VLA-Handbook</strong><span data-tc> 庫；
        SOTA 數據從 Evo-SOTA 自動拉取 CALVIN 等標準 Benchmark 的最新記錄。</span><span data-sc> 库；
        SOTA 数据从 Evo-SOTA 自动拉取 CALVIN 等标准 Benchmark 的最新记录。</span>
      </p>

      <!-- GitHub CTA row -->
      <div class="vdd-cta-row">
        <a href={GITHUB_THEORY_PATH} target="_blank" rel="noopener noreferrer" class="vdd-github-btn">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
              0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
              -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87
              2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95
              0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12
              0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27
              1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12
              .51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95
              .29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2
              0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          <span data-tc>VLA-Handbook 庫</span><span data-sc>VLA-Handbook 库</span>
          <span class="vdd-github-sub"><span data-tc>theory/ 目錄</span><span data-sc>theory/ 目录</span></span>
          <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M2 6h8M6 2l4 4-4 4"/>
          </svg>
        </a>
        <a href={GITHUB_SOTA_PATH} target="_blank" rel="noopener noreferrer" class="vdd-github-secondary">
          Evo-SOTA 排行榜 →
        </a>
        <div class="vdd-stats-row">
          <span class="vdd-stat">
            <span class="vdd-stat-num">{allCombined.length}</span>
            <span class="vdd-stat-lbl"><span data-tc>理論文章</span><span data-sc>理论文章</span></span>
          </span>
          <span class="vdd-stat-sep">·</span>
          <span class="vdd-stat">
            <span class="vdd-stat-num vdd-stat-num--cyan">{sota.length}</span>
            <span class="vdd-stat-lbl"><span data-tc>SOTA 記錄</span><span data-sc>SOTA 记录</span></span>
          </span>
        </div>
      </div>
    </header>

    <!-- ══════════════════════════════════════════
         SECTION 1: Theory Articles (pipeline-tracked)
    ══════════════════════════════════════════ -->
    <section class="vdd-section" aria-label="VLA 理論深挖">
      <div class="vdd-section-header">
        <h2 class="vdd-section-title"><span data-tc>📐 理論深挖</span><span data-sc>📐 理论深挖</span></h2>
        <a href={GITHUB_THEORY_PATH} target="_blank" rel="noopener noreferrer" class="vdd-section-link">
          <span data-tc>查看 GitHub 全庫</span><span data-sc>查看 GitHub 全库</span> →
        </a>
      </div>

      {theory.length === 0 ? (
        <p class="vdd-empty"><span data-tc>尚無理論文章資料</span><span data-sc>尚无理论文章资料</span></p>
      ) : (
        <>
          {/* --- 最近 2 週 card grid --- */}
          {recentTheory.length > 0 && (
            <div class="vdd-subsection">
              <div class="vdd-subsection-label">
                <span class="vdd-sublabel"><span data-tc>最近 2 週</span><span data-sc>最近 2 周</span></span>
                <span class="vdd-sublabel-count">{recentTheory.length} 篇</span>
              </div>
              <div class="vdd-card-grid">
                {recentTheory.map((article) => (
                  <article class="vdd-card">
                    <div class="vdd-card-top">
                      <time class="vdd-card-date">{dotDate(article.date)}</time>
                      {article.target_dir && (
                        <span class="vdd-card-tag vdd-card-tag--cyan">
                          {article.target_dir.replace('theory/', '').replace(/-/g, ' ')}
                        </span>
                      )}
                    </div>
                    <h3 class="vdd-card-title">{article.title}</h3>
                    <a
                      href={article.html_url ?? article.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="vdd-card-cta"
                    >
                      <span data-tc>GitHub 閱讀原文</span><span data-sc>GitHub 阅读原文</span>
                      <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M2 6h8M6 2l4 4-4 4"/>
                      </svg>
                    </a>
                  </article>
                ))}
              </div>
            </div>
          )}

          {/* --- 更多文章 list rows --- */}
          {olderTheory.length > 0 && (
            <div class="vdd-subsection">
              {recentTheory.length > 0 && (
                <div class="vdd-subsection-label">
                  <span class="vdd-sublabel">更多文章 · 全部在 GitHub</span>
                  <span class="vdd-sublabel-count">{olderTheory.length} 篇</span>
                </div>
              )}
              <div class="vdd-topics">
                {topics.map(topic => (
                  <div class="vdd-topic-group">
                    <div class="vdd-topic-label">
                      {topic.replace(/-/g, ' ')} &nbsp;·&nbsp; {byTopic[topic].length} 篇
                    </div>
                    <div class="vdd-art-list">
                      {byTopic[topic].map((article, i) => (
                        <a
                          href={article.html_url ?? article.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="vdd-art-row"
                          style={`animation-delay:${i * 0.03}s`}
                        >
                          <time class="vdd-art-date">{dotDate(article.date)}</time>
                          <span class="vdd-art-title">{article.title}</span>
                          <span class="vdd-art-ext" aria-label="在 GitHub 閱讀">
                            <svg width="11" height="11" viewBox="0 0 12 12" fill="none"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round">
                              <path d="M5 2H2a1 1 0 00-1 1v7a1 1 0 001 1h7a1 1 0 001-1V7"/>
                              <path d="M8 1h3v3M11 1L6 6"/>
                            </svg>
                          </span>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </>
      )}
    </section>

    <!-- ══════════════════════════════════════════
         SECTION 2: VLA-Handbook 全庫文章
    ══════════════════════════════════════════ -->
    <section class="vdd-section" aria-label="VLA-Handbook 全庫文章">
      <div class="vdd-section-header">
        <h2 class="vdd-section-title"><span data-tc>📚 VLA-Handbook 全庫文章</span><span data-sc>📚 VLA-Handbook 全库文章</span></h2>
        <a href={GITHUB_THEORY_PATH} target="_blank" rel="noopener noreferrer" class="vdd-section-link">
          GitHub theory/ →
        </a>
      </div>
      <p class="vdd-lib-desc">
        <span data-tc>包含 pipeline 追蹤 + 手動添加的全部理論文章（共 </span><span data-sc>包含 pipeline 追踪 + 手动添加的全部理论文章（共 </span>{allCombined.length}<span data-tc> 篇，去重後）</span><span data-sc> 篇，去重后）</span>。
      </p>

      {allCombined.length === 0 ? (
        <p class="vdd-empty"><span data-tc>尚無全庫資料</span><span data-sc>尚无全库资料</span></p>
      ) : (
        <>
          {/* --- 最近 2 週 cards --- */}
          {recentGhLibrary.length > 0 && (
            <div class="vdd-subsection">
              <div class="vdd-subsection-label">
                <span class="vdd-sublabel"><span data-tc>最近 2 週</span><span data-sc>最近 2 周</span></span>
                <span class="vdd-sublabel-count">{recentGhLibrary.length} 篇</span>
              </div>
              <div class="vdd-card-grid">
                {recentGhLibrary.map((article) => (
                  <article class="vdd-card">
                    <div class="vdd-card-top">
                      <time class="vdd-card-date">{dotDate(article.date)}</time>
                      <span class="vdd-card-tag vdd-card-tag--cyan">
                        {article.topic.replace(/-/g, ' ')}
                      </span>
                    </div>
                    <h3 class="vdd-card-title">{article.title}</h3>
                    <a
                      href={article.html_url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="vdd-card-cta"
                    >
                      <span data-tc>在 GitHub 閱讀</span><span data-sc>在 GitHub 阅读</span>
                      <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M2 6h8M6 2l4 4-4 4"/>
                      </svg>
                    </a>
                  </article>
                ))}
              </div>
            </div>
          )}

          {/* --- 更多文章 list rows --- */}
          {olderGhLibrary.length > 0 && (
            <div class="vdd-subsection">
              {recentGhLibrary.length > 0 && (
                <div class="vdd-subsection-label">
                  <span class="vdd-sublabel">更多文章 · 全部在 GitHub</span>
                  <span class="vdd-sublabel-count">{olderGhLibrary.length} 篇</span>
                </div>
              )}
              <div class="vdd-art-list">
                {olderGhLibrary.map((article, i) => (
                  <a
                    href={article.html_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="vdd-art-row"
                    style={`animation-delay:${i * 0.02}s`}
                  >
                    <time class="vdd-art-date">{dotDate(article.date)}</time>
                    <span class="vdd-art-title">{article.title}</span>
                    <span class="vdd-art-ext" aria-label="在 GitHub 閱讀">
                      <svg width="11" height="11" viewBox="0 0 12 12" fill="none"
                        stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <path d="M5 2H2a1 1 0 00-1 1v7a1 1 0 001 1h7a1 1 0 001-1V7"/>
                        <path d="M8 1h3v3M11 1L6 6"/>
                      </svg>
                    </span>
                  </a>
                ))}
              </div>
            </div>
          )}
        </>
      )}
    </section>

    <!-- ══════════════════════════════════════════
         SECTION 3: SOTA Leaderboard
    ══════════════════════════════════════════ -->
    <section class="vdd-section" aria-label="SOTA 排行">
      <div class="vdd-section-header">
        <h2 class="vdd-section-title">🏆 SOTA 排行</h2>
        <a href={GITHUB_SOTA_PATH} target="_blank" rel="noopener noreferrer" class="vdd-section-link">
          Evo-SOTA 完整榜 →
        </a>
      </div>

      {sota.length === 0 ? (
        <p class="vdd-empty"><span data-tc>尚無 SOTA 數據</span><span data-sc>尚无 SOTA 数据</span></p>
      ) : (
        <div class="vdd-sota-groups">
          {benchmarks.map(bench => {
            const entries = sotaByBenchmark[bench].sort((a, b) => b.value - a.value);
            const top = entries[0];
            return (
              <div class="sota-bench-block">
                <!-- Benchmark header -->
                <div class="sota-bench-header">
                  <div class="sota-bench-left">
                    <span class="sota-bench-name">
                      {top.leaderboard_url
                        ? <a href={top.leaderboard_url} target="_blank" rel="noopener noreferrer">{bench}</a>
                        : bench
                      }
                    </span>
                    {top.split && <span class="sota-bench-split">{top.split}</span>}
                  </div>
                  <span class="sota-bench-metric">{top.metric}</span>
                </div>

                <!-- Entries table -->
                <div class="sota-table-wrap">
                  <table class="sota-table">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Model</th>
                        <th>Score</th>
                        <th>vs Prev</th>
                        <th>Date</th>
                        <th>Paper</th>
                      </tr>
                    </thead>
                    <tbody>
                      {entries.map((e, rank) => (
                        <tr class:list={['sota-row', rank === 0 && 'sota-row--top']}>
                          <td class="sota-rank">{rank + 1}</td>
                          <td class="sota-model">{e.model}</td>
                          <td class="sota-score">{e.value}</td>
                          <td class="sota-baseline">{e.baseline ?? '—'}</td>
                          <td class="sota-date">{e.date}</td>
                          <td class="sota-paper">
                            {e.paper_url
                              ? <a href={e.paper_url} target="_blank" rel="noopener noreferrer">arxiv →</a>
                              : '—'
                            }
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </section>

  </div>
</BaseLayout>

<style>
.vdd-page {
  padding-top: 56px;
  padding-bottom: 80px;
}

/* ── Masthead ── */
.vdd-masthead { margin-bottom: 48px; }

.vdd-overline {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--text-tertiary);
  margin-bottom: 10px;
}

.vdd-title {
  font-family: Georgia, 'Songti SC', serif;
  font-size: clamp(2rem, 5vw, 3.4rem);
  font-weight: 700;
  color: var(--text-primary);
  margin: 0 0 16px;
  line-height: 1.1;
}

.vdd-accent-bar {
  height: 3px;
  width: 80px;
  background: var(--accent-cyan);
  border-radius: 2px;
  margin-bottom: 18px;
}

.vdd-desc {
  font-size: 0.92rem;
  color: var(--text-secondary);
  line-height: 1.75;
  max-width: 680px;
  margin: 0 0 28px;
}

.vdd-desc strong { color: var(--text-primary); }

/* ── CTA row ── */
.vdd-cta-row {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
}

.vdd-github-btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--text-primary);
  color: var(--bg);
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.05em;
  padding: 10px 18px;
  border-radius: 8px;
  text-decoration: none;
  transition: opacity 0.2s, transform 0.2s;
  opacity: 1;
}

.vdd-github-btn:hover { opacity: 0.85; transform: translateY(-1px); }

.vdd-github-sub {
  font-size: 0.6rem;
  opacity: 0.6;
  font-weight: 400;
  letter-spacing: 0.08em;
}

.vdd-github-secondary {
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 0.72rem;
  color: var(--accent-cyan);
  text-decoration: none;
  letter-spacing: 0.06em;
  opacity: 0.85;
  transition: opacity 0.15s;
}

.vdd-github-secondary:hover { opacity: 1; }

.vdd-stats-row {
  display: flex;
  align-items: baseline;
  gap: 8px;
  font-family: 'Menlo', 'Consolas', monospace;
  margin-left: auto;
}

.vdd-stat { display: flex; align-items: baseline; gap: 4px; }

.vdd-stat-num {
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--accent-amber);
  line-height: 1;
}

.vdd-stat-num--cyan { color: var(--accent-cyan); }

.vdd-stat-lbl {
  font-size: 0.62rem;
  letter-spacing: 0.1em;
  color: var(--text-tertiary);
  text-transform: uppercase;
}

.vdd-stat-sep { color: var(--border); font-size: 1rem; }

/* ── Sections ── */
.vdd-section {
  margin-top: 56px;
  padding-top: 40px;
  border-top: 1px solid var(--border);
}

.vdd-section-header {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 24px;
  gap: 16px;
}

.vdd-section-title {
  font-family: Georgia, 'Songti SC', serif;
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--text-primary);
  margin: 0;
}

.vdd-section-link {
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 0.68rem;
  letter-spacing: 0.06em;
  color: var(--accent-cyan);
  text-decoration: none;
  opacity: 0.85;
  transition: opacity 0.15s;
  flex-shrink: 0;
}

.vdd-section-link:hover { opacity: 1; }

.vdd-lib-desc {
  font-size: 0.82rem;
  color: var(--text-secondary);
  margin: -12px 0 20px;
  line-height: 1.6;
}

.vdd-empty {
  font-family: 'Menlo', monospace;
  font-size: 0.8rem;
  color: var(--text-tertiary);
  padding: 24px 0;
}

/* ── Subsections (within a section) ── */
.vdd-subsection { margin-bottom: 32px; }

.vdd-subsection-label {
  display: flex;
  align-items: baseline;
  gap: 10px;
  margin-bottom: 16px;
  padding-bottom: 8px;
  border-bottom: 1px dashed var(--border);
}

.vdd-sublabel {
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--accent-cyan);
  font-weight: 600;
}

.vdd-sublabel-count {
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 0.58rem;
  letter-spacing: 0.1em;
  color: var(--text-tertiary);
}

/* ── Card grid ── */
.vdd-card-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 16px;
}

.vdd-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-top: 3px solid var(--accent-cyan);
  border-radius: 12px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 10px;
