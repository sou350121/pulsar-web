---
/**
 * Footer.astro
 * Site footer — styled using the Pulsar design system from global.css.
 */
const year = new Date().getFullYear();
---

<footer aria-label="Site footer">
  <div class="container">
    <div class="footer-grid">

      <!-- Brand -->
      <div>
        <span class="footer-brand-logo">PUL<span>S</span>AR</span>
        <p class="footer-tagline" style="font-size:1.1rem;font-weight:500;margin-bottom:6px;">照　見</p>
        <p class="footer-tagline">
          AI 研究情報平台。每日自動聚合前沿論文、行業動態
          與實驗室信號，為研究者和從業者提供結構化洞察。
        </p>
        <div class="footer-auto-label">
          <span style="color:#4CAF50;">●</span>
          由 AI Pipeline 自動生成 · 每日更新
        </div>
      </div>

      <!-- Nav Column 1 -->
      <div>
        <h3 class="footer-col-title">內容頻道</h3>
        <ul class="footer-links" role="list">
          <li><a href="/ai-daily">AI App 日報</a></li>
          <li><a href="/vla">VLA 研究日報</a></li>
          <li><a href="/social">社交情報</a></li>
          <li><a href="/reports">雙週報告</a></li>
          <li><a href="/dashboard">數據面板</a></li>
        </ul>
      </div>

      <!-- Nav Column 2 -->
      <div>
        <h3 class="footer-col-title">系統工具</h3>
        <ul class="footer-links" role="list">
          <li><a href="/dashboard">管道儀表板</a></li>
          <li><a href="#">實體追蹤器</a></li>
          <li><a href="#">語義搜索</a></li>
          <li><a href="#">假設校準庫</a></li>
          <li><a href="#">跨域規則引擎</a></li>
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <span class="footer-copy">
        PULSAR · 照見 &copy; {year}
      </span>
      <span class="footer-version">
        Pipeline v6 · Qwen3.5-Plus · 每日更新
      </span>
    </div>
  </div>
</footer>
