---
import BaseLayout     from '../../layouts/BaseLayout.astro';
import TalentPageHero from '../../components/TalentPageHero.astro';
import PersonCard     from '../../components/PersonCard.astro';
import { loadPeople } from '../../utils/talent';

const people = loadPeople({ minPaperCount90d: 1 });

const linked     = people.filter(p => p.contactStatus === 'linked_via_lab');
const social     = people.filter(p => p.contactStatus === 'social_mention');
const bylineOnly = people.filter(p => p.contactStatus === 'not_linked');
---

<BaseLayout
  title="研究員 People · Talent Radar"
  description="研究员卡片 — 第一作者抽取 × 机构关联 × 社交情报 (无邮箱展示)"
>
  <main class="container talent-v2-page">
    <TalentPageHero
      sectionNum="04"
      titleTC="研究員"
      titleSC="研究员"
      titleEN="People"
      ledeTC={`<strong>${people.length} 位研究員</strong>，來源為評分論文第一作者抽取 + <code>entity-index.json</code> 策展研究員，機構經 <code>institution-registry.json</code> 解析。`}
      ledeSC={`<strong>${people.length} 位研究员</strong>，来源为评分论文第一作者抽取 + <code>entity-index.json</code> 策展研究员，机构经 <code>institution-registry.json</code> 解析。`}
    />

    <aside class="tv2-no-email">
      <span class="tv2-no-email-tag">NO-EMAIL</span>
      <span data-tc>Pulsar 從不儲存或顯示電子郵件。聯繫狀態為啟發式推斷，任何觸達前請自行核實。</span>
      <span data-sc>Pulsar 从不存储或显示邮箱。联系状态为启发式推断，外展前请自行核实。</span>
    </aside>

    <div class="tv2-toolbar">
      <input
        id="people-search"
        type="search"
        placeholder="Search by name, affiliation, paper title…"
        class="tv2-search"
        aria-label="Search people"
      />
      <p class="tv2-search-count" id="people-search-count" aria-live="polite"></p>
    </div>

    {/* Tier 1: linked via lab */}
    {linked.length > 0 && (
      <section class="tv2-section">
        <h2 class="tv2-section-h2">
          <span class="tv2-tier-dot" style="background: var(--accent-cyan);"></span>
          <span data-tc>機構已確認</span><span data-sc>机构已确认</span>
          <span class="tv2-section-count">· {linked.length}</span>
        </h2>
        <div class="picks-grid">
          {linked.map(p => <PersonCard record={p} />)}
        </div>
      </section>
    )}

    {/* Tier 2: social mention */}
    {social.length > 0 && (
      <section class="tv2-section">
        <h2 class="tv2-section-h2">
          <span class="tv2-tier-dot" style="background: var(--accent-amber);"></span>
          <span data-tc>社交情報提及</span><span data-sc>社交情报提及</span>
          <span class="tv2-section-count">· {social.length}</span>
        </h2>
        <div class="picks-grid">
          {social.map(p => <PersonCard record={p} />)}
        </div>
      </section>
    )}

    {/* Tier 3: byline only (collapsed by default) */}
    {bylineOnly.length > 0 && (
      <section class="tv2-section">
        <details>
          <summary class="tv2-byline-summary">
            <span class="tv2-tier-dot" style="background: var(--text-tertiary);"></span>
            <span data-tc>僅論文署名</span><span data-sc>仅论文署名</span>
            <span class="tv2-section-count">· {bylineOnly.length}</span>
            <span class="tv2-byline-cue">click to expand →</span>
          </summary>
          <p class="tv2-byline-note">
            First-author bylines without a resolvable affiliation or social mention in
            90 days. <em>Lowest confidence tier — surfaced for transparency only.</em>
          </p>
          <div class="picks-grid tv2-faded">
            {bylineOnly.slice(0, 30).map(p => <PersonCard record={p} />)}
          </div>
          {bylineOnly.length > 30 && (
            <p class="tv2-byline-truncated">
              Showing 30 of {bylineOnly.length}. The rest are deliberately hidden —
              no durable signal beyond the paper byline.
            </p>
          )}
        </details>
      </section>
    )}
  </main>

  <script is:inline>
    (() => {
      const input = document.getElementById('people-search');
      const counter = document.getElementById('people-search-count');
      if (!input) return;
      input.addEventListener('input', () => {
        const q = input.value.toLowerCase().trim();
        let shown = 0;
        document.querySelectorAll('article.card').forEach((card) => {
          const text = (card.textContent || '').toLowerCase();
          const hit = q === '' || text.includes(q);
          card.style.display = hit ? '' : 'none';
          if (hit) shown++;
        });
        document.querySelectorAll('.tv2-section').forEach((sec) => {
          const visible = sec.querySelectorAll('article.card:not([style*="display: none"])');
          sec.style.display = visible.length === 0 && q !== '' ? 'none' : '';
        });
        if (counter) counter.textContent = q === '' ? '' : `${shown} match${shown === 1 ? '' : 'es'}`;
      });
    })();
  </script>

  <style>
    .talent-v2-page { max-width: 1200px; margin: 0 auto; padding: 2rem 1rem 4rem; }
    .tv2-section { margin: 2.25rem 0; }
    .tv2-section-h2 {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 1.25rem; font-weight: 600;
      margin: 0 0 1rem; padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
      color: var(--text-primary);
      display: flex; align-items: center; gap: 0.6rem;
    }
    .tv2-tier-dot {
      width: 9px; height: 9px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .tv2-section-count {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem;
      color: var(--text-tertiary);
      font-weight: 400;
      margin-left: 0.25rem;
    }
    .tv2-no-email {
      display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem;
      margin: 0 0 1.5rem;
      padding: 0.65rem 0.95rem;
      background: var(--accent-amber-bg);
      border-left: 3px solid var(--accent-amber);
      border-radius: 4px;
      font-size: 0.85rem;
      color: var(--text-secondary);
    }
    .tv2-no-email-tag {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.18em;
      color: var(--accent-amber);
    }
    .tv2-toolbar { margin: 0 0 1.5rem; }
    .tv2-search {
      width: 100%; max-width: 480px;
      padding: 0.65rem 0.95rem;
      font-family: 'IBM Plex Mono', monospace; font-size: 0.9rem;
      background: var(--surface); color: var(--text-primary);
      border: 1px solid var(--border); border-radius: 8px;
    }
    .tv2-search:focus {
      outline: none; border-color: var(--accent-cyan);
      box-shadow: 0 0 0 3px var(--accent-cyan-bg);
    }
    .tv2-search-count {
      font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem;
      color: var(--text-tertiary); margin: 0.3rem 0 0;
      min-height: 1em;
    }
    .tv2-byline-summary {
      cursor: pointer;
      list-style: none;
      padding: 0.6rem 0;
      margin-bottom: 0.5rem;
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 1.1rem; font-weight: 600;
      color: var(--text-primary);
      display: flex; align-items: center; gap: 0.6rem;
      border-bottom: 1px solid var(--border);
    }
    .tv2-byline-summary::-webkit-details-marker { display: none; }
    .tv2-byline-cue {
      margin-left: auto;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem; font-weight: 400;
      letter-spacing: 0.06em;
      color: var(--accent-cyan);
      text-transform: lowercase;
    }
    details[open] .tv2-byline-cue { color: var(--text-tertiary); }
    details[open] .tv2-byline-cue::before { content: '↓ '; }
    .tv2-byline-note {
      color: var(--text-tertiary); font-size: 0.85rem;
      margin: 0.75rem 0 1rem;
    }
    .tv2-byline-note em { color: var(--accent-amber); font-style: normal; }
    .tv2-faded { opacity: 0.75; }
    .tv2-byline-truncated {
      text-align: center; color: var(--text-tertiary);
      font-style: italic; margin-top: 1rem; font-size: 0.85rem;
    }
  </style>
</BaseLayout>
