---
/**
 * src/pages/daily/index.astro
 * Combined AI App + VLA daily archive — 7-day summary + domain switcher + archive.
 * User intents: (1) catch up quickly → 7-day summary with top ⚡ signals,
 *               (2) switch domain focus → tab nav to /ai-daily or /vla,
 *               (3) find a specific day → archive list below.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadAIDailyPicks, loadVLADailyPicks, loadSocialIntel } from '../../utils/data';

const base = import.meta.env.BASE_URL;

const aiDays  = loadAIDailyPicks(60);
const vlaDays = loadVLADailyPicks(60);

// ── 7-day summary ────────────────────────────────────────────────────────────
const sevenAI  = aiDays.slice(0, 7);
const sevenVLA = vlaDays.slice(0, 7);

// Flatten items and tag with date + domain
const flatAI  = sevenAI.flatMap(d  => d.items.map(i => ({ ...i, date: d.date,  domain: 'ai'  as const })));
const flatVLA = sevenVLA.flatMap(d => d.items.map(i => ({ ...i, date: d.date,  domain: 'vla' as const })));
const flatAll = [...flatAI, ...flatVLA];

const aiTotal    = flatAI.length;
const vlaTotal   = flatVLA.length;

// Detect arxiv weekend gap — VLA relies on arxiv which doesn't publish Fri night–Mon
const vlaLatestDate = sevenVLA[0]?.date ?? '';
const vlaDaysSince  = vlaLatestDate
  ? Math.floor((Date.now() - new Date(vlaLatestDate + 'T00:00:00+08:00').getTime()) / 86400000)
  : 99;
const arxivGap = vlaTotal === 0 || vlaDaysSince >= 2;
const flashCount = flatAll.filter(i => i.rating === '⚡').length;
const wrenchCount= flatAll.filter(i => i.rating === '🔧').length;
const bookCount  = flatAll.filter(i => i.rating === '📖').length;

// Top ⚡ signals — interleave VLA (2) + AI (3) for variety
const topFlash = [
  ...flatVLA.filter(i => i.rating === '⚡').slice(0, 2),
  ...flatAI.filter(i  => i.rating === '⚡').slice(0, 3),
].slice(0, 5);

// Summary date range label
const summaryDates = [
  ...sevenAI.map(d => d.date),
  ...sevenVLA.map(d => d.date),
].sort();
const dateFrom = summaryDates[0] ?? '';
const dateTo   = summaryDates[summaryDates.length - 1] ?? '';

// ── 3-day content feed ────────────────────────────────────────────────────────
const threeAI  = aiDays.slice(0, 3);
const threeVLA = vlaDays.slice(0, 3);
const threeDayDates = [...new Set([
  ...threeAI.map(d => d.date),
  ...threeVLA.map(d => d.date),
])].sort().reverse().slice(0, 3);

function srcTag(s: string): string {
  return (s ?? 'SRC').toUpperCase().slice(0, 8);
}


// ── VLA social intel (daily, even weekends) ──────────────────────────────────
const vlaSocial = loadSocialIntel('vla', 3);
interface SocialSnippet {
  date: string;
  items: string[];
  trend: string;
}
const vlaSocialSnips: SocialSnippet[] = vlaSocial
  .filter(f => f.content.trim().length > 30)
  .map(f => {
    const items: string[] = [];
    let trend = '';
    for (const line of f.content.split('\n')) {
      const trimmed = line.trim();
      // Extract bullet points from 📊 section
      if (/^[-*•]\s*\[/.test(trimmed) || /^[-*•]\s*\S/.test(trimmed)) {
        const clean = trimmed.replace(/^[-*•]\s*/, '').replace(/https?:\/\/\S+/g, '').trim();
        if (clean.length > 15 && !clean.startsWith('本報告')) items.push(clean);
      }
      // Extract trend observation
      if (trend === '' && !/^[-*•#📊📡🔭]/.test(trimmed) && trimmed.length > 20 && !trimmed.startsWith('*本') && !trimmed.startsWith('http')) {
        trend = trimmed.length > 100 ? trimmed.slice(0, 100) + '…' : trimmed;
      }
    }
    return { date: f.date, items: items.slice(0, 3), trend };
  })
  .filter(s => s.items.length > 0);

// ── Merged archive ────────────────────────────────────────────────────────────
type DomainDay = {
  date: string; domain: 'ai' | 'vla';
  count: number; firstTitle: string; counts: Record<string, number>;
};

const merged: DomainDay[] = [
  ...aiDays.map(d => ({
    date: d.date, domain: 'ai' as const,
    count: d.items.length,
    firstTitle: d.items[0]?.title ?? '',
    counts: d.items.reduce<Record<string, number>>((a, i) => {
      a[i.rating] = (a[i.rating] ?? 0) + 1; return a;
    }, {}),
  })),
  ...vlaDays.map(d => ({
    date: d.date, domain: 'vla' as const,
    count: d.items.length,
    firstTitle: d.items[0]?.title ?? '',
    counts: d.items.reduce<Record<string, number>>((a, i) => {
      a[i.rating] = (a[i.rating] ?? 0) + 1; return a;
    }, {}),
  })),
].sort((a, b) => b.date.localeCompare(a.date) || (a.domain === 'ai' ? -1 : 1));

const today     = new Date().toISOString().slice(0, 10);
const yesterday = new Date(Date.now() - 86400000).toISOString().slice(0, 10);
const dayBefore = new Date(Date.now() - 172800000).toISOString().slice(0, 10);

function recencyLabel(date: string): string | null {
  if (date === today)     return '最新';
  if (date === yesterday) return '昨日';
  if (date === dayBefore) return '2日前';
  return null;
}

function dotDate(iso: string): string {
  const [y, m, d] = iso.split('-');
  return `${y} · ${m} · ${d}`;
}

let lastMonth = '';
---

<BaseLayout
  title="研究日報 — 近7日匯總 | AI App + VLA"
  description="AI App 精選與 VLA 論文的每日合輯 — 近7日綜合匯總、⚡突破信號、歸檔索引"
>
  <div class="daily-page page-container">

    <!-- ── Domain switcher tabs ── -->
    <nav class="domain-nav" aria-label="領域切換">
      <a href={`${base}/daily`} class="domain-tab domain-tab--active" aria-current="page">
        <span class="tab-dot tab-dot--both" aria-hidden="true"></span>
        全部
      </a>
      <a href={`${base}/ai-daily`} class="domain-tab">
        <span class="tab-dot tab-dot--ai" aria-hidden="true"></span>
        <span data-tc>AI App 線</span><span data-sc>AI App 线</span>
      </a>
      <a href={`${base}/vla`} class="domain-tab">
        <span class="tab-dot tab-dot--vla" aria-hidden="true"></span>
        <span data-tc>VLA 線</span><span data-sc>VLA 线</span>
      </a>
    </nav>

    <!-- ── Masthead ── -->
    <header class="daily-masthead">
      <p class="daily-overline">DAILY INTELLIGENCE · AI APP + VLA</p>
      <h1 class="daily-title"><span data-tc>研究日報</span><span data-sc>研究日报</span></h1>
      <div class="daily-rule">
        <span class="daily-rule-ai"></span>
        <span class="daily-rule-vla"></span>
      </div>
      <p class="daily-desc">
        <span data-tc>AI App 精選與 VLA 論文評級的每日合輯</span><span data-sc>AI App 精选与 VLA 论文评级的每日合辑</span>。
        <span data-tc>下方匯總近 7 天的信號總覽，歸檔索引可按領域過濾</span><span data-sc>下方汇总近 7 天的信号总览，归档索引可按领域过滤</span>。
      </p>
    </header>

    <!-- ── 7-Day Summary ── -->
    {(aiTotal > 0 || vlaTotal > 0) && (
      <section class="summary-block" aria-label="近7日匯總">

        <div class="summary-header">
          <span class="summary-eyebrow"><span data-tc>近 7 日匯總</span><span data-sc>近 7 日汇总</span></span>
          {dateFrom && dateTo && (
            <span class="summary-range">{dateFrom.slice(5)} → {dateTo.slice(5)}</span>
          )}
        </div>

        <!-- Stat chips row -->
        <div class="summary-stats">
          <div class="stat-chip stat-chip--ai">
            <span class="stat-num">{aiTotal}</span>
            <span class="stat-lbl"><span data-tc>AI精選</span><span data-sc>AI精选</span></span>
          </div>
          <div class="stat-chip stat-chip--vla">
            <span class="stat-num">{vlaTotal}</span>
            <span class="stat-lbl"><span data-tc>VLA論文</span><span data-sc>VLA论文</span></span>
          </div>
          {arxivGap && (
            <div class="arxiv-gap-note">
              <span data-tc>arXiv 週末休刊，VLA 論文將於下個工作日更新</span>
              <span data-sc>arXiv 周末休刊，VLA 论文将于下个工作日更新</span>
            </div>
          )}
          <div class="stat-chip stat-chip--flash">
            <span class="stat-num">⚡ {flashCount}</span>
            <span class="stat-lbl">突破</span>
          </div>
          <div class="stat-chip stat-chip--wrench">
            <span class="stat-num">🔧 {wrenchCount}</span>
            <span class="stat-lbl"><span data-tc>工具/技術</span><span data-sc>工具/技术</span></span>
          </div>
          <div class="stat-chip stat-chip--book">
            <span class="stat-num">📖 {bookCount}</span>
            <span class="stat-lbl"><span data-tc>背景/觀點</span><span data-sc>背景/观点</span></span>
          </div>
        </div>

        <!-- Top ⚡ signals -->
        {topFlash.length > 0 && (
          <div class="top-flash">
            <p class="top-flash-eyebrow">⚡ <span data-tc>本週最強信號</span><span data-sc>本周最强信号</span></p>
            <ul class="top-flash-list" role="list">
              {topFlash.map(item => (
                <li>
                  <a
                    href={item.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flash-row"
                    title={item.title}
                  >
                    <span class:list={['flash-dot', item.domain === 'vla' ? 'flash-dot--vla' : 'flash-dot--ai']} aria-hidden="true"></span>
                    <span class="flash-title">{item.title}</span>
                    <span class="flash-meta">{srcTag(item.source)}&thinsp;·&thinsp;{item.date.slice(5)}</span>
                    <svg width="10" height="10" viewBox="0 0 10 10" fill="none"
                      stroke="currentColor" stroke-width="1.5"
                      class="flash-arrow" aria-hidden="true">
                      <path d="M1 5h8M6 2l3 3-3 3"/>
                    </svg>
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Quick-jump links to latest day in each domain -->
        <div class="summary-quickjump">
          {aiDays[0] && (
            <a href={`${base}/ai-daily/${aiDays[0].date}`} class="qj-link qj-link--ai">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M1 6h10M7 2l4 4-4 4"/></svg>
              AI 今日 · {aiDays[0].date.slice(5)}
            </a>
          )}
          {vlaDays[0] && (
            <a href={`${base}/vla/${vlaDays[0].date}`} class="qj-link qj-link--vla">
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M1 6h10M7 2l4 4-4 4"/></svg>
              VLA 今日 · {vlaDays[0].date.slice(5)}
            </a>
          )}
        </div>

      </section>
    )}

    <!-- ── 3-Day Content Feed ── -->
    {threeDayDates.length > 0 && (
      <section class="recent-block" aria-label="近3天內容">

        <div class="recent-header">
          <span class="recent-eyebrow"><span data-tc>近 3 天內容</span><span data-sc>近 3 天内容</span></span>
          <span class="recent-range">{threeDayDates[threeDayDates.length - 1]?.slice(5)} → {threeDayDates[0]?.slice(5)}</span>
        </div>

        {threeDayDates.map(date => {
          const aiDay  = threeAI.find(d => d.date === date);
          const vlaDay = threeVLA.find(d => d.date === date);
          const recency = recencyLabel(date);
          const allItems = [
            ...(aiDay?.items  ?? []).map(i => ({ ...i, domain: 'ai'  as const })),
            ...(vlaDay?.items ?? []).map(i => ({ ...i, domain: 'vla' as const })),
          ];
          if (allItems.length === 0) return null;
          return (
            <div class="recent-day">
              <div class="recent-day-hd">
                <span class="recent-day-date">{date}</span>
                {recency && <span class="recency-tag">{recency}</span>}
                <span class="recent-day-count">{allItems.length} <span data-tc>條</span><span data-sc>条</span></span>
              </div>
              <div class="recent-items">
                {allItems.map(item => {
                  const emoji = [...item.rating][0] ?? item.rating;
                  const href  = item.domain === 'ai'
                    ? `${base}/ai-daily/${date}`
                    : `${base}/vla/${date}`;
                  return (
                    <a
                      href={item.url || href}
                      target={item.url ? '_blank' : undefined}
                      rel={item.url ? 'noopener noreferrer' : undefined}
                      class:list={['recent-item', `recent-item--${item.domain}`]}
                    >
                      <span class="recent-emoji" aria-hidden="true">{emoji}</span>
                      <span class="recent-title">{item.title}</span>
                      <span class:list={['recent-domain', `recent-domain--${item.domain}`]}>
                        {item.domain === 'ai' ? 'AI' : 'VLA'}
                      </span>
                    </a>
                  );
                })}
              </div>
            </div>
          );
        })}

      </section>
    )}

    <!-- ── VLA Social Intel ── -->
    {vlaSocialSnips.length > 0 && (
      <section class="social-block" aria-label="VLA 社交動態">
        <div class="social-header">
          <span class="social-eyebrow">📡 <span data-tc>VLA 社交動態</span><span data-sc>VLA 社交动态</span></span>
          <a href={`${base}/social`} class="social-more">
            <span data-tc>更多</span><span data-sc>更多</span> →
          </a>
        </div>
        <div class="social-cards">
          {vlaSocialSnips.map(day => (
            <div class="social-card">
              <div class="social-card-hd">
                <span class="social-card-date">{day.date.slice(5)}</span>
                <span class="social-card-count">{day.items.length} <span data-tc>條</span><span data-sc>条</span></span>
              </div>
              <ul class="social-card-items" role="list">
                {day.items.map(item => (
                  <li class="social-card-li">{item}</li>
                ))}
              </ul>
              {day.trend && (
                <p class="social-card-trend">🔭 {day.trend}</p>
              )}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ── Archive header ── -->
    <div class="archive-header-row">
      <h2 class="archive-heading"><span data-tc>歸檔索引</span><span data-sc>归档索引</span></h2>
      <span class="archive-badge">{merged.length} 期</span>
    </div>

    <!-- ── Archive list ── -->
    {merged.length === 0 ? (
      <p class="daily-empty"><span data-tc>尚無日報資料</span><span data-sc>尚无日报资料</span></p>
    ) : (
      <div class="daily-list">
        {merged.map(day => {
          const [y, m] = day.date.split('-');
          const monthKey = `${y}-${m}`;
          const showSep = monthKey !== lastMonth;
          lastMonth = monthKey;
          const recency = recencyLabel(day.date);
          const href = day.domain === 'ai'
            ? `${base}/ai-daily/${day.date}`
            : `${base}/vla/${day.date}`;
          return (
            <>
              {showSep && (
                <div class="month-sep">— {y} 年 {parseInt(m)} 月 —</div>
              )}
              <a href={href} class:list={['day-row', `day-row--${day.domain}`]}>
                <div class="day-left">
                  <span class:list={['domain-pill', `domain-pill--${day.domain}`]}>
                    {day.domain === 'ai' ? 'AI' : 'VLA'}
                  </span>
                  <time class="day-date">{dotDate(day.date)}</time>
                  {recency && <span class="recency-tag">{recency}</span>}
                </div>
                <div class="day-mid">
                  <span class="day-ratings">
                    {[['⚡','flash'],['🔧','wrench'],['📖','book'],['❌','x']].map(([r]) =>
                      day.counts[r] ? (
                        <span class:list={['rating-chip', `rating-chip--${r === '⚡' ? 'flash' : r === '🔧' ? 'wrench' : r === '📖' ? 'book' : 'x'}`]}>
                          {r} {day.counts[r]}
                        </span>
                      ) : null
                    )}
                  </span>
                  {day.firstTitle && (
                    <span class="day-teaser">{day.firstTitle}</span>
                  )}
                </div>
                <div class="day-right">
                  <span class="day-count">{day.count} 篇</span>
                  <svg width="14" height="14" viewBox="0 0 14 14" fill="none"
                    stroke="currentColor" stroke-width="2" class="day-arrow" aria-hidden="true">
                    <path d="M2 7h10M8 3l4 4-4 4"/>
                  </svg>
                </div>
              </a>
            </>
          );
        })}
      </div>
    )}

  </div>
</BaseLayout>

<style>
.daily-page {
  padding-top: 32px;
  padding-bottom: 80px;
}

/* ── Domain nav tabs ── */
.domain-nav {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-bottom: 32px;
  padding-bottom: 0;
  border-bottom: 1px solid var(--border-subtle);
}

.domain-tab {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  padding: 8px 14px 10px;
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 0.68rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-tertiary);
  text-decoration: none;
  border-bottom: 2px solid transparent;
  margin-bottom: -1px;
  transition: color 0.15s, border-color 0.15s;
}

.domain-tab:hover {
  color: var(--text-secondary);
}

.domain-tab--active {
  color: var(--text-primary);
  border-bottom-color: var(--text-primary);
}

.tab-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}

.tab-dot--ai   { background: var(--accent-amber); }
.tab-dot--vla  { background: var(--accent-cyan); }
.tab-dot--both {
  background: linear-gradient(90deg, var(--accent-amber) 50%, var(--accent-cyan) 50%);
}

/* ── Masthead ── */
.daily-masthead {
  margin-bottom: 36px;
}

.daily-overline {
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--text-tertiary);
  margin-bottom: 10px;
}

.daily-title {
  font-family: Georgia, 'Songti SC', serif;
  font-size: clamp(1.6rem, 5vw, 2.8rem);
  font-weight: 700;
  color: var(--text-primary);
  margin: 0 0 14px;
  line-height: 1.1;
}

.daily-rule {
  display: flex;
  height: 3px;
  width: 100px;
  margin-bottom: 14px;
  border-radius: 2px;
  overflow: hidden;
}

.daily-rule-ai  { flex: 3; background: var(--accent-amber); }
.daily-rule-vla { flex: 2; background: var(--accent-cyan); }

.daily-desc {
  font-size: 0.88rem;
  color: var(--text-secondary);
  line-height: 1.7;
  max-width: 560px;
  margin: 0;
}

/* ── 7-day summary block ── */
.summary-block {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 22px 24px 18px;
  margin-bottom: 40px;
  position: relative;
  overflow: hidden;
}

.summary-block::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 2px;
  background: linear-gradient(90deg, var(--accent-amber) 0%, var(--accent-cyan) 100%);
}

.summary-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 16px;
}

.summary-eyebrow {
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--text-tertiary);
}

.summary-range {
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.06em;
  color: var(--text-tertiary);
  opacity: 0.7;
}

/* Stat chips */
.summary-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 20px;
}

.stat-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8px 14px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--surface-2);
  min-width: 72px;
  transition: border-color 0.15s;
}

.stat-chip--ai     { border-color: rgba(212, 145, 10, 0.25); }
.stat-chip--vla    { border-color: rgba(15, 143, 160, 0.25); }
.stat-chip--flash  { border-color: rgba(212, 145, 10, 0.20); }
.stat-chip--wrench { border-color: rgba(43, 142, 199, 0.20); }
.stat-chip--book   { border-color: rgba(61, 139, 94, 0.20); }

.arxiv-gap-note {
  width: 100%;
  text-align: center;
  font-size: 0.78rem;
  color: var(--text-secondary, #8b949e);
  padding: 6px 12px;
  background: rgba(15, 143, 160, 0.06);
  border: 1px dashed rgba(15, 143, 160, 0.20);
  border-radius: 6px;
  margin-top: 2px;
}

.stat-num {
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1;
  margin-bottom: 4px;
}

.stat-chip--ai .stat-num  { color: var(--accent-amber); }
.stat-chip--vla .stat-num { color: var(--accent-cyan); }

.stat-lbl {
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 0.55rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-tertiary);
}

/* Top flash signals */
.top-flash {
  border-top: 1px solid var(--border-subtle);
  padding-top: 16px;
  margin-bottom: 16px;
}

.top-flash-eyebrow {
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 0.6rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--text-tertiary);
  margin-bottom: 10px;
}

.top-flash-list {
