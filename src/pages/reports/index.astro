---
/**
 * src/pages/reports/index.astro
 * Biweekly reports archive — "Intelligence Archive" editorial design.
 * Heavy vertical rhythm, serif typography, dramatic date display.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadBiweeklyReports, extractMarkdownSummary, loadAIDeepDive, loadVLASOTA, loadVLATheory } from '../../utils/data';

const base = import.meta.env.BASE_URL;

const reports     = loadBiweeklyReports(12, false);
const reflections = loadBiweeklyReports(12, true);

// Deep dive content
const aiDeepDives = loadAIDeepDive(12);
const vlaSOTA     = loadVLASOTA(10);
const vlaTheory   = loadVLATheory(12);

// Pair reports with reflections by date proximity
interface ReportEntry {
  date:            string;
  summary:         string;
  domain:          'vla' | 'ai';
  hasReflection:   boolean;
  reflectionDate?: string;
  reflectionSummary?: string;
}

const entries: ReportEntry[] = reports.map(r => {
  const refObj  = reflections.find(ref => ref.date >= r.date && ref.domain === r.domain);
  return {
    date:              r.date,
    summary:           extractMarkdownSummary(r.content, 280),
    domain:            r.domain,
    hasReflection:     !!refObj,
    reflectionDate:    refObj?.date,
    reflectionSummary: refObj ? extractMarkdownSummary(refObj.content, 120) : undefined,
  };
});

// Fallback mock data
const MOCK_ENTRIES: ReportEntry[] = [
  {
    date: '2026-03-01',
    summary: '本期整合 VLA 研究進展、AI 應用趨勢與社交情報。涵蓋 flow matching 突破（5篇 ⚡），Karpathy Software 3.0 論述，DeepSeek-V3 開源影響分析，前期 8 項預測驗證（6 ✅ / 1 ❌ / 1 ⏳）。',
    domain: 'vla',
    hasReflection: true,
    reflectionDate: '2026-03-01',
    reflectionSummary: '本期反思：flow matching 優勢或被高估；agentic IDE 滲透速度超出預期；下期關注 embodied reasoning 與 cursor-style tooling 的交叉點。',
  },
  {
    date: '2026-02-15',
    summary: '聚焦世界模型與具身推理的理論突破。JEPA vs autoregressive 路線分歧加深，Meta FAIR 和 DeepMind 各自佔據不同賭注。AI 應用端：Cursor 月活突破100萬。',
    domain: 'vla',
    hasReflection: true,
    reflectionDate: '2026-02-16',
    reflectionSummary: '反思：對 world model convergence timeline 過於樂觀，修正假設 A-07 信心值 −0.08。',
  },
  {
    date: '2026-02-01',
    summary: '二月首期雙週：VLA scaling law 實驗結果喜憂參半。30B+ 參數確見推理湧現，但 action precision 仍需視覺-運動訓練。AI 側：DeepSeek-R1 開源衝擊持續。',
    domain: 'vla',
    hasReflection: false,
  },
];

const displayEntries = entries.length > 0 ? entries : MOCK_ENTRIES;

// Format ISO date as numeric: "2026.02.12"
function formatDateNumeric(iso: string): string {
  const [y, m, d] = iso.split('-');
  return `${y}.${m}.${d}`;
}

// Format ISO date as Chinese: "2026年2月12日"
function formatDateZh(iso: string): string {
  const [year, month, day] = iso.split('-').map(Number);
  return `${year}年${month}月${day}日`;
}

// Compute a biweekly period label: e.g. "2026.02.16 – 03.01"
function formatPeriod(iso: string): string {
  const end   = new Date(iso);
  const start = new Date(end);
  start.setDate(start.getDate() - 13);
  const sm = String(start.getMonth() + 1).padStart(2, '0');
  const sd = String(start.getDate()).padStart(2, '0');
  const em = String(end.getMonth() + 1).padStart(2, '0');
  const ed = String(end.getDate()).padStart(2, '0');
  const ey = end.getFullYear();
  return `${ey}.${sm}.${sd} – ${em}.${ed}`;
}
---

<BaseLayout
  title="雙週報告 Biweekly"
  description="Pulsar AI 研究雙週深度報告 — VLA 進展、AI 應用、社交情報與校準分析"
>
  <div class="archive-page page-container">

    <!-- ═══════════════════════════════════════════════════
         PAGE MASTHEAD
    ══════════════════════════════════════════════════════ -->
    <header class="archive-masthead fade-in-1">
      <div class="masthead-overline">
        <span class="masthead-classification">CLASSIFIED · RESEARCH INTELLIGENCE</span>
        <span class="masthead-sep">|</span>
        <span class="masthead-cycle">雙週週期 · BIWEEKLY CYCLE</span>
      </div>

      <h1 class="masthead-title"><span data-tc>雙週報告</span><span data-sc>双周报告</span></h1>

      <p class="masthead-subtitle">
        PULSAR INTELLIGENCE ARCHIVE &nbsp;·&nbsp; 每兩週深度分析
      </p>

      <hr class="masthead-rule" />

      <p class="masthead-desc">
        <span data-tc>每兩週由 pipeline 自動生成，涵蓋 VLA 和 AI 應用兩條研究線的深度回顧、前期預測驗證（✅ / ❌ / ⏳）、假設校準，以及下期觀察重點。與純聚合摘要不同，Pulsar 對每條信號評級後跨域比對，並通過反思副本持續自我修正——假設信心值隨每期報告動態調整。</span><span data-sc>每两周由 pipeline 自动生成，涵盖 VLA 和 AI 应用两条研究线的深度回顾、前期预测验证（✅ / ❌ / ⏳）、假设校准，以及下期观察重点。与纯聚合摘要不同，Pulsar 对每条信号评级后跨域比对，并通过反思副本持续自我修正——假设信心值随每期报告动态调整。</span>
      </p>

      <div class="masthead-stats">
        <div class="stat-item">
          <span class="stat-num">{displayEntries.length}</span>
          <span class="stat-label">DISPATCHES</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat-item">
          <span class="stat-num">{displayEntries.filter(e => e.hasReflection).length}</span>
          <span class="stat-label">W/ REFLECTION</span>
        </div>
        <div class="stat-div"></div>
        <div class="stat-item">
          <span class="stat-num">14D</span>
          <span class="stat-label">CYCLE</span>
        </div>
      </div>
    </header>

    <!-- ═══════════════════════════════════════════════════
         ARCHIVE LEDGER
    ══════════════════════════════════════════════════════ -->
    <section class="archive-ledger" aria-label="報告存檔列表">

      {displayEntries.length === 0 && (
        <div class="empty-state">
          <div class="empty-icon">▣</div>
          <p class="empty-title">ARCHIVE PENDING</p>
          <p class="empty-sub"><span data-tc>Pipeline 尚未生成雙週報告 — 待下一個週期後自動同步</span><span data-sc>Pipeline 尚未生成双周报告 — 待下一个周期后自动同步</span></p>
          <div class="empty-blinker" aria-hidden="true">_</div>
        </div>
      )}

      {displayEntries.map((entry, i) => (
        <article class:list={['dispatch-row', i === 0 && 'dispatch-row--latest']} data-index={i}>

          <!-- ── Left: date column ─────────────────────── -->
          <div class="dispatch-date-col" aria-hidden="true">
            <time class="dispatch-date-big" datetime={entry.date}>
              {formatDateNumeric(entry.date)}
            </time>
            {i === 0 && <span class="dispatch-latest-pip">LATEST</span>}
          </div>

          <!-- ── Right: content column ─────────────────── -->
          <div class="dispatch-content-col">

            <!-- Report block -->
            <div class="dispatch-report">
              <div class="dispatch-meta-row">
                <span class={`dispatch-type-badge ${entry.domain === 'ai' ? 'dispatch-type-ai' : 'dispatch-type-report'}`}>
                  {entry.domain === 'ai'
                    ? <><span data-tc>AI 應用</span><span data-sc>AI 应用</span></>
                    : 'VLA'
                  }
                </span>
                <span class="dispatch-type-badge dispatch-type-report"><span data-tc>雙週報告</span><span data-sc>双周报告</span></span>
                <span class="dispatch-period">{formatPeriod(entry.date)}</span>
              </div>

              <h2 class="dispatch-title">
                <a href={`${base}/reports/${entry.domain === 'ai' ? `ai-${entry.date}` : entry.date}`} class="dispatch-title-link">
                  {entry.domain === 'ai' ? 'AI App ' : 'VLA '}深度分析 · {formatDateZh(entry.date)}
                  <span class="dispatch-arrow" aria-hidden="true">→</span>
                </a>
              </h2>

              <p class="dispatch-excerpt">{entry.summary}</p>

              <div class="dispatch-action-row">
                <a href={`${base}/reports/${entry.domain === 'ai' ? `ai-${entry.date}` : entry.date}`} class="dispatch-read-link">
                  <span data-tc>閱讀全文</span><span data-sc>阅读全文</span>
                  <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                    <path d="M2 6h8M6 2l4 4-4 4"/>
                  </svg>
                </a>
                <span class="dispatch-coverage">
                  VLA &nbsp;·&nbsp; AI App &nbsp;·&nbsp; <span data-tc>社交情報</span><span data-sc>社交情报</span> &nbsp;·&nbsp; <span data-tc>校準</span><span data-sc>校准</span>
                </span>
              </div>
            </div>

            <!-- Reflection block (indented, if exists) -->
            {entry.hasReflection && (
              <div class="dispatch-reflection">
                <div class="dispatch-reflection-label">
                  <span class="reflection-marker">反思</span>
                  <span class="reflection-date">· {entry.reflectionDate ? formatDateZh(entry.reflectionDate) : ''}</span>
                </div>
                {entry.reflectionSummary && (
                  <p class="reflection-excerpt">{entry.reflectionSummary}</p>
                )}
                <a href={`${base}/reports/${entry.domain === 'ai' ? `ai-${entry.reflectionDate}` : entry.reflectionDate}-reflection`} class="reflection-link">
                  查看反思 →
                </a>
              </div>
            )}

          </div>

        </article>
      ))}

    </section>

    <!-- ═══════════════════════════════════════════════════
         AI APP DEEP DIVE
    ══════════════════════════════════════════════════════ -->
    <section class="deep-dive-section" aria-label="AI App 深度追蹤">
      <div class="dd-header">
        <div class="dd-overline">AI APP 線 · DEEP DIVE</div>
        <h2 class="dd-title"><span data-tc>AI 深度追蹤</span><span data-sc>AI 深度追踪</span></h2>
        <div class="dd-rule dd-rule--amber"></div>
        <p class="dd-desc">
          <span data-tc>針對 AI Agent 工具、框架與產品發布的深度技術拆解。每次有重大發布或社交信號達閾值時，pipeline 自動生成深度分析文章，存入 Agent-Playbook 庫</span><span data-sc>针对 AI Agent 工具、框架与产品发布的深度技术拆解。每次有重大发布或社交讯号达阈值时，pipeline 自动生成深度分析文章，存入 Agent-Playbook 库</span>。
        </p>
        <div class="dd-count-row">
          <span class="dd-count">{aiDeepDives.length}</span>
          <span class="dd-count-label">篇深度文章</span>
        </div>
      </div>

      {aiDeepDives.length === 0 ? (
        <p class="dd-empty"><span data-tc>尚無 AI 深度追蹤資料 — pipeline 自動生成中</span><span data-sc>尚无 AI 深度追踪资料 — pipeline 自动生成中</span></p>
      ) : (
        <div class="dd-list">
          {aiDeepDives.map((article, i) => (
            <a href={article.html_url || article.url} target="_blank" rel="noopener noreferrer"
               class="dd-row dd-row--ai" style={`animation-delay:${i*0.04}s`}>
              <time class="dd-row-date">{formatDateNumeric(article.date)}</time>
              <div class="dd-row-body">
                <span class="dd-row-title">{article.title}</span>
                <span class="dd-row-tags">
                  <span class="dd-tag dd-tag--amber">{article.signal_type.replace('_', ' ')}</span>
                  <span class="dd-tag">{article.source}</span>
                </span>
              </div>
              <span class="dd-row-arrow">→</span>
            </a>
          ))}
        </div>
      )}
    </section>

    <!-- ═══════════════════════════════════════════════════
         VLA DEEP DIVE — Theory + SOTA
    ══════════════════════════════════════════════════════ -->
    <section class="deep-dive-section" aria-label="VLA 深度追蹤">
      <div class="dd-header">
        <div class="dd-overline">VLA 線 · DEEP DIVE</div>
        <h2 class="dd-title"><span data-tc>VLA 深度追蹤</span><span data-sc>VLA 深度追踪</span></h2>
        <div class="dd-rule dd-rule--cyan"></div>
        <p class="dd-desc">
          <span data-tc>VLA 理論深挖與 SOTA 排行追蹤。Theory 文章由 pipeline 解析 VLA-Handbook 理論庫；SOTA 數據從 Evo-SOTA 即時拉取 CALVIN 等標準 Benchmark 的最新記錄</span><span data-sc>VLA 理论深挖与 SOTA 排行追踪。Theory 文章由 pipeline 解析 VLA-Handbook 理论库；SOTA 数据从 Evo-SOTA 即时拉取 CALVIN 等标准 Benchmark 的最新记录</span>。
        </p>
        <div class="dd-count-row">
          <span class="dd-count dd-count--cyan">{vlaTheory.length}</span>
          <span class="dd-count-label"><span data-tc>理論文章</span><span data-sc>理论文章</span></span>
          <span class="dd-count-sep">·</span>
          <span class="dd-count dd-count--cyan">{vlaSOTA.length}</span>
          <span class="dd-count-label"><span data-tc>SOTA 記錄</span><span data-sc>SOTA 记录</span></span>
        </div>
      </div>

      <!-- Theory articles -->
      {vlaTheory.length > 0 && (
        <div class="dd-sub-section">
          <h3 class="dd-sub-title"><span data-tc>📐 理論深挖</span><span data-sc>📐 理论深挖</span></h3>
          <div class="dd-list">
            {vlaTheory.map((article, i) => (
              <a href={article.html_url || article.url} target="_blank" rel="noopener noreferrer"
                 class="dd-row dd-row--vla" style={`animation-delay:${i*0.04}s`}>
                <time class="dd-row-date">{formatDateNumeric(article.date)}</time>
                <div class="dd-row-body">
                  <span class="dd-row-title">{article.title}</span>
                  {article.target_dir && (
                    <span class="dd-row-tags">
                      <span class="dd-tag dd-tag--cyan">{article.target_dir}</span>
                    </span>
                  )}
                </div>
                <span class="dd-row-arrow">→</span>
              </a>
            ))}
          </div>
        </div>
      )}

      <!-- SOTA table -->
      {vlaSOTA.length > 0 && (
        <div class="dd-sub-section">
          <h3 class="dd-sub-title">🏆 SOTA 排行</h3>
          <div class="sota-table-wrap">
            <table class="sota-table">
              <thead>
                <tr>
                  <th>Benchmark</th>
                  <th>Model</th>
                  <th>Score</th>
                  <th>vs Baseline</th>
                  <th>Date</th>
                </tr>
              </thead>
              <tbody>
                {vlaSOTA.map(entry => (
                  <tr class="sota-row">
                    <td class="sota-benchmark">
                      {entry.leaderboard_url
                        ? <a href={entry.leaderboard_url} target="_blank" rel="noopener noreferrer">{entry.benchmark}{entry.split ? ` · ${entry.split}` : ''}</a>
                        : <span>{entry.benchmark}{entry.split ? ` · ${entry.split}` : ''}</span>
                      }
                    </td>
                    <td class="sota-model">
                      {entry.paper_url
                        ? <a href={entry.paper_url} target="_blank" rel="noopener noreferrer">{entry.model}</a>
                        : entry.model
                      }
                    </td>
                    <td class="sota-score">{entry.value}</td>
                    <td class="sota-baseline">{entry.baseline ?? '—'}</td>
                    <td class="sota-date">{entry.date}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}

    </section>

  </div>
</BaseLayout>

<style>
/* ============================================================
   REPORTS PAGE — INTELLIGENCE ARCHIVE DESIGN
   Scoped CSS: only affects this page
============================================================ */

/* ── Page wrapper ── */
.archive-page {
  padding-top: 32px;
  padding-bottom: 80px;
}

/* ── Masthead ── */
.archive-masthead {
  padding-bottom: 40px;
  margin-bottom: 0;
}

.masthead-overline {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 18px;
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.18em;
  color: var(--text-tertiary);
  text-transform: uppercase;
}

.masthead-classification {
  color: var(--accent-amber);
  opacity: 0.85;
}

.masthead-sep {
  opacity: 0.3;
}

.masthead-cycle {
  opacity: 0.6;
}

.masthead-title {
  /* Override global h1 to use the page-serif style */
  font-family: 'Georgia', 'Songti SC', 'SimSun', serif !important;
  font-size: clamp(2.8rem, 6vw, 4.8rem);
  font-weight: 700;
  letter-spacing: -0.03em;
  line-height: 1.05;
  color: var(--text-primary);
  margin-bottom: 8px;
}

.masthead-subtitle {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--text-tertiary);
  margin-bottom: 24px;
}

.masthead-rule {
  border: none;
  border-top: 2px solid var(--border);
  margin-bottom: 20px;
}

/* Thin amber accent line above rule */
.archive-masthead .masthead-rule {
  position: relative;
}

.archive-masthead .masthead-rule::before {
  content: '';
  position: absolute;
  top: -2px;
  left: 0;
  width: 80px;
  height: 2px;
  background: var(--accent-amber);
}

.masthead-desc {
  font-family: 'PingFang SC', 'Microsoft YaHei', 'Hiragino Sans GB', sans-serif;
  font-size: 0.9rem;
  line-height: 1.85;
  color: var(--text-secondary);
  max-width: 660px;
  margin-bottom: 28px;
}

/* Stats row */
.masthead-stats {
  display: flex;
  align-items: center;
  gap: 20px;
  padding: 16px 0;
  border-top: 1px solid var(--border-subtle);
  border-bottom: 1px solid var(--border-subtle);
  margin-bottom: 48px;
}

.stat-item {
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.stat-num {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 1.4rem;
  font-weight: 700;
  color: var(--accent-amber);
  line-height: 1;
}

.stat-label {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.58rem;
  letter-spacing: 0.18em;
  color: var(--text-tertiary);
  text-transform: uppercase;
}

.stat-div {
  width: 1px;
  height: 24px;
  background: var(--border);
  opacity: 0.6;
}

/* ── Archive ledger ── */
.archive-ledger {
  /* Use a left gutter for the date column */
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* ── Dispatch row ── */
.dispatch-row {
  display: grid;
  grid-template-columns: 160px 1fr;
  gap: 0 40px;
  padding: 36px 0;
  border-bottom: 1px solid var(--border-subtle);
  position: relative;
  /* Subtle left padding shift on hover via padding-left */
  padding-left: 0;
  transition: padding-left 0.22s ease;
}

.dispatch-row:first-child {
  border-top: 1px solid var(--border-subtle);
}

.dispatch-row:hover {
  padding-left: 4px;
}

/* Latest entry: amber left border on hover */
.dispatch-row--latest:hover .dispatch-date-big {
  color: var(--accent-amber);
}

/* Non-latest: cyan date on hover */
.dispatch-row:not(.dispatch-row--latest):hover .dispatch-date-big {
  color: var(--accent-cyan);
}

/* Hover left-border accent bar */
.dispatch-row::before {
  content: '';
  position: absolute;
  left: -2px;
  top: 20%;
  bottom: 20%;
  width: 2px;
  background: var(--accent-amber);
  border-radius: 1px;
  opacity: 0;
  transform: scaleY(0.4);
  transform-origin: center;
  transition: opacity 0.22s ease, transform 0.22s ease;
}

.dispatch-row:not(.dispatch-row--latest)::before {
  background: var(--accent-cyan);
}

.dispatch-row:hover::before {
  opacity: 1;
  transform: scaleY(1);
}

/* ── Date column ── */
.dispatch-date-col {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding-top: 4px;
}

.dispatch-date-big {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 1.05rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  color: var(--text-tertiary);
  line-height: 1.3;
  transition: color 0.22s ease;
  display: block;
}

.dispatch-latest-pip {
  display: inline-block;
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.52rem;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  color: var(--accent-amber);
  background: var(--accent-amber-bg);
  border: 1px solid rgba(212,145,10,0.25);
  padding: 2px 7px;
  border-radius: 3px;
  margin-top: 8px;
}

/* ── Content column ── */
.dispatch-content-col {
  display: flex;
  flex-direction: column;
  gap: 0;
}

/* ── Report block ── */
.dispatch-report {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.dispatch-meta-row {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-wrap: wrap;
}

.dispatch-type-badge {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.58rem;
  font-weight: 600;
