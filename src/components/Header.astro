---
/**
 * Header.astro
 * Frosted-glass navbar — ported from prototype design.
 * Logo uses IBM Plex Mono with amber accent; nav links use Noto Serif SC.
 */
import ThemeToggle from './ThemeToggle.astro';

const nav = [
  { href: '/',            label: '日　報' },
  { href: '/vla',         label: 'V L A' },
  { href: '/social',      label: '社交情報' },
  { href: '/dashboard',   label: '儀表板' },
  { href: '/reports',     label: '雙週報告' },
];

const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<nav class="nav" aria-label="Primary navigation">
  <div class="container">
    <div class="nav-inner">

      <!-- Logo / Brand -->
      <a href="/" class="nav-logo" aria-label="PULSAR 照見 — Home">
        PUL<span>S</span>AR
        <span class="logo-zh">照　見</span>
      </a>

      <div class="nav-divider" aria-hidden="true"></div>

      <!-- Primary Navigation links -->
      <ul class="nav-links" role="list">
        {nav.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[isActive(href) ? 'active' : '']}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right side: live indicator + theme toggle -->
      <div class="nav-right">
        <span class="live-dot">LIVE</span>
        <ThemeToggle />

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          type="button"
          class="mobile-menu-btn"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label="開啟選單"
        >
          <svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <rect y="3"  width="20" height="2" rx="1"/>
            <rect y="9"  width="20" height="2" rx="1"/>
            <rect y="15" width="20" height="2" rx="1"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation Drawer -->
  <nav
    id="mobile-menu"
    aria-label="行動版導航"
    class="mobile-menu hidden"
  >
    {nav.map(({ href, label }) => (
      <a
        href={href}
        class:list={['mobile-menu-link', isActive(href) ? 'active' : '']}
        aria-current={isActive(href) ? 'page' : undefined}
      >
        {label}
      </a>
    ))}
  </nav>
</nav>

<style>
  .mobile-menu-btn {
    display: none;
    padding: 8px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-secondary);
    cursor: pointer;
    transition: background 0.2s;
  }
  .mobile-menu-btn:hover {
    background: var(--surface-2);
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .mobile-menu-btn { display: flex; align-items: center; justify-content: center; }
  }

  .mobile-menu {
    background: var(--surface);
    border-top: 1px solid var(--border);
    padding: 8px 24px 16px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .mobile-menu.hidden { display: none; }

  .mobile-menu-link {
    font-family: 'Noto Serif SC', serif;
    font-size: 0.9rem;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 10px 0;
    border-bottom: 1px solid var(--border-subtle);
    transition: color 0.2s;
    opacity: 1;
  }

  .mobile-menu-link:last-child { border-bottom: none; }
  .mobile-menu-link:hover,
  .mobile-menu-link.active { color: var(--accent-amber); opacity: 1; }
</style>

<script>
  const btn  = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden') ?? true;
    const open = !isHidden;
    btn.setAttribute('aria-expanded', String(open));
    btn.setAttribute('aria-label', open ? '關閉選單' : '開啟選單');
  });
</script>
