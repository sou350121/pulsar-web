---
/**
 * src/pages/vla/index.astro
 * VLA Daily — archive list by date, mirroring ai-daily/index.astro
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadVLADailyPicks } from '../../utils/data';

const base = import.meta.env.BASE_URL;

// Use actual VLA daily rating data
const allDays = loadVLADailyPicks(60);
const vlaDays = allDays.map(day => {
  const counts = day.items.reduce<Record<string, number>>((acc, i) => {
    acc[i.rating] = (acc[i.rating] ?? 0) + 1;
    return acc;
  }, {});
  return { ...day, counts };
});
---

<BaseLayout
  title="VLA 研究日報"
  description="Vision-Language-Action 論文每日精選 — ⚡ 突破 · 🔧 技術 · 📖 觀點"
>
  <div class="page-container section">
    <!-- Page header -->
    <div class="mb-8">
      <p class="font-ibm-plex-mono text-xs uppercase tracking-widest text-pulsar-cyan mb-2">
        VLA 線 · Vision-Language-Action
      </p>
      <h1 class="font-lora text-3xl md:text-4xl font-bold text-pulsar-text mb-3">
        VLA 研究日報
      </h1>
      <p class="text-pulsar-muted max-w-xl">
        Vision-Language-Action（VLA）機器人系統 — 整合 cs.RO、cs.AI、cs.LG 三條 arxiv 流。
        重點追蹤 flow matching、世界模型、具身推理等前沿方向，每日 09:00 CST 由 Qwen3.5-Plus 自動評級。
      </p>
    </div>

    <!-- Archive list -->
    {vlaDays.length === 0 ? (
      <p class="text-pulsar-muted font-ibm-plex-mono text-sm">
        尚無 VLA 資料 — 請先同步 pipeline 資料。
      </p>
    ) : (
      <div class="space-y-3">
        {vlaDays.map(day => (
          <a
            href={`${base}/vla/${day.date}`}
            class="card flex items-center justify-between gap-4 hover:border-pulsar-cyan transition-colors group no-underline"
          >
            <!-- Date -->
            <time
              datetime={day.date}
              class="font-ibm-plex-mono font-semibold text-pulsar-text shrink-0 text-sm"
            >
              {day.date}
            </time>

            <!-- Rating breakdown badges -->
            <div class="flex flex-wrap gap-1.5 flex-1">
              {[['⚡','flash'],['🔧','wrench'],['📖','book'],['❌','x']].map(([r]) => (
                day.counts[r] ? (
                  <span class:list={[
                    'font-ibm-plex-mono text-xs px-1.5 py-0.5 rounded',
                    r === '⚡' ? 'bg-amber-100 dark:bg-amber-950/30 text-amber-700 dark:text-amber-400' : '',
                    r === '🔧' ? 'bg-cyan-100  dark:bg-cyan-950/30  text-cyan-700  dark:text-cyan-400'  : '',
                    r === '📖' ? 'bg-stone-100 dark:bg-stone-800    text-stone-600 dark:text-stone-400' : '',
                    r === '❌' ? 'bg-red-100   dark:bg-red-950/30   text-red-700   dark:text-red-400'   : '',
                  ]}>
                    {r} {day.counts[r]}
                  </span>
                ) : null
              ))}
            </div>

            <!-- Item count + arrow -->
            <div class="flex items-center gap-2 shrink-0">
              <span class="text-pulsar-muted text-xs font-ibm-plex-mono">
                {day.items.length} 篇
              </span>
              <svg
                width="14" height="14" viewBox="0 0 14 14" fill="none"
                stroke="currentColor" stroke-width="2"
                class="text-pulsar-muted group-hover:text-pulsar-cyan transition-colors"
                aria-hidden="true"
              >
                <path d="M2 7h10M8 3l4 4-4 4"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    )}
  </div>
</BaseLayout>
