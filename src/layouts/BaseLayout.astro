---
/**
 * BaseLayout.astro
 * Full HTML shell used by every page.
 * Props:
 *   title       — <title> tag content (appended with " | Pulsar")
 *   description — <meta name="description"> (defaults to site tagline)
 *   ogImage     — Open Graph image URL (optional)
 *   noIndex     — set true to add <meta name="robots" content="noindex">
 */
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title = 'Pulsar',
  description = 'AI Research Intelligence — 照見 (Zhàojiàn) pipeline monitoring, daily picks, and biweekly reflections.',
  ogImage = '/og-default.png',
  noIndex = false,
} = Astro.props;

const siteName = 'Pulsar';
const fullTitle = title === 'Pulsar' ? siteName : `${title} | ${siteName}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://pulsar.sou350121.github.io');
---

<!doctype html>
<html lang="zh-TW" class="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon (placeholder — replace with actual asset) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:site_name"   content={siteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!--
      Theme initialisation — must run BEFORE first paint to avoid flash.
      Reads localStorage and applies the 'dark' class to <html> synchronously.
    -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('pulsar-theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const useDark = stored === 'dark' || (!stored && prefersDark);
        document.documentElement.classList.toggle('dark', useDark);
        document.documentElement.classList.toggle('light', !useDark);
      })();
    </script>
  </head>

  <body class="min-h-screen flex flex-col bg-pulsar-bg text-pulsar-text">
    <!-- Skip to content link — accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-pulsar-amber focus:text-white focus:rounded"
    >
      Skip to content
    </a>

    <Header />

    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
