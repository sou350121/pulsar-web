                const vlaPct = Math.max(6, Math.round(d.vla / sparkMaxVLA * 100));
                const aiPct  = Math.max(6, Math.round(d.ai  / sparkMaxAI  * 100));
                const isLast = i === spark7.length - 1;
                return (
                  <div class={`hp-spark-col ${isLast ? 'hp-spark-col--today' : ''}`}>
                    <div class="hp-spark-bar hp-spark-bar--vla" style={`height:${vlaPct}%`} title={`${d.date} VLA:${d.vla}`}></div>
                    <div class="hp-spark-bar hp-spark-bar--ai"  style={`height:${aiPct}%`}  title={`${d.date} AI:${d.ai}`}></div>
                    <span class="hp-spark-date">{d.date.slice(8)}</span>
                  </div>
                );
              })}
            </div>
          ) : (
            <div class="sparkline" aria-label="7-day quality chart" role="img">
              <div class="spark-bar" style="height:68%;"></div>
              <div class="spark-bar" style="height:74%;"></div>
              <div class="spark-bar active" style="height:56%;"></div>
              <div class="spark-bar" style="height:82%;"></div>
              <div class="spark-bar" style="height:78%;"></div>
              <div class="spark-bar" style="height:90%;"></div>
