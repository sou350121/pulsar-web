---
/**
 * src/pages/talent/index.astro
 * Stage 4 — Talent Radar landing (v2 revamp).
 *
 * IA inversion from v1:
 *   v1: Subdirections → Labs → People → HR Queue (browse-first)
 *   v2: Weekly Brief → HR Shortlist → Velocity Board → Labs → Watchlist
 *       (signal-first, narrative-led, HR-actionable up top)
 *
 * No new utils — everything computed from the existing loaders.
 */
import BaseLayout        from '../../layouts/BaseLayout.astro';
import SubdirectionCard  from '../../components/SubdirectionCard.astro';
import LabCard           from '../../components/LabCard.astro';
import PersonCard        from '../../components/PersonCard.astro';
import RatingBadge       from '../../components/RatingBadge.astro';
import {
  loadSubdirections,
  loadLabs,
  loadPeople,
  loadHRQueue,
  loadTalentStats,
  slugifyName,
} from '../../utils/talent';

const base = import.meta.env.BASE_URL;

const stats     = loadTalentStats();
const allSubs   = loadSubdirections({ domain: 'all' });
const allLabs   = loadLabs({ minSignals: 3 });
const allPeople = loadPeople({ minPaperCount90d: 1 });
const allHR     = loadHRQueue();

// ── Weekly Brief: 3 lead facts ─────────────────────────────────────────────
const topMover = allSubs.find(s => s.status === 'accelerating') ?? allSubs[0];
const topLab   = allLabs[0];
const topHR    = allHR[0];

// ── Velocity board: top 8 by abs acceleration (mix accelerating + declining) ─
const velocityBoard = [...allSubs]
  .sort((a, b) => Math.abs(b.acceleration) - Math.abs(a.acceleration))
  .slice(0, 8);
const velocityMaxAbs = Math.max(0.01, ...velocityBoard.map(s => Math.abs(s.acceleration)));

// ── HR shortlist ───────────────────────────────────────────────────────────
const featuredHR = allHR[0];
const restHR     = allHR.slice(1, 4);

// ── Labs showcase: 6 with non-zero recent OR top by 90d signals ─────────────
const labsShowcase = allLabs.slice(0, 6);

// ── Researcher watchlist: prefer ⚡ + linked, then top by paperCount ─────────
const watchlistRaw = allPeople.filter(p =>
  p.topRating === '⚡' && p.contactStatus !== 'not_linked');
const watchlist = (watchlistRaw.length >= 6
  ? watchlistRaw
  : [...watchlistRaw, ...allPeople.filter(p => !watchlistRaw.includes(p) && p.contactStatus !== 'not_linked')]
).slice(0, 6);

// ── Freshness ──────────────────────────────────────────────────────────────
const dataDate = Date.parse(stats.dataAsOf + 'T00:00:00Z');
const daysOld = Number.isNaN(dataDate)
  ? null
  : Math.max(0, Math.floor((Date.now() - dataDate) / 86_400_000));
const freshnessTone =
  daysOld === null ? 'muted' :
  daysOld <= 1     ? 'fresh' :
  daysOld <= 3     ? 'ok'    :
  'stale';

// ── Format helpers ─────────────────────────────────────────────────────────
function fmtAccel(a: number): string {
  const pct = Math.round(a * 100);
  return `${pct > 0 ? '+' : ''}${pct}%`;
}
---

<BaseLayout
  title="人才雷達 Talent Radar"
  description="Stage 4 — 信號優先的人才雷達：本週簡報 → HR 候選人 → 方法族速度 → 活躍實驗室 → 觀察名單。從不儲存或顯示電子郵件。"
>
  <main class="talent-v2">
    <!-- ══ Hero ════════════════════════════════════════════════════════════ -->
    <header class="tv2-hero">
      <div class="tv2-hero-meta">
        <span class="tv2-stage">
          <span class="tv2-stage-dot" aria-hidden="true"></span>
          STAGE 04 · TALENT RADAR
        </span>
        <span class={`tv2-fresh tv2-fresh--${freshnessTone}`} title={`Data snapshot ${stats.dataAsOf}`}>
          <span class="tv2-fresh-dot" aria-hidden="true"></span>
          <span data-tc>資料 {stats.dataAsOf}</span>
          <span data-sc>数据 {stats.dataAsOf}</span>
          {daysOld !== null && <span class="tv2-fresh-age">· {daysOld === 0 ? 'today' : `${daysOld}d ago`}</span>}
        </span>
      </div>

      <div class="tv2-title-row">
        <h1 class="tv2-title">
          <span data-tc>人才雷達</span>
          <span data-sc>人才雷达</span>
        </h1>
        <p class="tv2-title-en">Talent Radar</p>
      </div>

      <p class="tv2-lede">
        <span data-tc>從論文池反推 — <strong>誰該聘</strong> · <strong>哪些方向在加速</strong> · <strong>哪些組織在攻頂</strong>。</span>
        <span data-sc>从论文池反推 — <strong>谁该聘</strong> · <strong>哪些方向在加速</strong> · <strong>哪些组织在攻顶</strong>。</span>
      </p>

      <p class="tv2-promise">
        <span class="tv2-promise-icon" aria-hidden="true">⏚</span>
        <span data-tc>每項推薦皆附論文級佐證。系統 <strong>從不儲存或顯示電子郵件</strong>。</span>
        <span data-sc>每项推荐皆附论文级佐证。系统 <strong>从不存储或显示邮箱</strong>。</span>
      </p>
    </header>

    <!-- ══ Weekly Brief — 3 narrative cards ═══════════════════════════════ -->
    <section class="tv2-brief" aria-label="Weekly brief">
      <h2 class="tv2-brief-label">
        <span data-tc>本週簡報</span>
        <span data-sc>本周简报</span>
        <span class="tv2-brief-en">/ This Week</span>
      </h2>

      <div class="tv2-brief-grid">
        <!-- 1. Top accelerating method -->
        {topMover && (
          <a class="tv2-brief-card" href={`${base}/talent/subdirections/#fam-${topMover.family}`}>
            <span class="tv2-brief-kicker">
              <span data-tc>加速最快的方向</span>
              <span data-sc>加速最快的方向</span>
            </span>
            <div class="tv2-brief-main">
              <span class="tv2-brief-head">{topMover.displayName}</span>
              <span class="tv2-brief-delta" data-pos={topMover.acceleration >= 0}>
                {fmtAccel(topMover.acceleration)}
              </span>
            </div>
            <div class="tv2-brief-sub">
              <span class="tv2-brief-domain">
                {topMover.domain === 'vla' ? 'VLA' : 'AI App'}
              </span>
              <span class="tv2-brief-meta">7d {topMover.velocity7d} · prior {topMover.velocityPrior7d}</span>
            </div>
          </a>
        )}

        <!-- 2. Top active lab -->
        {topLab && (
          <a class="tv2-brief-card" href={`${base}/talent/labs/#lab-${slugifyName(topLab.name)}`}>
            <span class="tv2-brief-kicker">
              <span data-tc>產能最高的實驗室</span>
              <span data-sc>产能最高的实验室</span>
            </span>
            <div class="tv2-brief-main">
              <span class="tv2-brief-head">{topLab.name}</span>
              <RatingBadge rating={topLab.topRating} size="sm" />
            </div>
            <div class="tv2-brief-sub">
              <span class="tv2-brief-meta">
                <span data-tc>{topLab.signalCount90d} 篇 · 90d · {topLab.methodFocus.slice(0, 2).join(' · ')}</span>
                <span data-sc>{topLab.signalCount90d} 篇 · 90d · {topLab.methodFocus.slice(0, 2).join(' · ')}</span>
              </span>
            </div>
          </a>
        )}

        <!-- 3. Top HR candidate -->
        {topHR && (
          <a class="tv2-brief-card tv2-brief-card--accent" href="#hr-shortlist">
            <span class="tv2-brief-kicker">
              <span data-tc>首推候選人</span>
              <span data-sc>首推候选人</span>
            </span>
            <div class="tv2-brief-main">
              <span class="tv2-brief-head">{topHR.name}</span>
              <RatingBadge rating={topHR.topRating} size="sm" />
            </div>
            <div class="tv2-brief-sub">
              {topHR.affiliation && (
                <span class="tv2-brief-meta tv2-brief-affil">{topHR.affiliation}</span>
              )}
              <span class="tv2-brief-meta">· {topHR.paperCount90d} 篇 · 90d</span>
            </div>
          </a>
        )}
      </div>
    </section>

    <!-- ══ Section 01 · HR SHORTLIST ══════════════════════════════════════ -->
    <section class="tv2-section" id="hr-shortlist">
      <header class="tv2-section-header">
        <div class="tv2-section-titlewrap">
          <span class="tv2-section-num">01</span>
          <h2 class="tv2-section-h2">
            <span data-tc>HR 候選人短名單</span>
            <span data-sc>HR 候选人短名单</span>
          </h2>
          <span class="tv2-section-en">/ Shortlist</span>
        </div>
        <a class="tv2-more" href={`${base}/talent/hr-queue/`}>
          <span data-tc>完整隊列 ({stats.hrQueueCount}) →</span>
          <span data-sc>完整队列 ({stats.hrQueueCount}) →</span>
        </a>
      </header>

      {allHR.length === 0 ? (
        <div class="tv2-empty">
          <p class="tv2-empty-title">
            <span data-tc>本週無候選人通過門檻</span>
            <span data-sc>本周无候选人通过门槛</span>
          </p>
          <p class="tv2-empty-sub">
            <span data-tc>門檻：≥ 2 篇 🔧+ 論文（90d）· 機構可解析 · 聯繫狀態非 not_linked</span>
            <span data-sc>门槛：≥ 2 篇 🔧+ 论文（90d）· 机构可解析 · 联系状态非 not_linked</span>
          </p>
        </div>
      ) : (
        <div class="tv2-hr-stack">
          {featuredHR && (
            <article class="tv2-hr-featured">
              <div class="tv2-hr-featured-stripe" aria-hidden="true"></div>
              <div class="tv2-hr-featured-body">
                <div class="tv2-hr-featured-head">
                  <span class="tv2-hr-featured-kicker">
                    <span data-tc>首推</span><span data-sc>首推</span>
                    · TOP CANDIDATE
                  </span>
                  <div class="tv2-hr-featured-title">
                    <h3>{featuredHR.name}</h3>
                    <RatingBadge rating={featuredHR.topRating} size="sm" />
                  </div>
                  {featuredHR.affiliation && (
                    <a class="tv2-hr-featured-affil"
                       href={`${base}/talent/labs/#lab-${slugifyName(featuredHR.affiliation)}`}>
                      {featuredHR.affiliation}
                    </a>
                  )}
                </div>

                <p class="tv2-hr-featured-why">
                  <span class="tv2-hr-why-tag">WHY NOW</span>
                  {featuredHR.whyNow}
                </p>

                <div class="tv2-hr-featured-stats">
                  <div class="tv2-hr-stat">
                    <span class="tv2-hr-stat-num">{featuredHR.paperCount90d}</span>
                    <span class="tv2-hr-stat-lbl">
                      <span data-tc>篇 · 90d</span><span data-sc>篇 · 90d</span>
                    </span>
                  </div>
                  <div class="tv2-hr-stat">
                    <span class="tv2-hr-stat-num">{featuredHR.gateHits.length}</span>
                    <span class="tv2-hr-stat-lbl">
                      <span data-tc>門檻命中</span><span data-sc>门槛命中</span>
                    </span>
                  </div>
                  <div class="tv2-hr-stat">
                    <span class="tv2-hr-stat-pill" data-status={featuredHR.contactStatus}>
                      {featuredHR.contactStatus === 'linked_via_lab' ? '機構已關聯' :
                       featuredHR.contactStatus === 'social_mention' ? '社交提及' : '僅署名'}
                    </span>
                    <span class="tv2-hr-stat-lbl">NO-EMAIL</span>
                  </div>
                </div>

                {featuredHR.evidence.length > 0 && (
                  <ul class="tv2-hr-featured-papers">
                    {featuredHR.evidence.slice(0, 3).map(ev => (
                      <li>
                        <a href={ev.url} target="_blank" rel="noopener noreferrer">
                          <RatingBadge rating={ev.rating} size="sm" />
                          <span class="tv2-paper-title">{ev.title}</span>
                          <span class="tv2-paper-date">{ev.date}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          )}

          {restHR.length > 0 && (
            <div class="tv2-hr-rest">
              {restHR.map(h => <PersonCard record={h} showWhyNow />)}
            </div>
          )}
        </div>
      )}
    </section>

    <!-- ══ Section 02 · VELOCITY BOARD ═════════════════════════════════════ -->
    <section class="tv2-section">
      <header class="tv2-section-header">
        <div class="tv2-section-titlewrap">
          <span class="tv2-section-num">02</span>
          <h2 class="tv2-section-h2">
            <span data-tc>方法族速度榜</span>
            <span data-sc>方法族速度榜</span>
          </h2>
          <span class="tv2-section-en">/ Velocity Board</span>
        </div>
        <a class="tv2-more" href={`${base}/talent/subdirections/`}>
          <span data-tc>全部 {stats.subdirectionCount} →</span>
          <span data-sc>全部 {stats.subdirectionCount} →</span>
        </a>
      </header>

      <p class="tv2-section-lede">
        <span data-tc>每行為一個方法族。<em>長條長度</em> = |加速度| 相對最大值；<em>顏色</em> = 加速（琥珀）/ 衰退（紅）。資料來自 <code>field-state-*.json</code>（機械化，零 LLM）。</span>
        <span data-sc>每行为一个方法族。<em>条形长度</em> = |加速度| 相对最大值；<em>颜色</em> = 加速（琥珀）/ 衰退（红）。数据来自 <code>field-state-*.json</code>（机械化，零 LLM）。</span>
      </p>

      <ol class="tv2-velocity-board">
        {velocityBoard.map((s, i) => {
          const pct = Math.abs(s.acceleration) / velocityMaxAbs * 100;
          const isUp = s.acceleration >= 0;
          return (
            <li class="tv2-vel-row" style={`--vel-pct: ${pct.toFixed(1)}%`}>
              <a href={`${base}/talent/subdirections/#fam-${s.family}`} class="tv2-vel-link">
                <span class="tv2-vel-rank">{String(i + 1).padStart(2, '0')}</span>
                <span class={`tv2-vel-domain ${s.domain === 'vla' ? 'tag-vla' : 'tag-ai'}`}>
                  {s.domain === 'vla' ? 'VLA' : 'AI'}
                </span>
                <span class="tv2-vel-name">{s.displayName}</span>
                <span class="tv2-vel-track">
                  <span class={`tv2-vel-bar ${isUp ? 'tv2-vel-bar--up' : 'tv2-vel-bar--down'}`}></span>
                </span>
                <span class={`tv2-vel-pct ${isUp ? 'tv2-vel-pct--up' : 'tv2-vel-pct--down'}`}>
                  {fmtAccel(s.acceleration)}
                </span>
                <span class="tv2-vel-vol">{s.velocity7d}/{s.velocityPrior7d}</span>
              </a>
            </li>
          );
        })}
      </ol>
    </section>

    <!-- ══ Section 03 · ACTIVE LABS ════════════════════════════════════════ -->
    <section class="tv2-section">
      <header class="tv2-section-header">
        <div class="tv2-section-titlewrap">
          <span class="tv2-section-num">03</span>
          <h2 class="tv2-section-h2">
            <span data-tc>活躍實驗室</span>
            <span data-sc>活跃实验室</span>
          </h2>
          <span class="tv2-section-en">/ Active Labs</span>
        </div>
        <a class="tv2-more" href={`${base}/talent/labs/`}>
          <span data-tc>全部 {stats.labCount} →</span>
          <span data-sc>全部 {stats.labCount} →</span>
        </a>
      </header>
      <div class="picks-grid">
        {labsShowcase.map(l => <LabCard record={l} />)}
      </div>
    </section>

    <!-- ══ Section 04 · WATCHLIST ══════════════════════════════════════════ -->
    <section class="tv2-section">
      <header class="tv2-section-header">
        <div class="tv2-section-titlewrap">
          <span class="tv2-section-num">04</span>
          <h2 class="tv2-section-h2">
            <span data-tc>研究員觀察名單</span>
            <span data-sc>研究员观察名单</span>
          </h2>
          <span class="tv2-section-en">/ Watchlist</span>
        </div>
        <a class="tv2-more" href={`${base}/talent/people/`}>
          <span data-tc>全部 {stats.peopleCount} →</span>
          <span data-sc>全部 {stats.peopleCount} →</span>
        </a>
      </header>
      <p class="tv2-section-lede">
        <span data-tc>優先列出 <strong>⚡-評級</strong> 且機構已關聯或有社交提及的研究員。</span>
        <span data-sc>优先列出 <strong>⚡-评级</strong> 且机构已关联或有社交提及的研究员。</span>
      </p>
      <div class="picks-grid">
        {watchlist.map(p => <PersonCard record={p} />)}
      </div>
    </section>

    <!-- ══ Methodology — collapsed by default ══════════════════════════════ -->
    <details class="tv2-method">
      <summary>
        <span class="tv2-method-summary-label">
          <span data-tc>方法論 · How this works</span>
          <span data-sc>方法论 · How this works</span>
        </span>
        <span class="tv2-method-summary-cue" aria-hidden="true">+</span>
      </summary>
      <ol class="tv2-method-list">
        <li><strong>Subdirections</strong> — 方法族趨勢來自 <code>field-state-*.json</code> + <code>ai-field-state-*.json</code>（機械化，零 LLM）。加速度 = (近 7d − 前 7d) / max(前值, 1)。</li>
        <li><strong>Labs</strong> — 來自 <code>entity-index.json</code> 的 <code>type=lab</code> 實體，90 日滾動窗口。</li>
        <li><strong>People</strong> — <code>vla-daily-rating-out-*.json</code> 第一作者抽取 + <code>entity-index.json</code> <code>type=researcher</code> 合併，機構經 <code>institution-registry.json</code> 解析。</li>
        <li><strong>HR Queue</strong> — People 上加門檻：頂評 ≥ 🔧、90 日 ≥ 2 篇、機構可解析、聯繫狀態非 <em>not_linked</em>。</li>
        <li><strong>Email 永不儲存或顯示</strong> — 僅 <code>contact_status</code> 枚舉：<em>linked_via_lab</em> / <em>social_mention</em> / <em>not_linked</em>。任何觸達前請自行核實。</li>
      </ol>
    </details>

    <p class="tv2-foot">
      Pipeline v6 · <span data-tc>資料截至</span><span data-sc>数据截至</span> <strong>{stats.dataAsOf}</strong>
      · {stats.subdirectionCount} subdirections · {stats.labCount} labs · {stats.peopleCount} people · {stats.hrQueueCount} HR
    </p>
  </main>

  <style>
    /* ══════════════════════════════════════════════════════════════════════
       Talent Radar v2 — design rules
       - lead with story, not metrics
       - HR (most actionable) up top
       - velocity board > 4 identical card grids
       - rely on the global fin-terminal palette (amber/cyan + serif title)
       ══════════════════════════════════════════════════════════════════ */

    .talent-v2 {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2rem 1rem 5rem;
      color: var(--text-primary);
    }

    /* ── HERO ────────────────────────────────────────────────────────── */
    .tv2-hero {
      position: relative;
      padding: 2.25rem 0 1.75rem;
      border-bottom: 1px solid var(--border);
      margin-bottom: 1.75rem;
    }
    .tv2-hero::after {
      content: '';
      position: absolute; left: 0; right: 0; bottom: -1px; height: 2px;
      background: linear-gradient(90deg, var(--accent-amber), var(--accent-cyan) 70%, transparent);
    }
    .tv2-hero-meta {
      display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: center;
      margin-bottom: 1rem;
    }
    .tv2-stage {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.65rem; font-weight: 700;
      letter-spacing: 0.18em;
      color: var(--accent-amber);
      padding: 0.25rem 0.65rem;
      border: 1px solid var(--accent-amber);
      border-radius: 999px;
      background: var(--accent-amber-bg);
    }
    .tv2-stage-dot {
      width: 5px; height: 5px;
      background: var(--accent-amber);
      border-radius: 50%;
      animation: tv2-pulse 2s ease-in-out infinite;
    }
    @keyframes tv2-pulse {
      0%, 100% { opacity: 1; }
      50%      { opacity: 0.3; }
    }
    .tv2-fresh {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.65rem; letter-spacing: 0.08em;
      padding: 0.25rem 0.65rem;
      border-radius: 999px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text-secondary);
    }
    .tv2-fresh-dot {
      width: 5px; height: 5px;
      background: var(--text-tertiary); border-radius: 50%;
    }
    .tv2-fresh-age { color: var(--text-tertiary); }
    .tv2-fresh--fresh .tv2-fresh-dot  { background: var(--rating-book); }
    .tv2-fresh--ok    .tv2-fresh-dot  { background: var(--accent-cyan); }
    .tv2-fresh--stale .tv2-fresh-dot  { background: var(--accent-amber); }
    .tv2-fresh--stale { color: var(--accent-amber); border-color: var(--accent-amber); }

    .tv2-title-row {
      display: flex; flex-wrap: wrap; align-items: baseline; gap: 1rem;
      margin: 0.5rem 0 0.75rem;
    }
    .tv2-title {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: clamp(2.25rem, 5.5vw, 3.5rem);
      font-weight: 600;
      letter-spacing: 0.08em;
      line-height: 1;
      margin: 0;
      color: var(--text-primary);
    }
    .tv2-title-en {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--text-tertiary);
      margin: 0;
    }
    .tv2-lede {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 1.05rem;
      line-height: 1.7;
      color: var(--text-secondary);
      margin: 0 0 0.5rem;
      max-width: 760px;
    }
    .tv2-lede strong { color: var(--text-primary); font-weight: 600; }
    .tv2-promise {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem;
      letter-spacing: 0.04em;
      color: var(--text-tertiary);
      margin: 0;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .tv2-promise-icon {
      color: var(--accent-amber); font-weight: 700;
    }
    .tv2-promise strong {
      color: var(--accent-amber);
      font-weight: 700;
    }

    /* ── WEEKLY BRIEF ────────────────────────────────────────────────── */
    .tv2-brief { margin: 1.5rem 0 2.75rem; }
    .tv2-brief-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.2em; text-transform: uppercase;
      color: var(--accent-cyan);
      margin: 0 0 0.75rem;
    }
    .tv2-brief-en { color: var(--text-tertiary); font-weight: 400; margin-left: 0.5rem; }
    .tv2-brief-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }
    .tv2-brief-card {
      display: flex; flex-direction: column; gap: 0.5rem;
      padding: 1.1rem 1.15rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--surface);
      color: var(--text-primary);
      text-decoration: none;
      transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
      position: relative;
      overflow: hidden;
    }
    .tv2-brief-card::before {
      content: '';
      position: absolute; left: 0; top: 0; bottom: 0;
      width: 3px;
      background: var(--border);
      transition: background 0.15s;
    }
    .tv2-brief-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-card-hover);
      border-color: var(--accent-cyan);
    }
    .tv2-brief-card:hover::before { background: var(--accent-cyan); }
    .tv2-brief-card--accent { border-color: var(--accent-amber); }
    .tv2-brief-card--accent::before { background: var(--accent-amber); }
    .tv2-brief-card--accent:hover { border-color: var(--accent-amber); }
    .tv2-brief-card--accent:hover::before { background: var(--accent-amber); }

    .tv2-brief-kicker {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--text-tertiary);
    }
    .tv2-brief-main {
      display: flex; align-items: baseline; gap: 0.75rem;
      flex-wrap: wrap;
    }
    .tv2-brief-head {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--text-primary);
      line-height: 1.2;
      flex: 1; min-width: 0;
    }
    .tv2-brief-delta {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--rating-x);
    }
    .tv2-brief-delta[data-pos="true"] { color: var(--accent-amber); }
    .tv2-brief-sub {
      display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem;
      color: var(--text-secondary);
    }
    .tv2-brief-domain {
      font-weight: 700;
      letter-spacing: 0.1em;
      color: var(--accent-cyan);
    }
    .tv2-brief-affil { color: var(--accent-amber); }
    .tv2-brief-meta  { color: var(--text-tertiary); }

    /* ── SECTION HEADER ─────────────────────────────────────────────── */
    .tv2-section { margin: 3rem 0; }
    .tv2-section-header {
      display: flex; align-items: baseline; justify-content: space-between;
      gap: 1rem; flex-wrap: wrap;
      padding-bottom: 0.55rem; margin-bottom: 1.25rem;
      border-bottom: 1px solid var(--border);
    }
    .tv2-section-titlewrap {
      display: flex; align-items: baseline; gap: 0.65rem;
    }
    .tv2-section-num {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.75rem; font-weight: 700;
      letter-spacing: 0.15em;
      color: var(--accent-amber);
    }
    .tv2-section-h2 {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 1.4rem;
      font-weight: 600;
      margin: 0;
      color: var(--text-primary);
    }
    .tv2-section-en {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem;
      color: var(--text-tertiary);
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .tv2-more {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.75rem;
      color: var(--accent-cyan);
      text-decoration: none;
      letter-spacing: 0.04em;
    }
    .tv2-more:hover { text-decoration: underline; }
    .tv2-section-lede {
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0 0 1.25rem;
      max-width: 820px;
    }
    .tv2-section-lede em { font-style: normal; color: var(--accent-amber); }
    .tv2-section-lede code {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85em;
      padding: 0.1em 0.35em;
      background: var(--surface-2);
      border-radius: 3px;
    }

    /* ── HR SHORTLIST ────────────────────────────────────────────────── */
    .tv2-hr-stack { display: flex; flex-direction: column; gap: 1.25rem; }
    .tv2-hr-featured {
      position: relative;
      background: var(--surface);
      border: 1px solid var(--accent-amber);
      border-radius: 12px;
      overflow: hidden;
      box-shadow: var(--shadow-card);
      display: flex;
    }
    .tv2-hr-featured-stripe {
      width: 6px;
      background: linear-gradient(180deg, var(--accent-amber), var(--accent-cyan));
      flex-shrink: 0;
    }
    .tv2-hr-featured-body {
      flex: 1;
      padding: 1.5rem 1.75rem;
      display: flex; flex-direction: column; gap: 1rem;
    }
    .tv2-hr-featured-head { display: flex; flex-direction: column; gap: 0.4rem; }
    .tv2-hr-featured-kicker {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.65rem; font-weight: 700;
      letter-spacing: 0.18em;
      color: var(--accent-amber);
    }
    .tv2-hr-featured-title {
      display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap;
    }
    .tv2-hr-featured-title h3 {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 1.75rem; font-weight: 600;
      margin: 0; line-height: 1.1;
      color: var(--text-primary);
    }
    .tv2-hr-featured-affil {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem; font-weight: 600;
      color: var(--accent-amber);
      text-decoration: none;
      align-self: flex-start;
    }
    .tv2-hr-featured-affil:hover { text-decoration: underline; }
    .tv2-hr-featured-why {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.95rem; line-height: 1.6;
      color: var(--text-secondary);
      margin: 0;
      padding: 0.65rem 0.9rem;
      background: var(--accent-amber-bg);
      border-left: 3px solid var(--accent-amber);
      border-radius: 4px;
    }
    .tv2-hr-why-tag {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.6rem; font-weight: 700;
      letter-spacing: 0.15em;
      color: var(--accent-amber);
      margin-right: 0.5rem;
    }
    .tv2-hr-featured-stats {
      display: flex; gap: 2rem; flex-wrap: wrap;
      padding: 0.75rem 0;
      border-top: 1px dashed var(--border);
      border-bottom: 1px dashed var(--border);
    }
    .tv2-hr-stat { display: flex; flex-direction: column; gap: 0.15rem; }
    .tv2-hr-stat-num {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 1.5rem; font-weight: 700;
      color: var(--text-primary);
      line-height: 1;
    }
    .tv2-hr-stat-lbl {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.12em;
      color: var(--text-tertiary);
      text-transform: uppercase;
    }
    .tv2-hr-stat-pill {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem; font-weight: 600;
      padding: 0.2rem 0.55rem;
      border-radius: 999px;
      border: 1px solid var(--accent-cyan);
      color: var(--accent-cyan);
      background: var(--accent-cyan-bg);
      display: inline-block;
      width: fit-content;
    }
    .tv2-hr-stat-pill[data-status="social_mention"] {
      border-color: var(--accent-amber);
      color: var(--accent-amber);
      background: var(--accent-amber-bg);
    }
    .tv2-hr-featured-papers {
      list-style: none; padding: 0; margin: 0;
      display: flex; flex-direction: column; gap: 0.55rem;
    }
    .tv2-hr-featured-papers li a {
      display: flex; align-items: flex-start; gap: 0.5rem;
      text-decoration: none;
      color: var(--text-primary);
      font-size: 0.85rem;
      line-height: 1.5;
      padding: 0.4rem 0.5rem;
      border-radius: 4px;
      transition: background 0.12s;
    }
    .tv2-hr-featured-papers li a:hover {
      background: var(--surface-2);
      color: var(--accent-amber);
    }
    .tv2-paper-title { flex: 1; }
    .tv2-paper-date {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem;
      color: var(--text-tertiary);
      flex-shrink: 0;
    }
    .tv2-hr-rest {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
    }

    /* ── VELOCITY BOARD ──────────────────────────────────────────────── */
    .tv2-velocity-board {
      list-style: none;
      padding: 0.5rem 0;
      margin: 0;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--surface);
      overflow: hidden;
    }
    .tv2-vel-row + .tv2-vel-row { border-top: 1px solid var(--border-subtle); }
    .tv2-vel-link {
      display: grid;
      grid-template-columns: 28px 50px 1fr 2fr 64px 56px;
      gap: 0.75rem;
      align-items: center;
      padding: 0.65rem 1rem;
      text-decoration: none;
      color: var(--text-primary);
      transition: background 0.12s;
    }
    .tv2-vel-link:hover { background: var(--surface-2); }
    .tv2-vel-rank {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem; font-weight: 700;
      color: var(--text-tertiary);
      letter-spacing: 0.04em;
    }
    .tv2-vel-domain {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.6rem; font-weight: 700;
      letter-spacing: 0.12em;
      text-align: center;
      padding: 0.18rem 0.4rem;
      border-radius: 4px;
    }
    .tv2-vel-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.95rem;
      font-weight: 500;
      color: var(--text-primary);
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .tv2-vel-track {
      position: relative;
      height: 8px;
      background: var(--surface-2);
      border-radius: 4px;
      overflow: hidden;
    }
    .tv2-vel-bar {
      position: absolute;
      left: 0; top: 0; bottom: 0;
      width: var(--vel-pct);
      border-radius: 4px;
      transition: width 0.4s ease-out;
    }
    .tv2-vel-bar--up   { background: linear-gradient(90deg, var(--accent-amber), color-mix(in srgb, var(--accent-amber) 65%, var(--accent-cyan))); }
    .tv2-vel-bar--down { background: linear-gradient(90deg, var(--rating-x), color-mix(in srgb, var(--rating-x) 60%, transparent)); opacity: 0.85; }
    .tv2-vel-pct {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.8rem; font-weight: 700;
      text-align: right;
    }
    .tv2-vel-pct--up   { color: var(--accent-amber); }
    .tv2-vel-pct--down { color: var(--rating-x); }
    .tv2-vel-vol {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.68rem;
      color: var(--text-tertiary);
      text-align: right;
    }

    /* ── METHODOLOGY <details> ───────────────────────────────────────── */
    .tv2-method {
      margin: 3rem 0 1.5rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--surface);
      padding: 0;
    }
    .tv2-method summary {
      list-style: none;
      cursor: pointer;
      padding: 1rem 1.25rem;
      display: flex; align-items: center; justify-content: space-between;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--text-primary);
    }
    .tv2-method summary::-webkit-details-marker { display: none; }
    .tv2-method-summary-cue {
      font-family: 'IBM Plex Mono', monospace;
      color: var(--accent-cyan);
      font-size: 1.2rem;
      transition: transform 0.2s;
    }
    .tv2-method[open] .tv2-method-summary-cue { transform: rotate(45deg); }
    .tv2-method-list {
      padding: 0 1.5rem 1.25rem 2.75rem;
      margin: 0;
      color: var(--text-secondary);
      font-size: 0.85rem;
      line-height: 1.7;
    }
    .tv2-method-list li + li { margin-top: 0.5rem; }
    .tv2-method-list code {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85em;
      padding: 0.1em 0.35em;
      background: var(--surface-2);
      border-radius: 3px;
    }
    .tv2-method-list strong { color: var(--text-primary); }

    /* ── EMPTY STATE ─────────────────────────────────────────────────── */
    .tv2-empty {
      padding: 2.25rem 1.5rem;
      background: var(--surface);
      border: 1px dashed var(--border);
      border-radius: 10px;
      text-align: center;
    }
    .tv2-empty-title {
      font-family: Georgia, 'Songti SC', serif;
      font-size: 1.05rem;
      color: var(--text-primary);
      margin: 0 0 0.4rem;
    }
    .tv2-empty-sub {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.75rem;
      color: var(--text-tertiary);
      margin: 0;
    }

    /* ── FOOT ────────────────────────────────────────────────────────── */
    .tv2-foot {
      margin: 2rem 0 0;
      text-align: center;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem;
      color: var(--text-tertiary);
      letter-spacing: 0.06em;
    }
    .tv2-foot strong { color: var(--text-primary); }

    /* ── RESPONSIVE ──────────────────────────────────────────────────── */
    @media (max-width: 900px) {
      .tv2-brief-grid { grid-template-columns: 1fr; }
      .tv2-hr-rest    { grid-template-columns: 1fr; }
      .tv2-vel-link {
        grid-template-columns: 24px 44px 1fr 56px;
        gap: 0.5rem;
      }
      .tv2-vel-track { grid-column: 1 / -1; }
      .tv2-vel-vol   { display: none; }
    }
    @media (max-width: 600px) {
      .tv2-hr-featured-body { padding: 1rem 1.15rem; }
      .tv2-hr-featured-title h3 { font-size: 1.4rem; }
      .tv2-hr-featured-stats { gap: 1.25rem; }
    }
  </style>
</BaseLayout>
