---
/**
 * PersonCard.astro
 * Researcher card for /talent/people and /talent/hr-queue.
 *
 * CRITICAL: never render email. Only `contactStatus` enum is allowed.
 * Even social-mention status surfaces only a status pill — no link.
 */
import type { PersonRecord, ContactStatus, HRCandidate } from '../utils/talent';
import { slugifyName } from '../utils/talent.ts';
import RatingBadge from './RatingBadge.astro';

interface Props {
  record: PersonRecord | HRCandidate;
  showWhyNow?: boolean;
}
const { record, showWhyNow = false } = Astro.props;

const CONTACT_META: Record<ContactStatus, { label: string; labelSC: string; bg: string; color: string }> = {
  linked_via_lab: {
    label:   'Linked via lab',
    labelSC: '通过机构关联',
    bg:      'rgba(15, 143, 160, 0.15)',
    color:   'var(--accent-cyan)',
  },
  social_mention: {
    label:   'Social mention',
    labelSC: '社交情报提及',
    bg:      'rgba(212, 145, 10, 0.15)',
    color:   'var(--accent-amber)',
  },
  not_linked: {
    label:   'Author byline only',
    labelSC: '仅论文署名',
    bg:      'rgba(120, 120, 120, 0.15)',
    color:   'var(--text-muted)',
  },
};

const contact = CONTACT_META[record.contactStatus];
const isHRCandidate = 'whyNow' in record;
const base = import.meta.env.BASE_URL;

// Initials avatar — stable hue per name, no PII stored.
// CJK leading → single glyph for legibility; Latin → first/last initials.
function avatarInitials(raw: string): string {
  const s = (raw ?? '').trim();
  if (!s) return '?';
  if (/^[一-鿿]/.test(s)) return s.slice(0, 1);
  const parts = s.split(/\s+/).filter(Boolean);
  if (parts.length >= 2) return (parts[0][0] + parts[parts.length - 1][0]).toUpperCase();
  return parts[0].slice(0, 2).toUpperCase();
}
function avatarHue(name: string): number {
  let h = 0;
  for (let i = 0; i < name.length; i++) h = (h * 31 + name.charCodeAt(i)) | 0;
  return Math.abs(h) % 360;
}
const initials = avatarInitials(record.name);
const hue      = avatarHue(record.name);
---

<article id={`person-${slugifyName(record.name)}`} class="card group flex flex-col gap-3 person-card">
  <!-- Header: avatar + name + rating -->
  <div class="flex items-center gap-3">
    <span
      class="person-avatar"
      style={`--av-hue: ${hue};`}
      aria-hidden="true"
    >{initials}</span>
    <h3 class="font-lora font-semibold text-pulsar-text text-base leading-snug flex-1 min-w-0">
      {record.name}
    </h3>
    <RatingBadge rating={record.topRating} size="sm" />
  </div>

  <!-- Affiliation as subtitle (anchor identity); paper count secondary -->
  <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1">
    {record.affiliation && (
      <a
        href={`${base}/talent/labs/#lab-${slugifyName(record.affiliation)}`}
        class="font-ibm-plex-mono text-sm font-semibold text-pulsar-amber hover:underline transition-colors"
      >{record.affiliation}</a>
    )}
    <span class="font-ibm-plex-mono text-xs text-pulsar-muted">
      <span data-tc>{record.paperCount90d} 篇 · 90d</span><span data-sc>{record.paperCount90d} 篇 · 90d</span>
    </span>
  </div>

  <!-- Contact status pill. NO-EMAIL is enforced at the data layer and stated
       on the page banner — repeating it per row was noisy. -->
  <div class="flex flex-wrap items-center gap-2">
    <span
      class="inline-flex items-center font-ibm-plex-mono rounded-full border px-2 py-0.5 text-xs"
      style={`background: ${contact.bg}; color: ${contact.color}; border-color: ${contact.color}`}
      title="Contact status — Pulsar never stores or displays email addresses"
    >
      <span data-tc>{contact.label}</span>
      <span data-sc>{contact.labelSC}</span>
    </span>
  </div>

  <!-- HR queue: why now -->
  {showWhyNow && isHRCandidate && (
    <p class="text-xs leading-relaxed font-noto-serif-sc text-pulsar-muted" style="border-left: 2px solid var(--accent-amber); padding-left: 8px;">
      <span class="font-ibm-plex-mono text-pulsar-amber" style="font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em; margin-right: 4px;">WHY NOW</span>
      {(record as HRCandidate).whyNow}
    </p>
  )}

  <!-- Evidence: top 2 papers -->
  {record.evidence.length > 0 && (
    <div class="flex flex-col gap-2 mt-1 pt-2 border-t border-pulsar-border">
      <span class="text-xs font-ibm-plex-mono text-pulsar-muted uppercase tracking-wide">
        <span data-tc>佐證論文</span><span data-sc>佐证论文</span>
      </span>
      {record.evidence.slice(0, 2).map(ev => (
        <a
          href={ev.url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-start gap-2 text-xs text-pulsar-text hover:text-pulsar-amber transition-colors leading-relaxed"
        >
          <RatingBadge rating={ev.rating} size="sm" />
          <span class="line-clamp-2 flex-1">
            {ev.title}
            <span class="ml-1 text-pulsar-muted font-ibm-plex-mono text-[0.65rem]">
              {ev.date}
            </span>
          </span>
        </a>
      ))}
      {record.evidence.length > 2 && (
        <span class="text-xs text-pulsar-muted italic">
          <span data-tc>+ {record.evidence.length - 2} 篇</span>
          <span data-sc>+ {record.evidence.length - 2} 篇</span>
        </span>
      )}
    </div>
  )}
</article>

<style>
  /* Initials avatar — stable per name, no PII stored. The HSL fallback uses
     light values for legibility on the cream background; dark mode picks
     deeper saturations via the .dark scope. */
  .person-avatar {
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    border: 1.5px solid hsl(var(--av-hue), 55%, 55%);
    background: hsl(var(--av-hue), 65%, 92%);
    color: hsl(var(--av-hue), 60%, 28%);
    transition: transform 0.12s ease, box-shadow 0.12s ease;
  }
  :global(html.dark) .person-avatar {
    background: hsl(var(--av-hue), 50%, 18%);
    border-color: hsl(var(--av-hue), 55%, 50%);
    color: hsl(var(--av-hue), 75%, 80%);
  }
  .person-card:hover .person-avatar {
    transform: scale(1.05);
    box-shadow: 0 0 0 3px color-mix(in srgb, hsl(var(--av-hue), 60%, 50%) 18%, transparent);
  }
</style>
