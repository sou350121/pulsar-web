---
/**
 * Footer.astro
 * Site footer — styled using the Pulsar design system from global.css.
 */
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer aria-label="Site footer">
  <div class="container">
    <div class="footer-grid">

      <!-- Brand -->
      <div>
        <span class="footer-brand-logo">PUL<span>S</span>AR</span>
        <p class="footer-tagline" style="font-size:1.1rem;font-weight:500;margin-bottom:6px;">照　見</p>
        <p class="footer-tagline">
          AI 研究情報平台。每日自動聚合前沿論文、行業動態
          與實驗室信號，為研究者和從業者提供結構化洞察。
        </p>
        <div class="footer-auto-label">
          <span style="color:#4CAF50;">●</span>
          由 AI Pipeline 自動生成 · 每日更新
        </div>
      </div>

      <!-- Nav Column 1 -->
      <div>
        <h3 class="footer-col-title"><span data-tc>內容頻道</span><span data-sc>内容频道</span></h3>
        <ul class="footer-links" role="list">
          <li><a href={`${base}/ai-daily`}>AI App <span data-tc>日報</span><span data-sc>日报</span></a></li>
          <li><a href={`${base}/vla`}>VLA <span data-tc>研究日報</span><span data-sc>研究日报</span></a></li>
          <li><a href={`${base}/social`}><span data-tc>社交情報</span><span data-sc>社交情报</span></a></li>
          <li><a href={`${base}/reports`}><span data-tc>雙週報告</span><span data-sc>双周报告</span></a></li>
          <li><a href={`${base}/dashboard`}><span data-tc>數據面板</span><span data-sc>数据面板</span></a></li>
        </ul>
      </div>

      <!-- Nav Column 2 -->
      <div>
        <h3 class="footer-col-title"><span data-tc>系統工具</span><span data-sc>系统工具</span></h3>
        <ul class="footer-links" role="list">
          <li><a href={`${base}/dashboard`}><span data-tc>管道儀表板</span><span data-sc>管道仪表板</span></a></li>
          <li><a href="#"><span data-tc>實體追蹤器</span><span data-sc>实体追踪器</span></a></li>
          <li><a href="#"><span data-tc>語義搜索</span><span data-sc>语义搜索</span></a></li>
          <li><a href="#"><span data-tc>假設校準庫</span><span data-sc>假设校准库</span></a></li>
          <li><a href="#"><span data-tc>跨域規則引擎</span><span data-sc>跨域规则引擎</span></a></li>
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <span class="footer-copy">
        PULSAR · 照見 &copy; {year}
      </span>
      <span class="footer-version">
        Pipeline v6 · Qwen3.5-Plus · <span data-tc>每日更新</span><span data-sc>每日更新</span>
      </span>
    </div>
  </div>
</footer>
