---
/**
 * src/pages/reports/[date].astro
 * Dynamic route — individual biweekly report view.
 * Generates one page per date found via loadBiweeklyReports().
 *
 * DESIGN: "Intelligence Briefing Dossier" — editorial magazine meets
 * classified briefing. Section-aware styling, pull-quote blockquotes,
 * prediction cards, and actionable callouts with distinct visual identity.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadBiweeklyReports } from '../../utils/data';

// getStaticPaths — required for Astro static output
export async function getStaticPaths() {
  const reports     = loadBiweeklyReports(60, false);
  const reflections = loadBiweeklyReports(60, true);
  return [
    ...reports.map(r => ({
      params: { date: r.domain === 'ai' ? `ai-${r.date}` : r.date },
      props:  { report: r },
    })),
    ...reflections.map(r => ({
      params: { date: r.domain === 'ai' ? `ai-${r.date}-reflection` : `${r.date}-reflection` },
      props:  { report: { ...r, date: r.domain === 'ai' ? `ai-${r.date}-reflection` : `${r.date}-reflection` } },
    })),
  ];
}

const { report } = Astro.props;
const { date, content } = report;
const base = import.meta.env.BASE_URL;

// Load all reports for prev/next navigation
const allReports = loadBiweeklyReports(60, false);
const allDates = [...new Set(allReports.map(r => r.date))].sort();
const idx = allDates.indexOf(date);
const prevDate = idx > 0 ? allDates[idx - 1] : null;
const nextDate = idx < allDates.length - 1 ? allDates[idx + 1] : null;

// Format ISO date as Chinese: "2026年2月25日"
function formatDateZh(iso: string): string {
  const [year, month, day] = iso.split('-').map(Number);
  return `${year}年${month}月${day}日`;
}

// ─────────────────────────────────────────────────────────────
// Section classification — determines visual treatment
// ─────────────────────────────────────────────────────────────
type SectionKind = 'action' | 'prediction' | 'prediction-review' | 'gap' | 'default';

function classifySection(heading: string): SectionKind {
  if (/如果你是|行动|建议|负责人/.test(heading))                  return 'action';
  if (/本期预测|预测$/.test(heading))                             return 'prediction';
  if (/预测回顾|上期预测|回顾/.test(heading))                     return 'prediction-review';
  if (/知识缺口|缺口|盲区|风险/.test(heading))                    return 'gap';
  return 'default';
}

let currentSection: SectionKind = 'default';
let sectionCounter = 0;

// ─────────────────────────────────────────────────────────────
// Markdown → HTML  (editorial-grade parser)
// ─────────────────────────────────────────────────────────────
function mdToHtml(md: string): string {
  const lines = md.split('\n');
  const out: string[] = [];
  let inList: 'ul' | 'ol' | false = false;
  let inSection = false;
  sectionCounter = 0;

  for (let i = 0; i < lines.length; i++) {
    const raw = lines[i];
    const trimmed = raw.trim();

    // Empty line
    if (!trimmed) {
      if (inList) { out.push(inList === 'ol' ? '</ol>' : '</ul>'); inList = false; }
      continue;
    }

    // Horizontal rule — section break ornament
    if (/^[-*_]{3,}\s*$/.test(trimmed) || /^━{3,}/.test(trimmed)) {
      if (inList) { out.push(inList === 'ol' ? '</ol>' : '</ul>'); inList = false; }
      if (inSection) { out.push('</section>'); inSection = false; }
      out.push('<hr class="rb-hr" />');
      continue;
    }

    // Headings
    const hMatch = trimmed.match(/^(#{1,4})\s+(.+)$/);
    if (hMatch) {
      if (inList) { out.push(inList === 'ol' ? '</ol>' : '</ul>'); inList = false; }
      const level = hMatch[1].length;
      const rawText = hMatch[2];
      const text = inlineFormat(rawText);
      const id = rawText.replace(/[^a-zA-Z0-9\u4e00-\u9fff]/g, '-').toLowerCase().slice(0, 50);

      if (level === 1) {
        // H1: report title — the big serif headline
        out.push(`<h1 class="rb-h1" id="${id}">${text}</h1>`);
      } else if (level === 2) {
        // Close previous section wrapper
        if (inSection) { out.push('</section>'); }
        sectionCounter++;
        currentSection = classifySection(rawText);
        const sectionClass = `rb-section rb-section--${currentSection}`;
        inSection = true;
        out.push(`<section class="${sectionClass}" data-section="${sectionCounter}">`);
        out.push(`<div class="rb-h2-wrap">`);
        out.push(`<span class="rb-section-num" aria-hidden="true">${String(sectionCounter).padStart(2, '0')}</span>`);
        out.push(`<h2 class="rb-h2" id="${id}">${text}</h2>`);
        out.push(`</div>`);
      } else {
        out.push(`<h${level} class="rb-h${level}" id="${id}">${text}</h${level}>`);
      }
      continue;
    }

    // Blockquote — editorial pull quote
    if (trimmed.startsWith('>')) {
      if (inList) { out.push(inList === 'ol' ? '</ol>' : '</ul>'); inList = false; }
      const text = inlineFormat(trimmed.replace(/^>\s*/, ''));
      out.push(`<blockquote class="rb-bq"><span class="rb-bq-mark" aria-hidden="true">"</span><span class="rb-bq-text">${text}</span></blockquote>`);
      continue;
    }

    // Prediction checklist items (✅ ⏳ ❌)
    if (/^[-*•]\s*(✅|⏳|❌)\s/.test(trimmed)) {
      if (inList && inList !== 'ul') { out.push('</ol>'); inList = false; }
      if (!inList) { out.push('<ul class="rb-predictions">'); inList = 'ul'; }
      const emoji = trimmed.match(/^[-*•]\s*(✅|⏳|❌)/)?.[1] ?? '';
      const statusClass = emoji === '✅' ? 'confirmed' : emoji === '❌' ? 'wrong' : 'pending';
      const statusLabel = emoji === '✅' ? 'CONFIRMED' : emoji === '❌' ? 'INVALIDATED' : 'TRACKING';
      const text = inlineFormat(trimmed.replace(/^[-*•]\s*(✅|⏳|❌)\s*/, ''));
      out.push(`<li class="rb-prediction-item rb-prediction--${statusClass}">`);
      out.push(`<span class="rb-prediction-status">${statusLabel}</span>`);
      out.push(`<span class="rb-prediction-text">${text}</span>`);
      out.push(`</li>`);
      continue;
    }

    // Ordered list (1. 2. 3. or (1) (2) (3))
    const olMatch = trimmed.match(/^(?:(\d+)[.)]\s+|\((\d+)\)\s+)(.+)$/);
    if (olMatch) {
      if (inList && inList !== 'ol') { out.push('</ul>'); inList = false; }
      if (!inList) { out.push('<ol class="rb-ol">'); inList = 'ol'; }
      const num = olMatch[1] || olMatch[2];
      const text = inlineFormat(olMatch[3]);
      out.push(`<li value="${num}">${text}</li>`);
      continue;
    }

    // Unordered list — bullet items (prediction items with bold leads)
    if (/^[-*•]\s/.test(trimmed)) {
      if (inList && inList !== 'ul') { out.push('</ol>'); inList = false; }
      const listClass = currentSection === 'prediction' ? 'rb-predictions' : 'rb-ul';
      if (!inList) { out.push(`<ul class="${listClass}">`); inList = 'ul'; }
      const text = inlineFormat(trimmed.replace(/^[-*•]\s*/, ''));

      if (currentSection === 'prediction') {
        out.push(`<li class="rb-prediction-item rb-prediction--new">`);
        out.push(`<span class="rb-prediction-status">FORECAST</span>`);
        out.push(`<span class="rb-prediction-text">${text}</span>`);
        out.push(`</li>`);
      } else {
        out.push(`<li>${text}</li>`);
      }
      continue;
    }

    // Emoji-prefixed lines (1️⃣ 2️⃣ etc. from reflections)
    const emojiNumMatch = trimmed.match(/^(\d️⃣|🔬|🤔)\s*(.+)$/);
    if (emojiNumMatch) {
      if (inList) { out.push(inList === 'ol' ? '</ol>' : '</ul>'); inList = false; }
      const emoji = emojiNumMatch[1];
      const text = inlineFormat(emojiNumMatch[2]);
      out.push(`<div class="rb-callout-line"><span class="rb-callout-emoji" aria-hidden="true">${emoji}</span><p class="rb-p">${text}</p></div>`);
      continue;
    }

    // Paragraph — the main prose block
    if (inList) { out.push(inList === 'ol' ? '</ol>' : '</ul>'); inList = false; }
    out.push(`<p class="rb-p">${inlineFormat(trimmed)}</p>`);
  }

  if (inList) out.push(inList === 'ol' ? '</ol>' : '</ul>');
  if (inSection) out.push('</section>');
  return out.join('\n');
}

// ─────────────────────────────────────────────────────────────
// Inline formatting — bold, italic, code, links, stat highlights
// ─────────────────────────────────────────────────────────────
function inlineFormat(text: string): string {
  return text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    // Bold
    .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
    // Italic (markdown *text* or _text_)
    .replace(/(?<!\w)\*([^*]+)\*(?!\w)/g, '<em>$1</em>')
    .replace(/(?<!\w)_([^_]+)_(?!\w)/g, '<em>$1</em>')
    // Inline code
    .replace(/`([^`]+)`/g, '<code class="rb-code">$1</code>')
    // Markdown links
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g, '<a href="$2" target="_blank" rel="noopener noreferrer">$1</a>')
    // Bare URLs
    .replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank" rel="noopener noreferrer" class="rb-link">$1</a>')
    // Stat highlights — dollar amounts, percentages, multipliers
    .replace(/(\$[\d,.]+[BMK]?\b)/g, '<span class="rb-stat">$1</span>')
    .replace(/(\d+(?:\.\d+)?%\+?)/g, '<span class="rb-stat">$1</span>')
    .replace(/(\d+(?:\.\d+)?x\b)/g, '<span class="rb-stat">$1</span>')
    // Chinese book quotes 「…」 → subtle emphasis
    .replace(/「([^」]+)」/g, '<span class="rb-cjk-quote">$1</span>');
}

const reportHtml = content ? mdToHtml(content) : '';

// Compute a biweekly period label: e.g. "2026.02.12 – 02.25"
function formatPeriod(iso: string): string {
  const end   = new Date(iso);
  const start = new Date(end);
  start.setDate(start.getDate() - 13);
  const sm = String(start.getMonth() + 1).padStart(2, '0');
  const sd = String(start.getDate()).padStart(2, '0');
  const em = String(end.getMonth() + 1).padStart(2, '0');
  const ed = String(end.getDate()).padStart(2, '0');
  const ey = end.getFullYear();
  return `${ey}.${sm}.${sd} – ${em}.${ed}`;
}
---

<BaseLayout
  title={`雙週報告 ${date} — PULSAR`}
  description={`PULSAR 雙週報告 ${formatDateZh(date)} — VLA 進展、AI 應用、社交情報與校準分析`}
>
  <div class="report-page page-container">

    <!-- ── Breadcrumb ── -->
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href={base} class="breadcrumb-link"><span data-tc>首頁</span><span data-sc>首页</span></a>
      <span class="breadcrumb-sep">/</span>
      <a href={`${base}/reports`} class="breadcrumb-link"><span data-tc>雙週報告</span><span data-sc>双周报告</span></a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">{date}</span>
    </nav>

    <!-- ── Page header ── -->
    <header class="report-header fade-in-1">
      <div class="report-overline">
        <span class="overline-badge"><span data-tc>雙週報告</span><span data-sc>双周报告</span></span>
        <span class="overline-sep">|</span>
        <span class="overline-period">{formatPeriod(date)}</span>
      </div>

      <h1 class="report-title">
        深度分析 · {formatDateZh(date)}
      </h1>

      <div class="report-meta-row">
        <span class="meta-tag meta-tag--ai"><span data-tc>AI App線</span><span data-sc>AI App线</span></span>
        <span class="meta-tag meta-tag--vla"><span data-tc>VLA線</span><span data-sc>VLA线</span></span>
        <span class="meta-tag meta-tag--default"><span data-tc>社交情報</span><span data-sc>社交情报</span></span>
        <span class="meta-tag meta-tag--default"><span data-tc>校準</span><span data-sc>校准</span></span>
      </div>

      <hr class="report-rule" />
    </header>

    <!-- ── Detail breadcrumb ── -->
    <nav class="detail-breadcrumb" aria-label="Breadcrumb">
      <a href={`${base}`} class="bc-link"><span data-tc>首頁</span><span data-sc>首页</span></a>
      <span class="bc-sep">&rsaquo;</span>
      <a href={`${base}/reports`} class="bc-link"><span data-tc>雙週報告</span><span data-sc>双周报告</span></a>
      <span class="bc-sep">&rsaquo;</span>
      <span class="bc-current">{date}</span>
    </nav>

    <!-- ── Report body ── -->
    <article class="report-article">
      {reportHtml
        ? <div class="report-body" set:html={reportHtml} />
        : (
          <div class="report-empty">
            <span class="empty-icon">▣</span>
            <p class="empty-title">CONTENT PENDING</p>
            <p class="empty-sub"><span data-tc>報告內容尚未同步 — pipeline 自動生成中</span><span data-sc>报告内容尚未同步 — pipeline 自动生成中</span></p>
          </div>
        )
      }
    </article>

    <!-- ── Prev / next report pagination ── -->
    <div class="report-pagination">
      {prevDate ? (
        <a href={`${base}/reports/${prevDate}`} class="rpag-btn rpag-btn--prev">
          &larr; {prevDate}
        </a>
      ) : <span />}
      <a href={`${base}/reports`} class="rpag-btn rpag-btn--list"><span data-tc>報告列表</span><span data-sc>报告列表</span></a>
      {nextDate ? (
        <a href={`${base}/reports/${nextDate}`} class="rpag-btn rpag-btn--next">
          {nextDate} &rarr;
        </a>
      ) : <span />}
    </div>

    <!-- ── Back link ── -->
    <div class="back-row">
      <a href={`${base}/reports`} class="back-link">
        <span class="back-arrow">&larr;</span> <span data-tc>返回報告列表</span><span data-sc>返回报告列表</span>
      </a>
    </div>

  </div>
</BaseLayout>

<style>
/* ============================================================
   REPORT DETAIL PAGE — "Intelligence Briefing Dossier"
   Scoped CSS: only affects this page.
   Design: editorial magazine meets classified briefing.
============================================================ */

/* ── Page wrapper ── */
.report-page {
  padding-top: 60px;
  padding-bottom: 80px;
}

/* ── Breadcrumb ── */
.breadcrumb {
  margin-bottom: 2rem;
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.72rem;
  color: var(--text-tertiary);
  display: flex;
  align-items: center;
  gap: 0.25rem;
  flex-wrap: wrap;
}

.breadcrumb-link {
  color: var(--text-tertiary);
  text-decoration: none;
  transition: color 0.2s;
}

.breadcrumb-link:hover {
  color: var(--text-secondary);
  opacity: 1;
}

.breadcrumb-sep {
  color: var(--border);
  margin: 0 0.2rem;
}

.breadcrumb-current {
  color: var(--text-secondary);
  font-weight: 600;
}

/* ── Page header ── */
.report-header {
  margin-bottom: 28px;
}

.report-overline {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.overline-badge {
  color: var(--accent-amber);
  background: var(--accent-amber-bg);
  border: 1px solid rgba(212,145,10,0.25);
  padding: 2px 8px;
  border-radius: 3px;
  font-weight: 600;
}

.overline-sep {
  color: var(--border);
  opacity: 0.5;
}

.overline-period {
  color: var(--text-tertiary);
  letter-spacing: 0.06em;
}

.report-title {
  font-family: 'Georgia', 'Songti SC', 'SimSun', serif !important;
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.15;
  color: var(--text-primary);
  margin-bottom: 16px;
}

.report-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 24px;
}

.meta-tag {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.58rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 2px 8px;
  border-radius: 3px;
  border: 1px solid;
}

.meta-tag--ai {
  color: var(--accent-amber);
  background: var(--accent-amber-bg);
  border-color: rgba(212,145,10,0.3);
}

.meta-tag--vla {
  color: var(--accent-cyan);
  background: var(--accent-cyan-bg);
  border-color: rgba(14,165,179,0.3);
}

.meta-tag--default {
  color: var(--text-tertiary);
  background: transparent;
  border-color: var(--border);
}

.report-rule {
  border: none;
  border-top: 1px solid var(--border);
  position: relative;
}

.report-rule::before {
  content: '';
  position: absolute;
  top: -1px;
  left: 0;
  width: 60px;
  height: 1px;
  background: var(--accent-amber);
}

/* ── Detail breadcrumb ── */
.detail-breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  flex-wrap: wrap;
  margin-bottom: 32px;
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.72rem;
  color: var(--text-tertiary);
  border-bottom: 1px solid var(--border);
  padding-bottom: 12px;
}

.bc-link {
  color: var(--text-tertiary);
  text-decoration: none;
  transition: color 0.2s;
}

.bc-link:hover {
  color: var(--accent-amber);
  opacity: 1;
}

.bc-sep {
  color: var(--border);
  margin: 0 0.2rem;
}

.bc-current {
  color: var(--text-secondary);
  font-weight: 600;
}

/* ── Prev / next pagination ── */
.report-pagination {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  margin: 32px 0 16px;
  flex-wrap: wrap;
}

.rpag-btn {
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 0.68rem;
  letter-spacing: 0.06em;
  padding: 6px 14px;
  border: 1px solid var(--border);
  border-radius: 6px;
  text-decoration: none;
  color: var(--text-secondary);
  background: var(--surface);
  transition: border-color 0.15s, color 0.15s;
}

.rpag-btn:hover {
  border-color: var(--accent-amber);
  color: var(--accent-amber);
  opacity: 1;
}

.rpag-btn--list {
  border-style: dashed;
}

/* ── Report article ── */
.report-article {
  max-width: 740px;
  margin-bottom: 48px;
}

/* ============================================================
   REPORT BODY — Editorial-grade rendered markdown
   Typography: CJK-optimized with generous vertical rhythm.
============================================================ */
.report-body {
  max-width: 740px;
  line-height: 1.95;
  font-size: 0.94rem;
  color: var(--text-secondary);
  font-family: 'PingFang SC', 'Microsoft YaHei', 'Hiragino Sans GB', sans-serif;
  counter-reset: rb-section;
}

/* ── H1: Report title — cinematic serif headline ── */
.report-body .rb-h1 {
  font-family: 'Georgia', 'Songti SC', 'SimSun', serif;
  font-size: 1.55rem;
  font-weight: 700;
  color: var(--text-primary);
  margin: 0 0 0.5em;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--border);
  position: relative;
  line-height: 1.35;
  letter-spacing: -0.01em;
}

.report-body .rb-h1::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 72px;
  height: 3px;
  background: linear-gradient(90deg, var(--accent-amber), transparent);
  border-radius: 2px;
}

/* ── Sections — semantic wrapper for each ## block ── */
.report-body .rb-section {
  margin-top: 3em;
  padding-top: 0;
  position: relative;
}

/* Subtle top border between sections */
.report-body .rb-section + .rb-section {
  border-top: 1px solid var(--border-subtle, var(--border));
  padding-top: 2.5em;
}

/* ── H2: Section headers with counter ── */
.report-body .rb-h2-wrap {
  display: flex;
  align-items: baseline;
  gap: 12px;
  margin-bottom: 1.4em;
}

.report-body .rb-section-num {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.6rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  color: var(--accent-amber);
  background: var(--accent-amber-bg);
  border: 1px solid rgba(212,145,10,0.2);
  padding: 2px 7px;
  border-radius: 3px;
  flex-shrink: 0;
  position: relative;
  top: -1px;
}

.report-body .rb-h2 {
  font-family: 'Georgia', 'Songti SC', 'SimSun', serif;
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--text-primary);
  line-height: 1.35;
  margin: 0;
  letter-spacing: 0.01em;
}

/* ── Section kind: ACTION — callout box ── */
.report-body .rb-section--action {
  background: var(--accent-amber-bg);
  border: 1px solid rgba(212,145,10,0.18);
  border-radius: 10px;
  padding: 28px 28px 20px;
  margin-top: 3em;
}

.report-body .rb-section--action + .rb-section {
  border-top: none;
}

.report-body .rb-section--action .rb-section-num {
  background: var(--accent-amber);
  color: #fff;
  border-color: var(--accent-amber);
}

html.dark .report-body .rb-section--action .rb-section-num {
  color: #07090E;
}

.report-body .rb-section--action .rb-h2 {
  color: var(--accent-amber);
}

/* ── Section kind: GAP — warning stripe ── */
.report-body .rb-section--gap {
  border-left: 3px solid var(--rating-x, #C94040);
  padding-left: 24px;
}

.report-body .rb-section--gap .rb-section-num {
  background: var(--rating-x-bg, rgba(201,64,64,0.12));
  color: var(--rating-x, #C94040);
  border-color: rgba(201,64,64,0.25);
