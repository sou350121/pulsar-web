                  ['FlowMatching', 12, 100],
                  ['Pi0 / Pi0.5',  9,  75],
                  ['WorldModel',   7,  58],
                  ['Mamba / SSM',  6,  50],
                  ['DiffusionPolicy', 5, 42],
