---
/**
 * src/pages/talent/index.astro
 * Stage 4 — Talent Radar landing (v2 revamp).
 *
 * IA inversion from v1:
 *   v1: Subdirections → Labs → People → HR Queue (browse-first)
 *   v2: Weekly Brief → HR Shortlist → Velocity Board → Labs → Watchlist
 *       (signal-first, narrative-led, HR-actionable up top)
 *
 * No new utils — everything computed from the existing loaders.
 */
import BaseLayout        from '../../layouts/BaseLayout.astro';
import SubdirectionCard  from '../../components/SubdirectionCard.astro';
import LabCard           from '../../components/LabCard.astro';
import PersonCard        from '../../components/PersonCard.astro';
import RatingBadge       from '../../components/RatingBadge.astro';
import {
  loadSubdirections,
  loadLabs,
  loadPeople,
  loadHRScout,
  loadTalentStats,
  loadResearcherConstellation,
  loadLabNetwork,
  loadWatchlist,
  slugifyName,
  topMethodsForEvidence,
} from '../../utils/talent';

const base = import.meta.env.BASE_URL;

const stats     = loadTalentStats();
const allSubs   = loadSubdirections({ domain: 'all' });
const allLabs   = loadLabs({ minSignals: 3 });
const allPeople = loadPeople({ minPaperCount90d: 1 });
const scout     = loadHRScout();

// ── Trustworthy subset for ranking ─────────────────────────────────────────
// A family with prior_volume = 0 produces a clamped acceleration value
// (often +999%) that is mathematically meaningless. Separate those from the
// signal-bearing population and surface them under a distinct "Emerging"
// label instead of letting them dominate the velocity board.
const rankedSubs   = allSubs.filter(s => s.status !== 'insufficient_data');
const emergingSubs = allSubs
  .filter(s => s.status === 'insufficient_data' && s.velocity7d > 0)
  .sort((a, b) => b.velocity7d - a.velocity7d);

// ── Weekly Brief: 3 lead facts ─────────────────────────────────────────────
const topMover  = rankedSubs.find(s => s.acceleration > 0) ?? rankedSubs[0];
const topLab    = allLabs[0];
const topEmerge = emergingSubs[0];   // new card 3: "emerging on the radar"

// ── Velocity board: top 8 by abs acceleration, excluding insufficient_data ─
const velocityBoard = [...rankedSubs]
  .sort((a, b) => Math.abs(b.acceleration) - Math.abs(a.acceleration))
  .slice(0, 8);
const velocityMaxAbs = Math.max(0.01, ...velocityBoard.map(s => Math.abs(s.acceleration)));

// ── HR scout funnel ────────────────────────────────────────────────────────
//   HOT   — full gate passers
//   WARM  — missing one criterion (rising star / prolific-no-aff / social)
//   WATCH — ⚡ outliers without durable signal
const featuredHR = scout.hot[0];
const restHot    = scout.hot.slice(1);
const warmShown  = scout.warm.slice(0, 8);
const warmRest   = Math.max(0, scout.warm.length - warmShown.length);
const watchShown = scout.watch.slice(0, 12);

// Featured candidate gets enriched method tags for the hero card
const featuredMethods = featuredHR
  ? topMethodsForEvidence(featuredHR.evidence, 3)
  : [];

// ── Labs showcase: 6 with non-zero recent OR top by 90d signals ─────────────
const labsShowcase = allLabs.slice(0, 6);

// ── Lab Network + researcher constellation + full watchlist ────────────────
// Section 04 now stacks two relational charts:
//   1. Lab Cluster Network — the LAB-level structural view. Reveals which
//      labs share method focus (= compete for the same hires) and which
//      method is the connective tissue across the field.
//   2. Researcher × Method constellation — the BIPARTITE view (existing).
// Then the dense grid of all rated researchers.
const labNet        = loadLabNetwork();
const constellation = loadResearcherConstellation();
const watchlist     = loadWatchlist();

// Lookup table so the SVG can show affiliation in the tooltip
const methodIndex = new Map(constellation.methods.map(m => [m.family, m]));

// Method-family stats for the legend cards below the chart
const methodLegend = constellation.methods.map(m => {
  const people = constellation.people.filter(pp => pp.primaryFamily === m.family);
  const sparkRatings = people.map(pp => pp.topRating);
  return {
    family:       m.family,
    displayName:  m.displayName,
    domain:       m.domain,
    total:        m.count,
    rated:        people.length,
    flashes:      sparkRatings.filter(r => r === '⚡').length,
    polish:       sparkRatings.filter(r => r === '🔧').length,
  };
});

// Bridge researchers list — the most actionable signal from the chart
const bridgePeople = constellation.people
  .filter(pp => pp.secondaryFamily !== null)
  .sort((a, b) =>
    (a.topRating === '⚡' ? 0 : 1) - (b.topRating === '⚡' ? 0 : 1) ||
    b.paperCount90d - a.paperCount90d);

// ── Freshness ──────────────────────────────────────────────────────────────
const dataDate = Date.parse(stats.dataAsOf + 'T00:00:00Z');
const daysOld = Number.isNaN(dataDate)
  ? null
  : Math.max(0, Math.floor((Date.now() - dataDate) / 86_400_000));
const freshnessTone =
  daysOld === null ? 'muted' :
  daysOld <= 1     ? 'fresh' :
  daysOld <= 3     ? 'ok'    :
  'stale';

// ── Format helpers ─────────────────────────────────────────────────────────
function fmtAccel(a: number): string {
  // Cap displayed magnitude at 500% — anything beyond that is a small-
  // baseline artefact, not signal. Caller is responsible for excluding
  // insufficient_data rows before formatting.
  const pct = Math.round(a * 100);
  if (pct >= 500)  return '+500%↑';
  if (pct <= -500) return '−500%↓';
  return `${pct > 0 ? '+' : ''}${pct}%`;
}
---

<BaseLayout
  title="人才雷達 Talent Radar"
  description="Stage 4 — 信號優先的人才雷達：本週簡報 → HR 候選人 → 方法族速度 → 活躍實驗室 → 觀察名單。從不儲存或顯示電子郵件。"
>
  <main class="talent-v2">
    <!-- ══ Hero ════════════════════════════════════════════════════════════ -->
    <header class="tv2-hero">
      <div class="tv2-hero-meta">
        <span class="tv2-stage">
          <span class="tv2-stage-dot" aria-hidden="true"></span>
          STAGE 04 · TALENT RADAR
        </span>
        <span class={`tv2-fresh tv2-fresh--${freshnessTone}`} title={`Data snapshot ${stats.dataAsOf}`}>
          <span class="tv2-fresh-dot" aria-hidden="true"></span>
          <span data-tc>資料 {stats.dataAsOf}</span>
          <span data-sc>数据 {stats.dataAsOf}</span>
          {daysOld !== null && <span class="tv2-fresh-age">· {daysOld === 0 ? 'today' : `${daysOld}d ago`}</span>}
        </span>
      </div>

      <div class="tv2-title-row">
        <h1 class="tv2-title">
          <span data-tc>人才雷達</span>
          <span data-sc>人才雷达</span>
        </h1>
        <p class="tv2-title-en">Talent Radar</p>
      </div>

      <p class="tv2-lede">
        <span data-tc>從論文池反推 — <strong>誰該聘</strong> · <strong>哪些方向在加速</strong> · <strong>哪些組織在攻頂</strong>。</span>
        <span data-sc>从论文池反推 — <strong>谁该聘</strong> · <strong>哪些方向在加速</strong> · <strong>哪些组织在攻顶</strong>。</span>
      </p>

      <p class="tv2-promise">
        <span class="tv2-promise-icon" aria-hidden="true">⏚</span>
        <span data-tc>每項推薦皆附論文級佐證。系統 <strong>從不儲存或顯示電子郵件</strong>。</span>
        <span data-sc>每项推荐皆附论文级佐证。系统 <strong>从不存储或显示邮箱</strong>。</span>
      </p>
    </header>

    <!-- ══ Weekly Brief — 3 narrative cards ═══════════════════════════════ -->
    <section class="tv2-brief" aria-label="Weekly brief">
      <h2 class="tv2-brief-label">
        <span data-tc>本週簡報</span>
        <span data-sc>本周简报</span>
        <span class="tv2-brief-en">/ This Week</span>
      </h2>

      <div class="tv2-brief-grid">
        <!-- 1. Top accelerating method -->
        {topMover && (
          <a class="tv2-brief-card" href={`${base}/talent/subdirections/#fam-${topMover.family}`}>
            <span class="tv2-brief-kicker">
              <span data-tc>加速最快的方向</span>
              <span data-sc>加速最快的方向</span>
            </span>
            <div class="tv2-brief-main">
              <span class="tv2-brief-head">{topMover.displayName}</span>
              <span class="tv2-brief-delta" data-pos={topMover.acceleration >= 0}>
                {fmtAccel(topMover.acceleration)}
              </span>
            </div>
            <div class="tv2-brief-sub">
              <span class="tv2-brief-domain">
                {topMover.domain === 'vla' ? 'VLA' : 'AI App'}
              </span>
              <span class="tv2-brief-meta">7d {topMover.velocity7d} · prior {topMover.velocityPrior7d}</span>
            </div>
          </a>
        )}

        <!-- 2. Top active lab -->
        {topLab && (
          <a class="tv2-brief-card" href={`${base}/talent/labs/#lab-${slugifyName(topLab.name)}`}>
            <span class="tv2-brief-kicker">
              <span data-tc>產能最高的實驗室</span>
              <span data-sc>产能最高的实验室</span>
            </span>
            <div class="tv2-brief-main">
              <span class="tv2-brief-head">{topLab.name}</span>
              <RatingBadge rating={topLab.topRating} size="sm" />
            </div>
            <div class="tv2-brief-sub">
              <span class="tv2-brief-meta">
                <span data-tc>{topLab.signalCount90d} 篇 · 90d · {topLab.methodFocus.slice(0, 2).join(' · ')}</span>
                <span data-sc>{topLab.signalCount90d} 篇 · 90d · {topLab.methodFocus.slice(0, 2).join(' · ')}</span>
              </span>
            </div>
          </a>
        )}

        {/* 3. Emerging family, OR fall back to the top HR scout pick when
              no insufficient_data family is on the board this week. */}
        {topEmerge ? (
          <a class="tv2-brief-card tv2-brief-card--accent" href={`${base}/talent/subdirections/#fam-${topEmerge.family}`}>
            <span class="tv2-brief-kicker">
              <span data-tc>新冒頭的方向</span>
              <span data-sc>新冒头的方向</span>
            </span>
            <div class="tv2-brief-main">
              <span class="tv2-brief-head">{topEmerge.displayName}</span>
              <span class="tv2-brief-emerge-badge">NEW</span>
            </div>
            <div class="tv2-brief-sub">
              <span class="tv2-brief-domain">
                {topEmerge.domain === 'vla' ? 'VLA' : 'AI App'}
              </span>
              <span class="tv2-brief-meta">
                <span data-tc>本週首見 · {topEmerge.velocity7d} 篇</span>
                <span data-sc>本周首见 · {topEmerge.velocity7d} 篇</span>
              </span>
            </div>
          </a>
        ) : featuredHR && (
          <a class="tv2-brief-card tv2-brief-card--accent" href="#hr-shortlist">
            <span class="tv2-brief-kicker">
              <span data-tc>首推候選人</span>
              <span data-sc>首推候选人</span>
            </span>
            <div class="tv2-brief-main">
              <span class="tv2-brief-head">{featuredHR.name}</span>
              <RatingBadge rating={featuredHR.topRating} size="sm" />
            </div>
            <div class="tv2-brief-sub">
              {featuredHR.affiliation && (
                <span class="tv2-brief-meta tv2-brief-affil">{featuredHR.affiliation}</span>
              )}
              <span class="tv2-brief-meta">· {featuredHR.paperCount90d} 篇 · 90d</span>
            </div>
          </a>
        )}
      </div>
    </section>

    <!-- ══ Section 01 · HR SCOUT FUNNEL ═══════════════════════════════════
         A real shortlist is a funnel, not a one-tier gate. We expose:
           HOT   = gate passers (interview-ready)
           WARM  = close-to-gate (need follow-up or affiliation lookup)
           WATCH = ⚡ flashes (one-paper outliers, curiosity tier)
         Each entry carries top method tags so HR knows what to interview on.
    ══════════════════════════════════════════════════════════════════════ -->
    <section class="tv2-section" id="hr-shortlist">
      <header class="tv2-section-header">
        <div class="tv2-section-titlewrap">
          <span class="tv2-section-num">01</span>
          <h2 class="tv2-section-h2">
            <span data-tc>HR 候選人短名單</span>
            <span data-sc>HR 候选人短名单</span>
          </h2>
          <span class="tv2-section-en">/ HR Scout · {scout.totals.pool}</span>
        </div>
        <a class="tv2-more" href={`${base}/talent/hr-queue/`}>
          <span data-tc>完整隊列 →</span>
          <span data-sc>完整队列 →</span>
        </a>
      </header>

      <p class="tv2-section-lede">
        <span data-tc>從 {stats.peopleCount} 名研究員中漏出 <strong>{scout.totals.pool}</strong> 位進入候選池 ·
          <span class="tv2-tier-tag tv2-tier-tag--hot">HOT {scout.totals.hot}</span> 通過完整門檻 ·
          <span class="tv2-tier-tag tv2-tier-tag--warm">WARM {scout.totals.warm}</span> 缺一道門檻 ·
          <span class="tv2-tier-tag tv2-tier-tag--watch">WATCH {scout.totals.watch}</span> ⚡ 異常爆點</span>
        <span data-sc>从 {stats.peopleCount} 名研究员中漏出 <strong>{scout.totals.pool}</strong> 位进入候选池 ·
          <span class="tv2-tier-tag tv2-tier-tag--hot">HOT {scout.totals.hot}</span> 通过完整门槛 ·
          <span class="tv2-tier-tag tv2-tier-tag--warm">WARM {scout.totals.warm}</span> 缺一道门槛 ·
          <span class="tv2-tier-tag tv2-tier-tag--watch">WATCH {scout.totals.watch}</span> ⚡ 异常爆点</span>
      </p>

      {scout.totals.pool === 0 ? (
        <div class="tv2-empty">
          <p class="tv2-empty-title">
            <span data-tc>本週無候選人</span>
            <span data-sc>本周无候选人</span>
          </p>
          <p class="tv2-empty-sub">
            <span data-tc>掃描了 {stats.peopleCount} 位研究員，無人達到候選池閾值。等待下一輪 entity-tracker。</span>
            <span data-sc>扫描了 {stats.peopleCount} 位研究员，无人达到候选池阈值。等待下一轮 entity-tracker。</span>
          </p>
        </div>
      ) : (
        <div class="tv2-scout">
          {/* ── Featured top candidate ──────────────────────────────── */}
          {featuredHR && (
            <article class="tv2-hr-featured">
              <div class="tv2-hr-featured-stripe" aria-hidden="true"></div>
              <div class="tv2-hr-featured-body">
                <div class="tv2-hr-featured-head">
                  <span class="tv2-hr-featured-kicker">
                    <span data-tc>首推 · </span><span data-sc>首推 · </span>HOT #1
                  </span>
                  <div class="tv2-hr-featured-title">
                    <h3>{featuredHR.name}</h3>
                    <RatingBadge rating={featuredHR.topRating} size="sm" />
                  </div>
                  <div class="tv2-hr-featured-meta">
                    {featuredHR.affiliation && (
                      <a class="tv2-hr-featured-affil"
                         href={`${base}/talent/labs/#lab-${slugifyName(featuredHR.affiliation)}`}>
                        {featuredHR.affiliation}
                      </a>
                    )}
                    {featuredMethods.length > 0 && (
                      <span class="tv2-method-tags">
                        {featuredMethods.map(m => (
                          <span class="tv2-method-tag">{m}</span>
                        ))}
                      </span>
                    )}
                  </div>
                </div>

                <p class="tv2-hr-featured-why">
                  <span class="tv2-hr-why-tag">WHY NOW</span>
                  {featuredHR.whyNow}
                </p>

                <div class="tv2-hr-featured-stats">
                  <div class="tv2-hr-stat">
                    <span class="tv2-hr-stat-num">{featuredHR.paperCount90d}</span>
                    <span class="tv2-hr-stat-lbl">
                      <span data-tc>篇 · 90d</span><span data-sc>篇 · 90d</span>
                    </span>
                  </div>
                  <div class="tv2-hr-stat">
                    <span class="tv2-hr-stat-num">{featuredHR.gateHits.length}/4</span>
                    <span class="tv2-hr-stat-lbl">
                      <span data-tc>門檻命中</span><span data-sc>门槛命中</span>
                    </span>
                  </div>
                  <div class="tv2-hr-stat">
                    <span class="tv2-hr-stat-pill" data-status={featuredHR.contactStatus}>
                      {featuredHR.contactStatus === 'linked_via_lab' ? '機構已關聯' :
                       featuredHR.contactStatus === 'social_mention' ? '社交提及' : '僅署名'}
                    </span>
                    <span class="tv2-hr-stat-lbl">NO-EMAIL</span>
                  </div>
                </div>

                {featuredHR.evidence.length > 0 && (
                  <ul class="tv2-hr-featured-papers">
                    {featuredHR.evidence.slice(0, 3).map(ev => (
                      <li>
                        <a href={ev.url} target="_blank" rel="noopener noreferrer">
                          <RatingBadge rating={ev.rating} size="sm" />
                          <span class="tv2-paper-title">{ev.title}</span>
                          <span class="tv2-paper-date">{ev.date}</span>
                        </a>
                      </li>
                    ))}
                  </ul>
                )}
              </div>
            </article>
          )}

          {/* ── HOT table (remaining gate-passers, compact rows) ────── */}
          {restHot.length > 0 && (
            <div class="tv2-tier tv2-tier--hot">
              <div class="tv2-tier-head">
                <span class="tv2-tier-dot" data-tier="hot" aria-hidden="true"></span>
                <span class="tv2-tier-label">
                  <span data-tc>HOT · 通過完整門檻</span>
                  <span data-sc>HOT · 通过完整门槛</span>
                </span>
                <span class="tv2-tier-count">{scout.totals.hot}</span>
              </div>
              <table class="tv2-scout-table">
                <tbody>
                  {restHot.map((c, i) => (
                    <tr>
                      <td class="tv2-scout-rank">#{i + 2}</td>
                      <td class="tv2-scout-rating"><RatingBadge rating={c.topRating} size="sm" /></td>
                      <td class="tv2-scout-name">{c.name}</td>
                      <td class="tv2-scout-aff">
                        {c.affiliation && (
                          <a href={`${base}/talent/labs/#lab-${slugifyName(c.affiliation)}`}>
                            {c.affiliation}
                          </a>
                        )}
                      </td>
                      <td class="tv2-scout-methods">
                        {c.topMethods.map(m => <span class="tv2-method-tag">{m}</span>)}
                      </td>
                      <td class="tv2-scout-papers">{c.paperCount90d}<span class="tv2-scout-unit"> · 90d</span></td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}

          {/* ── WARM grid (close-to-gate, 8 cards with gate-missed line) ─ */}
          {warmShown.length > 0 && (
            <div class="tv2-tier tv2-tier--warm">
              <div class="tv2-tier-head">
                <span class="tv2-tier-dot" data-tier="warm" aria-hidden="true"></span>
                <span class="tv2-tier-label">
                  <span data-tc>WARM · 缺一道門檻</span>
                  <span data-sc>WARM · 缺一道门槛</span>
                </span>
                <span class="tv2-tier-count">{scout.totals.warm}</span>
                {warmRest > 0 && (
                  <a class="tv2-tier-more" href={`${base}/talent/hr-queue/`}>+{warmRest} →</a>
                )}
              </div>
              <p class="tv2-tier-lede">
                <span data-tc>補上隸屬機構或下一篇高評論文後即進入 HOT。</span>
                <span data-sc>补上隶属机构或下一篇高评论文后即进入 HOT。</span>
              </p>
              <div class="tv2-warm-grid">
                {warmShown.map(c => (
                  <article class="tv2-warm-card">
                    <div class="tv2-warm-head">
                      <RatingBadge rating={c.topRating} size="sm" />
                      <span class="tv2-warm-name">{c.name}</span>
                      <span class="tv2-warm-papers">{c.paperCount90d}<span class="tv2-warm-unit"> 篇</span></span>
                    </div>
                    <div class="tv2-warm-affil">
                      {c.affiliation ? (
                        <a href={`${base}/talent/labs/#lab-${slugifyName(c.affiliation)}`}>{c.affiliation}</a>
                      ) : (
                        <span class="tv2-warm-noaff">org: unknown</span>
                      )}
                    </div>
                    {c.topMethods.length > 0 && (
                      <div class="tv2-method-tags tv2-method-tags--warm">
                        {c.topMethods.map(m => <span class="tv2-method-tag">{m}</span>)}
                      </div>
                    )}
                    {c.gateMissed && (
                      <p class="tv2-warm-missed">
                        <span class="tv2-warm-missed-tag">MISSING</span>
                        {c.gateMissed}
                      </p>
                    )}
                  </article>
                ))}
              </div>
            </div>
          )}

          {/* ── WATCH list (⚡ flashes, collapsible) ─────────────────── */}
          {watchShown.length > 0 && (
            <details class="tv2-tier tv2-tier--watch">
              <summary class="tv2-tier-head tv2-tier-head--clickable">
                <span class="tv2-tier-dot" data-tier="watch" aria-hidden="true"></span>
                <span class="tv2-tier-label">
                  <span data-tc>WATCH · ⚡ 異常爆點 · 單篇高評</span>
                  <span data-sc>WATCH · ⚡ 异常爆点 · 单篇高评</span>
                </span>
                <span class="tv2-tier-count">{scout.totals.watch}</span>
                <span class="tv2-tier-cue">click to expand →</span>
              </summary>
              <p class="tv2-tier-lede">
                <span data-tc>單篇 ⚡ 評級的作者，無已知機構。可能是新生力量，也可能是匿名/化名。</span>
                <span data-sc>单篇 ⚡ 评级的作者，无已知机构。可能是新生力量，也可能是匿名/化名。</span>
              </p>
              <table class="tv2-scout-table">
                <tbody>
                  {watchShown.map((c, i) => (
                    <tr>
                      <td class="tv2-scout-rank">#{i + 1}</td>
                      <td class="tv2-scout-rating"><RatingBadge rating={c.topRating} size="sm" /></td>
                      <td class="tv2-scout-name">{c.name}</td>
                      <td class="tv2-scout-methods">
                        {c.topMethods.map(m => <span class="tv2-method-tag">{m}</span>)}
                      </td>
                      <td class="tv2-scout-papers">{c.paperCount90d}<span class="tv2-scout-unit"> · 90d</span></td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </details>
          )}
        </div>
      )}
    </section>

    <!-- ══ Section 02 · VELOCITY BOARD ═════════════════════════════════════ -->
    <section class="tv2-section">
      <header class="tv2-section-header">
        <div class="tv2-section-titlewrap">
          <span class="tv2-section-num">02</span>
          <h2 class="tv2-section-h2">
            <span data-tc>方法族速度榜</span>
            <span data-sc>方法族速度榜</span>
          </h2>
          <span class="tv2-section-en">/ Velocity Board</span>
        </div>
        <a class="tv2-more" href={`${base}/talent/subdirections/`}>
          <span data-tc>全部 {stats.subdirectionCount} →</span>
          <span data-sc>全部 {stats.subdirectionCount} →</span>
        </a>
      </header>

      <p class="tv2-section-lede">
        <span data-tc>每行為一個方法族。<em>長條長度</em> = |加速度| 相對最大值；<em>顏色</em> = 加速（琥珀）/ 衰退（紅）。資料來自 <code>field-state-*.json</code>（機械化，零 LLM）。</span>
        <span data-sc>每行为一个方法族。<em>条形长度</em> = |加速度| 相对最大值；<em>颜色</em> = 加速（琥珀）/ 衰退（红）。数据来自 <code>field-state-*.json</code>（机械化，零 LLM）。</span>
      </p>

      <ol class="tv2-velocity-board">
        {velocityBoard.map((s, i) => {
          const pct = Math.abs(s.acceleration) / velocityMaxAbs * 100;
          const isUp = s.acceleration >= 0;
          return (
            <li class="tv2-vel-row" style={`--vel-pct: ${pct.toFixed(1)}%`}>
              <a href={`${base}/talent/subdirections/#fam-${s.family}`} class="tv2-vel-link">
                <span class="tv2-vel-rank">{String(i + 1).padStart(2, '0')}</span>
                <span class={`tv2-vel-domain ${s.domain === 'vla' ? 'tag-vla' : 'tag-ai'}`}>
                  {s.domain === 'vla' ? 'VLA' : 'AI'}
                </span>
                <span class="tv2-vel-name">{s.displayName}</span>
                <span class="tv2-vel-track">
                  <span class={`tv2-vel-bar ${isUp ? 'tv2-vel-bar--up' : 'tv2-vel-bar--down'}`}></span>
                </span>
                <span class={`tv2-vel-pct ${isUp ? 'tv2-vel-pct--up' : 'tv2-vel-pct--down'}`}>
                  {fmtAccel(s.acceleration)}
                </span>
                <span class="tv2-vel-vol">{s.velocity7d}/{s.velocityPrior7d}</span>
              </a>
            </li>
          );
        })}
      </ol>

      {/* Emerging families (zero prior volume — surfaced separately so they
          don't inflate the main board with clamped 999% values) */}
      {emergingSubs.length > 0 && (
        <div class="tv2-emerging">
          <span class="tv2-emerging-label">
            <span data-tc>新冒頭</span><span data-sc>新冒头</span>
            <span class="tv2-emerging-en">· EMERGING · prior volume = 0</span>
          </span>
          <ul class="tv2-emerging-list">
            {emergingSubs.slice(0, 4).map(s => (
              <li>
                <a href={`${base}/talent/subdirections/#fam-${s.family}`}>
                  <span class={`tv2-vel-domain ${s.domain === 'vla' ? 'tag-vla' : 'tag-ai'}`}>
                    {s.domain === 'vla' ? 'VLA' : 'AI'}
                  </span>
                  <span class="tv2-emerging-name">{s.displayName}</span>
                  <span class="tv2-emerging-count">{s.velocity7d}<span class="tv2-emerging-unit"> 篇 · 7d</span></span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>

    <!-- ══ Section 03 · ACTIVE LABS ════════════════════════════════════════ -->
    <section class="tv2-section">
      <header class="tv2-section-header">
        <div class="tv2-section-titlewrap">
          <span class="tv2-section-num">03</span>
          <h2 class="tv2-section-h2">
            <span data-tc>產能最高的實驗室</span>
            <span data-sc>产能最高的实验室</span>
          </h2>
          <span class="tv2-section-en">/ Top Labs · 90d</span>
        </div>
        <a class="tv2-more" href={`${base}/talent/labs/`}>
          <span data-tc>全部 {stats.labCount} →</span>
          <span data-sc>全部 {stats.labCount} →</span>
        </a>
      </header>
      <div class="picks-grid">
        {labsShowcase.map(l => <LabCard record={l} />)}
      </div>
    </section>

    <!-- ══ Section 04 · WATCHLIST ══════════════════════════════════════════
         Four sub-blocks, ordered macro → micro:
           4a · Lab Cluster Network  — which labs share methods (compete)
           4b · Researcher × Method  — which methods crowd which talent
           4c · Polymath callout      — cross-method researchers (action list)
           4d · Full rated grid       — every ⚡/🔧 person we tracked
         Read top-down: from the field structure (A) down to specific names (D).
    ──────────────────────────────────────────────────────────────────────── -->
    <section class="tv2-section">
      <header class="tv2-section-header">
        <div class="tv2-section-titlewrap">
          <span class="tv2-section-num">04</span>
          <h2 class="tv2-section-h2">
            <span data-tc>研究員觀察名單</span>
            <span data-sc>研究员观察名单</span>
          </h2>
          <span class="tv2-section-en">/ Watchlist · {watchlist.length}</span>
        </div>
        <a class="tv2-more" href={`${base}/talent/people/`}>
          <span data-tc>全部 {stats.peopleCount} →</span>
          <span data-sc>全部 {stats.peopleCount} →</span>
        </a>
      </header>
      <p class="tv2-section-lede">
        <span data-tc>兩張圖揭示三層關係 — <strong>實驗室之間</strong>共享哪些方法（誰在搶同一批人）、<strong>研究員之間</strong>各自寫什麼方向、誰是<strong>橋樑型</strong>跨方向作者。</span>
        <span data-sc>两张图揭示三层关系 — <strong>实验室之间</strong>共享哪些方法（谁在抢同一批人）、<strong>研究员之间</strong>各自写什么方向、谁是<strong>桥梁型</strong>跨方向作者。</span>
      </p>

      {/* ── 4a · Lab Cluster Network — the LAB-level relational view ──── */}
      <figure class="tv2-labnet">
        <figcaption class="tv2-labnet-title">
          <span class="tv2-labnet-title-num">A</span>
          <span class="tv2-labnet-title-name">
            <span data-tc>實驗室聚類圖 · 共享方法的實驗室會被一條線連起來</span>
            <span data-sc>实验室聚类图 · 共享方法的实验室会被一条线连起来</span>
          </span>
          <span class="tv2-labnet-title-en">
            · Lab × Lab method-overlap network
          </span>
        </figcaption>
        <svg
          class="tv2-labnet-svg"
          viewBox={`0 0 ${labNet.width} ${labNet.height}`}
          role="img"
          aria-label="Lab cluster network — method-overlap edges between labs"
        >
          {/* Outer faint ring as visual anchor */}
          <circle
            cx={labNet.centerX} cy={labNet.centerY}
            r={labNet.ringRadius}
            fill="none"
            stroke="var(--border)"
            stroke-dasharray="2 5"
            stroke-width="1"
            opacity="0.45"
          />

          {/* Edges drawn first so node bubbles sit on top */}
          {labNet.edges.map(e => {
            const a = labNet.nodes[e.fromIdx];
            const b = labNet.nodes[e.toIdx];
            // weight 1 = thin / weight 3 = thick
            const sw = 0.9 + e.weight * 1.1;
            const op = 0.18 + e.weight * 0.14;
            const tip = `${a.name} ↔ ${b.name}: ${e.sharedMethods.join(' · ')}`;
            return (
              <g>
                <title>{tip}</title>
                <path
                  d={`M ${a.cx} ${a.cy} Q ${e.ctrlX} ${e.ctrlY} ${b.cx} ${b.cy}`}
                  fill="none"
                  stroke="var(--accent-cyan)"
                  stroke-width={sw}
                  opacity={op}
                  stroke-linecap="round"
                />
              </g>
            );
          })}

          {/* Lab bubbles */}
          {labNet.nodes.map(n => {
            const stroke = n.domain === 'ai' ? 'var(--accent-cyan)'
                         : n.domain === 'mixed' ? 'var(--accent-amber)'
                         : 'var(--accent-amber)';
            const fill = n.domain === 'ai' ? 'rgba(15,143,160,0.10)'
                       : 'rgba(212,145,10,0.10)';
            const tip = `${n.name} · ${n.signalCount90d} signals · ${n.methodFocus.join(', ') || 'no methods'}`;
            return (
              <g class="tv2-labnet-node">
                <title>{tip}</title>
                <a href={`${base}/talent/labs/#lab-${n.slug}`}>
                  <circle
                    cx={n.cx} cy={n.cy} r={n.radius}
                    fill={fill}
                    stroke={stroke}
                    stroke-width="2"
                    class="tv2-labnet-bubble"
                  />
                  <text
                    x={n.cx} y={n.cy - 3}
                    text-anchor="middle"
                    class="tv2-labnet-bubble-name"
                  >{n.name}</text>
                  <text
                    x={n.cx} y={n.cy + 13}
                    text-anchor="middle"
                    class="tv2-labnet-bubble-count"
                  >{n.signalCount90d} · 90d</text>
                </a>
                {/* method chips outside the bubble, on the outward radial */}
                <text
                  x={n.labelX} y={n.labelY}
                  text-anchor={n.labelAnchor}
                  class="tv2-labnet-bubble-method"
                >{n.methodFocus.slice(0, 2).join(' · ') || '—'}</text>
              </g>
            );
          })}
        </svg>
        <div class="tv2-labnet-foot">
          <div class="tv2-labnet-stats">
            <span><strong>{labNet.totals.labs}</strong> <span data-tc>實驗室</span><span data-sc>实验室</span></span>
            <span class="tv2-labnet-stats-sep">·</span>
            <span><strong>{labNet.totals.edges}</strong> <span data-tc>連線</span><span data-sc>连线</span></span>
            <span class="tv2-labnet-stats-sep">·</span>
            <span><strong>{labNet.totals.connectedLabs}</strong> <span data-tc>有連線</span><span data-sc>有连线</span></span>
            <span class="tv2-labnet-stats-sep">·</span>
            <span><strong class="tv2-labnet-isolated">{labNet.totals.isolatedLabs}</strong> <span data-tc>孤立（獨佔方向）</span><span data-sc>孤立（独占方向）</span></span>
          </div>
          {labNet.methodHubs.length > 0 && (
            <div class="tv2-labnet-hubs">
              <span class="tv2-labnet-hubs-label">
                <span data-tc>連接最多實驗室的方法（人才戰場）</span>
                <span data-sc>连接最多实验室的方法（人才战场）</span>
                <span class="tv2-labnet-hubs-en">· hub methods</span>
              </span>
              <ul class="tv2-labnet-hubs-list">
                {labNet.methodHubs.slice(0, 4).map(h => (
                  <li>
                    <span class="tv2-labnet-hub-name">{h.method}</span>
                    <span class="tv2-labnet-hub-meta">
                      <strong>{h.labCount}</strong> labs
                      <span class="tv2-labnet-hub-sep">·</span>
                      <strong>{h.spans}</strong> edges
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </figure>

      <figcaption class="tv2-const-title">
        <span class="tv2-const-title-num">B</span>
        <span class="tv2-const-title-name">
          <span data-tc>研究員 × 方法族 圖譜</span>
          <span data-sc>研究员 × 方法族 图谱</span>
        </span>
        <span class="tv2-const-title-en">
          · {constellation.totals.researchers} researchers anchored to method families
          · {constellation.totals.bridges} polymath{constellation.totals.bridges === 1 ? '' : 's'}
        </span>
      </figcaption>

      {/* ── 4b · Researcher × Method Constellation SVG ─────────────────── */}
      <figure class="tv2-const">
        <svg
          class="tv2-const-svg"
          viewBox={`0 0 ${constellation.width} ${constellation.height}`}
          role="img"
          aria-label="Researcher × method-family constellation"
        >
          {/* faint anchor ring */}
          <circle
            cx={constellation.centerX} cy={constellation.centerY}
            r={constellation.methodRadius}
            fill="none"
            stroke="var(--border)"
            stroke-dasharray="2 4"
            stroke-width="1"
            opacity="0.55"
          />
          {/* center bullseye reminding readers the middle = polymath zone */}
          <circle
            cx={constellation.centerX} cy={constellation.centerY}
            r="58"
            fill="none"
            stroke="var(--accent-cyan)"
            stroke-dasharray="3 5"
            stroke-width="1"
            opacity="0.35"
          />
          <text
            x={constellation.centerX}
            y={constellation.centerY - 64}
            class="tv2-const-bridgehint"
            text-anchor="middle"
          >POLYMATH ZONE</text>

          {/* radial spokes from center to each method anchor */}
          {constellation.methods.map(m => (
            <line
              x1={constellation.centerX} y1={constellation.centerY}
              x2={m.cx} y2={m.cy}
              stroke="var(--border)" stroke-width="1" opacity="0.4"
            />
          ))}

          {/* method anchor nodes */}
          {constellation.methods.map(m => (
            <g class="tv2-const-method">
              <circle
                cx={m.cx} cy={m.cy}
                r={Math.min(28, 12 + m.count * 1.8)}
                fill={m.domain === 'vla' ? 'var(--accent-amber-bg, rgba(212,145,10,0.18))' : 'rgba(15,143,160,0.18)'}
                stroke={m.domain === 'vla' ? 'var(--accent-amber)' : 'var(--accent-cyan)'}
                stroke-width="1.5"
              />
              <text
                x={m.cx} y={m.cy + 4}
                text-anchor="middle"
                class="tv2-const-method-count"
              >{m.count}</text>
              <text
                x={m.labelX} y={m.labelY}
                text-anchor="middle"
                class="tv2-const-method-label"
              >{m.displayName}</text>
            </g>
          ))}

          {/* researcher dots */}
          {constellation.people.map(pp => {
            const method = methodIndex.get(pp.primaryFamily);
            const isFlash = pp.topRating === '⚡';
            const isBridge = pp.secondaryFamily !== null;
            const fill = isFlash
              ? 'var(--accent-amber, #d4910a)'
              : 'var(--accent-cyan, #0f8fa0)';
            const aff = pp.affiliation ?? 'unaffiliated';
            const second = pp.secondaryFamily
              ? ` · bridges ${methodIndex.get(pp.secondaryFamily)?.displayName ?? pp.secondaryFamily}`
              : '';
            return (
              <a href={`${base}/talent/people/#person-${pp.slug}`} class="tv2-const-dot-link">
                {/* thin line from researcher to its primary method */}
                {method && (
                  <line
                    x1={pp.x} y1={pp.y}
                    x2={method.cx} y2={method.cy}
                    stroke={fill}
                    stroke-width="0.5"
                    opacity={isBridge ? 0.5 : 0.22}
                    stroke-dasharray={isBridge ? '3 3' : ''}
                  />
                )}
                <circle
                  cx={pp.x} cy={pp.y}
                  r={isFlash ? 5 : 4}
                  fill={fill}
                  stroke="var(--surface)"
                  stroke-width={isBridge ? 1.5 : 1}
                  class={`tv2-const-dot ${isBridge ? 'tv2-const-dot--bridge' : ''}`}
                />
                <title>{pp.topRating} {pp.name} · {aff}{second}</title>
              </a>
            );
          })}
        </svg>

        <figcaption class="tv2-const-caption">
          <span class="tv2-const-legend">
            <span class="tv2-const-leg-dot" style="background:var(--accent-amber)"></span>
            <span data-tc>⚡ 評級</span><span data-sc>⚡ 评级</span>
            <span class="tv2-const-leg-dot" style="background:var(--accent-cyan); margin-left:1.2rem"></span>
            <span data-tc>🔧 評級</span><span data-sc>🔧 评级</span>
            <span class="tv2-const-leg-dot tv2-const-leg-bridge" style="margin-left:1.2rem"></span>
            <span data-tc>橋樑（雙方法）</span><span data-sc>桥梁（双方法）</span>
          </span>
          <span class="tv2-const-coverage">
            {constellation.totals.familiesShown} <span data-tc>方法族</span><span data-sc>方法族</span>
            · {constellation.totals.researchers} <span data-tc>已上圖</span><span data-sc>已上图</span>
            · {constellation.totals.unmatched} <span data-tc>無法歸類</span><span data-sc>无法归类</span>
          </span>
        </figcaption>
      </figure>

      {/* ── Method legend cards — clickable to filter the grid below ─── */}
      <div class="tv2-const-methodbar">
        {methodLegend.map(m => (
          <a
            href={`#watchlist-grid`}
            class={`tv2-const-methodchip tv2-const-methodchip--${m.domain}`}
            data-family={m.family}
          >
            <span class="tv2-const-methodchip-name">{m.displayName}</span>
            <span class="tv2-const-methodchip-stats">
              <span class="tv2-const-methodchip-count">{m.rated}</span>
              {m.flashes > 0 && <span class="tv2-const-methodchip-flash">⚡{m.flashes}</span>}
              {m.polish  > 0 && <span class="tv2-const-methodchip-polish">🔧{m.polish}</span>}
            </span>
          </a>
        ))}
      </div>

      {/* ── 4c · Bridge researchers callout (the actionable polymath list) */}
      {bridgePeople.length > 0 && (
        <div class="tv2-bridges">
          <div class="tv2-bridges-header">
            <span class="tv2-bridges-label">
              <span data-tc>橋樑型研究員</span>
              <span data-sc>桥梁型研究员</span>
              <span class="tv2-bridges-en">· POLYMATHS · cross-method authors</span>
            </span>
            <span class="tv2-bridges-hint">
              <span data-tc>同時在兩個方法族上發過論文 — 通常最值得首先約訪</span>
              <span data-sc>同时在两个方法族上发过论文 — 通常最值得首先约访</span>
            </span>
          </div>
          <ul class="tv2-bridges-list">
            {bridgePeople.slice(0, 12).map(pp => {
              const primary = methodIndex.get(pp.primaryFamily)?.displayName ?? pp.primaryFamily;
              const second  = pp.secondaryFamily ? (methodIndex.get(pp.secondaryFamily)?.displayName ?? pp.secondaryFamily) : '';
              return (
                <li>
                  <a href={`${base}/talent/people/#person-${pp.slug}`}>
                    <span class={`tv2-bridges-rating tv2-bridges-rating--${pp.topRating === '⚡' ? 'flash' : 'polish'}`}>{pp.topRating}</span>
                    <span class="tv2-bridges-name">{pp.name}</span>
                    <span class="tv2-bridges-aff">{pp.affiliation ?? '—'}</span>
                    <span class="tv2-bridges-arc">
                      <span class="tv2-bridges-arc-a">{primary}</span>
                      <span class="tv2-bridges-arc-link">↔</span>
                      <span class="tv2-bridges-arc-b">{second}</span>
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      )}

      {/* ── 4d · Full rated grid ──────────────────────────────────────── */}
      <h3 id="watchlist-grid" class="tv2-const-gridtitle">
        <span data-tc>全部已評級研究員</span>
        <span data-sc>全部已评级研究员</span>
        <span class="tv2-const-gridtitle-en">· {watchlist.length} researchers · ⚡ {watchlist.filter(p => p.topRating === '⚡').length} · 🔧 {watchlist.filter(p => p.topRating === '🔧').length}</span>
      </h3>
      <div class="picks-grid">
        {watchlist.map(p => <PersonCard record={p} />)}
      </div>
    </section>

    <!-- ══ Methodology — collapsed by default ══════════════════════════════
         Kept current with the page. When you change a loader or chart in
         Section 01-04, update the matching bullet here too.
    ──────────────────────────────────────────────────────────────────────── -->
    <details class="tv2-method">
      <summary>
        <span class="tv2-method-summary-label">
          <span data-tc>方法論 · How this works</span>
          <span data-sc>方法论 · How this works</span>
        </span>
        <span class="tv2-method-summary-cue" aria-hidden="true">+</span>
      </summary>
      <ol class="tv2-method-list">
        <li><strong>Section 01 · HR 候選人 (Scout)</strong> — 三層漏斗：<em>HOT</em> 通過完整門檻（頂評 ≥ 🔧、90 日 ≥ 2 篇、機構可解析、聯繫狀態非 <em>not_linked</em>）；<em>WARM</em> 缺一道門檻（新星型、產量未達、機構未確認）；<em>WATCH</em> 為單篇 ⚡ 異常爆點。每位候選人附 <em>方法標籤</em>（同 §4b 詞表）。</li>
        <li><strong>Section 02 · 速度榜 (Subdirections)</strong> — 方法族趨勢來自 <code>field-state-*.json</code> + <code>ai-field-state-*.json</code>（機械化，零 LLM）。加速度 = (近 7d − 前 7d) / max(前值, 1)；顯示時 ±500% 為上限以避開小樣本噪音。<em>新冒頭</em>欄目單獨展示 <em>insufficient_data</em>（前期樣本 = 0）的方向。</li>
        <li><strong>Section 03 · 實驗室</strong> — 來自 <code>entity-index.json</code> 的 <code>type=lab</code> 實體，90 日滾動窗口；卡片含 14 日活躍走勢條。</li>
        <li><strong>§4a · 實驗室聚類圖 (Lab Network)</strong> — 取信號數前 14 名實驗室，按主要方法錨向排列；兩個實驗室共享 ≥1 方法族 → 一條弧線，線寬隨共享數加粗。<em>連接最多實驗室的方法</em>（hub methods）= 當前人才戰場。</li>
        <li><strong>§4b · 研究員 × 方法族圖譜 (Constellation)</strong> — <em>關鍵字詞表</em>比對：每個方法族維護一個短語清單（如 <em>flow_matching</em> 涵蓋「rectified flow」「flow policy」「mean flow」等同義詞）；任一短語出現於論文標題即計分；特定型方法族（Diffusion Policy 等）排序時優先於 catch-all 族（VLA Core / Manipulation）。<em>橋樑型</em>研究員（同時匹配兩個方法族）置於圓心方向。</li>
        <li><strong>§4d · 全部已評級研究員</strong> — <code>vla-daily-rating-out-*.json</code> 第一作者抽取 + <code>entity-index.json</code> <code>type=researcher</code> 合併（機構經 <code>institution-registry.json</code> 解析）；保留 ⚡ 與 🔧 評級全集，按評級 → 篇數 → 姓名排序。<em>arXiv 僅曝光首位作者</em>，故無法重建合作者網絡 — §4a/§4b 已是現有資料下最強的關係視角。</li>
        <li><strong>Email 永不儲存或顯示</strong> — 僅 <code>contact_status</code> 枚舉：<em>linked_via_lab</em> / <em>social_mention</em> / <em>not_linked</em>。型別層以 <code>email?: never</code> 強制；觸達前請自行核實。</li>
      </ol>
    </details>

