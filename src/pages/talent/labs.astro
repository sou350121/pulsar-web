---
import BaseLayout     from '../../layouts/BaseLayout.astro';
import TalentPageHero from '../../components/TalentPageHero.astro';
import LabCard        from '../../components/LabCard.astro';
import { loadLabs }   from '../../utils/talent';

const labs    = loadLabs({ minSignals: 2 });
const vlaLabs = labs.filter(l => l.domains.includes('vla'));
const aiLabs  = labs.filter(l => l.domains.includes('ai_app'));
---

<BaseLayout
  title="實驗室 Labs · Talent Radar"
  description="实验室活动 — 90 天滚动信号 + 方法聚焦 + 近期论文"
>
  <main class="container talent-v2-page">
    <TalentPageHero
      sectionNum="03"
      titleTC="實驗室"
      titleSC="实验室"
      titleEN="Labs"
      ledeTC={`<strong>${labs.length} 個實驗室</strong> 在 90 天滾動窗口中有 ≥2 條信號，按信號數排序；<em>14 日走勢圖</em>顯示每日活躍度。`}
      ledeSC={`<strong>${labs.length} 个实验室</strong> 在 90 天滚动窗口中有 ≥2 条信号，按信号数排序；<em>14 日走势图</em>显示每日活跃度。`}
    />

    {labs.length === 0 ? (
      <p class="tv2-empty">
        No labs surfaced yet. Wait for entity-tracker to populate (runs daily at 09:55).
      </p>
    ) : (
      <>
        <div class="tv2-toolbar">
          <input
            id="lab-search"
            type="search"
            placeholder="Search labs, methods, recent papers…"
            class="tv2-search"
            aria-label="Search labs"
          />
          <p class="tv2-search-count" id="lab-search-count" aria-live="polite"></p>
        </div>

        <section class="tv2-section">
          <h2 class="tv2-section-h2">
            <span class="tv2-domain-pill tag-vla">VLA</span>
            · {vlaLabs.length}
          </h2>
          {vlaLabs.length === 0 ? (
            <p class="tv2-empty">No VLA labs in the 90-day window.</p>
          ) : (
            <div class="picks-grid">
              {vlaLabs.map(l => <LabCard record={l} />)}
            </div>
          )}
        </section>

        <section class="tv2-section">
          <h2 class="tv2-section-h2">
            <span class="tv2-domain-pill tag-ai">AI App</span>
            · {aiLabs.length}
          </h2>
          {aiLabs.length === 0 ? (
            <p class="tv2-empty">No AI App labs in the 90-day window.</p>
          ) : (
            <div class="picks-grid">
              {aiLabs.map(l => <LabCard record={l} />)}
            </div>
          )}
        </section>
      </>
    )}
  </main>

  <script is:inline>
    (() => {
      const input = document.getElementById('lab-search');
      const counter = document.getElementById('lab-search-count');
      if (!input) return;
      input.addEventListener('input', () => {
        const q = input.value.toLowerCase().trim();
        let shown = 0;
        document.querySelectorAll('article.card').forEach((card) => {
          const text = (card.textContent || '').toLowerCase();
          const hit = q === '' || text.includes(q);
          card.style.display = hit ? '' : 'none';
          if (hit) shown++;
        });
        document.querySelectorAll('.tv2-section').forEach((sec) => {
          const visible = sec.querySelectorAll('article.card:not([style*="display: none"])');
          sec.style.display = visible.length === 0 && q !== '' ? 'none' : '';
        });
        if (counter) counter.textContent = q === '' ? '' : `${shown} match${shown === 1 ? '' : 'es'}`;
      });
    })();
  </script>

  <style>
    .talent-v2-page { max-width: 1200px; margin: 0 auto; padding: 2rem 1rem 4rem; }
    .tv2-section { margin: 2.25rem 0; }
    .tv2-section-h2 {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 1.25rem; font-weight: 600;
      margin: 0 0 1rem; padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
      color: var(--text-primary);
      display: flex; align-items: baseline; gap: 0.65rem;
    }
    .tv2-domain-pill {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.62rem; font-weight: 700;
      letter-spacing: 0.14em;
      padding: 0.22rem 0.5rem;
      border-radius: 4px;
    }
    .tv2-empty {
      text-align: center; color: var(--text-tertiary); font-style: italic;
      padding: 2.5rem; background: var(--surface);
      border: 1px dashed var(--border); border-radius: 8px;
    }
    .tv2-toolbar { margin: 0 0 1.5rem; }
    .tv2-search {
      width: 100%; max-width: 480px;
      padding: 0.65rem 0.95rem;
      font-family: 'IBM Plex Mono', monospace; font-size: 0.9rem;
      background: var(--surface); color: var(--text-primary);
      border: 1px solid var(--border); border-radius: 8px;
    }
    .tv2-search:focus {
      outline: none; border-color: var(--accent-cyan);
      box-shadow: 0 0 0 3px var(--accent-cyan-bg);
    }
    .tv2-search-count {
      font-family: 'IBM Plex Mono', monospace; font-size: 0.72rem;
      color: var(--text-tertiary); margin: 0.3rem 0 0;
      min-height: 1em;
    }
  </style>
</BaseLayout>
