              { name: '<span data-tc>語義索引重建</span><span data-sc>语义索引重建</span>',    time: '11:15', ok: true  },
              { name: '<span data-tc>跨域規則引擎</span><span data-sc>跨域规则引擎</span>',    time: '10:20', ok: true  },
              { name: '<span data-tc>上游 arxiv 監測</span><span data-sc>上游 arxiv 监测</span>', time: '00:50', ok: true  },
            ].map(item => (
              <div class="health-item">
                <span class:list={['health-icon', item.ok ? 'health-ok' : 'health-warn']}>
                  {item.ok ? '✓' : '⚠'}
                </span>
                <span class="health-name" style={!item.ok ? 'color:var(--accent-amber);' : ''} set:html={item.name}></span>
                <span class="health-time">{item.time}</span>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <hr class="grid-rule" />

