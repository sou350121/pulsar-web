---
/**
 * /talent/match/ — HR demand zone.
 *
 * HR types/clicks a requirement → see ranked candidate list.
 *
 * Matching strategy (designed for GitHub Pages static deploy):
 *   1. Canonical query chips — DashScope-embedded at BUILD time. Each chip
 *      resolves to a pre-baked top-30 list. Click → instant ranked candidates.
 *   2. Facet filters — pure client-side filter over the full population:
 *      rating tier · method family · region · paperCount minimum · contact
 *      status. Works in tandem with the chip selection.
 *   3. Free-text — substring match across name + affiliation + paper titles.
 *      Falls back to keyword-OR over method-family vocabulary so common HR
 *      phrasing ("diffusion policy expert") routes to the right family.
 *   4. Find similar to X — pre-baked person×person top-10 cosine neighbours.
 *
 * The whole page never calls an LLM/embedding API at runtime. The browser
 * just reads pre-baked JSON and filters in memory.
 *
 * If src/data/talent-embeddings.json is absent (script not run yet), the
 * page degrades to facet-only mode and shows a small notice.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import RatingBadge from '../../components/RatingBadge.astro';
import {
  loadPeople,
  loadMatchData,
  loadPoolViz,
  loadStructuralChips,
  loadPoolSanity,
  topMethodsForEvidence,
  chipLabelV2,
  inferRegion,
} from '../../utils/talent';

const base       = import.meta.env.BASE_URL;
const matchData  = loadMatchData();
const poolViz    = loadPoolViz();

// Build the canonical person table even without embeddings — facet-only mode.
const pool = loadPeople({ minPaperCount90d: 1 })
  .filter(p => p.topRating === '⚡' || p.topRating === '🔧' || p.topRating === '📖');

// Pool sanity — pre-render the ceiling so HR sees it before fiddling.
const sanity = loadPoolSanity(pool);

// Structural chips — polymath / production / safety computed by rule, not
// embedding. The audit showed embedding chips at these concepts returned
// 0/30 to noise. Structural rules over the same pool are honest and instant.
const structuralChips = loadStructuralChips(pool);

// inferRegion lives in utils/talent.ts now — single source of truth that
// consults the institution_region map (post-enrichment) before its legacy
// substring fallbacks. Imported above.

// Materialise the people array we expose to client JS. Mirrors MatchPerson
// shape so the client filter code is identical whether or not embeddings
// JSON exists.
// `evidenceTeaser` carries top 2 paper titles + ratings for the card body —
// this delivers on the lede's promise of "完整論文佐證" without bloating
// the payload (~80 bytes/title × 2 × 751 ≈ 120 KB).
const peopleClient = pool.map((p, idx) => ({
  idx,
  slug:          p.slug,
  name:          p.name,
  affiliation:   p.affiliation,
  topRating:     p.topRating,
  paperCount90d: p.paperCount90d,
  contactStatus: p.contactStatus,
  region:        inferRegion(p.affiliation),
  topMethods:    topMethodsForEvidence(p.evidence, 3),
  evidenceTeaser: p.evidence.slice(0, 2).map(e => ({
    title:  e.title,
    rating: e.rating,
    url:    e.url,
  })),
  // Lower-case haystack for free-text substring match (name + affiliation + titles)
  haystack: [
    p.name,
    p.affiliation ?? '',
    ...p.evidence.map(e => e.title),
  ].join(' ').toLowerCase(),
}));

// When embeddings exist, use the embedding-side person list (it has neighbor
// data + primaryFamily). When they don't, fall back to client-side person list.
const useEmbeddings = matchData !== null && matchData.people.length > 0;

// Page state — facet options derived from data
const ratingOpts = [
  { key: '⚡', label: '⚡ Flash', labelSC: '⚡ 突破' },
  { key: '🔧', label: '🔧 Polish', labelSC: '🔧 精修' },
  { key: '📖', label: '📖 Read', labelSC: '📖 已讀' },
];
const regionOpts = [
  { key: 'cn',    label: '中國機構', labelSC: '中国机构' },
  { key: 'us',    label: '北美機構', labelSC: '北美机构' },
  { key: 'eu',    label: '歐洲機構', labelSC: '欧洲机构' },
  { key: 'other', label: '其他 / 無', labelSC: '其他 / 无' },
];
// Method family options — top 15 by population
const familyOpts = poolViz.heatmapFamilies.slice(0, 15);

// Chip lineup:
//   * Semantic chips (one per top method family) — from embedding JSON.
//     These survive the audit because the queries are vocabulary-anchored.
//   * Structural chips (polymath / production / safety) — computed by rule,
//     not embedding. They replaced the verbose semantic chips that failed
//     the audit. Marked with `kind: 'structural'` for visual distinction.
type ChipForRender = {
  id:       string;
  label:    string;
  labelSC:  string;
  text:     string;
  results:  Array<{ pi: number; score: number }>;
  kind:     'semantic' | 'structural';
};
// PR 3: chip labels are baked into talent-embeddings.json keyed by V1 slug.
// When V2 is active, alias-resolve so chip text reflects the new taxonomy
// (e.g. `family:vla_core` → "Vla Generalist"). The embedding vectors and
// `results` arrays stay V1-keyed — that's PR 4/5's re-bake.
const semanticChips: ChipForRender[] = (matchData?.queries ?? []).map(q => ({
  id:      q.id,
  label:   chipLabelV2(q.id, q.label),
  labelSC: chipLabelV2(q.id, q.labelSC),
  text:    q.text,
  results: q.results,
  kind:    'semantic',
}));
const ruleChips: ChipForRender[] = structuralChips.map(q => ({
  id: q.id, label: q.label, labelSC: q.labelSC, text: q.text, results: q.results, kind: 'structural',
}));
const chips: ChipForRender[] = [...semanticChips, ...ruleChips];

// Stat summary
const totalPool = peopleClient.length;
const lastUpdated = matchData?.generated_at?.slice(0, 10) ?? '—';
---
<BaseLayout title="HR · Talent Match" lang="en">
  <main class="match-main">
    <!-- ── Header / page intro ─────────────────────────────────────────── -->
    <header class="match-header">
      <div class="match-header-text">
        <div class="match-backlinks">
          <a href={`${base}/talent/`} class="match-back">
            <span data-tc>← 返回人才雷達</span>
            <span data-sc>← 返回人才雷达</span>
          </a>
          <a href={`${base}/talent/hr-queue/`} class="match-back match-back--alt">
            <span data-tc>完整 HR 隊列 →</span>
            <span data-sc>完整 HR 队列 →</span>
          </a>
        </div>
        <h1 class="match-h1">
          <span data-tc>HR 需求台</span>
          <span data-sc>HR 需求台</span>
          <span class="match-h1-en">/ Talent Match</span>
        </h1>
        <p class="match-lede">
          <span data-tc>輸入需求或點擊預設標籤 — 從 <strong>{totalPool}</strong> 位已評研究員中過濾出對應人選。每位候選人都帶完整論文佐證。</span>
          <span data-sc>输入需求或点击预设标签 — 从 <strong>{totalPool}</strong> 位已评研究员中过滤出对应人选。每位候选人都带完整论文佐证。</span>
        </p>
        <p class="match-meta">
          <span class="match-meta-pill">
            <span data-tc>無郵箱 · 純論文署名匹配</span>
            <span data-sc>无邮箱 · 纯论文署名匹配</span>
          </span>
          {useEmbeddings ? (
            <span class="match-meta-pill match-meta-pill--on">
              <span data-tc>{semanticChips.length} 語意 + {ruleChips.length} 結構標籤 · {lastUpdated}</span>
              <span data-sc>{semanticChips.length} 语意 + {ruleChips.length} 结构标签 · {lastUpdated}</span>
            </span>
          ) : (
            <span class="match-meta-pill match-meta-pill--off">
              <span data-tc>{ruleChips.length} 結構標籤 · 未生成 embedding</span>
              <span data-sc>{ruleChips.length} 结构标签 · 未生成 embedding</span>
            </span>
          )}
        </p>
      </div>
    </header>

    {/* ── Pool sanity banner — surface the ceiling BEFORE the HR clicks ─ */}
    <aside class="match-sanity" role="note" aria-label="Pool reality check">
      <span class="match-sanity-kicker">
        <span data-tc>池子體質</span><span data-sc>池子体质</span>
        <span class="match-sanity-kicker-en">· pool ceiling</span>
      </span>
      <ul class="match-sanity-stats">
        <li>
          <strong>{sanity.withAffiliation}/{sanity.total}</strong>
          <span class="match-sanity-stats-label">
            <span data-tc>有機構標記 ({sanity.withAffiliationPct}%)</span>
            <span data-sc>有机构标记 ({sanity.withAffiliationPct}%)</span>
          </span>
        </li>
        <li>
          <strong>{sanity.maxPapers90d}</strong>
          <span class="match-sanity-stats-label">
            <span data-tc>單人 90 日最高篇數</span>
            <span data-sc>单人 90 日最高篇数</span>
          </span>
        </li>
        <li>
          <strong>{sanity.countWith3Plus}</strong>
          <span class="match-sanity-stats-label">
            <span data-tc>≥ 3 篇研究員</span>
            <span data-sc>≥ 3 篇研究员</span>
          </span>
        </li>
        <li>
          <strong>{sanity.countFlash}⚡</strong>
          <span class="match-sanity-stats-label">
            +{sanity.countPolish}🔧 +{sanity.countRead}📖
          </span>
        </li>
      </ul>
      <p class="match-sanity-note">
        <span data-tc>※ arXiv 第一作者署名 90 日窗口；多數研究員只見過一篇，故「地區」/「跨方法族」匹配仰賴 affiliation 解析。在 affiliation 覆蓋拉到 50%+ 之前，請優先用「方法族」chip + 自由文字。</span>
        <span data-sc>※ arXiv 第一作者署名 90 日窗口；多数研究员只见过一篇，故「地区」/「跨方法族」匹配仰赖 affiliation 解析。在 affiliation 覆盖拉到 50%+ 之前，请优先用「方法族」chip + 自由文字。</span>
      </p>
    </aside>

    <!-- ── Canonical query chips ──────────────────────────────────────── -->
    {chips.length > 0 && (
      <section class="match-chips-section">
        <h2 class="match-section-h2">
          <span data-tc>① 預設標籤</span>
          <span data-sc>① 预设标签</span>
          <span class="match-section-h2-en">· semantic family chips + structural rule chips · click for top 30</span>
        </h2>
        <div class="match-chips">
          {semanticChips.length > 0 && (
            <span class="match-chips-divider">
              <span data-tc>方法族 ·</span>
              <span data-sc>方法族 ·</span>
              <span class="match-chips-divider-en">embedding</span>
            </span>
          )}
          {semanticChips.map(q => (
            <button
              type="button"
              class="match-chip match-chip--semantic"
              data-chip-id={q.id}
              title={q.text}
            >
              <span data-tc>{q.label}</span>
              <span data-sc>{q.labelSC}</span>
            </button>
          ))}
          {ruleChips.length > 0 && (
            <span class="match-chips-divider">
              <span data-tc>結構規則 ·</span>
              <span data-sc>结构规则 ·</span>
              <span class="match-chips-divider-en">rules</span>
            </span>
          )}
          {ruleChips.map(q => (
            <button
              type="button"
              class="match-chip match-chip--structural"
              data-chip-id={q.id}
              title={q.text}
            >
              <span data-tc>{q.label}</span>
              <span data-sc>{q.labelSC}</span>
            </button>
          ))}
          <button
            type="button"
            class="match-chip match-chip--clear"
            data-chip-id="__clear__"
          >
            <span data-tc>✕ 清除標籤</span>
            <span data-sc>✕ 清除标签</span>
          </button>
        </div>
      </section>
    )}

    <!-- ── Free-text + facet filters ──────────────────────────────────── -->
    <section class="match-controls">
      <h2 class="match-section-h2">
        <span data-tc>{chips.length > 0 ? '② 自由文字 + 細部條件' : '① 自由文字 + 細部條件'}</span>
        <span data-sc>{chips.length > 0 ? '② 自由文字 + 细部条件' : '① 自由文字 + 细部条件'}</span>
        <span class="match-section-h2-en">· free-text · faceted filters</span>
      </h2>
      <div class="match-controls-grid">
        <label class="match-control match-control--wide">
          <span class="match-control-label">
            <span data-tc>關鍵字</span>
            <span data-sc>关键字</span>
          </span>
          <input
            id="match-query"
            type="search"
            placeholder="e.g. diffusion policy, world model, manipulation…"
            class="match-input"
            autocomplete="off"
          />
        </label>

        <label class="match-control">
          <span class="match-control-label">
            <span data-tc>評分</span>
            <span data-sc>评分</span>
          </span>
          <span class="match-pills">
            {ratingOpts.map(r => (
              <label class="match-pill">
                <input type="checkbox" data-facet="rating" value={r.key} checked />
                <span data-tc>{r.label}</span><span data-sc>{r.labelSC}</span>
              </label>
            ))}
          </span>
        </label>

        <label class="match-control">
          <span class="match-control-label">
            <span data-tc>地區</span>
            <span data-sc>地区</span>
          </span>
          <span class="match-pills">
            {regionOpts.map(r => (
              <label class="match-pill">
                <input type="checkbox" data-facet="region" value={r.key} checked />
                <span data-tc>{r.label}</span><span data-sc>{r.labelSC}</span>
              </label>
            ))}
          </span>
        </label>

        {familyOpts.length > 0 && (
          <label class="match-control match-control--wide">
            <span class="match-control-label">
              <span data-tc>方法族</span>
              <span data-sc>方法族</span>
              <span class="match-control-hint">
                <span data-tc>· 不勾為「全部」</span>
                <span data-sc>· 不勾为「全部」</span>
              </span>
            </span>
            <span class="match-pills">
              {familyOpts.map(f => (
                <label class="match-pill">
                  <input type="checkbox" data-facet="family" value={f.familyDisplay} />
                  <span>{f.familyDisplay}</span>
                </label>
              ))}
            </span>
          </label>
        )}

        <label class="match-control">
          <span class="match-control-label">
            <span data-tc>最少論文數</span>
            <span data-sc>最少论文数</span>
            <span class="match-control-hint" id="match-papermin-display">≥ 1</span>
          </span>
          <input
            id="match-papermin"
            type="range"
            min="1" max="8" step="1" value="1"
            class="match-range"
          />
        </label>

        <label class="match-control">
          <span class="match-control-label">
            <span data-tc>聯繫狀態</span>
            <span data-sc>联系状态</span>
          </span>
          <span class="match-pills">
            <label class="match-pill">
              <input type="checkbox" data-facet="contact" value="linked_via_lab" checked />
              <span data-tc>機構關聯</span><span data-sc>机构关联</span>
            </label>
            <label class="match-pill">
              <input type="checkbox" data-facet="contact" value="social_mention" checked />
              <span data-tc>社交提及</span><span data-sc>社交提及</span>
            </label>
            <label class="match-pill">
              <input type="checkbox" data-facet="contact" value="not_linked" checked />
              <span data-tc>僅署名</span><span data-sc>仅署名</span>
            </label>
          </span>
        </label>
      </div>
    </section>

    <!-- ── Results ─────────────────────────────────────────────────────── -->
    <section class="match-results">
      <header class="match-results-header">
        <h2 class="match-section-h2">
          <span data-tc>③ 候選名單</span>
          <span data-sc>③ 候选名单</span>
          <span class="match-section-h2-en">· ranked candidates</span>
        </h2>
        <span class="match-results-count">
          <span id="match-count">{totalPool}</span>
          <span data-tc> 位候選人</span>
          <span data-sc> 位候选人</span>
        </span>
      </header>
      <div id="match-grid" class="match-grid">
        {/* Client-side JS rebuilds this list. Server-rendered seed shows the
            first 30 unsorted so something is visible before JS hydrates and
            so crawlers see real content. */}
        {peopleClient.slice(0, 30).map(p => (
          <article class="match-card" data-slug={p.slug}>
            <div class="match-card-head">
              <span class="match-card-rating">{p.topRating}</span>
              <h3 class="match-card-name">{p.name}</h3>
              <button
                type="button"
                class="match-card-similar"
                data-similar-slug={p.slug}
                aria-label={`Find researchers similar to ${p.name}`}
                title="Find similar"
              >≈</button>
            </div>
            <div class="match-card-meta">
              <span class="match-card-aff">{p.affiliation ?? '—'}</span>
              <span class="match-card-sep">·</span>
              <span class="match-card-papers">{p.paperCount90d} <span data-tc>篇 90d</span><span data-sc>篇 90d</span></span>
            </div>
            {p.topMethods.length > 0 && (
              <div class="match-card-methods">
                {p.topMethods.map(t => <span class="match-card-method">{t}</span>)}
              </div>
            )}
            {p.evidenceTeaser.length > 0 && (
              <ul class="match-card-evidence">
                {p.evidenceTeaser.map(ev => (
                  <li>
                    <span class="match-card-evidence-rating">{ev.rating}</span>
                    <a href={ev.url} target="_blank" rel="noopener noreferrer" class="match-card-evidence-title">{ev.title}</a>
                  </li>
                ))}
              </ul>
            )}
          </article>
        ))}
      </div>
    </section>

    <!-- ── Method box for client JS ───────────────────────────────────── -->
    <details class="match-method">
      <summary>
        <span data-tc>方法論 · How matching works</span>
        <span data-sc>方法论 · How matching works</span>
      </summary>
      <ul>
        <li>
          <strong>方法族 chip · 語意</strong>
          <span data-tc> — query 文字在 build 時被 DashScope text-embedding-v3 編碼（1024-dim），對全 pool 算 cosine，預烤 top 30。對單一方法詞彙 chip 表現良好（tactile / dexterous / flow_matching 等）。瀏覽器只查表。</span>
          <span data-sc> — query 文字在 build 时被 DashScope text-embedding-v3 编码（1024-dim），对全 pool 算 cosine，预烤 top 30。对单一方法词汇 chip 表现良好（tactile / dexterous / flow_matching 等）。浏览器只查表。</span>
        </li>
        <li>
          <strong>結構 chip · 規則</strong>
          <span data-tc> — Polymath / Production-deployable / Safety/Eval 改走結構規則，不走 embedding。Polymath = 90 日論文跨 ≥ 2 個方法族；Production = 標題命中 efficient/deploy/real-time/inference 等；Safety = 標題命中 safety/eval/benchmark/align 等。零幻覺、零 API。</span>
          <span data-sc> — Polymath / Production-deployable / Safety/Eval 改走结构规则，不走 embedding。Polymath = 90 日论文跨 ≥ 2 个方法族；Production = 标题命中 efficient/deploy/real-time/inference 等；Safety = 标题命中 safety/eval/benchmark/align 等。零幻觉、零 API。</span>
        </li>
        <li>
          <strong>≈ 找相似 · 語意</strong>
          <span data-tc> — 點某人卡片的 ≈ → 顯示 cosine 最近的 10 位（build 時預烤的 person × person 鄰居）。這是 embedding 唯一真正擅長的場景：薄 profile 對薄 profile 公平比較。Score 銜帶顯示 ≥80%=強 / 60-79%=可 / &lt;60%=弱。</span>
          <span data-sc> — 点某人卡片的 ≈ → 显示 cosine 最近的 10 位（build 时预烤的 person × person 邻居）。这是 embedding 唯一真正擅长的场景：薄 profile 对薄 profile 公平比较。Score 衔带显示 ≥80%=强 / 60-79%=可 / &lt;60%=弱。</span>
        </li>
        <li>
          <strong>自由文字</strong>
          <span data-tc> — substring 匹配 name + affiliation + 90 日內所有論文標題。不走 embedding（瀏覽器無法在 GH Pages 做 inference）。</span>
          <span data-sc> — substring 匹配 name + affiliation + 90 日内所有论文标题。不走 embedding（浏览器无法在 GH Pages 做 inference）。</span>
        </li>
        <li>
          <strong>Facet 細部條件</strong>
          <span data-tc> — 評分 / 地區 / 方法族 / 最少論文數 / 聯繫狀態，AND 邏輯。注意：池子 affiliation 覆蓋僅 ~3%，地區 facet 多數記為「其他/無」— 這也是移除了原本「方法族 × 地區」chip 的原因，請改用 facet 控制地區。</span>
          <span data-sc> — 评分 / 地区 / 方法族 / 最少论文数 / 联系状态，AND 逻辑。注意：池子 affiliation 覆盖仅 ~3%，地区 facet 多数记为「其他/无」— 这也是移除了原本「方法族 × 地区」chip 的原因，请改用 facet 控制地区。</span>
        </li>
        <li>
          <strong>已知限制</strong>
          <span data-tc> — 資料源是 arXiv 第一作者 90 日窗口；多數研究員只見過一篇 paper。「跨方法族匹配」和「真正地區匹配」要等 affiliation 回灌（OpenReview / Semantic Scholar）才會活化。在此之前 polymath 走結構規則、地區走 facet。</span>
          <span data-sc> — 资料源是 arXiv 第一作者 90 日窗口；多数研究员只见过一篇 paper。「跨方法族匹配」和「真正地区匹配」要等 affiliation 回灌（OpenReview / Semantic Scholar）才会活化。在此之前 polymath 走结构规则、地区走 facet。</span>
        </li>
        <li>
          <strong>NO-EMAIL</strong>
          <span data-tc> — 整個 pipeline 不存任何郵箱欄位；PersonRecord 在型別層強制 <code>email?: never</code>，smoke 測試額外做 runtime assert。</span>
          <span data-sc> — 整个 pipeline 不存任何邮箱字段；PersonRecord 在类型层强制 <code>email?: never</code>，smoke 测试额外做 runtime assert。</span>
        </li>
      </ul>
    </details>
  </main>

  <!-- ── Data injection for client JS ───────────────────────────────────
       Astro's define:vars serialises straight into the script, no fetch needed.
       Each JSON payload escapes `<` to `<` so a stray `</script>`
       inside a paper title can't close the JSON block early — the HTML
       parser only looks for the literal `</script>` byte sequence.
  ───────────────────────────────────────────────────────────────────── -->
  <script type="application/json" id="match-people-data" set:html={JSON.stringify(peopleClient).replace(/</g, '\\u003c')} />
  {/* Chips JSON always includes structural chips even in facet-only mode.
      Semantic chips ride along iff matchData is present. */}
  <script type="application/json" id="match-queries-data" set:html={JSON.stringify(chips.map(c => ({ id: c.id, label: c.label, labelSC: c.labelSC, text: c.text, results: c.results, kind: c.kind }))).replace(/</g, '\\u003c')} />
  {matchData && (
    <script type="application/json" id="match-neighbors-data" set:html={JSON.stringify(matchData.people.map(p => ({ slug: p.slug, neighbors: p.neighbors }))).replace(/</g, '\\u003c')} />
  )}

  <script is:inline>
    (function () {
      const peopleEl = document.getElementById('match-people-data');
      if (!peopleEl) return;
      const PEOPLE = JSON.parse(peopleEl.textContent);
      const slugToIdx = new Map(PEOPLE.map((p, i) => [p.slug, i]));

      const queriesEl   = document.getElementById('match-queries-data');
      const neighborsEl = document.getElementById('match-neighbors-data');
      const QUERIES   = queriesEl   ? JSON.parse(queriesEl.textContent)   : [];
      const NEIGHBORS = neighborsEl ? JSON.parse(neighborsEl.textContent) : [];
      const queryById     = new Map(QUERIES.map(q => [q.id, q]));
      const neighborsBySlug = new Map(NEIGHBORS.map(n => [n.slug, n.neighbors]));

      const grid       = document.getElementById('match-grid');
      const countEl    = document.getElementById('match-count');
      const queryInput = document.getElementById('match-query');
      const paperMin   = document.getElementById('match-papermin');
      const paperMinDisplay = document.getElementById('match-papermin-display');

      let activeChipId = null;
      let similarOfSlug = null;

      function readFacet(name) {
        return [...document.querySelectorAll(`input[data-facet="${name}"]:checked`)].map(el => el.value);
      }
      function readFamilies() {
        // Special case: facet "family" with no boxes ticked means "any family".
        return [...document.querySelectorAll('input[data-facet="family"]:checked')].map(el => el.value);
      }

      function passes(p, q, ratings, regions, families, minPapers, contacts) {
        if (!ratings.includes(p.topRating))    return false;
        if (!regions.includes(p.region))       return false;
        if (!contacts.includes(p.contactStatus)) return false;
        if (p.paperCount90d < minPapers)       return false;
        if (families.length > 0) {
          // OR over selected families — at least one tag matches
          const hit = p.topMethods.some(t => families.includes(t));
          if (!hit) return false;
        }
        if (q && !p.haystack.includes(q)) return false;
        return true;
      }

      function render() {
        const q = (queryInput.value || '').trim().toLowerCase();
        const ratings  = readFacet('rating');
        const regions  = readFacet('region');
        const families = readFamilies();
        const contacts = readFacet('contact');
        const minPapers = parseInt(paperMin.value, 10) || 1;
        paperMinDisplay.textContent = '≥ ' + minPapers;

        // Decide candidate index order:
        //   1. If similar-to active → pre-baked neighbor order
        //   2. Else if chip active   → chip's pre-baked top-30 order
        //   3. Else                  → all people (no scoring)
        let order = null;     // array of indices in ranked order, or null
        let scores = null;
        if (similarOfSlug && neighborsBySlug.has(similarOfSlug)) {
          // First the source (visually anchor), then their neighbors
          const srcIdx = slugToIdx.get(similarOfSlug);
          const nbs = neighborsBySlug.get(similarOfSlug).map(n => n.pi);
          order = [srcIdx, ...nbs].filter(i => i !== undefined);
          scores = new Map([[srcIdx, 1.0]]);
          neighborsBySlug.get(similarOfSlug).forEach(n => scores.set(n.pi, n.score));
        } else if (activeChipId && queryById.has(activeChipId)) {
          order = queryById.get(activeChipId).results.map(r => r.pi);
          scores = new Map(queryById.get(activeChipId).results.map(r => [r.pi, r.score]));
        }

        let candidates;
        if (order) {
          candidates = order.map(i => PEOPLE[i]).filter(Boolean);
          // Apply facet filters even on top of chip ranking
          candidates = candidates.filter(p => passes(p, q, ratings, regions, families, minPapers, contacts));
        } else {
          candidates = PEOPLE.filter(p => passes(p, q, ratings, regions, families, minPapers, contacts));
          // Default sort: ⚡ first, then 🔧, then 📖; tie-break by paperCount desc
          const rOrder = r => r === '⚡' ? 0 : r === '🔧' ? 1 : 2;
          candidates.sort((a, b) => rOrder(a.topRating) - rOrder(b.topRating) || b.paperCount90d - a.paperCount90d || a.name.localeCompare(b.name));
        }

        countEl.textContent = candidates.length;

        // Empty-state branch — explain WHY zero before showing the
        // generic "no candidates" message. The three causes we can
        // distinguish from page state:
        //   1. find-similar with a slug that has no neighbor data
        //   2. a chip is active but facets nuked all candidates
        //   3. plain free-text / facet filtering returned nothing
        if (candidates.length === 0) {
          let body;
          if (similarOfSlug && !neighborsBySlug.has(similarOfSlug)) {
            // case 1 — similarity data missing (e.g. embeddings not rebuilt
            // after a new researcher entered the pool).
            body = `<strong>找相似資料缺失</strong> · this researcher has no pre-computed similarity data.<br/>` +
                   `<span style="opacity:0.85">Run <code>pnpm embed:talent</code> locally to populate, or pick another candidate.</span>`;
          } else if (similarOfSlug) {
            // case 1b — neighbors exist but facets filtered them all out
            body = `<strong>相似研究員已被細部條件篩光</strong> · facets filtered out all neighbors.`;
          } else if (activeChipId) {
            // case 2 — chip active, facets too strict
            body = `<strong>標籤已選但 facet 篩光所有候選人</strong> · try clearing facets or pick a different tag.`;
          } else {
            // case 3 — open filter state, no hits
            body = `<strong>沒有符合條件的候選人</strong> · no matching candidates · 試試放寬條件`;
          }
          grid.innerHTML = `<div class="match-empty">${body}<div class="match-empty-actions"><button type="button" class="match-empty-btn" data-action="reset">重置全部 · Reset</button></div></div>`;
          return;
        }

        // Render cards.
        //
        // Score badge policy (post-audit):
        //   * Only show on ≈ similar results (person↔person cosine — true semantic).
        //   * Hide on chip results — chip text↔person text similarity is noisy
        //     and HR misread the number as a "match quality".
        //   * Banding: ≥0.80 strong / 0.60-0.79 ok / <0.60 weak. The colour
        //     hints whether to trust the rank.
        const html = candidates.slice(0, 80).map(p => {
          const score = scores ? scores.get(slugToIdx.get(p.slug)) : null;
          const showScore = similarOfSlug !== null && score !== null && score !== undefined;
          let scoreBadge = '';
          if (showScore) {
            const pct = (score * 100).toFixed(0);
            const tier = score >= 0.80 ? 'strong' : score >= 0.60 ? 'ok' : 'weak';
            scoreBadge = `<span class="match-card-score match-card-score--${tier}" title="similarity to source researcher">≈ ${pct}%</span>`;
          }
          const methods = (p.topMethods || []).map(t => `<span class="match-card-method">${escapeHtml(t)}</span>`).join('');
          const evidence = (p.evidenceTeaser || []).map(ev =>
            `<li><span class="match-card-evidence-rating">${ev.rating}</span><a href="${escapeAttr(ev.url)}" target="_blank" rel="noopener noreferrer" class="match-card-evidence-title">${escapeHtml(ev.title)}</a></li>`
          ).join('');
          const safeName = escapeHtml(p.name);
          return `<article class="match-card" data-slug="${p.slug}">
            <div class="match-card-head">
              <span class="match-card-rating">${p.topRating}</span>
              <h3 class="match-card-name">${safeName}</h3>
              ${scoreBadge}
              <button type="button" class="match-card-similar" data-similar-slug="${p.slug}" aria-label="Find researchers similar to ${safeName}" title="Find similar">≈</button>
            </div>
            <div class="match-card-meta">
              <span class="match-card-aff">${escapeHtml(p.affiliation || '—')}</span>
              <span class="match-card-sep">·</span>
              <span class="match-card-papers">${p.paperCount90d} 篇 90d</span>
            </div>
            ${methods ? `<div class="match-card-methods">${methods}</div>` : ''}
            ${evidence ? `<ul class="match-card-evidence">${evidence}</ul>` : ''}
          </article>`;
        }).join('');
        grid.innerHTML = html;
      }

      // Reset all controls back to their initial open state.
      function resetAll() {
        activeChipId = null;
        similarOfSlug = null;
        queryInput.value = '';
        paperMin.value = '1';
        document.querySelectorAll('input[data-facet]').forEach(el => {
          // Family checkboxes default OFF (their semantic is "any"); everything
          // else defaults ON (rating tiers / regions / contact statuses).
          el.checked = el.dataset.facet !== 'family';
        });
        document.querySelectorAll('.match-chip').forEach(b => b.classList.remove('match-chip--active'));
        render();
      }

      function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
      }
      // Stricter for `href`: forbid javascript: schemes and escape quotes.
      function escapeAttr(s) {
        const str = String(s).trim();
        if (/^\s*javascript:/i.test(str)) return '#';
        return str.replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
      }

      // Wire up controls
      queryInput.addEventListener('input', render);
      paperMin.addEventListener('input', render);
      document.querySelectorAll('input[data-facet]').forEach(el => el.addEventListener('change', render));

      // Chip clicks
      document.querySelectorAll('.match-chip').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = btn.getAttribute('data-chip-id');
          if (id === '__clear__') {
            activeChipId = null;
            similarOfSlug = null;
            document.querySelectorAll('.match-chip').forEach(b => b.classList.remove('match-chip--active'));
          } else {
            activeChipId  = id;
            similarOfSlug = null;
            document.querySelectorAll('.match-chip').forEach(b => b.classList.remove('match-chip--active'));
            btn.classList.add('match-chip--active');
          }
          render();
        });
      });

      // Find-similar + reset buttons (event delegation so dynamically rendered
      // cards/empty-state buttons work).
      grid.addEventListener('click', (ev) => {
        const resetBtn = ev.target.closest('[data-action="reset"]');
        if (resetBtn) {
          ev.preventDefault();
          resetAll();
          return;
        }
        const target = ev.target.closest('.match-card-similar');
        if (!target) return;
        ev.preventDefault();
        const slug = target.getAttribute('data-similar-slug');
        if (!slug) return;
        // Always set similarOfSlug so the empty-state branch can explain
        // missing-data cases instead of silently doing nothing. The render
        // path detects the missing neighbor data and surfaces a helpful
        // message + reset button.
        similarOfSlug = slug;
        activeChipId = null;
        document.querySelectorAll('.match-chip').forEach(b => b.classList.remove('match-chip--active'));
        render();
      });

      // Initial render
      render();
    })();
  </script>

