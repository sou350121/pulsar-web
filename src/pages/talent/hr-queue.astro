---
import BaseLayout     from '../../layouts/BaseLayout.astro';
import TalentPageHero from '../../components/TalentPageHero.astro';
import PersonCard     from '../../components/PersonCard.astro';
import { loadHRQueue, DEFAULT_HR_GATE } from '../../utils/talent';

const queue = loadHRQueue();
---

<BaseLayout
  title="HR 推薦隊列 HR Queue · Talent Radar"
  description="Gate-filtered candidate queue — evidence-driven, no auto-hire, no email"
>
  <main class="container talent-v2-page">
    <TalentPageHero
      sectionNum="01"
      titleTC="HR 推薦隊列"
      titleSC="HR 推荐队列"
      titleEN="HR Queue"
      ledeTC="唯讀分診介面。<strong>不自動錄用，不自動拒絕。</strong>每條記錄須滿足以下<em>所有</em>預設門檻。任何觸達前請自行核實。"
      ledeSC="只读分诊界面。<strong>不自动录用，不自动拒绝。</strong>每条记录须满足以下<em>所有</em>预设门槛。外展前请自行核实。"
    />

    <section class="tv2-gate">
      <h3 class="tv2-gate-title">
        <span data-tc>當前篩選門檻</span>
        <span data-sc>当前筛选门槛</span>
        <span class="tv2-gate-en">/ Active Gate Criteria</span>
      </h3>
      <ul class="tv2-gate-list">
        <li>
          <span class="tv2-gate-key">Rating floor</span>
          <span class="tv2-gate-val">≥ {DEFAULT_HR_GATE.ratingFloor}</span>
          <span class="tv2-gate-note">author on at least one breakthrough or practical paper</span>
        </li>
        <li>
          <span class="tv2-gate-key">Paper count (90d)</span>
          <span class="tv2-gate-val">≥ {DEFAULT_HR_GATE.minPaperCount90d}</span>
          <span class="tv2-gate-note">sustained output, not a one-off</span>
        </li>
        <li>
          <span class="tv2-gate-key">Affiliation</span>
          <span class="tv2-gate-val">{DEFAULT_HR_GATE.requireAffiliation ? 'required' : 'optional'}</span>
          <span class="tv2-gate-note">resolvable via institution-registry</span>
        </li>
        <li>
          <span class="tv2-gate-key">Contact status</span>
          <span class="tv2-gate-val">≠ not_linked</span>
          <span class="tv2-gate-note">at least one durable signal beyond paper byline</span>
        </li>
        <li class="tv2-gate-strong">
          <span class="tv2-gate-key">Email</span>
          <span class="tv2-gate-val">NEVER stored or shown</span>
          <span class="tv2-gate-note">enforced in code path; verify externally</span>
        </li>
      </ul>
    </section>

    {queue.length === 0 ? (
      <div class="tv2-empty">
        <p class="tv2-empty-title">
          <span data-tc>目前沒有任何候選人通過全部門檻</span>
          <span data-sc>目前没有任何候选人通过全部门槛</span>
        </p>
        <p class="tv2-empty-sub">
          This is normal early in deployment — wait 2–4 weeks for the entity-index to
          accumulate sufficient signal before expecting candidates.
        </p>
      </div>
    ) : (
      <>
        <p class="tv2-queue-count">
          <strong>{queue.length}</strong>
          <span data-tc> 位候選人通過篩選 / candidates passed the gate</span>
          <span data-sc> 位候选人通过筛选 / candidates passed the gate</span>
        </p>
        <div class="picks-grid">
          {queue.map(c => <PersonCard record={c} showWhyNow />)}
        </div>
      </>
    )}
  </main>

  <style>
    .talent-v2-page { max-width: 1200px; margin: 0 auto; padding: 2rem 1rem 4rem; }

    .tv2-gate {
      margin: 0 0 2rem;
      padding: 1.25rem 1.4rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent-amber);
      border-radius: 10px;
    }
    .tv2-gate-title {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 1.05rem; font-weight: 600;
      margin: 0 0 0.85rem;
      color: var(--text-primary);
      display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem;
    }
    .tv2-gate-en {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem;
      color: var(--text-tertiary);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 400;
    }
    .tv2-gate-list {
      list-style: none; padding: 0; margin: 0;
      display: grid; gap: 0.45rem;
    }
    .tv2-gate-list li {
      display: grid;
      grid-template-columns: 180px 160px 1fr;
      gap: 0.85rem;
      align-items: baseline;
      font-size: 0.85rem;
      padding: 0.25rem 0;
      border-bottom: 1px dashed var(--border-subtle);
    }
    .tv2-gate-list li:last-child { border-bottom: none; }
    .tv2-gate-key {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-tertiary);
    }
    .tv2-gate-val {
      font-family: 'IBM Plex Mono', monospace;
      color: var(--accent-cyan);
      font-weight: 700;
      font-size: 0.85rem;
    }
    .tv2-gate-note {
      color: var(--text-tertiary);
      font-style: italic;
    }
    .tv2-gate-strong .tv2-gate-val { color: var(--accent-amber); }

    .tv2-queue-count {
      margin: 1.5rem 0 1rem;
      font-family: 'IBM Plex Mono', monospace;
      color: var(--text-tertiary);
      font-size: 0.85rem;
    }
    .tv2-queue-count strong {
      font-size: 1.6rem; color: var(--text-primary); margin-right: 0.5rem;
      font-weight: 700;
    }

    .tv2-empty {
      padding: 2.5rem 1.5rem;
      background: var(--surface);
      border: 1px dashed var(--border);
      border-radius: 10px;
      text-align: center;
    }
    .tv2-empty-title {
      font-family: Georgia, 'Songti SC', serif;
      font-size: 1.05rem;
      color: var(--text-primary);
      margin: 0 0 0.5rem;
    }
    .tv2-empty-sub {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.78rem;
      color: var(--text-tertiary);
      max-width: 540px; margin: 0 auto;
      line-height: 1.6;
    }

    @media (max-width: 768px) {
      .tv2-gate-list li {
        grid-template-columns: 1fr;
        gap: 0.2rem;
        padding: 0.5rem 0;
      }
    }
  </style>
</BaseLayout>
