              {entityCount > 0 ? entityCount + ' 實體' : '7日追蹤'}
            </span>
          </div>
          <div class="entity-list">
            {entityCount > 0
              ? Object.values(entityIndex.entities)
                  .sort((a, b) => (b.signals?.length ?? 0) - (a.signals?.length ?? 0))
                  .slice(0, 5)
                  .map((ent, idx) => {
                    const count = ent.signals?.length ?? 0;
                    const max   = Object.values(entityIndex.entities).reduce((m, e) => Math.max(m, e.signals?.length ?? 0), 1);
                    const pct   = Math.max(12, Math.round(count / max * 100));
                    return (
                      <div class="entity-row">
                        <div class="entity-row-meta">
                          <span class="entity-name">{ent.name}</span>
                          <span class="entity-count">{count} 信號</span>
