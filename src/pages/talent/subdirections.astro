---
import BaseLayout       from '../../layouts/BaseLayout.astro';
import TalentPageHero   from '../../components/TalentPageHero.astro';
import SubdirectionCard from '../../components/SubdirectionCard.astro';
import { loadSubdirections } from '../../utils/talent';

const vlaSubs = loadSubdirections({ domain: 'vla' });
const aiSubs  = loadSubdirections({ domain: 'ai' });
const all     = [...vlaSubs, ...aiSubs];

// Velocity board excludes insufficient_data (prior=0) rows — those produce
// clamped 999% values that overwhelm the legitimate signal.
const board = [...all]
  .filter(s => s.status !== 'insufficient_data')
  .sort((a, b) => Math.abs(b.acceleration) - Math.abs(a.acceleration))
  .slice(0, 8);
const maxAbs = Math.max(0.01, ...board.map(s => Math.abs(s.acceleration)));
const emerging = all
  .filter(s => s.status === 'insufficient_data' && s.velocity7d > 0)
  .sort((a, b) => b.velocity7d - a.velocity7d);

function fmtAccel(a: number): string {
  const pct = Math.round(a * 100);
  if (pct >= 500)  return '+500%↑';
  if (pct <= -500) return '−500%↓';
  return `${pct > 0 ? '+' : ''}${pct}%`;
}
---

<BaseLayout
  title="小方向 Subdirections · Talent Radar"
  description="方法族趋势 — 哪些技术方向在加速, 哪些在衰减"
>
  <main class="container talent-v2-page">
    <TalentPageHero
      sectionNum="02"
      titleTC="小方向"
      titleSC="小方向"
      titleEN="Subdirections"
      ledeTC="方法族趨勢來源於 <code>field-state-*.json</code>（機械化，零 LLM）。<strong>加速度</strong> = (近 7d − 前 7d) / max(前值, 1)。"
      ledeSC="方法族趋势来源于 <code>field-state-*.json</code>（机械化，零 LLM）。<strong>加速度</strong> = (近 7d − 前 7d) / max(前值, 1)。"
    />

    <section class="tv2-section">
      <h2 class="tv2-section-h2">
        <span data-tc>速度榜 · 前 8 名</span>
        <span data-sc>速度榜 · 前 8 名</span>
        <span class="tv2-section-en">/ Velocity Top 8</span>
      </h2>
      <ol class="tv2-velocity-board">
        {board.map((s, i) => {
          const pct = Math.abs(s.acceleration) / maxAbs * 100;
          const isUp = s.acceleration >= 0;
          return (
            <li class="tv2-vel-row" style={`--vel-pct: ${pct.toFixed(1)}%`}>
              <a href={`#fam-${s.family}`} class="tv2-vel-link">
                <span class="tv2-vel-rank">{String(i + 1).padStart(2, '0')}</span>
                <span class={`tv2-vel-domain ${s.domain === 'vla' ? 'tag-vla' : 'tag-ai'}`}>
                  {s.domain === 'vla' ? 'VLA' : 'AI'}
                </span>
                <span class="tv2-vel-name">{s.displayName}</span>
                <span class="tv2-vel-track">
                  <span class={`tv2-vel-bar ${isUp ? 'tv2-vel-bar--up' : 'tv2-vel-bar--down'}`}></span>
                </span>
                <span class={`tv2-vel-pct ${isUp ? 'tv2-vel-pct--up' : 'tv2-vel-pct--down'}`}>
                  {fmtAccel(s.acceleration)}
                </span>
                <span class="tv2-vel-vol">{s.velocity7d}/{s.velocityPrior7d}</span>
              </a>
            </li>
          );
        })}
      </ol>

      {emerging.length > 0 && (
        <div class="tv2-emerging">
          <span class="tv2-emerging-label">
            <span data-tc>新冒頭</span><span data-sc>新冒头</span>
            <span class="tv2-emerging-en">· EMERGING · prior volume = 0</span>
          </span>
          <ul class="tv2-emerging-list">
            {emerging.map(s => (
              <li>
                <a href={`#fam-${s.family}`}>
                  <span class={`tv2-vel-domain ${s.domain === 'vla' ? 'tag-vla' : 'tag-ai'}`}>
                    {s.domain === 'vla' ? 'VLA' : 'AI'}
                  </span>
                  <span class="tv2-emerging-name">{s.displayName}</span>
                  <span class="tv2-emerging-count">{s.velocity7d}<span class="tv2-emerging-unit"> 篇 · 7d</span></span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </section>

    <section class="tv2-section">
      <h2 class="tv2-section-h2">
        <span class="tv2-domain-pill tag-vla">VLA</span>
        · {vlaSubs.length}
      </h2>
      {vlaSubs.length === 0 ? (
        <p class="tv2-empty">No VLA subdirections yet — waiting for field-state-*.json.</p>
      ) : (
        <div class="picks-grid">
          {vlaSubs.map(s => <SubdirectionCard record={s} />)}
        </div>
      )}
    </section>

    <section class="tv2-section">
      <h2 class="tv2-section-h2">
        <span class="tv2-domain-pill tag-ai">AI App</span>
        · {aiSubs.length}
      </h2>
      {aiSubs.length === 0 ? (
        <p class="tv2-empty">No AI subdirections yet — waiting for ai-field-state-*.json.</p>
      ) : (
        <div class="picks-grid">
          {aiSubs.map(s => <SubdirectionCard record={s} />)}
        </div>
      )}
    </section>
  </main>

  <style>
    .talent-v2-page { max-width: 1200px; margin: 0 auto; padding: 2rem 1rem 4rem; }
    .tv2-section { margin: 2.25rem 0; }
    .tv2-section-h2 {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 1.25rem; font-weight: 600;
      margin: 0 0 1rem; padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
      color: var(--text-primary);
      display: flex; align-items: baseline; gap: 0.65rem;
    }
    .tv2-section-en {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem; color: var(--text-tertiary);
      letter-spacing: 0.12em; text-transform: uppercase;
    }
    .tv2-domain-pill {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.62rem; font-weight: 700;
      letter-spacing: 0.14em;
      padding: 0.22rem 0.5rem;
      border-radius: 4px;
    }
    .tv2-empty {
      text-align: center; color: var(--text-tertiary); font-style: italic;
      padding: 2rem; background: var(--surface);
      border: 1px dashed var(--border); border-radius: 8px;
    }
    .tv2-velocity-board {
      list-style: none; padding: 0.5rem 0; margin: 0;
      border: 1px solid var(--border); border-radius: 10px;
      background: var(--surface); overflow: hidden;
    }
    .tv2-vel-row + .tv2-vel-row { border-top: 1px solid var(--border-subtle); }
    .tv2-vel-link {
      display: grid;
      grid-template-columns: 28px 50px 1fr 2fr 64px 56px;
      gap: 0.75rem; align-items: center;
      padding: 0.65rem 1rem;
      text-decoration: none; color: var(--text-primary);
      transition: background 0.12s;
    }
    .tv2-vel-link:hover { background: var(--surface-2); }
    .tv2-vel-rank {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem; font-weight: 700;
      color: var(--text-tertiary); letter-spacing: 0.04em;
    }
    .tv2-vel-domain {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.6rem; font-weight: 700;
      letter-spacing: 0.12em; text-align: center;
      padding: 0.18rem 0.4rem; border-radius: 4px;
    }
    .tv2-vel-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.95rem; font-weight: 500;
      color: var(--text-primary);
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .tv2-vel-track {
      position: relative; height: 8px;
      background: var(--surface-2); border-radius: 4px; overflow: hidden;
    }
    .tv2-vel-bar {
      position: absolute; left: 0; top: 0; bottom: 0;
      width: var(--vel-pct); border-radius: 4px;
      transition: width 0.4s ease-out;
    }
    .tv2-vel-bar--up   { background: linear-gradient(90deg, var(--accent-amber), color-mix(in srgb, var(--accent-amber) 65%, var(--accent-cyan))); }
    .tv2-vel-bar--down { background: linear-gradient(90deg, var(--rating-x), color-mix(in srgb, var(--rating-x) 60%, transparent)); opacity: 0.85; }
    .tv2-vel-pct {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.8rem; font-weight: 700; text-align: right;
    }
    .tv2-vel-pct--up   { color: var(--accent-amber); }
    .tv2-vel-pct--down { color: var(--rating-x); }
    .tv2-vel-vol {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.68rem; color: var(--text-tertiary); text-align: right;
    }
    .tv2-emerging {
      margin-top: 0.75rem;
      padding: 0.75rem 1rem;
      background: var(--surface-2);
      border: 1px dashed var(--border);
      border-radius: 8px;
    }
    .tv2-emerging-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.65rem; font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent-cyan);
      display: block; margin-bottom: 0.5rem;
    }
    .tv2-emerging-en {
      color: var(--text-tertiary); font-weight: 400; margin-left: 0.35rem;
    }
    .tv2-emerging-list {
      list-style: none; padding: 0; margin: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.4rem 1rem;
    }
    .tv2-emerging-list li a {
      display: flex; align-items: center; gap: 0.6rem;
      padding: 0.35rem 0.5rem;
      text-decoration: none;
      border-radius: 4px;
      color: var(--text-primary);
      transition: background 0.12s;
    }
    .tv2-emerging-list li a:hover { background: var(--surface); }
    .tv2-emerging-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.9rem; flex: 1;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .tv2-emerging-count {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem; font-weight: 700;
      color: var(--accent-cyan);
    }
    .tv2-emerging-unit {
      font-weight: 400; color: var(--text-tertiary); font-size: 0.7rem;
    }
    @media (max-width: 900px) {
      .tv2-vel-link {
        grid-template-columns: 24px 44px 1fr 56px;
        gap: 0.5rem;
      }
      .tv2-vel-track { grid-column: 1 / -1; }
      .tv2-vel-vol   { display: none; }
      .tv2-emerging-list { grid-template-columns: 1fr; }
    }
  </style>
</BaseLayout>
