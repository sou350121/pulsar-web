---
import BaseLayout     from '../../layouts/BaseLayout.astro';
import TalentPageHero from '../../components/TalentPageHero.astro';
import PersonCard     from '../../components/PersonCard.astro';
import RatingBadge    from '../../components/RatingBadge.astro';
import {
  loadHRScout,
  loadTalentStats,
  slugifyName,
  DEFAULT_HR_GATE,
} from '../../utils/talent';

const base  = import.meta.env.BASE_URL;
const stats = loadTalentStats();
const scout = loadHRScout();
---

<BaseLayout
  title="HR 推薦隊列 HR Queue · Talent Radar"
  description="Gate-filtered candidate funnel — HOT / WARM / WATCH tiers. Evidence-driven, no auto-hire, no email."
>
  <main class="container talent-v2-page">
    <TalentPageHero
      sectionNum="01"
      titleTC="HR 候選人隊列"
      titleSC="HR 候选人队列"
      titleEN="HR Scout"
      ledeTC={`從 <strong>${stats.peopleCount}</strong> 名研究員中漏出 <strong>${scout.totals.pool}</strong> 位進入候選池。<em>不自動錄用，不自動拒絕。</em>每位均附論文佐證；任何觸達前請自行核實機構與聯繫資訊。`}
      ledeSC={`从 <strong>${stats.peopleCount}</strong> 名研究员中漏出 <strong>${scout.totals.pool}</strong> 位进入候选池。<em>不自动录用，不自动拒绝。</em>每位均附论文佐证；外展前请自行核实机构与联系信息。`}
    />

    {/* Funnel summary */}
    <section class="tv2-funnel">
      <div class="tv2-funnel-tier" data-tier="hot">
        <span class="tv2-funnel-dot" aria-hidden="true"></span>
        <a href="#tier-hot">
          <span class="tv2-funnel-count">{scout.totals.hot}</span>
          <span class="tv2-funnel-label">HOT</span>
          <span class="tv2-funnel-sub">
            <span data-tc>通過完整門檻</span>
            <span data-sc>通过完整门槛</span>
          </span>
        </a>
      </div>
      <div class="tv2-funnel-tier" data-tier="warm">
        <span class="tv2-funnel-dot" aria-hidden="true"></span>
        <a href="#tier-warm">
          <span class="tv2-funnel-count">{scout.totals.warm}</span>
          <span class="tv2-funnel-label">WARM</span>
          <span class="tv2-funnel-sub">
            <span data-tc>缺一道門檻</span>
            <span data-sc>缺一道门槛</span>
          </span>
        </a>
      </div>
      <div class="tv2-funnel-tier" data-tier="watch">
        <span class="tv2-funnel-dot" aria-hidden="true"></span>
        <a href="#tier-watch">
          <span class="tv2-funnel-count">{scout.totals.watch}</span>
          <span class="tv2-funnel-label">WATCH</span>
          <span class="tv2-funnel-sub">
            <span data-tc>⚡ 異常爆點</span>
            <span data-sc>⚡ 异常爆点</span>
          </span>
        </a>
      </div>
    </section>

    {/* Gate criteria */}
    <section class="tv2-gate">
      <h3 class="tv2-gate-title">
        <span data-tc>HOT 篩選門檻</span>
        <span data-sc>HOT 筛选门槛</span>
        <span class="tv2-gate-en">/ Active Gate Criteria</span>
      </h3>
      <ul class="tv2-gate-list">
        <li>
          <span class="tv2-gate-key">Rating floor</span>
          <span class="tv2-gate-val">≥ {DEFAULT_HR_GATE.ratingFloor}</span>
          <span class="tv2-gate-note">author on at least one breakthrough or practical paper</span>
        </li>
        <li>
          <span class="tv2-gate-key">Paper count · 90d</span>
          <span class="tv2-gate-val">≥ {DEFAULT_HR_GATE.minPaperCount90d}</span>
          <span class="tv2-gate-note">sustained output, not a one-off</span>
        </li>
        <li>
          <span class="tv2-gate-key">Affiliation</span>
          <span class="tv2-gate-val">{DEFAULT_HR_GATE.requireAffiliation ? 'required' : 'optional'}</span>
          <span class="tv2-gate-note">resolvable via institution-registry</span>
        </li>
        <li>
          <span class="tv2-gate-key">Contact status</span>
          <span class="tv2-gate-val">≠ not_linked</span>
          <span class="tv2-gate-note">at least one durable signal beyond paper byline</span>
        </li>
        <li class="tv2-gate-strong">
          <span class="tv2-gate-key">Email</span>
          <span class="tv2-gate-val">NEVER stored or shown</span>
          <span class="tv2-gate-note">enforced in code path; verify externally</span>
        </li>
      </ul>
    </section>

    {/* HOT tier — full PersonCards with whyNow */}
    <section class="tv2-section" id="tier-hot">
      <h2 class="tv2-section-h2">
        <span class="tv2-tier-dot-h2" data-tier="hot" aria-hidden="true"></span>
        HOT · <span data-tc>通過完整門檻</span><span data-sc>通过完整门槛</span>
        <span class="tv2-section-count">· {scout.totals.hot}</span>
      </h2>
      {scout.hot.length === 0 ? (
        <p class="tv2-empty-mini">No HOT candidates this cycle.</p>
      ) : (
        <div class="picks-grid">
          {scout.hot.map(c => <PersonCard record={c} showWhyNow />)}
        </div>
      )}
    </section>

    {/* WARM tier — compact table */}
    <section class="tv2-section" id="tier-warm">
      <h2 class="tv2-section-h2">
        <span class="tv2-tier-dot-h2" data-tier="warm" aria-hidden="true"></span>
        WARM · <span data-tc>缺一道門檻</span><span data-sc>缺一道门槛</span>
        <span class="tv2-section-count">· {scout.totals.warm}</span>
      </h2>
      {scout.warm.length === 0 ? (
        <p class="tv2-empty-mini">No WARM candidates this cycle.</p>
      ) : (
        <table class="tv2-funnel-table">
          <thead>
            <tr>
              <th></th>
              <th><span data-tc>姓名</span><span data-sc>姓名</span></th>
              <th><span data-tc>機構</span><span data-sc>机构</span></th>
              <th>methods</th>
              <th>papers · 90d</th>
              <th><span data-tc>缺什麼</span><span data-sc>缺什么</span></th>
            </tr>
          </thead>
          <tbody>
            {scout.warm.map(c => (
              <tr>
                <td><RatingBadge rating={c.topRating} size="sm" /></td>
                <td class="tv2-funnel-name">{c.name}</td>
                <td>
                  {c.affiliation ? (
                    <a href={`${base}/talent/labs/#lab-${slugifyName(c.affiliation)}`} class="tv2-funnel-aff">
                      {c.affiliation}
                    </a>
                  ) : (
                    <span class="tv2-funnel-noaff">—</span>
                  )}
                </td>
                <td>
                  <span class="tv2-method-tags">
                    {c.topMethods.map(m => <span class="tv2-method-tag">{m}</span>)}
                  </span>
                </td>
                <td class="tv2-funnel-papers">{c.paperCount90d}</td>
                <td class="tv2-funnel-missed">{c.gateMissed}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </section>

    {/* WATCH tier — flash outliers */}
    <section class="tv2-section" id="tier-watch">
      <h2 class="tv2-section-h2">
        <span class="tv2-tier-dot-h2" data-tier="watch" aria-hidden="true"></span>
        WATCH · ⚡ <span data-tc>異常爆點</span><span data-sc>异常爆点</span>
        <span class="tv2-section-count">· {scout.totals.watch}</span>
      </h2>
      <p class="tv2-section-lede">
        <span data-tc>單篇 ⚡ 評級的第一作者，機構未知。可能是新生力量，也可能是匿名/化名。</span>
        <span data-sc>单篇 ⚡ 评级的第一作者，机构未知。可能是新生力量，也可能是匿名/化名。</span>
      </p>
      {scout.watch.length === 0 ? (
        <p class="tv2-empty-mini">No WATCH candidates this cycle.</p>
      ) : (
        <table class="tv2-funnel-table">
          <tbody>
            {scout.watch.map(c => (
              <tr>
                <td><RatingBadge rating={c.topRating} size="sm" /></td>
                <td class="tv2-funnel-name">{c.name}</td>
                <td>
                  <span class="tv2-method-tags">
                    {c.topMethods.map(m => <span class="tv2-method-tag">{m}</span>)}
                  </span>
                </td>
                <td class="tv2-funnel-papers">{c.paperCount90d}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )}
    </section>
  </main>

  <style>
    .talent-v2-page { max-width: 1200px; margin: 0 auto; padding: 2rem 1rem 4rem; }

    /* Funnel summary strip */
    .tv2-funnel {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 0.75rem;
      margin: 0 0 1.75rem;
    }
    .tv2-funnel-tier a {
      display: flex; flex-direction: column; gap: 0.25rem;
      padding: 1rem 1.15rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--surface);
      text-decoration: none;
      color: var(--text-primary);
      position: relative;
      transition: transform 0.12s, box-shadow 0.12s, border-color 0.12s;
    }
    .tv2-funnel-tier a:hover {
      transform: translateY(-1px);
      box-shadow: var(--shadow-card-hover);
    }
    .tv2-funnel-tier[data-tier="hot"]   a { border-color: var(--accent-amber); }
    .tv2-funnel-tier[data-tier="warm"]  a { border-color: var(--accent-cyan); }
    .tv2-funnel-tier[data-tier="watch"] a { border-color: var(--border); }
    .tv2-funnel-tier {
      position: relative;
    }
    .tv2-funnel-dot {
      position: absolute;
      top: 1rem; right: 1rem;
      width: 9px; height: 9px;
      border-radius: 50%;
      z-index: 1;
    }
    .tv2-funnel-tier[data-tier="hot"]   .tv2-funnel-dot { background: var(--accent-amber); box-shadow: 0 0 0 3px var(--accent-amber-bg); }
    .tv2-funnel-tier[data-tier="warm"]  .tv2-funnel-dot { background: var(--accent-cyan);  box-shadow: 0 0 0 3px var(--accent-cyan-bg); }
    .tv2-funnel-tier[data-tier="watch"] .tv2-funnel-dot { background: var(--text-tertiary); }
    .tv2-funnel-count {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 2rem; font-weight: 700; line-height: 1;
      color: var(--text-primary);
    }
    .tv2-funnel-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.78rem; font-weight: 700;
      letter-spacing: 0.18em;
      color: var(--text-primary);
    }
    .tv2-funnel-tier[data-tier="hot"]  .tv2-funnel-label { color: var(--accent-amber); }
    .tv2-funnel-tier[data-tier="warm"] .tv2-funnel-label { color: var(--accent-cyan); }
    .tv2-funnel-sub {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem;
      color: var(--text-tertiary);
      letter-spacing: 0.04em;
    }

    /* Gate criteria card */
    .tv2-gate {
      margin: 0 0 2rem;
      padding: 1.25rem 1.4rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent-amber);
      border-radius: 10px;
    }
    .tv2-gate-title {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 1.05rem; font-weight: 600;
      margin: 0 0 0.85rem;
      color: var(--text-primary);
      display: flex; flex-wrap: wrap; align-items: baseline; gap: 0.5rem;
    }
    .tv2-gate-en {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.72rem;
      color: var(--text-tertiary);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      font-weight: 400;
    }
    .tv2-gate-list {
      list-style: none; padding: 0; margin: 0;
      display: grid; gap: 0.45rem;
    }
    .tv2-gate-list li {
      display: grid;
      grid-template-columns: 180px 160px 1fr;
      gap: 0.85rem;
      align-items: baseline;
      font-size: 0.85rem;
      padding: 0.25rem 0;
      border-bottom: 1px dashed var(--border-subtle);
    }
    .tv2-gate-list li:last-child { border-bottom: none; }
    .tv2-gate-key {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-tertiary);
    }
    .tv2-gate-val {
      font-family: 'IBM Plex Mono', monospace;
      color: var(--accent-cyan);
      font-weight: 700;
      font-size: 0.85rem;
    }
    .tv2-gate-note { color: var(--text-tertiary); font-style: italic; }
    .tv2-gate-strong .tv2-gate-val { color: var(--accent-amber); }

    /* Sections */
    .tv2-section { margin: 2.25rem 0; }
    .tv2-section-h2 {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 1.25rem; font-weight: 600;
      margin: 0 0 1rem; padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
      color: var(--text-primary);
      display: flex; align-items: center; gap: 0.6rem;
    }
    .tv2-tier-dot-h2 {
      width: 11px; height: 11px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .tv2-tier-dot-h2[data-tier="hot"]   { background: var(--accent-amber); box-shadow: 0 0 0 3px var(--accent-amber-bg); }
    .tv2-tier-dot-h2[data-tier="warm"]  { background: var(--accent-cyan);  box-shadow: 0 0 0 3px var(--accent-cyan-bg); }
    .tv2-tier-dot-h2[data-tier="watch"] { background: var(--text-tertiary); }
    .tv2-section-count {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem;
      color: var(--text-tertiary);
      font-weight: 400;
      margin-left: 0.25rem;
    }
    .tv2-section-lede {
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.6;
      margin: 0 0 1rem;
      max-width: 820px;
    }

    /* Method tag chip */
    .tv2-method-tags { display: inline-flex; flex-wrap: wrap; gap: 0.3rem; }
    .tv2-method-tag {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.62rem; font-weight: 600;
      padding: 0.12rem 0.45rem;
      border-radius: 3px;
      background: var(--accent-cyan-bg);
      color: var(--accent-cyan);
      border: 1px solid color-mix(in srgb, var(--accent-cyan) 30%, transparent);
      white-space: nowrap;
    }

    /* Funnel table */
    .tv2-funnel-table {
      width: 100%;
      border-collapse: collapse;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
    }
    .tv2-funnel-table th {
      text-align: left;
      padding: 0.65rem 0.85rem;
      background: var(--surface-2);
      border-bottom: 1px solid var(--border);
      font-size: 0.65rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text-tertiary);
    }
    .tv2-funnel-table td {
      padding: 0.6rem 0.85rem;
      border-bottom: 1px solid var(--border-subtle);
      vertical-align: middle;
    }
    .tv2-funnel-table tr:last-child td { border-bottom: none; }
    .tv2-funnel-table tr:hover td { background: var(--surface-2); }
    .tv2-funnel-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-primary);
      white-space: nowrap;
    }
    .tv2-funnel-aff {
      color: var(--accent-amber);
      text-decoration: none;
      font-weight: 600;
    }
    .tv2-funnel-aff:hover { text-decoration: underline; }
    .tv2-funnel-noaff { color: var(--text-tertiary); font-style: italic; }
    .tv2-funnel-papers {
      text-align: right;
      font-weight: 700;
      color: var(--text-primary);
    }
    .tv2-funnel-missed {
      color: var(--text-secondary);
      font-size: 0.78rem;
    }

    .tv2-empty-mini {
      text-align: center;
      color: var(--text-tertiary);
      font-style: italic;
      padding: 1.5rem;
      background: var(--surface);
      border: 1px dashed var(--border);
      border-radius: 8px;
      margin: 0;
    }

    @media (max-width: 900px) {
      .tv2-funnel { grid-template-columns: 1fr; }
      .tv2-funnel-table { font-size: 0.78rem; }
      .tv2-funnel-table th:nth-child(4), .tv2-funnel-table td:nth-child(4) { display: none; }
    }
    @media (max-width: 768px) {
      .tv2-gate-list li {
        grid-template-columns: 1fr;
        gap: 0.2rem;
        padding: 0.5rem 0;
      }
      .tv2-funnel-table th:nth-child(3), .tv2-funnel-table td:nth-child(3) { display: none; }
    }
  </style>
</BaseLayout>
