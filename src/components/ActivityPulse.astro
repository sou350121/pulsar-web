---
/**
 * ActivityPulse.astro
 * ───────────────────
 * Homepage activity panel — answers "is this site alive + how active?"
 *
 * Shows for each content stream:
 *   - today delta ("+3 today")
 *   - total count
 *   - 7-day sparkline (unicode block chars)
 *   - relative time since last update
 *
 * All metrics computed at build time. No runtime JS.
 * Pipeline health side-effect: if stream silent > 2d, reader + I both see it.
 */
import fs from 'node:fs';
import path from 'node:path';

const base = import.meta.env.BASE_URL;

// ---------------------------------------------------------------------------
// Data loading — local to this component to avoid polluting data.ts
// ---------------------------------------------------------------------------
function readJson<T = unknown>(rel: string): T | null {
  try {
    const p = path.resolve(process.cwd(), 'src/data', rel);
    return JSON.parse(fs.readFileSync(p, 'utf8')) as T;
  } catch {
    return null;
  }
}

const theoryData = readJson<{ articles?: Array<{ date: string }> }>('vla-github-theory.json');
const hotspotsData = readJson<{ reported_papers?: Array<{ date: string; rating?: string }> }>('vla-daily-hotspots.json');
const aiPicksData = readJson<{ daily_picks?: Array<{ date: string; items?: unknown[] }> }>('ai-daily-pick.json');
const aiDeepDiveData = readJson<{ deep_dive_articles?: Array<{ date: string }> }>('ai-app-deep-dive-articles.json');

// Weekly/biweekly — scan filenames
function weeklyDates(): string[] {
  try {
    const dir = path.resolve(process.cwd(), 'src/data');
    const files = fs.readdirSync(dir);
    const dates: string[] = [];
    for (const f of files) {
      const m = f.match(/_(?:ai_)?(?:weekly|biweekly)(?:_reflection)?_(\d{4}-\d{2}-\d{2})\.md$/);
      if (m) dates.push(m[1]);
    }
    return dates.sort().reverse();
  } catch {
    return [];
  }
}

// ---------------------------------------------------------------------------
// Metric computation
// ---------------------------------------------------------------------------
const today = new Date();
const todayStr = today.toISOString().slice(0, 10);
const TZ_OFFSET_MS = 8 * 3600 * 1000; // display in Beijing time

function startOfDay(d: Date): number {
  const copy = new Date(d);
  copy.setUTCHours(0, 0, 0, 0);
  return copy.getTime();
}

function countOnDate(dates: string[], targetDate: string): number {
  return dates.filter((d) => d === targetDate).length;
}

function countInLast7Days(dates: string[]): number[] {
  const bins: number[] = [];
  for (let i = 6; i >= 0; i--) {
    const d = new Date(today.getTime() - i * 86400000);
    const dstr = d.toISOString().slice(0, 10);
    bins.push(countOnDate(dates, dstr));
  }
  return bins;
}

function sparkline(bins: number[]): string {
  const chars = ['▁', '▂', '▃', '▄', '▅', '▆', '▇', '█'];
  const max = Math.max(...bins, 1);
  return bins.map((v) => (v === 0 ? '·' : chars[Math.min(Math.floor((v / max) * (chars.length - 1)), chars.length - 1)])).join('');
}

function latestDate(dates: string[]): string | null {
  if (!dates.length) return null;
  return dates.slice().sort().reverse()[0];
}

function relativeAgo(dateStr: string | null): string {
  if (!dateStr) return '—';
  const then = new Date(dateStr + 'T12:00:00Z').getTime();
  const now = Date.now();
  const diffHr = Math.floor((now - then) / 3600_000);
  if (diffHr < 1) return '刚刚';
  if (diffHr < 24) return `${diffHr}h ago`;
  const days = Math.floor(diffHr / 24);
  if (days < 7) return `${days}d ago`;
  const weeks = Math.floor(days / 7);
  return `${weeks}w ago`;
}

function freshnessClass(dateStr: string | null): 'fresh' | 'ok' | 'stale' {
  if (!dateStr) return 'stale';
  const then = new Date(dateStr + 'T12:00:00Z').getTime();
  const diffDays = (Date.now() - then) / 86_400_000;
  if (diffDays <= 1.5) return 'fresh';
  if (diffDays <= 5) return 'ok';
  return 'stale';
}

// ---------------------------------------------------------------------------
// Per-stream data
// ---------------------------------------------------------------------------
const theoryDates = (theoryData?.articles || []).map((a) => a.date).filter(Boolean);
const hotspotDates = (hotspotsData?.reported_papers || [])
  .filter((p) => p.rating === '⚡' || p.rating === '🔧')
  .map((p) => p.date)
  .filter(Boolean);

// AI picks: daily_picks is one row per day; today delta = count of items on today's row
const aiPickRows = aiPicksData?.daily_picks || [];
const aiPickItemDates: string[] = aiPickRows.flatMap((row) =>
  Array(row.items?.length ?? 0).fill(row.date),
);
const aiDeepDiveDates = (aiDeepDiveData?.deep_dive_articles || []).map((a) => a.date).filter(Boolean);
const aiAllDates = [...aiPickItemDates, ...aiDeepDiveDates];

const weeklyAllDates = weeklyDates();

interface StreamMetric {
  emoji: string;
  label: string;
  todayDelta: number;
  total: number;
  spark: string;
  lastDate: string | null;
  fresh: 'fresh' | 'ok' | 'stale';
  href: string;
  feedHref: string;
}

const streams: StreamMetric[] = [
  {
    emoji: '🧠',
    label: 'VLA 新文章',
    todayDelta: countOnDate(theoryDates, todayStr),
    total: theoryDates.length,
    spark: sparkline(countInLast7Days(theoryDates)),
    lastDate: latestDate(theoryDates),
    fresh: freshnessClass(latestDate(theoryDates)),
    href: `${base}/vla-deepdive`,
    feedHref: `${base}/rss/vla-theory.xml`,
  },
  {
    emoji: '⚡',
    label: 'VLA 每日信号',
    todayDelta: countOnDate(hotspotDates, todayStr),
    total: hotspotDates.length,
    spark: sparkline(countInLast7Days(hotspotDates)),
    lastDate: latestDate(hotspotDates),
    fresh: freshnessClass(latestDate(hotspotDates)),
    href: `${base}/daily`,
    feedHref: `${base}/rss/vla-daily.xml`,
  },
  {
    emoji: '📘',
    label: 'AI 每日',
    todayDelta: countOnDate(aiAllDates, todayStr),
    total: aiAllDates.length,
    spark: sparkline(countInLast7Days(aiAllDates)),
    lastDate: latestDate(aiAllDates),
    fresh: freshnessClass(latestDate(aiAllDates)),
    href: `${base}/ai-deepdive`,
    feedHref: `${base}/rss/ai-daily.xml`,
  },
  {
    emoji: '📚',
    label: '周/双周报告',
    todayDelta: 0, // weekly granularity — use 7d count instead
    total: weeklyAllDates.length,
    spark: sparkline(countInLast7Days(weeklyAllDates)),
    lastDate: latestDate(weeklyAllDates),
    fresh: freshnessClass(latestDate(weeklyAllDates)),
    href: `${base}/reports`,
    feedHref: `${base}/rss/weekly.xml`,
  },
];

const overallFresh = streams.some((s) => s.fresh === 'fresh');
---

<section class="activity-pulse" aria-label="系统活性">
  <div class="container">
    <div class="pulse-box">
      <header class="pulse-header">
        <span class={`pulse-dot ${overallFresh ? 'live' : 'idle'}`} aria-hidden="true"></span>
        <span class="pulse-title">
          <span data-tc>LIVE · Pulsar 照見 每日自動更新</span>
          <span data-sc>LIVE · Pulsar 照见 每日自动更新</span>
        </span>
        <a class="pulse-subscribe" href={`${base}/subscribe`}>
          📡 <span data-tc>訂閱</span><span data-sc>订阅</span>
        </a>
      </header>

      <ul class="pulse-streams" role="list">
        {streams.map((s) => (
          <li class={`pulse-row pulse-row--${s.fresh}`}>
            <a class="pulse-row-main" href={s.href}>
              <span class="pulse-emoji" aria-hidden="true">{s.emoji}</span>
              <span class="pulse-label">{s.label}</span>
              <span class="pulse-delta">
                {s.todayDelta > 0 ? `今天 +${s.todayDelta}` : s.total > 0 ? '' : '—'}
              </span>
              <span class="pulse-total">
                <span data-tc>總 {s.total}</span>
                <span data-sc>总 {s.total}</span>
              </span>
              <span class="pulse-spark" title="last 7 days">{s.spark}</span>
              <span class="pulse-ago">{relativeAgo(s.lastDate)}</span>
            </a>
            <a class="pulse-feed" href={s.feedHref} title="RSS feed" aria-label={`${s.label} RSS`}>
              RSS
            </a>
          </li>
        ))}
      </ul>

      <footer class="pulse-footer">
        <span class="pulse-foot-text">
          <span data-tc>每日自動更新 · 最後建置 {new Date().toISOString().slice(0, 16).replace('T', ' ')} UTC</span>
          <span data-sc>每日自动更新 · 最后建置 {new Date().toISOString().slice(0, 16).replace('T', ' ')} UTC</span>
        </span>
        <a class="pulse-opml" href={`${base}/rss/opml.xml`}>
          <span data-tc>一鍵 OPML 導入全部 feed</span>
          <span data-sc>一键 OPML 导入全部 feed</span>
        </a>
      </footer>
    </div>
  </div>
</section>

<style>
  .activity-pulse {
    padding: 1.25rem 0;
  }
  .pulse-box {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem 1.25rem;
  }
  .pulse-header {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding-bottom: 0.6rem;
    border-bottom: 1px solid var(--border-subtle);
    margin-bottom: 0.5rem;
  }
  .pulse-dot {
    width: 8px; height: 8px; border-radius: 50%;
    flex-shrink: 0;
  }
  .pulse-dot.live  { background: #22c55e; box-shadow: 0 0 8px rgba(34,197,94,0.6); animation: pulse 2s ease-in-out infinite; }
  .pulse-dot.idle  { background: #9ca3af; }
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50%      { opacity: 0.4; }
  }
  .pulse-title {
    flex: 1;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-primary);
    letter-spacing: 0.02em;
  }
  .pulse-subscribe {
    font-size: 0.82rem;
    padding: 0.3rem 0.7rem;
    border-radius: 6px;
    background: var(--accent-amber-bg);
    color: var(--accent-amber);
    text-decoration: none;
    font-weight: 500;
    transition: background 0.15s, color 0.15s;
  }
  .pulse-subscribe:hover { background: var(--accent-amber); color: #fff; }

  .pulse-streams {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }
  .pulse-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.3rem;
    border-radius: 6px;
    transition: background 0.12s;
  }
  .pulse-row:hover { background: var(--surface-2); }
  .pulse-row-main {
    flex: 1;
    display: grid;
    grid-template-columns: 24px minmax(100px, 1fr) minmax(70px, auto) minmax(70px, auto) minmax(80px, 100px) minmax(70px, auto);
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text-primary);
    font-size: 0.85rem;
  }
  .pulse-emoji { font-size: 1.1rem; text-align: center; }
  .pulse-label { font-weight: 500; color: var(--text-primary); }
  .pulse-delta {
    font-size: 0.78rem;
    color: var(--accent-amber);
    font-weight: 500;
    text-align: right;
  }
  .pulse-total {
    font-size: 0.78rem;
    color: var(--text-tertiary);
    text-align: right;
  }
  .pulse-spark {
    font-family: var(--font-mono, 'Menlo', monospace);
    font-size: 0.9rem;
    color: var(--accent-cyan);
    letter-spacing: 0.02em;
    text-align: center;
  }
  .pulse-ago {
    font-size: 0.78rem;
    text-align: right;
  }
  .pulse-row--fresh .pulse-ago { color: #16a34a; }
  .pulse-row--ok    .pulse-ago { color: var(--text-secondary); }
  .pulse-row--stale .pulse-ago { color: #dc2626; font-weight: 500; }

  .pulse-feed {
    font-size: 0.7rem;
    padding: 0.2rem 0.45rem;
    border-radius: 4px;
    background: var(--surface-2);
    color: var(--text-tertiary);
    text-decoration: none;
    border: 1px solid var(--border-subtle);
    flex-shrink: 0;
  }
  .pulse-feed:hover {
    background: var(--accent-cyan-bg);
    color: var(--accent-cyan);
    border-color: var(--accent-cyan);
  }

  .pulse-footer {
    padding-top: 0.6rem;
    margin-top: 0.5rem;
    border-top: 1px solid var(--border-subtle);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.8rem;
    font-size: 0.75rem;
  }
  .pulse-foot-text { color: var(--text-tertiary); }
  .pulse-opml { color: var(--accent-cyan); text-decoration: none; font-weight: 500; }
  .pulse-opml:hover { text-decoration: underline; }

  @media (max-width: 700px) {
    .pulse-row-main {
      grid-template-columns: 24px 1fr auto auto;
      font-size: 0.78rem;
    }
    .pulse-total, .pulse-spark { display: none; }
    .pulse-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.3rem;
    }
  }
</style>
