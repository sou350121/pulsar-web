---
/**
 * DigestFeed.astro
 *
 * Bloomberg Terminal meets Telegram channel — a dense, scannable unified
 * briefing feed that renders AI picks and VLA papers as a flat list of rows.
 *
 * Props:
 *   date      — Display date string, e.g. "2026-03-01"
 *   aiItems   — Daily AI pick items
 *   vlaItems  — VLA paper items (Qwen3.5-Plus rated)
 *   showLinks — Wrap rows in <a> tags (default true)
 *   maxItems  — Max items per section (default 12)
 *   title     — Override header wordmark text (optional)
 */

import './DigestFeed.css';

interface DigestItem {
  title:   string;
  summary: string;
  /** '⚡' | '🔧' | '📖' | '❌' or longer form like '🔧 工具' */
  rating:  string;
  source:  string;
  url:     string;
  domain:  'ai' | 'vla';
}

interface Props {
  date:            string;
  aiItems:         DigestItem[];
  vlaItems:        DigestItem[];
  deepDiveItems?:  DigestItem[];
  showLinks?:      boolean;
  maxItems?:       number;
  title?:          string;
}

const {
  date,
  aiItems,
  vlaItems,
  deepDiveItems = [],
  showLinks = true,
  maxItems  = 12,
  title,
} = Astro.props;

/**
 * Extract the leading emoji from a rating string like '🔧 工具'.
 * Uses Unicode regex so multi-byte emoji (⚡, 🔧, 📖) are captured correctly.
 * Falls back to the first Unicode code point via spread iterator.
 */
function ratingEmoji(rating: string): string {
  const m = rating.match(/(\p{Emoji_Presentation}|\p{Extended_Pictographic})/u);
  if (m) return m[0];
  // Spread to get the first Unicode codepoint (handles multi-byte correctly)
  return [...rating][0] ?? rating.slice(0, 1);
}

/**
 * Map a rating to the BEM modifier that drives left-border colour on hover.
 */
function ratingModifier(rating: string): string {
  const emoji = ratingEmoji(rating);
  if (emoji === '⚡') return 'digest-item--flash';
  if (emoji === '🔧') return 'digest-item--wrench';
  if (emoji === '📖') return 'digest-item--book';
  return 'digest-item--neutral';
}

/** Normalise a source string to ALLCAPS, max 8 chars for the tag column. */
function sourceTag(src: string): string {
  return (src ?? 'SRC').toUpperCase().slice(0, 8);
}

const aiSlice       = aiItems.slice(0, maxItems);
const vlaSlice      = vlaItems.slice(0, maxItems);
const deepDiveSlice = deepDiveItems.slice(0, maxItems);

const hasAi       = aiSlice.length       > 0;
const hasVla      = vlaSlice.length      > 0;
const hasDeepDive = deepDiveSlice.length > 0;

const wordmark = title ?? 'PULSAR DIGEST';
---

<div class="digest-feed" role="feed" aria-label={`Pulsar Digest — ${date}`}>

  <!-- ── HEADER ── -->
  <header class="digest-header" aria-label="Digest header">
    <time class="digest-header-date" datetime={date}>{date}</time>

    <div class="digest-header-wordmark" aria-label={wordmark}>
      {wordmark}
      <span class="digest-header-zh">照見系統</span>
    </div>

    <span class="digest-header-live" aria-label="Live feed">
      <span class="digest-live-dot" aria-hidden="true"></span>
      LIVE
    </span>
  </header>

  <!-- ── AI LINE ── -->
  {hasAi && (
    <section aria-labelledby="digest-section-ai">
      <div class="digest-section-header digest-section--ai">
        <span class="digest-section-label" id="digest-section-ai">
          AI APP 線&nbsp;&middot;&nbsp;行業&nbsp;·&nbsp;工具&nbsp;·&nbsp;趨勢
        </span>
        <span class="digest-section-meta" aria-hidden="true">
          {aiSlice.length}&thinsp;條
        </span>
      </div>

      <ul class="digest-list" role="list">
        {aiSlice.map((item) => {
          const emoji    = ratingEmoji(item.rating);
          const modifier = ratingModifier(item.rating);
          const tag      = sourceTag(item.source);
          const rowClass = `digest-item digest-item--ai ${modifier}`;

          return (
            <li class={rowClass}>
              {showLinks ? (
                <a
                  class="digest-item-link"
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  title={item.title}
                  aria-label={`${emoji} ${item.title} — ${item.summary}`}
                >
                  <span class="digest-rating" aria-hidden="true">{emoji}</span>
                  <span class="digest-content">
                    <span class="digest-title">{item.title}</span>
                    <span class="digest-sep" aria-hidden="true">—</span>
                    <span class="digest-summary">{item.summary}</span>
                  </span>
                  <span class="digest-source" aria-label={`來源: ${item.source}`}>
                    {tag}
                  </span>
                </a>
              ) : (
                <div class="digest-item-link" aria-label={`${emoji} ${item.title} — ${item.summary}`}>
                  <span class="digest-rating" aria-hidden="true">{emoji}</span>
                  <span class="digest-content">
                    <span class="digest-title">{item.title}</span>
                    <span class="digest-sep" aria-hidden="true">—</span>
                    <span class="digest-summary">{item.summary}</span>
                  </span>
                  <span class="digest-source" aria-label={`來源: ${item.source}`}>
                    {tag}
                  </span>
                </div>
              )}
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {!hasAi && (
    <div class="digest-empty" role="status">
      — AI 線今日無資料 —
    </div>
  )}

  <!-- ── VLA LINE ── -->
  {hasVla && (
    <section aria-labelledby="digest-section-vla">
      <div class="digest-section-header digest-section--vla">
        <span class="digest-section-label" id="digest-section-vla">
          VLA 線&nbsp;&middot;&nbsp;cs.RO&nbsp;·&nbsp;cs.AI&nbsp;·&nbsp;cs.LG
        </span>
        <span class="digest-section-meta" aria-hidden="true">
          Qwen3.5-Plus&nbsp;·&nbsp;{vlaSlice.length}&thinsp;篇
        </span>
      </div>

      <ul class="digest-list" role="list">
        {vlaSlice.map((item) => {
          const emoji    = ratingEmoji(item.rating);
          const modifier = ratingModifier(item.rating);
          const tag      = sourceTag(item.source);
          const rowClass = `digest-item digest-item--vla ${modifier}`;

          return (
            <li class={rowClass}>
              {showLinks ? (
                <a
                  class="digest-item-link"
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  title={item.title}
                  aria-label={`${emoji} ${item.title} — ${item.summary}`}
                >
                  <span class="digest-rating" aria-hidden="true">{emoji}</span>
                  <span class="digest-content">
                    <span class="digest-title">{item.title}</span>
                    <span class="digest-sep" aria-hidden="true">—</span>
                    <span class="digest-summary">{item.summary}</span>
                  </span>
                  <span class="digest-source" aria-label={`來源: ${item.source}`}>
                    {tag}
                  </span>
                </a>
              ) : (
                <div class="digest-item-link" aria-label={`${emoji} ${item.title} — ${item.summary}`}>
                  <span class="digest-rating" aria-hidden="true">{emoji}</span>
                  <span class="digest-content">
                    <span class="digest-title">{item.title}</span>
                    <span class="digest-sep" aria-hidden="true">—</span>
                    <span class="digest-summary">{item.summary}</span>
                  </span>
                  <span class="digest-source" aria-label={`來源: ${item.source}`}>
                    {tag}
                  </span>
                </div>
              )}
            </li>
          );
        })}
      </ul>
    </section>
  )}

  {!hasVla && (
    <div class="digest-empty" role="status">
      — VLA 線今日無資料 —
    </div>
  )}

  <!-- ── DEEP DIVE LINE ── -->
  {hasDeepDive && (
    <section aria-labelledby="digest-section-deepdive">
      <div class="digest-section-header digest-section--deepdive">
        <span class="digest-section-label" id="digest-section-deepdive">
          DEEP DIVE 深析&nbsp;&middot;&nbsp;新增文章&nbsp;·&nbsp;近 3 天
        </span>
        <span class="digest-section-meta" aria-hidden="true">
          {deepDiveSlice.length}&thinsp;篇
        </span>
      </div>

      <ul class="digest-list" role="list">
        {deepDiveSlice.map((item) => {
          const emoji    = ratingEmoji(item.rating);
          const modifier = ratingModifier(item.rating);
          const tag      = sourceTag(item.source);
          const domainMod = item.domain === 'vla' ? 'digest-item--vla' : 'digest-item--ai';
          const rowClass = `digest-item ${domainMod} ${modifier} digest-item--deepdive`;

          return (
            <li class={rowClass}>
              {showLinks ? (
                <a
                  class="digest-item-link"
                  href={item.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  title={item.title}
                  aria-label={`${emoji} ${item.title}`}
                >
                  <span class="digest-rating" aria-hidden="true">{emoji}</span>
                  <span class="digest-content">
                    <span class="digest-title">{item.title}</span>
                    <span class="digest-sep" aria-hidden="true">—</span>
                    <span class="digest-summary digest-summary--type">{item.summary}</span>
                  </span>
                  <span class="digest-source" aria-label={`來源: ${item.source}`}>
                    {tag}
                  </span>
                </a>
              ) : (
                <div class="digest-item-link" aria-label={`${emoji} ${item.title}`}>
                  <span class="digest-rating" aria-hidden="true">{emoji}</span>
                  <span class="digest-content">
                    <span class="digest-title">{item.title}</span>
                    <span class="digest-sep" aria-hidden="true">—</span>
                    <span class="digest-summary digest-summary--type">{item.summary}</span>
                  </span>
                  <span class="digest-source" aria-label={`來源: ${item.source}`}>
                    {tag}
                  </span>
                </div>
              )}
            </li>
          );
        })}
      </ul>
    </section>
  )}

</div>
