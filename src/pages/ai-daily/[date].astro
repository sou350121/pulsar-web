---
/**
 * src/pages/ai-daily/[date].astro
 * Dynamic route — individual day view for AI daily picks.
 * Generates one page per date found in ai-daily-pick.json.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import RatingBadge from '../../components/RatingBadge.astro';
import DigestFeed from '../../components/DigestFeed.astro';
import { loadAIDailyPicks } from '../../utils/data';

// getStaticPaths — required for Astro static output
export async function getStaticPaths() {
  const picks = loadAIDailyPicks(90);  // generate up to 90 day pages
  return picks.map(day => ({
    params: { date: day.date },
    props:  { day },
  }));
}

const { day } = Astro.props;
const { date, items } = day;
const base = import.meta.env.BASE_URL;

// Group items by rating for the summary bar
const byRating: Record<string, typeof items> = {};
for (const item of items) {
  (byRating[item.rating] ??= []).push(item);
}

// Load all days to find actual prev/next dates and their counts
const allDays = loadAIDailyPicks(90);
const allDates = allDays.map(d => d.date).sort();
const idx = allDates.indexOf(date);
const prevDate = idx > 0 ? allDates[idx - 1] : null;
const nextDate = idx < allDates.length - 1 ? allDates[idx + 1] : null;

// Count articles for prev/next nav boxes
const prevCount = prevDate ? (allDays.find(d => d.date === prevDate)?.items.length ?? 0) : 0;
const nextCount = nextDate ? (allDays.find(d => d.date === nextDate)?.items.length ?? 0) : 0;

// Format date for breadcrumb display
function formatDateDisplay(d: string): string {
  const [y, m, day] = d.split('-');
  return `${y} 年 ${parseInt(m, 10)} 月 ${parseInt(day, 10)} 日`;
}
---

<BaseLayout
  title={`AI 日報 ${date}`}
  description={`${date} AI 每日精選 — ${items.length} 篇，含 VLA、應用、模型最新動態`}
>
  <!-- ── Detail breadcrumb ── -->
  <nav class="detail-breadcrumb page-container" aria-label="麵包屑">
    <a href={`${base}/daily`} class="bc-link"><span data-tc>日報</span><span data-sc>日报</span></a>
    <span class="bc-sep">›</span>
    <a href={`${base}/ai-daily`} class="bc-link bc-link--ai"><span data-tc>AI App 線</span><span data-sc>AI App 线</span></a>
    <span class="bc-sep">›</span>
    <span class="bc-current">{date}</span>
  </nav>

  <!-- ── Detail domain bar (cross-link to VLA same day) ── -->
  <div class="detail-domain-bar page-container">
    <span class="ddb-label">AI App 線</span>
    <span class="ddb-sep">·</span>
    <a href={`${base}/vla/${date}`} class="ddb-cross"><span data-tc>查看同日 VLA 報告 →</span><span data-sc>查看同日 VLA 报告 →</span></a>
  </div>

  <!-- Telegram-style digest at top — all items in a dense list -->
  <section class="digest-block" aria-label="今日 AI 情報摘要">
    <div class="container">
      <DigestFeed
        date={date}
        title="AI APP 日報"
        aiItems={items.map(i => ({ ...i, domain: 'ai' as const }))}
        vlaItems={[]}
      />
    </div>
  </section>

  <div class="page-container section">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href={base} class="breadcrumb-link"><span data-tc>首頁</span><span data-sc>首页</span></a>
      <span class="breadcrumb-sep">/</span>
      <a href={`${base}/ai-daily`} class="breadcrumb-link"><span data-tc>AI 日報</span><span data-sc>AI 日报</span></a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">{date}</span>
    </nav>

    <!-- Header -->
    <div class="mb-8">
      <time datetime={date} class="font-ibm-plex-mono text-pulsar-muted text-sm">
        {date}
      </time>
      <h1 class="font-lora text-3xl font-bold text-pulsar-text mt-1 mb-4">
        AI 日報
      </h1>

      <!-- Rating summary row -->
      <div class="flex flex-wrap gap-2 items-center">
        {Object.entries(byRating).map(([rating, rItems]) => (
          <RatingBadge rating={rating} label={`${rItems.length} 篇`} size="sm" />
        ))}
        <span class="text-pulsar-muted text-xs font-ibm-plex-mono ml-2">
          共 {items.length} 篇
        </span>
      </div>
    </div>

    <!-- ⚡ Breakthroughs first (if any) -->
    {(byRating['⚡'] ?? []).length > 0 && (
      <div class="mb-8">
        <h2 class="font-lora text-xl font-semibold text-pulsar-amber mb-4 flex items-center gap-2">
          ⚡ 突破
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {(byRating['⚡'] ?? []).map(item => (
            <ArticleCard
              title={item.title}
              summary={item.summary}
              rating={item.rating}
              source={item.source}
              date={date}
              domain={item.domain ?? 'ai'}
              url={item.url}
            />
          ))}
        </div>
      </div>
    )}

    <!-- 🔧 Practical -->
    {(byRating['🔧'] ?? []).length > 0 && (
      <div class="mb-8">
        <h2 class="font-lora text-xl font-semibold text-pulsar-cyan mb-4">
          🔧 <span data-tc>實用</span><span data-sc>实用</span>
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {(byRating['🔧'] ?? []).map(item => (
            <ArticleCard
              title={item.title}
              summary={item.summary}
              rating={item.rating}
              source={item.source}
              date={date}
              domain={item.domain ?? 'ai'}
              url={item.url}
            />
          ))}
        </div>
      </div>
    )}

    <!-- 📖 Background -->
    {(byRating['📖'] ?? []).length > 0 && (
      <div class="mb-8">
        <h2 class="font-lora text-xl font-semibold text-pulsar-muted mb-4">
          📖 <span data-tc>背景閱讀</span><span data-sc>背景阅读</span>
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {(byRating['📖'] ?? []).map(item => (
            <ArticleCard
              title={item.title}
              summary={item.summary}
              rating={item.rating}
              source={item.source}
              date={date}
              domain={item.domain ?? 'ai'}
              url={item.url}
            />
          ))}
        </div>
      </div>
    )}

    <!-- ── Pagination ── -->
    <hr class="pulsar-divider" />

    <nav class="pagination-nav" aria-label="日報導航">
      <!-- Prev box -->
      <div class="pagination-prev-slot">
        {prevDate ? (
          <a href={`${base}/ai-daily/${prevDate}`} class="pagination-box pagination-box-prev">
            <span class="pagination-dir">← 前一天</span>
            <span class="pagination-date">{prevDate}</span>
            {prevCount > 0 && (
              <span class="pagination-count">{prevCount} 篇</span>
            )}
          </a>
        ) : (
          <div class="pagination-box pagination-box-disabled" aria-hidden="true">
            <span class="pagination-dir">← 前一天</span>
            <span class="pagination-date">—</span>
          </div>
        )}
      </div>

      <!-- Center: back to list -->
      <div class="pagination-center">
        <a href={`${base}/ai-daily`} class="pagination-list-btn">
          <span data-tc>返回日報列表</span><span data-sc>返回日报列表</span>
        </a>
      </div>

      <!-- Next box -->
      <div class="pagination-next-slot">
        {nextDate ? (
          <a href={`${base}/ai-daily/${nextDate}`} class="pagination-box pagination-box-next">
            <span class="pagination-dir">下一天 →</span>
            <span class="pagination-date">{nextDate}</span>
            {nextCount > 0 && (
              <span class="pagination-count">{nextCount} 篇</span>
            )}
          </a>
        ) : (
          <div class="pagination-box pagination-box-disabled" aria-hidden="true">
            <span class="pagination-dir">下一天 →</span>
            <span class="pagination-date">—</span>
          </div>
        )}
      </div>
    </nav>

    <!-- Breadcrumb trail below pagination -->
    <div class="pagination-breadcrumb">
      <a href={base} class="pag-bc-link"><span data-tc>首頁</span><span data-sc>首页</span></a>
      <span class="pag-bc-sep">/</span>
      <a href={`${base}/ai-daily`} class="pag-bc-link"><span data-tc>AI 日報</span><span data-sc>AI 日报</span></a>
      <span class="pag-bc-sep">/</span>
      <span class="pag-bc-current">{date}</span>
    </div>
  </div>
</BaseLayout>

<style>
/* ── Breadcrumb (top) ── */
.breadcrumb {
  margin-bottom: 1.5rem;
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.72rem;
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  gap: 0.25rem;
  flex-wrap: wrap;
}

.breadcrumb-link {
  color: var(--text-secondary);
  text-decoration: none;
  transition: color 0.2s;
}
.breadcrumb-link:hover {
  color: var(--text-primary);
  opacity: 1;
}

.breadcrumb-sep {
  color: var(--border);
  margin: 0 0.2rem;
}

.breadcrumb-current {
  color: var(--text-primary);
  font-weight: 600;
}

/* ── Pagination nav ── */
.pagination-nav {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 1rem;
  align-items: center;
  margin-bottom: 1.5rem;
}

.pagination-prev-slot { display: flex; justify-content: flex-start; }
.pagination-next-slot { display: flex; justify-content: flex-end; }
.pagination-center    { display: flex; justify-content: center; }

/* Shared box style */
.pagination-box {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
  padding: 0.85rem 1.1rem;
  border-radius: 10px;
  border: 1px solid var(--border);
  background: var(--surface);
  text-decoration: none;
  color: inherit;
  min-width: 130px;
  max-width: 200px;
  transition:
    border-color 0.2s ease,
    background 0.2s ease,
    box-shadow 0.2s ease,
    transform 0.15s ease;
}

/* Prev: amber accent on left edge */
.pagination-box-prev {
  border-left: 3px solid var(--accent-amber);
}
.pagination-box-prev:hover {
  background: var(--surface-2);
  box-shadow: var(--shadow-card);
  transform: translateX(-2px);
}
.pagination-box-prev:hover .pagination-date {
  color: var(--accent-amber);
}

/* Next: amber accent on right edge */
.pagination-box-next {
  border-right: 3px solid var(--accent-amber);
  text-align: right;
  align-items: flex-end;
}
.pagination-box-next:hover {
  background: var(--surface-2);
  box-shadow: var(--shadow-card);
  transform: translateX(2px);
}
.pagination-box-next:hover .pagination-date {
  color: var(--accent-amber);
}

/* Disabled (no prev/next) */
.pagination-box-disabled {
  opacity: 0.35;
  cursor: default;
  pointer-events: none;
}

.pagination-dir {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.65rem;
  letter-spacing: 0.08em;
  color: var(--text-tertiary);
  text-transform: uppercase;
}

.pagination-date {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--text-primary);
  letter-spacing: 0.02em;
  transition: color 0.2s ease;
}

.pagination-count {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.65rem;
  color: var(--accent-amber);
  font-weight: 600;
  background: var(--accent-amber-bg);
  padding: 1px 6px;
  border-radius: 3px;
  width: fit-content;
}

/* Center pill button */
.pagination-list-btn {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: var(--text-secondary);
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-radius: 9999px;
  padding: 0.5rem 1.1rem;
  text-decoration: none;
  white-space: nowrap;
  transition: background 0.2s ease, color 0.2s ease, border-color 0.2s ease;
}

.pagination-list-btn:hover {
  background: var(--accent-amber-bg);
  border-color: var(--accent-amber);
  color: var(--accent-amber);
  opacity: 1;
}

/* Bottom breadcrumb trail */
.pagination-breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.65rem;
  color: var(--text-tertiary);
  flex-wrap: wrap;
}

.pag-bc-link {
  color: var(--text-tertiary);
  text-decoration: none;
  transition: color 0.2s;
}
.pag-bc-link:hover {
  color: var(--text-secondary);
  opacity: 1;
}

.pag-bc-sep {
  color: var(--border);
  margin: 0 0.2rem;
}

.pag-bc-current {
  color: var(--text-secondary);
  font-weight: 600;
}

/* ── Detail breadcrumb ── */
.detail-breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  padding-top: 24px;
  padding-bottom: 0;
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 0.65rem;
  color: var(--text-tertiary);
}
.bc-link {
  color: var(--text-tertiary);
  text-decoration: none;
  transition: color 0.15s;
}
.bc-link:hover { color: var(--text-secondary); }
.bc-link--ai:hover { color: var(--accent-amber); }
.bc-sep { opacity: 0.4; }
.bc-current { color: var(--text-secondary); font-weight: 600; }

/* ── Detail domain bar ── */
.detail-domain-bar {
  display: flex;
  align-items: center;
  gap: 8px;
  padding-top: 8px;
  padding-bottom: 8px;
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 0.65rem;
  border-bottom: 1px solid var(--border-subtle);
  margin-bottom: 8px;
}
.ddb-label {
  font-weight: 700;
  color: var(--accent-amber);
  letter-spacing: 0.08em;
  text-transform: uppercase;
}
.ddb-sep { color: var(--text-tertiary); opacity: 0.4; }
.ddb-cross {
  color: var(--text-tertiary);
  text-decoration: none;
  transition: color 0.15s;
}
.ddb-cross:hover { color: var(--accent-cyan); }

/* ── Mobile: stack pagination vertically ── */
@media (max-width: 640px) {
  .pagination-nav {
    grid-template-columns: 1fr;
    grid-template-rows: auto auto auto;
  }

  .pagination-prev-slot,
  .pagination-next-slot,
  .pagination-center {
    justify-content: stretch;
  }

  .pagination-center {
    order: 2;
  }

  .pagination-prev-slot { order: 1; }
  .pagination-next-slot { order: 3; }

  .pagination-box {
    max-width: 100%;
    width: 100%;
  }

  .pagination-box-next {
    align-items: flex-start;
    text-align: left;
  }
}
</style>
