                  <div class="entity-row">
                    <div class="entity-row-meta">
                      <span class="entity-name">{name}</span>
                      <span class="entity-count">{count} 信號</span>
                    </div>
                    <div class="entity-bar-track">
                      <div class="entity-bar-fill" style={`width:${pct}%;`}></div>
                    </div>
                  </div>
