---
/**
 * SubdirectionCard.astro
 * Method family card for /talent/subdirections.
 * Reuses .card class + rating tokens; no new CSS.
 */
import type { SubdirectionRecord } from '../utils/talent';
import { slugifyName } from '../utils/talent.ts';
import RatingBadge from './RatingBadge.astro';

interface Props {
  record: SubdirectionRecord;
}
const { record } = Astro.props;
const base = import.meta.env.BASE_URL;

const domainTag = record.domain === 'vla' ? 'tag-vla' : 'tag-ai';
const domainLabel = record.domain === 'vla' ? 'VLA' : 'AI App';

// Acceleration display
const accelPct = Math.round(record.acceleration * 100);
const accelSign = accelPct > 0 ? '+' : '';
const accelColor =
  record.acceleration > 0.15 ? 'var(--accent-amber)' :
  record.acceleration < -0.15 ? '#C94040' :
  'var(--text-muted)';

const statusLabel: Record<string, string> = {
  accelerating:   'Accelerating',
  declining:      'Declining',
  stable:         'Stable',
  low_confidence: 'Low signal',
};
---

<article id={`fam-${record.family}`} class="card group flex gap-4">
  <!-- Left gutter: big accel % anchors the eye across many cards -->
  <div
    class="flex-shrink-0 w-16 text-right font-ibm-plex-mono font-bold text-2xl leading-none pt-1"
    style={`color: ${accelColor}`}
    title={`${statusLabel[record.status] ?? record.status}`}
  >
    {accelSign}{accelPct}%
    <div class="text-[0.6rem] font-normal uppercase tracking-wider mt-1 text-pulsar-muted">
      {record.velocity7d}/{record.velocityPrior7d}
    </div>
  </div>

  <!-- Right column: domain, name, top labs, evidence -->
  <div class="flex flex-col gap-3 flex-1 min-w-0">
    <div class="flex items-center gap-2 flex-wrap">
      <span class:list={['tag', domainTag]}>{domainLabel}</span>
      <h3 class="font-lora font-semibold text-pulsar-text text-base leading-snug flex-1 min-w-0">
        {record.displayName}
        <span class="font-ibm-plex-mono text-xs text-pulsar-muted ml-1">
          {record.family}
        </span>
      </h3>
    </div>

  <!-- Top labs in this method -->
  {record.topLabs.length > 0 && (
    <div class="flex flex-wrap gap-1 mt-1">
      <span class="text-xs text-pulsar-muted font-ibm-plex-mono uppercase tracking-wide self-center mr-1">
        <span data-tc>頂尖實驗室：</span><span data-sc>顶尖实验室：</span>
      </span>
      {record.topLabs.map(lab => (
        <a
          href={`${base}/talent/labs/#lab-${slugifyName(lab)}`}
          class="tag tag-affiliation font-ibm-plex-mono text-xs hover:text-pulsar-amber transition-colors"
        >{lab}</a>
      ))}
    </div>
  )}

  <!-- Evidence: up to 3 papers -->
  {record.evidence.length > 0 && (
    <div class="flex flex-col gap-2 mt-1 pt-2 border-t border-pulsar-border">
      <span class="text-xs font-ibm-plex-mono text-pulsar-muted uppercase tracking-wide">
        <span data-tc>佐證論文</span><span data-sc>佐证论文</span>
      </span>
      {record.evidence.map(ev => (
        <a
          href={ev.url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-start gap-2 text-xs text-pulsar-text hover:text-pulsar-amber transition-colors leading-relaxed"
        >
          <RatingBadge rating={ev.rating} size="sm" />
          <span class="line-clamp-2">{ev.title}</span>
        </a>
      ))}
    </div>
  )}

  {record.evidence.length === 0 && (
    <p class="text-xs text-pulsar-muted italic">
      No evidence papers matched in the last 90 days. This family is tracked
      mechanically — when the threshold fires, papers will appear here.
    </p>
  )}
  </div>
</article>
