</style>

<script>
// Module filter
const filter = document.getElementById('mod-filter');
const browse = document.getElementById('mod-browse');
if (filter && browse) {
  filter.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest<HTMLButtonElement>('.mf-btn');
    if (!btn) return;
    const mod = btn.dataset.mod ?? 'all';
    filter.querySelectorAll('.mf-btn').forEach(b => {
      b.classList.remove('active');
      b.setAttribute('aria-selected', 'false');
    });
    btn.classList.add('active');
    btn.setAttribute('aria-selected', 'true');
    browse.querySelectorAll<HTMLElement>('.mod-group').forEach(g => {
      g.hidden = mod !== 'all' && g.dataset.mod !== mod;
    });
  });
}

// Deep dive expand
const expandBtn = document.getElementById('dd-expand-btn');
if (expandBtn) {
  expandBtn.addEventListener('click', () => {
    document.querySelectorAll('.dd-row--hidden').forEach(el => {
      el.classList.remove('dd-row--hidden');
    });
    expandBtn.style.display = 'none';
  });
}

// Deep dive tag filter
const tagFilter = document.getElementById('dd-tag-filter');
const ddList = document.getElementById('dd-list');
if (tagFilter && ddList) {
  tagFilter.addEventListener('click', (e) => {
    const btn = (e.target as Element).closest<HTMLButtonElement>('.dtf-btn');
    if (!btn) return;
    const tag = btn.dataset.tag ?? 'all';
    tagFilter.querySelectorAll('.dtf-btn').forEach(b => {
      b.classList.remove('active');
      b.setAttribute('aria-selected', 'false');
    });
    btn.classList.add('active');
    btn.setAttribute('aria-selected', 'true');

    // When filtering by tag, first expand all rows so hidden ones become visible
    if (tag !== 'all' && expandBtn) {
      document.querySelectorAll('.dd-row--hidden').forEach(el => {
        el.classList.remove('dd-row--hidden');
      });
      expandBtn.style.display = 'none';
    }

    ddList.querySelectorAll<HTMLElement>('.dd-row').forEach(row => {
      if (tag === 'all') {
        row.classList.remove('dd-row--tag-hidden');
      } else {
        const rowTags = (row.dataset.tags ?? '').split(',');
        row.classList.toggle('dd-row--tag-hidden', !rowTags.includes(tag));
      }
    });
  });
}
</script>
