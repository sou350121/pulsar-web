---
/**
 * src/pages/index.astro
 * ---------------------
 * Pulsar Homepage — Situation Room
 * Sections:
 *   1. Ticker bar (dynamic)
 *   2. DigestFeed
 *   3. Hero — stat strip + two featured cards
 *   4. Signal Mix — top AI + VLA picks sorted by strength
 *   5. Cross-Domain Pulse (new)
 *   6. Social Intel strip
 *   7. System Status + Biweekly teaser
 */
import BaseLayout from '../layouts/BaseLayout.astro';
import RatingBadge from '../components/RatingBadge.astro';
import DigestFeed from '../components/DigestFeed.astro';
import {
  loadAIDailyPicks,
  loadVLADailyPicks,
  loadDriftMetrics,
  loadEntityIndex,
  loadSocialIntel,
  loadBiweeklyReports,
  loadAIDeepDive,
  loadVLATheory,
  loadVLAGitHubArticles,
  loadCrossDomainInsights,
  extractMarkdownSummary,
  type DailyPickDay,
  type DriftMetricsFile,
} from '../utils/data';

// ---------------------------------------------------------------------------
// Load data
// ---------------------------------------------------------------------------
const recentPicks   = loadAIDailyPicks(1);
const recentVLA     = loadVLADailyPicks(2);
const { state: driftState, metrics: driftMetrics } = loadDriftMetrics();
const entityIndex   = loadEntityIndex();
const aiSocial      = loadSocialIntel('ai',  3);
const vlaSocial     = loadSocialIntel('vla', 2);
const biweekly      = loadBiweeklyReports(1);
const crossDomain   = loadCrossDomainInsights(6);

// Deep dive — recent 3 days
const DEEP_DIVE_DAYS = 3;
const deepDiveCutoff = new Date(Date.now() - DEEP_DIVE_DAYS * 86400000).toISOString().slice(0, 10);
const SIGNAL_EMOJI: Record<string, string> = {
  technical_breakthrough: '⚡',
  product_release:        '🔧',
  breaking_change:        '🔧',
  research_update:        '📖',
  ecosystem_signal:       '📊',
};
const aiDeepDiveRaw = loadAIDeepDive(60).filter(a => a.date >= deepDiveCutoff);

// VLA: merge pipeline-tracked theory + manually added GitHub articles,
// deduplicated by URL, filtered to the 2-day cutoff.
const vlaTheoryRaw   = loadVLATheory(200).filter(a => a.date >= deepDiveCutoff);
const vlaGitHubRaw   = loadVLAGitHubArticles(300).filter(a => a.date >= deepDiveCutoff);
const seenVlaUrls    = new Set(vlaTheoryRaw.map(a => a.html_url ?? a.url));
const vlaGitHubExtra = vlaGitHubRaw.filter(a => !seenVlaUrls.has(a.html_url ?? a.url));

const deepDiveItems = [
  ...aiDeepDiveRaw.map(a => ({
    title:   a.title,
    summary: a.signal_type?.replace(/_/g, ' ') ?? 'deep dive',
    rating:  SIGNAL_EMOJI[a.signal_type ?? ''] ?? '📖',
    source:  (a.source ?? 'AI').replace(/^social-/, '').slice(0, 10),
    url:     a.html_url ?? a.url,
    domain:  'ai' as const,
  })),
  // Pipeline-tracked VLA theory articles
  ...vlaTheoryRaw.map(a => ({
    title:   a.title,
    summary: a.target_dir?.replace('theory/', '') ?? 'theory',
    rating:  '📐',
    source:  'VLA-THEORY',
    url:     a.html_url ?? a.url,
    domain:  'vla' as const,
  })),
  // Manually added VLA GitHub articles not already in pipeline list
  ...vlaGitHubExtra.map(a => ({
    title:   a.title,
    summary: a.topic ?? 'theory',
    rating:  '📐',
    source:  'VLA-GITHUB',
    url:     a.html_url ?? a.url,
    domain:  'vla' as const,
  })),
];

// ---------------------------------------------------------------------------
// Mock fallbacks
// ---------------------------------------------------------------------------
const MOCK_PICKS: DailyPickDay = {
  date: '2026-03-01',
  items: [
    {
      title: 'Flow Matching for Robot Learning: A Unified Framework',
      url: 'https://arxiv.org/abs/2501.00001',
      summary: '本文提出統一的流匹配框架，用於機器人學習中的多模態動作分佈建模。與擴散模型相比，訓練速度提升3倍，推理延遲降低40%。在RLBench上超越當前SOTA。',
      rating: '⚡', source: 'arxiv', domain: 'vla',
    },
    {
      title: 'Scaling Language Models for Embodied Reasoning',
      url: 'https://arxiv.org/abs/2501.00002',
      summary: '探索大型語言模型在具身推理任務中的縮放規律。7B到70B參數範圍的實驗顯示，推理能力在30B+出現湧現，但動作精度仍需視覺-運動訓練。',
      rating: '🔧', source: 'arxiv', domain: 'vla',
    },
    {
      title: 'Karpathy: Software 3.0 時代的意圖驅動開發',
      url: 'https://karpathy.ai/blog/software3',
      summary: 'Karpathy 在最新文章中提出 Software 3.0 框架——開發範式從「寫語法」轉向「編排意圖」。AI coding agent 將成為主要生產力工具。',
      rating: '⚡', source: 'blog', domain: 'ai',
    },
    {
      title: 'DeepSeek-V3 在代碼生成基準測試中的表現分析',
      url: 'https://ithome.com/0/abc123',
      summary: '第三方分析顯示 DeepSeek-V3 在 HumanEval 和 MBPP 基準上達到 GPT-4o 水準，但長上下文推理仍有差距。開源成本優勢顯著。',
      rating: '🔧', source: 'ithome', domain: 'ai',
    },
    {
      title: 'World Models for Long-Horizon Planning in Manipulation',
      url: 'https://arxiv.org/abs/2501.00003',
      summary: '介紹基於世界模型的長時域操作規劃方法，在模擬到真實遷移上取得顯著進展。背景閱讀：與 DreamerV3 的比較分析。',
      rating: '📖', source: 'arxiv', domain: 'vla',
    },
    {
      title: 'Cursor 月活突破 200 萬：Vibe Coding 浪潮重塑技術棧選型',
      url: 'https://36kr.com/placeholder',
      summary: 'AI IDE 賽道進入爆發期，Lovable、Bolt 等產品相繼宣布百萬用戶里程碑，傳統 IDE 廠商加速整合 AI 功能。',
      rating: '📖', source: '36kr', domain: 'ai',
    },
  ],
};

const MOCK_SOCIAL = [
  { entity: 'AI App · 03-01', event: 'OpenAI 与美国国防部达成协议，引发 Cancel ChatGPT 运动；Qwen3.5 122B 声称达到 Sonnet 4.5 性能；Gemini CLI 解除 Antigravity 禁令后开源社区热议不断。', date: '2026-03-01', domain: 'ai', tag: 'AI App' },
  { entity: 'VLA 情報 · 03-01', event: 'Physical Intelligence Pi0.5 开放 API 访问，覆盖 7 种机器人形态；Google DeepMind 公布 Gemini Robotics Q2 路线图；VLA SOTA 基准 Bidex 刷新纪录。', date: '2026-03-01', domain: 'vla', tag: 'VLA' },
  { entity: 'AI App · 02-28', event: 'Yann LeCun 转发 WorldModelBench 论文：「评估标准缺失是具身 AI 进展缓慢的根本原因」；Ilya Sutskever SSI 博客暗示探索 Transformer 替代架构。', date: '2026-02-28', domain: 'ai', tag: 'AI App' },
];

// ---------------------------------------------------------------------------
// Resolve: real vs mock
// ---------------------------------------------------------------------------
const todayPicks  = recentPicks[0]  ?? MOCK_PICKS;
const displayDate = todayPicks.date;
const todayVLA    = recentVLA[0];

const heroAI  = todayPicks.items[0];
const heroVLA = todayVLA?.items.find(i => i.rating === '⚡')
             ?? todayVLA?.items.find(i => i.rating === '🔧')
             ?? todayVLA?.items[0]
             ?? todayPicks.items[1];

// Entity stats
const driftOk     = !driftState?.drift_active;
const entityCount = Object.keys(entityIndex.entities).length;
const labCount    = Object.values(entityIndex.entities).filter(e => e.type === 'lab').length;
const methodCount = Object.values(entityIndex.entities).filter(e => e.type === 'method').length;
const base        = import.meta.env.BASE_URL;

// Today's counts
const digestAiItems = todayPicks.items
  .filter(i => i.domain === 'ai')
  .map(i => ({ ...i, domain: 'ai' as const }));
const digestVlaItems = (todayVLA?.items ?? todayPicks.items.filter(i => i.domain === 'vla'))
  .map(i => ({ ...i, domain: 'vla' as const }));

const todayAICount  = digestAiItems.length;
const todayVLACount = digestVlaItems.length;
const crossDomainCount = crossDomain.length;

// Mixed signals grid — top AI + VLA sorted by rating strength
const SIGNAL_ORDER: Record<string, number> = { '⚡': 3, '🔧': 2, '📖': 1, '❌': 0 };
const mixedSignals = [
  ...digestAiItems,
  ...digestVlaItems,
].sort((a, b) => {
  const aS = SIGNAL_ORDER[[...a.rating][0] ?? a.rating] ?? 1;
  const bS = SIGNAL_ORDER[[...b.rating][0] ?? b.rating] ?? 1;
  return bS - aS;
}).slice(0, 6);

// Real sparkline from drift metrics — flat array format:
// [{ date, vla_papers_scanned, aiapp_items_scanned, ... }, ...]
const sparkHistory: Array<{ date: string; vla: number; ai: number }> = (
  Array.isArray(driftMetrics) ? driftMetrics : []
)
  .sort((a: { date: string }, b: { date: string }) => a.date.localeCompare(b.date))
  .map((entry: any) => ({
    date: entry.date ?? '',
    vla:  entry.vla_papers_scanned  ?? 0,
    ai:   entry.aiapp_items_scanned ?? 0,
  }));
const spark7      = sparkHistory.slice(-7);
const sparkMaxVLA = Math.max(1, ...spark7.map(d => d.vla));
const sparkMaxAI  = Math.max(1, ...spark7.map(d => d.ai));

// Fixed social intel — proper entity names from domain + date
const realSocial = [
  ...aiSocial.map(s => ({
    entity: `AI App · ${s.date.slice(5)}`,
    event:  extractMarkdownSummary(s.content, 230),
    date:   s.date,
    domain: 'ai',
    tag:    'AI App',
  })),
  ...vlaSocial.map(s => ({
    entity: `VLA 情報 · ${s.date.slice(5)}`,
    event:  extractMarkdownSummary(s.content, 230),
    date:   s.date,
    domain: 'vla',
    tag:    'VLA',
  })),
].filter(s => s.event.length > 20);
const socialItems = realSocial.length >= 2 ? realSocial.slice(0, 6) : MOCK_SOCIAL;

// Biweekly
const latestReport  = biweekly[0] ?? null;
const reportSummary = latestReport
  ? extractMarkdownSummary(latestReport.content, 320)
  : 'VLA 技術演進的範式轉移：本期報告系統梳理過去兩週 VLA 領域的六項關鍵技術突破，重點分析流匹配架構、SSM 模型和世界模型三條技術路線的收斂趨勢。結合 Physical Intelligence 的實驗數據，我們認為當前 VLA 正從「模仿學習的縮放定律」轉向「物理常識的顯式建模」。';
const reportDate = latestReport?.date ?? displayDate;

// Rating helpers
const ratingClass: Record<string, string> = {
  '⚡': 'rating-badge rating-flash',
  '🔧': 'rating-badge rating-wrench',
  '📖': 'rating-badge rating-book',
  '❌': 'rating-badge rating-x',
};
const ratingLabel: Record<string, string> = {
  '⚡': '突破', '🔧': '<span data-tc>技術</span><span data-sc>技术</span>', '📖': '<span data-tc>觀點</span><span data-sc>观点</span>', '❌': '<span data-tc>低關聯</span><span data-sc>低关联</span>',
};
function getRatingClass(r: string): string {
  return ratingClass[[...r][0] ?? r] ?? 'rating-badge rating-book';
}
function getRatingLabel(r: string): string {
  const first = [...r][0] ?? r;
  if (ratingLabel[first]) return ratingLabel[first];
  if (r.includes(' ')) return r.split(' ').slice(1).join(' ');
  return ratingLabel[r] ?? r;
}

// Cross-domain rule labels
const RULE_LABELS: Record<string, string> = {
  R001: 'VLA 技法 → AI',
  R002: '世界模型 → AI',
  R003: 'AI Agent → VLA',
};
---

<BaseLayout
  title="總覽 Overview"
  description="AI Research Intelligence — VLA pipeline monitoring, daily picks, and biweekly reflections."
>

  <!-- ═══════════════════════════════════════════════════════════════
       1. TICKER — dynamic real-data feed
       ═══════════════════════════════════════════════════════════════ -->
  <div class="ticker" role="marquee" aria-label="Breaking signals">
    <div class="container">
      <div class="ticker-inner">
        <span class="ticker-label">⚡ PULSAR</span>
        <span class="ticker-text">
          {displayDate} 已更新&ensp;·&ensp;
          AI <span data-tc>精選</span><span data-sc>精选</span> {todayAICount || '?'} 條&ensp;·&ensp;
          VLA <span data-tc>論文</span><span data-sc>论文</span> {todayVLACount || '?'} 篇&ensp;·&ensp;
          <span data-tc>品質漂移</span><span data-sc>品质漂移</span> {driftOk ? '正常 ✓' : '注意 ⚠'}&ensp;·&ensp;
          <span data-tc>追蹤</span><span data-sc>追踪</span> {entityCount || '—'} <span data-tc>實體</span><span data-sc>实体</span> · {labCount || '—'} <span data-tc>機構</span><span data-sc>机构</span> · {methodCount || '—'} 方法&ensp;·&ensp;
          <span data-tc>跨域訊號</span><span data-sc>跨域讯号</span> {crossDomainCount} 條&ensp;·&ensp;
          Deep Dive 近 3 日 {deepDiveItems.length} 篇&ensp;·&ensp;
        </span>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════════════════════════════
       2. DAILY DIGEST
       ═══════════════════════════════════════════════════════════════ -->
  <section class="digest-block" aria-label="今日情報摘要">
    <div class="container">
      <DigestFeed
        date={displayDate}
        aiItems={digestAiItems}
        vlaItems={digestVlaItems}
        deepDiveItems={deepDiveItems}
      />
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       2.5. SYSTEM BRIEFING — intro + update schedule
       ═══════════════════════════════════════════════════════════════ -->
  <section class="hp-briefing" aria-label="系統簡介">
    <div class="container">
      <div class="hp-briefing-grid">

        <!-- Left: system intro -->
        <div class="hp-briefing-left">
          <p class="hp-briefing-overline">RESEARCH INTELLIGENCE · PULSAR</p>
          <h2 class="hp-briefing-name">PULSAR · <span class="hp-briefing-zh"><span data-tc>照見</span><span data-sc>照见</span></span></h2>
          <p class="hp-briefing-problem">
            <span data-tc>注意力比訊息更稀缺。很少有系統追蹤自己說過的話。</span><span data-sc>注意力比信息更稀缺。很少有系统追踪自己说过的话。</span>
          </p>
          <p class="hp-briefing-body">
            <span data-tc>Pulsar 不同：同時覆蓋 <strong><abbr class="hp-abbr-vla" title="Vision-Language-Action">VLA</abbr> 機器人前沿 × AI 應用趨勢</strong>，LLM 每日為信號評級而非轉發（⚡ 突破 · 🔧 技術 · 📖 觀點）；跨域共振引擎標記兩條線的技術交叉；雙週校準讓每一個預判都有結果——<em>包括誤判</em>。這是情報，不是摘要。</span><span data-sc>Pulsar 不同：同时覆盖 <strong>VLA 机器人前沿 × AI 应用趋势</strong>，LLM 每日为讯号评级而非转发（⚡ 突破 · 🔧 技术 · 📖 观点）；跨域共振引擎标记两条线的技术交叉；双周校准让每一个预判都有结果——<em>包括误判</em>。这是情报，不是摘要。</span>
          </p>

        </div>

        <!-- Right: domain explainer — answers "what is VLA?" for new visitors -->
        <div class="hp-domain-explainer">
          <div class="hp-domain-card hp-domain-card--vla">
            <span class="hp-domain-icon" aria-hidden="true">🤖</span>
            <div class="hp-domain-content">
              <span class="hp-domain-pill hp-domain-pill--vla">VLA 域</span>
              <p class="hp-domain-fullname">Vision-Language-Action</p>
              <p class="hp-domain-desc"><span data-tc>機器人如何「看懂」世界、理解語言並執行動作的前沿研究 · 每天 12:00 更新</span><span data-sc>机器人如何"看懂"世界、理解语言并执行动作的前沿研究 · 每天 12:00 更新</span></p>
            </div>
          </div>
          <div class="hp-domain-card hp-domain-card--ai">
            <span class="hp-domain-icon" aria-hidden="true">🧠</span>
            <div class="hp-domain-content">
              <span class="hp-domain-pill hp-domain-pill--ai">AI App 域</span>
              <p class="hp-domain-fullname">Agent · Tools · Ecosystem</p>
              <p class="hp-domain-desc"><span data-tc>AI 工具、Agent 框架與產業生態——軟體如何被 AI 重新定義 · 每天 12:00 更新</span><span data-sc>AI 工具、Agent 框架与产业生态——软件如何被 AI 重新定义 · 每天 12:00 更新</span></p>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       3. HERO — stat strip + two featured cards
       ═══════════════════════════════════════════════════════════════ -->
  <section class="hero" id="daily" aria-labelledby="hero-title">
    <div class="container">

      <div class="hero-meta fade-in-1">
        <span class="hero-date">{displayDate} · PULSAR</span>
        <span class="hero-sep" aria-hidden="true"></span>
        <span class="live-dot">Pipeline 已更新</span>
      </div>

      <div class="hero-headline fade-in-2">
        <span class="overline">DAILY INTELLIGENCE · {displayDate}</span>
        <h1 id="hero-title">今日 <em>AI + VLA</em> 洞察</h1>
      </div>

      <!-- Stat strip (real data) -->
      <div class="hp-stats fade-in-3">
        <div class="hp-stat">
          <span class="hp-stat-num hp-amber">{todayAICount || '—'}</span>
          <span class="hp-stat-label">AI <span data-tc>精選</span><span data-sc>精选</span></span>
        </div>
        <div class="hp-stat-div"></div>
        <div class="hp-stat">
          <span class="hp-stat-num hp-cyan">{todayVLACount || '—'}</span>
          <span class="hp-stat-label">VLA <span data-tc>論文</span><span data-sc>论文</span></span>
        </div>
        <div class="hp-stat-div"></div>
        <div class="hp-stat">
          <span class="hp-stat-num">{entityCount || '—'}</span>
          <span class="hp-stat-label"><span data-tc>追蹤</span><span data-sc>追踪</span><span data-tc>實體</span><span data-sc>实体</span></span>
        </div>
        <div class="hp-stat-div"></div>
        <div class="hp-stat">
          <span class={`hp-stat-num ${driftOk ? 'hp-ok' : 'hp-warn'}`}>{driftOk ? '✓ 正常' : '⚠ 注意'}</span>
          <span class="hp-stat-label"><span data-tc>品質漂移</span><span data-sc>品质漂移</span></span>
        </div>
        <div class="hp-stat-div hp-stat-div--hide-mobile"></div>
        <div class="hp-stat hp-stat--hide-mobile">
          <span class="hp-stat-num">{crossDomainCount}</span>
          <span class="hp-stat-label"><span data-tc>跨域訊號</span><span data-sc>跨域讯号</span></span>
        </div>
        <div class="hp-stat-div hp-stat-div--hide-mobile"></div>
        <div class="hp-stat hp-stat--hide-mobile">
          <span class="hp-stat-num">{deepDiveItems.length}</span>
          <span class="hp-stat-label">深析新增</span>
        </div>
      </div>

      <!-- Hero two-column featured cards -->
      <div class="hero-grid fade-in-4">

        <article class="hero-card hero-card-ai" aria-labelledby="hero-ai-title">
          <div class="hero-card-label"><span><span data-tc>今日 AI 精選</span><span data-sc>今日 AI 精选</span></span></div>
          <span class={getRatingClass(heroAI.rating)} set:html={`${[...heroAI.rating][0]} ${getRatingLabel(heroAI.rating)}`}></span>
          <h2 class="hero-card-title" id="hero-ai-title">{heroAI.title}</h2>
          <p class="hero-card-summary">{heroAI.summary}</p>
          <div class="hero-card-footer">
            <div class="hero-card-tags">
              <span class="source-tag">{heroAI.source.toUpperCase()}</span>
              <span class="source-tag">AI App</span>
            </div>
            <a href={heroAI.url} target="_blank" rel="noopener noreferrer" class="btn btn-amber">閱讀全文 →</a>
          </div>
        </article>

        <article class="hero-card hero-card-vla" aria-labelledby="hero-vla-title">
          <div class="hero-card-label"><span><span data-tc>今日 VLA 論文</span><span data-sc>今日 VLA 论文</span></span></div>
          <span class={getRatingClass(heroVLA.rating)} set:html={`${[...heroVLA.rating][0]} ${getRatingLabel(heroVLA.rating)}`}></span>
          <h2 class="hero-card-title" id="hero-vla-title">{heroVLA.title}</h2>
          <p class="hero-card-summary">{heroVLA.summary}</p>
          <div class="hero-card-footer">
            <div class="hero-card-tags">
              <span class="source-tag">{heroVLA.source.toUpperCase()}</span>
              <span class="source-tag">VLA</span>
            </div>
            <a href={heroVLA.url} target="_blank" rel="noopener noreferrer" class="btn btn-outline">閱讀 →</a>
          </div>
        </article>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       4. SIGNAL MIX — top AI + VLA sorted by rating strength
       ═══════════════════════════════════════════════════════════════ -->
  <section class="section" id="picks" aria-labelledby="picks-title">
    <div class="container">

      <div class="section-header fade-in-1">
        <div>
          <span class="section-label section-number">03 — 今日訊號</span>
          <h2 id="picks-title"><span class="accent-line" aria-hidden="true"></span><span data-tc>精選訊號 · AI + VLA</span><span data-sc>精选讯号 · AI + VLA</span></h2>
        </div>
