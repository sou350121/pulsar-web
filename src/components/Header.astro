---
/**
 * Header.astro
 * Frosted-glass navbar — ported from prototype design.
 * Logo uses system monospace with amber accent; nav links use system CJK fonts.
 */
import ThemeToggle from './ThemeToggle.astro';

const base = import.meta.env.BASE_URL; // e.g. '/pulsar-web/'
const nav = [
  { href: base,                   label: '日　報' },
  { href: `${base}/vla`,           label: 'V L A' },
  { href: `${base}/social`,        label: '社交情報' },
  { href: `${base}/dashboard`,     label: '儀表板' },
  { href: `${base}/reports`,       label: '雙週報告' },
];

const rootPath = base.replace(/\/$/, '') || '/';
const pathname = Astro.url.pathname.replace(/\/$/, '') || rootPath;
const isActive = (href: string) => {
  const h = href.replace(/\/$/, '') || rootPath;
  return h === rootPath ? pathname === rootPath : pathname.startsWith(h);
};
---

<nav class="nav" aria-label="Primary navigation">
  <div class="container">
    <div class="nav-inner">

      <!-- Logo / Brand -->
      <a href={base} class="nav-logo" aria-label="PULSAR 照見 — Home">
        PUL<span>S</span>AR
        <span class="logo-zh">照　見</span>
      </a>

      <div class="nav-divider" aria-hidden="true"></div>

      <!-- Primary Navigation links -->
      <ul class="nav-links" role="list">
        {nav.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class:list={[isActive(href) ? 'active' : '']}
              aria-current={isActive(href) ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Right side: live indicator + theme toggle -->
      <div class="nav-right">
        <span class="live-dot">LIVE</span>
        <ThemeToggle />

        <!-- Mobile hamburger / close toggle -->
        <button
          id="mobile-menu-btn"
          type="button"
          class="mobile-menu-btn"
          aria-controls="mobile-menu"
          aria-expanded="false"
          aria-label="開啟選單"
        >
          <!-- Hamburger icon (shown when menu is closed) -->
          <svg id="menu-icon-open" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <rect y="3"  width="20" height="2" rx="1"/>
            <rect y="9"  width="20" height="2" rx="1"/>
            <rect y="15" width="20" height="2" rx="1"/>
          </svg>
          <!-- Close icon (shown when menu is open) -->
          <svg id="menu-icon-close" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true" style="display:none;">
            <line x1="3" y1="3" x2="17" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <line x1="17" y1="3" x2="3" y2="17" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile Navigation Drawer -->
  <nav
    id="mobile-menu"
    aria-label="行動版導航"
    class="mobile-menu hidden"
  >
    {nav.map(({ href, label }) => (
      <a
        href={href}
        class:list={['mobile-menu-link', isActive(href) ? 'active' : '']}
        aria-current={isActive(href) ? 'page' : undefined}
      >
        {label}
      </a>
    ))}
  </nav>
</nav>

<style>
  /* ── Hamburger button: hidden on desktop, shown on mobile ── */
  .mobile-menu-btn {
    display: none;
    /* 44px minimum tap target */
    width: 44px;
    height: 44px;
    padding: 0;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-secondary);
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .mobile-menu-btn:hover {
    background: var(--surface-2);
    color: var(--text-primary);
  }
  .mobile-menu-btn:focus-visible {
    outline: 2px solid var(--accent-amber);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .mobile-menu-btn { display: flex; }
  }

  /* ── Mobile Navigation Drawer ── */
  .mobile-menu {
    background: var(--nav-bg);
    backdrop-filter: blur(16px) saturate(1.4);
    -webkit-backdrop-filter: blur(16px) saturate(1.4);
    border-top: 1px solid var(--border);
    /* Generous left/right padding for breathing room */
    padding: 8px 0 20px;
    display: flex;
    flex-direction: column;
    gap: 0;
    box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  }

  .mobile-menu.hidden { display: none; }

  /* ── Individual nav links: 48px min touch target ── */
  .mobile-menu-link {
    font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Microsoft YaHei', 'Segoe UI', sans-serif;
    font-size: 16px;
    font-weight: 400;
    color: var(--text-secondary);
    text-decoration: none;
    /* 16px horizontal padding, enough vertical for 48px touch target */
    padding: 14px 24px;
    border-bottom: 1px solid var(--border-subtle);
    /* min-height ensures at least 48px on any device */
    min-height: 48px;
    display: flex;
    align-items: center;
    letter-spacing: 0.03em;
    transition: color 0.15s, background 0.15s;
    opacity: 1;
  }

  /* Last item: remove the separator line */
  .mobile-menu-link:last-child { border-bottom: none; }

  .mobile-menu-link:hover {
    color: var(--text-primary);
    background: var(--surface-2);
  }

  .mobile-menu-link.active {
    color: var(--accent-amber);
    font-weight: 500;
  }

  .mobile-menu-link:focus-visible {
    outline: 2px solid var(--accent-amber);
    outline-offset: -2px;
  }
</style>

<script>
  const btn       = document.getElementById('mobile-menu-btn');
  const menu      = document.getElementById('mobile-menu');
  const iconOpen  = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden') ?? true;
    const open = !isHidden;
    btn.setAttribute('aria-expanded', String(open));
    btn.setAttribute('aria-label', open ? '關閉選單' : '開啟選單');
    // Swap hamburger ↔ close (✕) icon
    if (iconOpen)  iconOpen.style.display  = open ? 'none'  : '';
    if (iconClose) iconClose.style.display = open ? ''      : 'none';
  });
</script>
