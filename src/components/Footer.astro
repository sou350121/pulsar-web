---
/**
 * Footer.astro
 * Site footer with tagline, quick links, and build info.
 */
const year = new Date().getFullYear();
---

<footer class="border-t border-pulsar-border bg-pulsar-surface mt-auto">
  <div class="page-container py-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <!-- Brand / Tagline -->
      <div>
        <p class="font-lora font-bold text-pulsar-text mb-1">Pulsar · 照見</p>
        <p class="text-pulsar-muted text-sm leading-relaxed">
          AI Research Intelligence — VLA pipeline monitoring,<br/>
          daily picks, and biweekly reflections.
        </p>
        <p class="text-pulsar-muted text-xs mt-3 font-ibm-plex-mono">
          Powered by Moltbot + DashScope
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <p class="text-xs font-ibm-plex-mono uppercase tracking-widest text-pulsar-muted mb-3">
          Quick Links
        </p>
        <ul class="space-y-1.5 text-sm">
          {[
            ['/ai-daily', 'AI 日報'],
            ['/vla',      'VLA 研究'],
            ['/social',   '社交情報'],
            ['/reports',  '雙週報告'],
            ['/dashboard','數據面板'],
          ].map(([href, label]) => (
            <li>
              <a
                href={href}
                class="text-pulsar-muted hover:text-pulsar-cyan transition-colors font-noto-serif-sc"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Pipeline Status / Info -->
      <div>
        <p class="text-xs font-ibm-plex-mono uppercase tracking-widest text-pulsar-muted mb-3">
          Pipeline
        </p>
        <ul class="space-y-1 text-xs font-ibm-plex-mono text-pulsar-muted">
          <li><span class="text-green-500">●</span> VLA RSS — daily 09:00</li>
          <li><span class="text-green-500">●</span> AI Daily — daily 07:00</li>
          <li><span class="text-green-500">●</span> Entity Tracker — 09:55</li>
          <li><span class="text-green-500">●</span> Quality Drift — 10:10</li>
          <li><span class="text-green-500">●</span> Semantic Index — 11:15</li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-8 pt-4 border-t border-pulsar-border flex flex-col sm:flex-row items-center justify-between gap-2">
      <p class="text-pulsar-muted text-xs font-ibm-plex-mono">
        &copy; {year} Pulsar · 照見系統
      </p>
      <p class="text-pulsar-muted text-xs">
        Data refreshed daily via cron pipeline
      </p>
    </div>
  </div>
</footer>
