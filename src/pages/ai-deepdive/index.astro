---
/**
 * src/pages/ai-deepdive/index.astro — 學習導向重設計
 * 問題：93 篇全落入「最近 2 週」，讀者被 93 張卡片轟炸，不知從何入手。
 * 解法：入門路徑 → 精選必讀 8 篇 → PULSAR <span data-tc>深度分析</span><span data-sc>深度分析</span> → 模塊過濾 + 緊湊列表。
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadAIGitHubArticles, loadAIDeepDive, AI_DEEP_DIVE_TAGS, matchDeepDiveTags, loadLatestAIFieldState, getTopAIOrgs } from '../../utils/data';
import type { AIGitHubArticle } from '../../utils/data';

const topAIOrgs = getTopAIOrgs(15);

const articles = loadAIGitHubArticles(200);
const deepDiveArticles = loadAIDeepDive(50);
const aiFieldState = loadLatestAIFieldState();

// Pre-compute AI method trend data for rendering
const aiTrendVisible = aiFieldState?.method_trends?.filter(t => t.count_7d > 0) ?? [];
const aiTrendMaxCount = aiTrendVisible.reduce((m, t) => Math.max(m, t.count_7d), 0);

// Pre-compute tags for each deep dive article
const ddTagsMap = new Map<number, string[]>();
const tagCounts: Record<string, number> = {};
for (const [idx, article] of deepDiveArticles.entries()) {
  const tags = matchDeepDiveTags(article.title);
  ddTagsMap.set(idx, tags);
  for (const t of tags) { tagCounts[t] = (tagCounts[t] ?? 0) + 1; }
}
// Build tag lookup for template use
const TAG_MAP = new Map(AI_DEEP_DIVE_TAGS.map(t => [t.id, t]));
const GITHUB_REPO = 'https://github.com/sou350121/Agent-Playbook';
const gh = (mod: string, slug: string) => `${GITHUB_REPO}/blob/main/theory/${mod}/${slug}`;

// ── Module metadata ─────────────────────────────────────────────────────────
const MODULE_ORDER = ['01-principles','02-agent-design','03-engineering','04-paradigm','05-strategy','06-frontier'];
const MM: Record<string, { label: string; labelSC: string; accent: string; star?: boolean }> = {
  '01-principles':   { label: '底層原理',   labelSC: '底层原理',   accent: 'blue' },
  '02-agent-design': { label: 'Agent 設計', labelSC: 'Agent 设计', accent: 'purple' },
  '03-engineering':  { label: '工程實戰',   labelSC: '工程实战',   accent: 'amber', star: true },
  '04-paradigm':     { label: '範式轉變',   labelSC: '范式转变',   accent: 'green' },
  '05-strategy':     { label: '戰略生存',   labelSC: '战略生存',   accent: 'red' },
  '06-frontier':     { label: '前沿研究',   labelSC: '前沿研究',   accent: 'cyan' },
};

// Group by module, sort alphabetically within each
const byModule: Record<string, AIGitHubArticle[]> = {};
for (const a of articles) { (byModule[a.module] ??= []).push(a); }
for (const m of MODULE_ORDER) { byModule[m]?.sort((a, b) => a.title.localeCompare(b.title)); }

// ── Curated pinned articles (8 must-reads) ──────────────────────────────────
const PINNED = [
  { mod: '03-engineering', slug: '00-glossary-for-beginners.md',
    title: '新手詞彙表',        titleSC: '新手词汇表',        desc: '掌握 Agent 工程核心術語，第一篇必讀', descSC: '掌握 Agent 工程核心术语，第一篇必读' },
  { mod: '01-principles',  slug: 'agent-mental-model.md',
    title: 'Agent 心智模型',    titleSC: 'Agent 心智模型',    desc: '理解 Agent 如何「思考」的底層認知框架', descSC: '理解 Agent 如何"思考"的底层认知框架' },
  { mod: '03-engineering', slug: 'context-engineering-field-guide.md',
    title: 'Context 工程手冊',  titleSC: 'Context 工程手册',  desc: '從壓縮到結構化注入的完整方法論', descSC: '从压缩到结构化注入的完整方法论' },
  { mod: '03-engineering', slug: 'agent-failure-taxonomy.md',
    title: 'T1–T6 故障分類法', titleSC: 'T1–T6 故障分类法', desc: '生產部署前必讀的 Agent 失敗模式大全', descSC: '生产部署前必读的 Agent 失败模式大全' },
  { mod: '03-engineering', slug: 'trust-tier-design.md',
    title: '信任分層設計',       titleSC: '信任分层设计',       desc: '防止 Agent 越權的多層級權限架構', descSC: '防止 Agent 越权的多层级权限架构' },
  { mod: '03-engineering', slug: 'eval-loop-as-production-practice.md',
    title: '評估環路即生產實踐', titleSC: '评估环路即生产实践', desc: '把評估從測試階段提升為持續生產實踐', descSC: '把评估从测试阶段提升为持续生产实践' },
  { mod: '03-engineering', slug: 'delegation-not-automation-engineering-principles.md',
    title: '委托而非自動化',     titleSC: '委托而非自动化',     desc: '重新定義 Agent 與人類協作的工程邊界', descSC: '重新定义 Agent 与人类协作的工程边界' },
  { mod: '05-strategy',    slug: 'agent-native-org-roles.md',
    title: 'Agent 原生組織角色', titleSC: 'Agent 原生组织角色', desc: 'Agent 時代的職能重構與角色設計', descSC: 'Agent 时代的职能重构与角色设计' },
].map((p, i) => ({
  ...p,
  url: gh(p.mod, p.slug),
  accent: MM[p.mod]?.accent ?? 'amber',
  modLabel: MM[p.mod]?.label ?? '',
  num: String(i + 1).padStart(2, '0'),
}));

// ── Learning paths ───────────────────────────────────────────────────────────
const PATHS = [
  {
    role: '工程師入門', roleSC: '工程师入门', icon: '⚙',
    desc: '從零建立完整的 Agentic 工程認知', descSC: '从零建立完整的 Agentic 工程认知',
    accent: 'amber',
    steps: [
      { label: '新手詞彙表', labelSC: '新手词汇表',        url: gh('03-engineering', '00-glossary-for-beginners.md') },
      { label: 'Agent 心智模型', labelSC: 'Agent 心智模型',     url: gh('01-principles',  'agent-mental-model.md') },
      { label: 'Context 工程手冊', labelSC: 'Context 工程手册',   url: gh('03-engineering', 'context-engineering-field-guide.md') },
      { label: 'T1–T6 故障分類法', labelSC: 'T1–T6 故障分类法',  url: gh('03-engineering', 'agent-failure-taxonomy.md') },
      { label: 'Agent 記憶系統', labelSC: 'Agent 记忆系统',     url: gh('02-agent-design','agent-memory-system-short-to-long.md') },
    ],
  },
  {
    role: '系統架構師', roleSC: '系统架构师', icon: '⬡',
    desc: '設計可靠的多 Agent 控制平面與治理', descSC: '设计可靠的多 Agent 控制平面与治理',
    accent: 'purple',
    steps: [
      { label: '信任分層設計', labelSC: '信任分层设计',        url: gh('03-engineering', 'trust-tier-design.md') },
      { label: '控制平面設計', labelSC: '控制平面设计',        url: gh('03-engineering', 'agentic-control-plane-design.md') },
      { label: '委托而非自動化', labelSC: '委托而非自动化',      url: gh('03-engineering', 'delegation-not-automation-engineering-principles.md') },
      { label: 'Agentic 編排元系統', labelSC: 'Agentic 编排元系统', url: gh('02-agent-design', 'agentic-orchestration-meta-system.md') },
      { label: 'Agent 原生組織角色', labelSC: 'Agent 原生组织角色',  url: gh('05-strategy',    'agent-native-org-roles.md') },
    ],
  },
  {
    role: '產品 / 戰略', roleSC: '产品 / 战略', icon: '◎',
    desc: '把握範式轉變，制定 AI 時代競爭策略', descSC: '把握范式转变，制定 AI 时代竞争策略',
    accent: 'green',
    steps: [
      { label: 'Vibe Coding 範式', labelSC: 'Vibe Coding 范式',   url: gh('04-paradigm', 'vibe-coding-paradigm.md') },
      { label: '智能作為資源', labelSC: '智能作为资源',        url: gh('04-paradigm', 'intelligence-as-a-resource.md') },
      { label: 'Agent 原生組織角色', labelSC: 'Agent 原生组织角色',  url: gh('05-strategy', 'agent-native-org-roles.md') },
      { label: '評估環路即生產實踐', labelSC: '评估环路即生产实践',  url: gh('03-engineering','eval-loop-as-production-practice.md') },
    ],
  },
];

// ── Deep dive signal_type mapping ────────────────────────────────────────────
const SIGNAL_MAP: Record<string, { label: string; accent: string }> = {
  product_release:   { label: '新發布',     labelSC: '新发布',     accent: 'amber' },
  breaking_change:   { label: '破壞性變更', labelSC: '破坏性变更', accent: 'red' },
  framework_update:  { label: '框架更新',   labelSC: '框架更新',   accent: 'purple' },
  blog_post:         { label: '深度文章',   labelSC: '深度文章',   accent: 'cyan' },
};

// Initial display limit for deep dive articles
const DD_INITIAL = 12;

const base = import.meta.env.BASE_URL;

/** Show "N天前" badge for recently committed articles (≤14 days). Returns null for older ones. */
function artNewBadge(dateStr: string): string | null {
  if (!dateStr) return null;
  const now  = new Date();
  const d    = new Date(dateStr + 'T00:00:00+08:00');
  const diff = Math.floor((now.getTime() - d.getTime()) / 86400000);
  if (diff <= 0)  return '今天';
  if (diff === 1) return '昨天';
  if (diff <= 14) return `${diff}天前`;
  return null;
}
---

<BaseLayout
  title="AI 理論文章庫"
  description="Agentic Engineering 学习指南 — 深度文章，从入门到架构师"
>
<div class="dd-page page-container">

  <!-- ── Breadcrumb ── -->
  <nav class="breadcrumb" aria-label="breadcrumb">
    <a href={`${base}`} class="bc-a">首頁</a>
    <span class="bc-sep">›</span>
    <span class="bc-cur">AI 理論文章庫</span>
  </nav>

  <!-- ── Masthead ── -->
  <header class="masthead">
    <div class="masthead-overline">AGENT-PLAYBOOK · THEORY ARCHIVE</div>
    <h1 class="masthead-title">Agentic Engineering<br/><span data-tc>學習知識庫</span><span data-sc>学习知识库</span></h1>
    <div class="masthead-bar"></div>
    <div class="masthead-stats">
      <span class="stat"><strong>{MODULE_ORDER.filter(m => byModule[m]).length}</strong> <span data-tc>個模塊</span><span data-sc>个模块</span></span>
      <span class="stat-div">·</span>
      <span class="stat"><strong>{articles.length}</strong> <span data-tc>篇文章</span><span data-sc>篇文章</span></span>
      <span class="stat-div">·</span>
      <span class="stat">Pulsar 每日自動更新</span>
      <a href={`${GITHUB_REPO}/tree/main/theory`} target="_blank" rel="noopener noreferrer" class="masthead-gh">
        GitHub 全庫 →
      </a>
    </div>
  </header>

  <!-- ══════════════════════════════
       SECTION A2: AI METHOD TRENDS
  ══════════════════════════════ -->
  {aiFieldState && aiFieldState.method_trends.length > 0 && (
    <section class="fin-panel" aria-label="AI Agent 趋势看板">
      <div class="fin-header">
        <div class="fin-header-left">
          <h2 class="fin-title">AI AGENT TRENDS</h2>
          <span class="fin-meta">
            {aiFieldState.date} · {aiFieldState.total_mentions_7d} mentions · 7d window · {aiFieldState.method_trends.length} families
          </span>
        </div>
      </div>

      <div class="fin-ticker-wrap">
        <div class="fin-ticker-header" style="display:grid; grid-template-columns: 1fr auto 50px 60px; gap:6px; padding:4px 0;">
          <span class="fin-th">FAMILY</span>
          <span class="fin-th">MOM</span>
          <span class="fin-th" style="text-align:right">7d</span>
          <span class="fin-th" style="text-align:right">ACC</span>
        </div>
        <div class="fin-ticker">
          {aiTrendVisible.map(t => {
            const barPct = aiTrendMaxCount > 0 ? (t.count_7d / aiTrendMaxCount * 100) : 0;
            const accColor = t.acceleration >= 2.0 ? 'var(--fin-up, #22c55e)' :
                            (0.33 >= t.acceleration) ? 'var(--fin-down, #ef4444)' :
                            'var(--accent-cyan)';
            const statusDot = t.status === 'surging' ? '▲' :
                             t.status === 'accelerating' ? '△' :
                             t.status === 'declining' ? '▼' :
                             t.status === 'insufficient_data' ? '○' : '●';
            return (
              <div class="fin-row" style="display:grid; grid-template-columns: 1fr auto 50px 60px; gap:6px; align-items:center;">
                <span class="fin-name">{t.label}</span>
                <div style={`width:80px; height:12px; background:rgba(128,128,128,0.08); border-radius:2px; overflow:hidden;`}>
                  <div style={`width:${barPct}%; height:100%; background:${accColor}; border-radius:2px; min-width:2px;`}></div>
                </div>
                <span class="fin-vol tabular-nums" style="text-align:right">{t.count_7d}</span>
                <span class={`fin-accel tabular-nums`} style={`text-align:right; color:${accColor}`}>
                  {statusDot} {t.acceleration.toFixed(2)}x
                </span>
              </div>
            );
          })}
        </div>
      </div>

      {aiFieldState.competition_pairs && aiFieldState.competition_pairs.length > 0 && (
        <details class="vdd-fold vdd-fold--nested fin-competition" open>
          <summary class="fin-sub-title">
            <span class="vdd-fold-chevron"></span>
            COMPETITION PAIRS
            <span class="vdd-fold-badge fin-pair-badge">{aiFieldState.competition_pairs.length}</span>
          </summary>
          <div class="fin-pairs-grid">
            {aiFieldState.competition_pairs.map(pair => {
              const a = aiFieldState.method_trends.find(t => t.family === pair.familyA);
              const b = aiFieldState.method_trends.find(t => t.family === pair.familyB);
              if (!a || !b) return null;
              if (a.count_7d === 0 && b.count_7d === 0) return null;
              const total = a.count_7d + b.count_7d;
              const pctA = Math.min(95, Math.max(5, total > 0 ? Math.round(a.count_7d / total * 100) : 50));
              const ratio = b.count_7d > 0 ? (a.count_7d / b.count_7d).toFixed(2) : '—';
              return (
                <div class="fin-pair-card">
                  <div class="fin-pair-label">{pair.label}</div>
                  {pair.desc && <div class="fin-pair-desc">{pair.desc}</div>}
                  <div class="fin-pair-bar">
                    <span class="fin-pair-name-left">{a.label}</span>
                    <div class="fin-pair-track">
                      <div class="fin-pair-pct fin-pair-pct--a" style={`width:${pctA}%`}>{pctA}%</div>
                      <div class="fin-pair-pct fin-pair-pct--b" style={`width:${100-pctA}%`}>{100-pctA}%</div>
                    </div>
                    <span class="fin-pair-name-right">{b.label}</span>
                  </div>
                  <div class="fin-pair-ratio">
                    <span class="fin-pair-ratio-num">{a.count_7d}</span> vs <span class="fin-pair-ratio-num">{b.count_7d}</span>
                    &nbsp;·&nbsp;ratio {ratio}x
                  </div>
                </div>
              );
            })}
          </div>
        </details>
      )}
    </section>
  )}

  <!-- ══════════════════════════════
       TOP AI ORGS: Entity-based org ranking
  ══════════════════════════════ -->
  {topAIOrgs.length > 0 && (
    <section class="fin-panel fin-institutions-panel" aria-label="AI 组织排名">
      <details class="vdd-fold">
        <summary class="fin-header vdd-fold-summary">
          <span class="vdd-fold-chevron"></span>
          <div class="fin-header-left">
            <h2 class="fin-title">TOP AI ORGS</h2>
            <span class="fin-meta">
              30d window · {topAIOrgs.length} orgs · AI domain
            </span>
          </div>
          <span class="vdd-fold-badge fin-emerging-badge">
            {topAIOrgs.filter(i => i.recentCount > 0).length} active / 30d
          </span>
        </summary>

        <div class="fin-inst-grid-header fin-inst-grid">
          <span class="fin-th">ORGANIZATION</span>
          <span class="fin-th" style="text-align:right">TOTAL</span>
          <span class="fin-th" style="text-align:right">LAST SEEN</span>
          <span class="fin-th fin-inst-activity-th">ACTIVITY</span>
        </div>
        <div class="fin-inst-rows">
          {topAIOrgs.map((org, idx) => {
            const barWidth = (topAIOrgs[0].totalCount > 0 && org.recentCount > 0)
              ? Math.max(4, (org.totalCount / topAIOrgs[0].totalCount) * 100)
              : 0;
            return (
              <div class={`fin-inst-row fin-inst-grid ${idx < 3 ? 'fin-inst-top3' : ''}`}>
                <span class="fin-inst-name">
                  {idx < 3 && <span class="fin-inst-rank">{idx + 1}</span>}
                  {org.name}
                </span>
                <span class="fin-inst-count tabular-nums">{org.totalCount}</span>
                <span class="fin-inst-date tabular-nums">{org.lastSeen ? org.lastSeen.slice(5) : '—'}</span>
                <span class="fin-inst-bar-wrap">
                  <span class="fin-inst-bar" style={`width:${barWidth}%`} />
                </span>
              </div>
            );
          })}
        </div>
        <div class="fin-inst-footer">
          <span class="fin-meta">
            source: entity-index.json · AI App daily picks · keyword matching
          </span>
        </div>
      </details>
    </section>
  )}

  <!-- ══════════════════════════════
       SECTION A: 入門路徑
  ══════════════════════════════ -->
  <section class="start-here">
    <div class="sh-label">✦ <span data-tc>不知道從哪裡開始？選一條路徑</span><span data-sc>不知道从哪里开始？选一条路径</span></div>
    <div class="path-grid">
      {PATHS.map(path => (
        <div class={`path-card path-card--${path.accent}`}>
          <div class="path-head">
            <span class="path-icon">{path.icon}</span>
            <div>
              <div class="path-role"><span data-tc>{path.role}</span><span data-sc>{path.roleSC}</span></div>
              <div class="path-desc"><span data-tc>{path.desc}</span><span data-sc>{path.descSC}</span></div>
            </div>
          </div>
          <ol class="path-steps">
            {path.steps.map((step, i) => (
              <li class="path-step">
                <span class="step-n">{i + 1}</span>
                <a href={step.url} target="_blank" rel="noopener noreferrer" class="step-link">
                  <span data-tc>{step.label}</span><span data-sc>{step.labelSC ?? step.label}</span>
                  <svg width="9" height="9" viewBox="0 0 10 10" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                    <path d="M4 1H1.5a.5.5 0 00-.5.5v7a.5.5 0 00.5-.5h7a.5.5 0 00.5-.5V7M7 1h2v2M9 1L5 5"/>
                  </svg>
                </a>
              </li>
            ))}
          </ol>
        </div>
      ))}
    </div>
  </section>


  <!-- ══════════════════════════════
       SECTION B: 精選必讀 8 篇
  ══════════════════════════════ -->
  <section class="pinned-section">
    <div class="section-hd">
      <h2 class="section-title"><span data-tc>精選必讀</span><span data-sc>精选必读</span></h2>
      <span class="section-sub"><span data-tc>建立 Agentic 工程直覺的 8 篇核心文章</span><span data-sc>建立 Agentic 工程直觉的 8 篇核心文章</span></span>
    </div>
    <div class="pinned-grid">
      {PINNED.map(p => (
        <a href={p.url} target="_blank" rel="noopener noreferrer" class={`pinned-card pinned-card--${p.accent}`}>
          <div class="pinned-num">{p.num}</div>
          <div class="pinned-body">
            <span class={`pinned-mod pinned-mod--${p.accent}`}><span data-tc>{p.modLabel}</span><span data-sc>{MM[p.mod]?.labelSC ?? p.modLabel}</span></span>
            <div class="pinned-title"><span data-tc>{p.title}</span><span data-sc>{p.titleSC}</span></div>
            <div class="pinned-desc"><span data-tc>{p.desc}</span><span data-sc>{p.descSC}</span></div>
          </div>
          <span class="pinned-arrow" aria-hidden="true">→</span>
        </a>
      ))}
    </div>
  </section>

  <!-- ══════════════════════════════
       SECTION B2: PULSAR <span data-tc>深度分析</span><span data-sc>深度分析</span>
  ══════════════════════════════ -->
  {deepDiveArticles.length > 0 && (
    <section class="dd-section">
      <div class="section-hd">
        <h2 class="section-title">PULSAR <span data-tc>深度分析</span><span data-sc>深度分析</span></h2>
        <span class="section-sub">{deepDiveArticles.length} <span data-tc>篇 · Pipeline 自動生成</span><span data-sc>篇 · Pipeline 自动生成</span></span>
      </div>

      <!-- Tag filter bar -->
      <div class="dd-tag-filter" id="dd-tag-filter" role="tablist" aria-label="标签过滤">
        <button class="dtf-btn dtf-btn--all active" data-tag="all" role="tab" aria-selected="true">
          <span data-tc>全部</span><span data-sc>全部</span> <span class="dtf-ct">{deepDiveArticles.length}</span>
        </button>
        {AI_DEEP_DIVE_TAGS.filter(t => (tagCounts[t.id] ?? 0) > 0).map(t => (
          <button class={`dtf-btn dtf-btn--${t.accent}`} data-tag={t.id} role="tab" aria-selected="false">
            <span data-tc>{t.label}</span><span data-sc>{t.labelSC}</span>
            <span class="dtf-ct">{tagCounts[t.id] ?? 0}</span>
          </button>
        ))}
      </div>

      <div class="dd-list" id="dd-list">
        {deepDiveArticles.map((article, idx) => {
          const sig = SIGNAL_MAP[article.signal_type] ?? { label: article.signal_type, labelSC: article.signal_type, accent: 'cyan' };
          const tags = ddTagsMap.get(idx) ?? [];
          return (
            <a
              href={article.html_url || article.url}
              target="_blank"
              rel="noopener noreferrer"
              class={`dd-row ${idx >= DD_INITIAL ? 'dd-row--hidden' : ''}`}
              data-dd-idx={idx}
              data-tags={tags.join(',')}
            >
              <time class="dd-date">{article.date}</time>
              <span class={`dd-signal dd-signal--${sig.accent}`}><span data-tc>{sig.label}</span><span data-sc>{sig.labelSC ?? sig.label}</span></span>
              <span class="dd-title">{article.title}</span>
              <span class="dd-tags">
                {tags.map(tid => {
                  const t = TAG_MAP.get(tid);
