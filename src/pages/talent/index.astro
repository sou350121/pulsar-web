      transition: width 0.4s ease-out;
    }
    .tv2-vel-bar--up   { background: linear-gradient(90deg, var(--accent-amber), color-mix(in srgb, var(--accent-amber) 65%, var(--accent-cyan))); }
    .tv2-vel-bar--down { background: linear-gradient(90deg, var(--rating-x), color-mix(in srgb, var(--rating-x) 60%, transparent)); opacity: 0.85; }
    .tv2-vel-pct {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.8rem; font-weight: 700;
      text-align: right;
    }
    .tv2-vel-pct--up   { color: var(--accent-amber); }
    .tv2-vel-pct--down { color: var(--rating-x); }
    .tv2-vel-vol {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.68rem;
      color: var(--text-tertiary);
      text-align: right;
    }

    /* ── METHODOLOGY <details> ───────────────────────────────────────── */
    .tv2-method {
      margin: 3rem 0 1.5rem;
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--surface);
      padding: 0;
    }
    .tv2-method summary {
      list-style: none;
      cursor: pointer;
      padding: 1rem 1.25rem;
      display: flex; align-items: center; justify-content: space-between;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem;
      font-weight: 600;
      letter-spacing: 0.04em;
      color: var(--text-primary);
    }
    .tv2-method summary::-webkit-details-marker { display: none; }
    .tv2-method-summary-cue {
      font-family: 'IBM Plex Mono', monospace;
      color: var(--accent-cyan);
      font-size: 1.2rem;
      transition: transform 0.2s;
    }
    .tv2-method[open] .tv2-method-summary-cue { transform: rotate(45deg); }
    .tv2-method-list {
      padding: 0 1.5rem 1.25rem 2.75rem;
      margin: 0;
      color: var(--text-secondary);
      font-size: 0.85rem;
      line-height: 1.7;
    }
    .tv2-method-list li + li { margin-top: 0.5rem; }
    .tv2-method-list code {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85em;
      padding: 0.1em 0.35em;
      background: var(--surface-2);
      border-radius: 3px;
    }
    .tv2-method-list strong { color: var(--text-primary); }

    /* ── EMPTY STATE ─────────────────────────────────────────────────── */
    .tv2-empty {
      padding: 2.25rem 1.5rem;
      background: var(--surface);
      border: 1px dashed var(--border);
      border-radius: 10px;
      text-align: center;
    }
    .tv2-empty-title {
      font-family: Georgia, 'Songti SC', serif;
      font-size: 1.05rem;
      color: var(--text-primary);
      margin: 0 0 0.4rem;
    }
    .tv2-empty-sub {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.75rem;
      color: var(--text-tertiary);
      margin: 0;
    }

    /* ── FOOT ────────────────────────────────────────────────────────── */
    .tv2-foot {
      margin: 2rem 0 0;
      text-align: center;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem;
      color: var(--text-tertiary);
      letter-spacing: 0.06em;
    }
    .tv2-foot strong { color: var(--text-primary); }

    /* ── HR SCOUT FUNNEL ─────────────────────────────────────────────── */
    .tv2-scout { display: flex; flex-direction: column; gap: 1.5rem; }
    .tv2-hr-featured-meta {
      display: flex; flex-wrap: wrap; align-items: center; gap: 0.65rem;
      margin-top: 0.25rem;
    }

    /* Tier headers — share visual language across HOT / WARM / WATCH */
    .tv2-tier {
      border: 1px solid var(--border);
      border-radius: 10px;
      background: var(--surface);
      overflow: hidden;
    }
    .tv2-tier-head {
      display: flex; align-items: center; gap: 0.65rem;
      padding: 0.75rem 1rem;
      border-bottom: 1px solid var(--border);
      background: var(--surface-2);
    }
    .tv2-tier-head--clickable {
      cursor: pointer;
      user-select: none;
      list-style: none;
    }
    .tv2-tier-head--clickable::-webkit-details-marker { display: none; }
    .tv2-tier-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.75rem; font-weight: 700;
      letter-spacing: 0.14em;
      color: var(--text-primary);
      flex: 1; min-width: 0;
    }
    .tv2-tier-count {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem; font-weight: 700;
      color: var(--text-primary);
      padding: 0.15rem 0.55rem;
      border-radius: 999px;
      background: var(--surface);
      border: 1px solid var(--border);
    }
    .tv2-tier--hot   .tv2-tier-count { color: var(--accent-amber); border-color: var(--accent-amber); }
    .tv2-tier--warm  .tv2-tier-count { color: var(--accent-cyan);  border-color: var(--accent-cyan); }
    .tv2-tier--watch .tv2-tier-count { color: var(--text-secondary); }
    .tv2-tier-dot {
      width: 9px; height: 9px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .tv2-tier-dot[data-tier="hot"]   { background: var(--accent-amber); box-shadow: 0 0 0 3px var(--accent-amber-bg); }
    .tv2-tier-dot[data-tier="warm"]  { background: var(--accent-cyan);  box-shadow: 0 0 0 3px var(--accent-cyan-bg); }
    .tv2-tier-dot[data-tier="watch"] { background: var(--text-tertiary); }
    .tv2-tier-more {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem;
      color: var(--accent-cyan);
      text-decoration: none;
      letter-spacing: 0.05em;
    }
    .tv2-tier-more:hover { text-decoration: underline; }
    .tv2-tier-cue {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.68rem; font-weight: 400;
      color: var(--accent-cyan);
      letter-spacing: 0.05em;
    }
    details[open] .tv2-tier-cue::before { content: '↓ '; }
    details[open] .tv2-tier-cue { color: var(--text-tertiary); }
    .tv2-tier-lede {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.85rem;
      color: var(--text-secondary);
      line-height: 1.55;
      margin: 0;
      padding: 0.75rem 1rem 0;
    }

    /* Inline tier tags inside the section lede */
    .tv2-tier-tag {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.1em;
      padding: 0.1rem 0.45rem;
      border-radius: 4px;
      margin-right: 0.15rem;
    }
    .tv2-tier-tag--hot   { background: var(--accent-amber-bg); color: var(--accent-amber); }
    .tv2-tier-tag--warm  { background: var(--accent-cyan-bg);  color: var(--accent-cyan); }
    .tv2-tier-tag--watch { background: var(--surface-2);       color: var(--text-secondary); border: 1px solid var(--border); }

    /* Method tag chips — used on featured card + tables + warm cards */
    .tv2-method-tags {
      display: inline-flex; flex-wrap: wrap; gap: 0.3rem;
    }
    .tv2-method-tag {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.65rem; font-weight: 600;
      letter-spacing: 0.04em;
      padding: 0.15rem 0.5rem;
      border-radius: 4px;
      background: var(--accent-cyan-bg);
      color: var(--accent-cyan);
      border: 1px solid color-mix(in srgb, var(--accent-cyan) 30%, transparent);
      white-space: nowrap;
    }

    /* HOT compact scout table */
    .tv2-scout-table {
      width: 100%;
      border-collapse: collapse;
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem;
    }
    .tv2-scout-table td {
      padding: 0.6rem 0.75rem;
      border-bottom: 1px solid var(--border-subtle);
      vertical-align: middle;
    }
    .tv2-scout-table tr:last-child td { border-bottom: none; }
    .tv2-scout-table tr:hover td { background: var(--surface-2); }
    .tv2-scout-rank {
      width: 38px;
      color: var(--text-tertiary);
      font-weight: 700;
    }
    .tv2-scout-rating { width: 36px; }
    .tv2-scout-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.95rem;
      font-weight: 600;
      color: var(--text-primary);
      white-space: nowrap;
    }
    .tv2-scout-aff a {
      color: var(--accent-amber);
      text-decoration: none;
      font-weight: 600;
    }
    .tv2-scout-aff a:hover { text-decoration: underline; }
    .tv2-scout-methods { display: flex; flex-wrap: wrap; gap: 0.3rem; }
    .tv2-scout-papers {
      text-align: right;
      color: var(--text-primary);
      font-weight: 700;
      white-space: nowrap;
    }
    .tv2-scout-unit {
      color: var(--text-tertiary); font-weight: 400; font-size: 0.7rem;
    }

    /* WARM grid */
    .tv2-warm-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
      padding: 0.75rem 1rem 1rem;
    }
    .tv2-warm-card {
      display: flex; flex-direction: column; gap: 0.4rem;
      padding: 0.75rem 0.85rem;
      border: 1px solid var(--border);
      border-left: 3px solid var(--accent-cyan);
      border-radius: 8px;
      background: var(--surface-2);
      transition: transform 0.12s, box-shadow 0.12s;
    }
    .tv2-warm-card:hover {
      transform: translateY(-1px);
      box-shadow: var(--shadow-card);
    }
    .tv2-warm-head {
      display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap;
    }
    .tv2-warm-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 1.02rem; font-weight: 600;
      color: var(--text-primary);
      flex: 1; min-width: 0;
    }
    .tv2-warm-papers {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem; font-weight: 700;
      color: var(--text-primary);
    }
    .tv2-warm-unit {
      font-weight: 400; color: var(--text-tertiary); font-size: 0.7rem;
    }
    .tv2-warm-affil {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.78rem;
    }
    .tv2-warm-affil a {
      color: var(--accent-amber);
      text-decoration: none;
      font-weight: 600;
    }
    .tv2-warm-affil a:hover { text-decoration: underline; }
    .tv2-warm-noaff {
      color: var(--text-tertiary);
      font-style: italic;
      letter-spacing: 0.04em;
    }
    .tv2-method-tags--warm { margin-top: 0.1rem; }
    .tv2-warm-missed {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.7rem;
      color: var(--text-secondary);
      margin: 0;
      padding-top: 0.3rem;
      border-top: 1px dashed var(--border);
    }
    .tv2-warm-missed-tag {
      font-weight: 700;
      letter-spacing: 0.14em;
      color: var(--accent-cyan);
      margin-right: 0.4rem;
    }

    /* ── EMERGING (zero-prior families) ──────────────────────────────── */
    .tv2-emerging {
      margin-top: 0.75rem;
      padding: 0.75rem 1rem;
      background: var(--surface-2);
      border: 1px dashed var(--border);
      border-radius: 8px;
    }
    .tv2-emerging-label {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.65rem; font-weight: 700;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--accent-cyan);
      display: block; margin-bottom: 0.5rem;
    }
    .tv2-emerging-en {
      color: var(--text-tertiary); font-weight: 400; margin-left: 0.35rem;
    }
    .tv2-emerging-list {
      list-style: none; padding: 0; margin: 0;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.4rem 1rem;
    }
    .tv2-emerging-list li a {
      display: flex; align-items: center; gap: 0.6rem;
      padding: 0.35rem 0.5rem;
      text-decoration: none;
      border-radius: 4px;
      color: var(--text-primary);
      transition: background 0.12s;
    }
    .tv2-emerging-list li a:hover { background: var(--surface); }
    .tv2-emerging-name {
      font-family: Georgia, 'Songti SC', 'Noto Serif SC', serif;
      font-size: 0.9rem; flex: 1;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .tv2-emerging-count {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.85rem; font-weight: 700;
      color: var(--accent-cyan);
    }
    .tv2-emerging-unit {
      font-weight: 400; color: var(--text-tertiary); font-size: 0.7rem;
    }
    .tv2-brief-emerge-badge {
      font-family: 'IBM Plex Mono', monospace;
      font-size: 0.6rem; font-weight: 700;
      letter-spacing: 0.16em;
      padding: 0.18rem 0.45rem;
      border-radius: 4px;
      background: var(--accent-cyan-bg);
      color: var(--accent-cyan);
      border: 1px solid var(--accent-cyan);
    }

    /* ── RESPONSIVE ──────────────────────────────────────────────────── */
    @media (max-width: 900px) {
      .tv2-brief-grid { grid-template-columns: 1fr; }
      .tv2-hr-rest    { grid-template-columns: 1fr; }
      .tv2-vel-link {
        grid-template-columns: 24px 44px 1fr 56px;
        gap: 0.5rem;
      }
      .tv2-vel-track { grid-column: 1 / -1; }
      .tv2-vel-vol   { display: none; }
      .tv2-emerging-list { grid-template-columns: 1fr; }
      .tv2-warm-grid     { grid-template-columns: 1fr; }
      .tv2-scout-aff     { display: none; }
      .tv2-scout-name    { font-size: 0.88rem; }
    }
    @media (max-width: 600px) {
      .tv2-scout-methods { display: none; }
    }
    @media (max-width: 600px) {
      .tv2-hr-featured-body { padding: 1rem 1.15rem; }
      .tv2-hr-featured-title h3 { font-size: 1.4rem; }
      .tv2-hr-featured-stats { gap: 1.25rem; }
    }
  </style>
</BaseLayout>
