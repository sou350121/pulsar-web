---
/**
 * LabCard.astro
 * Lab profile card for /talent/labs.
 * Renders inline 14-day sparkline (CSS-only, no JS).
 */
import type { LabRecord } from '../utils/talent';
import RatingBadge from './RatingBadge.astro';

interface Props {
  record: LabRecord;
}
const { record } = Astro.props;

const maxBar = Math.max(1, ...record.velocityBars);
const recent7Color = record.recentSignalCount7d > 0 ? 'var(--accent-cyan)' : 'var(--text-muted)';
---

<article class="card group flex flex-col gap-3">
  <!-- Header: lab name + top rating -->
  <div class="flex items-start gap-2 flex-wrap">
    <h3 class="font-lora font-semibold text-pulsar-text text-base leading-snug flex-1 min-w-0">
      {record.name}
    </h3>
    <RatingBadge rating={record.topRating} size="sm" />
  </div>

  <!-- Stats row -->
  <div class="flex items-center gap-4 text-xs font-ibm-plex-mono">
    <span class="text-pulsar-muted">
      90d <span class="text-pulsar-text font-semibold">{record.signalCount90d}</span>
    </span>
    <span style={`color: ${recent7Color}`}>
      7d <span class="font-semibold">{record.recentSignalCount7d}</span>
    </span>
    <span class="text-pulsar-muted ml-auto">
      Last: {record.lastSeen}
    </span>
  </div>

  <!-- Sparkline: 14-day -->
  <div class="flex items-end gap-0.5 h-6" aria-label={`14-day activity sparkline for ${record.name}`}>
    {record.velocityBars.map(count => {
      const h = count === 0 ? '8%' : `${Math.max(15, Math.round(count / maxBar * 100))}%`;
      const bg = count === 0 ? 'var(--border)' : 'var(--accent-cyan)';
      return (
        <span
          style={`width: 6%; height: ${h}; background: ${bg}; border-radius: 1px; flex: 0 0 auto;`}
          title={`${count} signal(s)`}
        />
      );
    })}
  </div>

  <!-- Method focus -->
  {record.methodFocus.length > 0 && (
    <div class="flex flex-wrap gap-1">
      <span class="text-xs text-pulsar-muted font-ibm-plex-mono uppercase tracking-wide self-center mr-1">
        Focus:
      </span>
      {record.methodFocus.map(m => (
        <span class="tag tag-affiliation font-ibm-plex-mono text-xs">{m}</span>
      ))}
    </div>
  )}

  <!-- Evidence: top 3 papers -->
  {record.evidence.length > 0 && (
    <div class="flex flex-col gap-2 mt-1 pt-2 border-t border-pulsar-border">
      <span class="text-xs font-ibm-plex-mono text-pulsar-muted uppercase tracking-wide">
        Recent ⚡/🔧
      </span>
      {record.evidence.map(ev => (
        <a
          href={ev.url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-start gap-2 text-xs text-pulsar-text hover:text-pulsar-amber transition-colors leading-relaxed"
        >
          <RatingBadge rating={ev.rating} size="sm" />
          <span class="line-clamp-2 flex-1">
            {ev.title}
            <span class="ml-1 text-pulsar-muted font-ibm-plex-mono text-[0.65rem]">
              {ev.date}
            </span>
          </span>
        </a>
      ))}
    </div>
  )}
</article>
