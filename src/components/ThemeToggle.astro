---
/**
 * ThemeToggle.astro
 * Sun/moon button. Reads/writes localStorage key 'pulsar-theme'.
 * The <html> class switch triggers CSS variable swaps in global.css.
 */
---

<button
  id="theme-toggle"
  type="button"
  aria-label="切換深色模式"
  title="Toggle dark mode"
  class="p-2 rounded-md text-pulsar-muted hover:text-pulsar-text hover:bg-pulsar-surface transition-colors"
>
  <!-- Sun icon — shown in dark mode (click to go light) -->
  <svg
    id="icon-sun"
    xmlns="http://www.w3.org/2000/svg"
    width="18" height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="hidden dark:block"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="4"/>
    <line x1="12" y1="2"  x2="12" y2="4"/>
    <line x1="12" y1="20" x2="12" y2="22"/>
    <line x1="4.22"  y1="4.22"  x2="5.64"  y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="2"  y1="12" x2="4"  y2="12"/>
    <line x1="20" y1="12" x2="22" y2="12"/>
    <line x1="4.22"  y1="19.78" x2="5.64"  y2="18.36"/>
    <line x1="18.36" y1="5.64"  x2="19.78" y2="4.22"/>
  </svg>

  <!-- Moon icon — shown in light mode (click to go dark) -->
  <svg
    id="icon-moon"
    xmlns="http://www.w3.org/2000/svg"
    width="18" height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="block dark:hidden"
    aria-hidden="true"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    document.documentElement.classList.toggle('light', !isDark);
    localStorage.setItem('pulsar-theme', isDark ? 'dark' : 'light');
    btn.setAttribute('aria-label', isDark ? '切換淺色模式' : '切換深色模式');
  });
</script>
