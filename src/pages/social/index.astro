---
/**
 * src/pages/social/index.astro
 * Social intel archive — date-grouped, click-to-expand full reports.
 * Design: classified briefing aesthetic with amber (AI) / cyan (VLA) channels.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadSocialIntel, extractMarkdownSummary } from '../../utils/data';

const base = import.meta.env.BASE_URL;

const aiSocial  = loadSocialIntel('ai',  10);
const vlaSocial = loadSocialIntel('vla', 10);

// Detect empty-shell reports ("无重大信号" stubs ≤ 200 chars)
function isEmptyShell(content: string): boolean {
  const trimmed = content.trim();
  return trimmed.length <= 200 && /无重大信号/.test(trimmed);
}

// Compute last real update date per channel and staleness
function channelMeta(entries: typeof aiSocial) {
  const real = entries.filter(f => f.content.trim().length > 30 && !isEmptyShell(f.content));
  const lastDate = real[0]?.date ?? entries[0]?.date ?? null;
  const daysSince = lastDate
    ? Math.round((Date.now() - new Date(lastDate + 'T00:00:00+08:00').getTime()) / 86400000)
    : Infinity;
  return { lastDate, daysSince, stale: daysSince > 2 };
}
const aiMeta  = channelMeta(aiSocial);
const vlaMeta = channelMeta(vlaSocial);

// Format date as "3月8日"
function formatDateZh(iso: string): string {
  const [, m, d] = iso.split('-').map(Number);
  return `${m}月${d}日`;
}

// Format date as compact "03.08"
function formatCompact(iso: string): string {
  const parts = iso.split('-');
  return parts.length >= 3 ? `${parts[1]}.${parts[2]}` : iso;
}

// Relative day label
function relativeDay(iso: string): string {
  const diff = Math.round((Date.now() - new Date(iso).getTime()) / 86400000);
  if (Number.isNaN(diff)) return iso;
  if (diff === 0) return '今天';
  if (diff === 1) return '昨天';
  if (diff === 2) return '前天';
  return `${diff}天前`;
}

// Extract first meaningful line as preview
function extractPreview(content: string, maxLen = 120): string {
  for (const line of content.split('\n')) {
    const trimmed = line.replace(/^[#\s*-]+/, '').trim();
    if (trimmed.length > 20 && !trimmed.startsWith('http') && !trimmed.startsWith('*本')) {
      return trimmed.length > maxLen ? trimmed.slice(0, maxLen) + '…' : trimmed;
    }
  }
  return extractMarkdownSummary(content, maxLen);
}

// Count meaningful items in content
function countItems(content: string): number {
  return content.split('\n').filter(l => /^[-*•]\s*\S/.test(l.trim())).length;
}

// Markdown → compact HTML (dense layout, inline URLs, skip redundant headers)
function mdToHtml(md: string): string {
  const seenH1 = new Set<string>();
  return md
    .split('\n')
    .map(line => {
      const trimmed = line.trim();
      // Skip auto-generated footer + empty lines + HRs
      if (trimmed.startsWith('*本') || !trimmed || /^---\s*$/.test(trimmed)) return '';
      // Skip duplicate H1 (markdown has title twice: "# AI 社交情报" + "🛰️ AI 社交情报")
      if (/^#\s/.test(trimmed) && !trimmed.startsWith('##')) {
        const key = trimmed.replace(/^#\s*/, '').replace(/[\s|·]/g, '').slice(0, 20);
        if (seenH1.has(key)) return '';
        seenH1.add(key);
        return '';  // skip H1 entirely — date is already in the card header
      }
      // Section headers (## or emoji-prefixed) → compact label
      if (/^##\s/.test(trimmed)) return `<div class="si-sec">${trimmed.replace(/^##\s*/, '')}</div>`;
      // Emoji section header (e.g. "🔥 热议/争论")
      if (/^[\u{1F300}-\u{1FAFF}\u{2600}-\u{27BF}]/u.test(trimmed) && trimmed.length < 40 && !trimmed.startsWith('-')) {
        return `<div class="si-sec">${trimmed}</div>`;
      }
      // Standalone URL line → skip (will be inlined in the list item above)
      if (/^https?:\/\//.test(trimmed)) {
        return `<a href="${encodeURI(trimmed)}" target="_blank" rel="noopener noreferrer" class="si-url">[source]</a>`;
      }
      // Bold + inline links
      let html = line
        .replace(/\*\*([^*]+)\*\*/g, '<strong>$1</strong>')
        .replace(/(https?:\/\/[^\s<)]+)/g, (_m, url) => `<a href="${encodeURI(url)}" target="_blank" rel="noopener noreferrer" class="si-url">[link]</a>`);
      // List item
      if (/^[-*•]\s/.test(trimmed)) {
        html = `<div class="si-li">${html.replace(/^[\s]*[-*•]\s*/, '')}</div>`;
      } else {
        html = `<p class="si-p">${html}</p>`;
      }
      return html;
    })
    .filter(Boolean)
    .join('\n');
}

interface DayReport {
  date:    string;
  content: string;
  preview: string;
  count:   number;
  html:    string;
  empty:   boolean;   // true for "无重大信号" stubs
}

function buildDays(entries: typeof aiSocial): DayReport[] {
  return entries
    .filter(f => f.content.trim().length > 30)
    .map(f => {
      const empty = isEmptyShell(f.content);
      return {
        date:    f.date,
        content: f.content,
        preview: empty ? '当日无重大信号' : extractPreview(f.content),
        count:   empty ? 0 : countItems(f.content),
        html:    empty ? '<p class="si-p si-empty-note">当日无重大信号 — 系统正常运行，未检测到值得关注的社交动态。</p>' : mdToHtml(f.content),
        empty,
      };
    });
}

const aiDays  = buildDays(aiSocial);
const vlaDays = buildDays(vlaSocial);
---

<BaseLayout
  title="社交情報 Social Intel"
  description="AI 研究社群動態 — 追蹤頂尖研究者、機構與開源項目最新動態"
>
  <div class="social-page page-container">

    <!-- ── Breadcrumb ── -->
    <nav class="social-breadcrumb" aria-label="麵包屑">
      <a href={`${base}/`} class="bc-link"><span data-tc>首頁</span><span data-sc>首页</span></a>
      <span class="bc-sep">›</span>
      <span class="bc-current"><span data-tc>社交情報</span><span data-sc>社交情报</span></span>
    </nav>

    <!-- ═══ PAGE MASTHEAD ══════════════════════════════ -->
    <header class="social-masthead fade-in-1">
      <p class="social-overline">
        SIGNAL MONITORING · 72H WINDOW · AUTO-COLLECTED
      </p>
      <h1 class="social-page-title"><span data-tc>社交情報</span><span data-sc>社交情报</span></h1>
      <p class="social-page-subtitle">SOCIAL INTELLIGENCE FEED</p>
      <hr class="social-rule" />
      <p class="social-desc">
        每日追蹤 Karpathy · Altman · Amodei · LeCun · Sutskever · Hassabis · <span data-tc>李飛飛</span><span data-sc>李飞飞</span>
        及<span data-tc>頂級機構動態</span><span data-sc>顶级机构动态</span>。<span data-tc>點擊日期卡片展開完整報告</span><span data-sc>点击日期卡片展开完整报告</span>。
      </p>

      {/* ── Staleness notices ── */}
      {(aiMeta.stale || vlaMeta.stale) && (
        <div class="social-stale-notice">
          {aiMeta.stale && aiMeta.lastDate && (
            <span class="stale-tag stale-tag--ai">AI <span data-tc>最後有效更新</span><span data-sc>最后有效更新</span>：{aiMeta.lastDate.slice(5)}（{aiMeta.daysSince}<span data-tc>天前</span><span data-sc>天前</span>）· <span data-tc>數據可能延遲</span><span data-sc>数据可能延迟</span></span>
          )}
          {vlaMeta.stale && vlaMeta.lastDate && (
            <span class="stale-tag stale-tag--vla">VLA <span data-tc>最後有效更新</span><span data-sc>最后有效更新</span>：{vlaMeta.lastDate.slice(5)}（{vlaMeta.daysSince}<span data-tc>天前</span><span data-sc>天前</span>）· <span data-tc>數據可能延遲</span><span data-sc>数据可能延迟</span></span>
          )}
        </div>
      )}
    </header>

    <!-- ═══ TWO-COLUMN FEED ════════════════════════════ -->
    <div class="dual-feed fade-in-2">

      <!-- AI App channel -->
      <section class="feed-channel" aria-label="AI 應用情報">
        <header class="channel-header">
          <div class="channel-header-top">
            <div class="channel-dot channel-dot--ai"></div>
            <h2 class="channel-title"><span data-tc>AI 應用情報</span><span data-sc>AI 应用情报</span></h2>
            <span class="channel-count">{aiDays.length} <span data-tc>天</span><span data-sc>天</span></span>
          </div>
          <p class="channel-subtitle">
            <span data-tc>前沿研究者觀點 · 產品動態 · 範式轉換信號</span><span data-sc>前沿研究者观点 · 产品动态 · 范式转换讯号</span>
          </p>
          <div class="channel-accent-line channel-accent-line--ai"></div>
        </header>

        <div class="day-list">
          {aiDays.length > 0 ? aiDays.map((day, i) => (
            <details class={`day-card day-card--ai ${day.empty ? 'day-card--empty' : ''}`} data-day-idx={i} open={i === 0 && !day.empty}>
              <summary class="day-summary">
                <div class="day-summary-left">
                  <span class="day-date-badge day-date-badge--ai">{formatCompact(day.date)}</span>
                  <span class="day-relative">{relativeDay(day.date)}</span>
                  {day.empty && <span class="day-empty-badge"><span data-tc>無信號</span><span data-sc>无信号</span></span>}
                </div>
                <span class="day-preview">{day.preview}</span>
                <div class="day-summary-right">
                  {!day.empty && <span class="day-item-count">{day.count} <span data-tc>條</span><span data-sc>条</span></span>}
                  <span class="day-chevron" aria-hidden="true"></span>
                </div>
              </summary>
              <div class="day-body" set:html={day.html} />
            </details>
          )) : (
            <p class="feed-empty"><span data-tc>尚無 AI 情報資料</span><span data-sc>尚无 AI 情报资料</span></p>
          )}
        </div>
      </section>

      <!-- Vertical divider -->
      <div class="feed-divider" aria-hidden="true">
        <div class="feed-divider-line"></div>
      </div>

      <!-- VLA Research channel -->
      <section class="feed-channel" aria-label="VLA 研究情報">
        <header class="channel-header">
          <div class="channel-header-top">
            <div class="channel-dot channel-dot--vla"></div>
            <h2 class="channel-title"><span data-tc>VLA 研究情報</span><span data-sc>VLA 研究情报</span></h2>
            <span class="channel-count">{vlaDays.length} <span data-tc>天</span><span data-sc>天</span></span>
          </div>
          <p class="channel-subtitle">
            <span data-tc>機器人學習 · Benchmark 更新 · 實驗室動態</span><span data-sc>机器人学习 · Benchmark 更新 · 实验室动态</span>
          </p>
          <div class="channel-accent-line channel-accent-line--vla"></div>
        </header>

        <div class="day-list">
          {vlaDays.length > 0 ? vlaDays.map((day, i) => (
            <details class={`day-card day-card--vla ${day.empty ? 'day-card--empty' : ''}`} data-day-idx={i} open={i === 0 && !day.empty}>
              <summary class="day-summary">
                <div class="day-summary-left">
                  <span class="day-date-badge day-date-badge--vla">{formatCompact(day.date)}</span>
                  <span class="day-relative">{relativeDay(day.date)}</span>
                  {day.empty && <span class="day-empty-badge"><span data-tc>無信號</span><span data-sc>无信号</span></span>}
                </div>
                <span class="day-preview">{day.preview}</span>
                <div class="day-summary-right">
                  {!day.empty && <span class="day-item-count">{day.count} <span data-tc>條</span><span data-sc>条</span></span>}
                  <span class="day-chevron" aria-hidden="true"></span>
                </div>
              </summary>
              <div class="day-body" set:html={day.html} />
            </details>
          )) : (
            <p class="feed-empty"><span data-tc>尚無 VLA 情報資料</span><span data-sc>尚无 VLA 情报资料</span></p>
          )}
        </div>
      </section>

    </div>

    <!-- ── Bottom note ── -->
    <footer class="social-footer fade-in-3">
      <span class="footer-note">
        <span data-tc>資料來源</span><span data-sc>资料来源</span>：DashScope <span data-tc>網路搜尋</span><span data-sc>网络搜寻</span> · 每日 07:45 / 09:30 <span data-tc>自動採集</span><span data-sc>自动采集</span> · 72h 硬截止去重
      </span>
      <span class="footer-report-link">
        深度分析 → <a href={`${base}/reports`}><span data-tc>雙週報告</span><span data-sc>双周报告</span></a>
      </span>
    </footer>

  </div>
</BaseLayout>

<style>
/* ============================================================
   SOCIAL INTEL PAGE — EXPANDABLE DATE CARDS
============================================================ */

.social-page { padding-top: 32px; padding-bottom: 80px; }

/* ── Masthead ── */
.social-masthead { padding-bottom: 24px; }

.social-overline {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.58rem; letter-spacing: 0.22em;
  text-transform: uppercase; color: var(--text-tertiary); margin-bottom: 14px;
}

.social-page-title {
  font-family: 'Georgia', 'Songti SC', 'SimSun', serif !important;
  font-size: clamp(2.4rem, 5vw, 4rem); font-weight: 700;
  letter-spacing: -0.03em; line-height: 1.05;
  color: var(--text-primary); margin-bottom: 6px;
}

.social-page-subtitle {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.62rem; letter-spacing: 0.24em;
  text-transform: uppercase; color: var(--text-tertiary); margin-bottom: 22px;
}

.social-rule {
  border: none; border-top: 2px solid var(--border);
  position: relative; margin-bottom: 18px;
}
.social-rule::before {
  content: ''; position: absolute; top: -2px; left: 0;
  width: 60px; height: 2px; background: var(--accent-amber);
}
.social-rule::after {
  content: ''; position: absolute; top: -2px; left: 64px;
  width: 40px; height: 2px; background: var(--accent-cyan);
}

.social-desc {
  font-family: 'PingFang SC', 'Microsoft YaHei', 'Hiragino Sans GB', sans-serif;
  font-size: 0.875rem; line-height: 1.6; color: var(--text-secondary); max-width: 700px;
}

/* ── Two-column grid ── */
.dual-feed {
  display: grid; grid-template-columns: 1fr auto 1fr;
  gap: 0; align-items: start; margin-bottom: 40px;
}

.feed-divider { display: flex; justify-content: center; padding: 0 28px; padding-top: 70px; }
.feed-divider-line {
  width: 1px; height: 100%; min-height: 300px;
  background: linear-gradient(to bottom, transparent, var(--border) 15%, var(--border) 85%, transparent);
}

/* ── Channel ── */
.feed-channel { padding-top: 24px; }

.channel-header { padding-bottom: 10px; margin-bottom: 2px; }
.channel-header-top { display: flex; align-items: center; gap: 10px; margin-bottom: 4px; }

.channel-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.channel-dot--ai  { background: var(--accent-amber); }
.channel-dot--vla { background: var(--accent-cyan); }

.channel-title {
  font-family: 'Georgia', 'Songti SC', 'SimSun', serif !important;
  font-size: 1.15rem; font-weight: 700; color: var(--text-primary); margin: 0; line-height: 1.2;
}

.channel-count {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.62rem; font-weight: 600; color: var(--text-tertiary);
  background: var(--surface-2); border: 1px solid var(--border);
  padding: 1px 7px; border-radius: 3px; letter-spacing: 0.04em; margin-left: auto;
}

.channel-subtitle {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.58rem; letter-spacing: 0.1em; text-transform: uppercase;
  color: var(--text-tertiary); margin-bottom: 12px; line-height: 1.5;
}

.channel-accent-line { height: 2px; border-radius: 1px; width: 100%; }
.channel-accent-line--ai  { background: linear-gradient(to right, var(--accent-amber), transparent); }
.channel-accent-line--vla { background: linear-gradient(to right, var(--accent-cyan), transparent); }

/* ── Day card list ── */
.day-list { display: flex; flex-direction: column; gap: 4px; }

/* ── Day card (details/summary) ── */
.day-card {
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--surface);
  overflow: hidden;
  transition: border-color 0.2s;
}
.day-card:hover { border-color: var(--text-tertiary); }
.day-card[open] { border-color: var(--text-tertiary); }
.day-card--ai[open]  { border-color: rgba(212,145,10,0.4); }
.day-card--vla[open] { border-color: rgba(14,165,179,0.4); }

/* Summary row (always visible) */
.day-summary {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 14px;
  cursor: pointer;
  user-select: none;
  list-style: none;
  transition: background 0.15s;
}
.day-summary::-webkit-details-marker { display: none; }
.day-summary::marker { display: none; content: ''; }
.day-summary:hover { background: var(--surface-2); }

.day-summary-left {
  display: flex; align-items: center; gap: 8px; flex-shrink: 0;
}

.day-date-badge {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.68rem; font-weight: 700; letter-spacing: 0.04em;
  padding: 2px 8px; border-radius: 4px;
}
.day-date-badge--ai {
  color: var(--accent-amber); background: var(--accent-amber-bg);
  border: 1px solid rgba(212,145,10,0.25);
}
.day-date-badge--vla {
  color: var(--accent-cyan); background: var(--accent-cyan-bg);
  border: 1px solid rgba(14,165,179,0.25);
}

.day-relative {
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 0.68rem; color: var(--text-tertiary);
}

.day-preview {
  flex: 1; min-width: 0;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
  font-size: 0.78rem; color: var(--text-secondary);
  white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
/* Hide preview when open */
.day-card[open] .day-preview { display: none; }

.day-summary-right {
  display: flex; align-items: center; gap: 8px; flex-shrink: 0;
}

.day-item-count {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.58rem; color: var(--text-tertiary);
  letter-spacing: 0.04em;
}

.day-chevron {
  display: inline-block; width: 14px; height: 14px;
  position: relative; flex-shrink: 0;
  transition: transform 0.2s;
}
.day-chevron::before {
  content: '';
  position: absolute; top: 4px; left: 3px;
  width: 7px; height: 7px;
  border-right: 1.5px solid var(--text-tertiary);
  border-bottom: 1.5px solid var(--text-tertiary);
  transform: rotate(45deg);
  transition: transform 0.2s;
}
.day-card[open] .day-chevron::before {
  transform: rotate(-135deg);
  top: 6px;
}

/* ── Day body (expanded content) ── */
.day-body {
  padding: 4px 16px 12px;
  font-family: 'PingFang SC', 'Microsoft YaHei', 'Hiragino Sans GB', sans-serif;
  font-size: 0.8rem;
  line-height: 1.6;
  color: var(--text-secondary);
  border-top: 1px solid var(--border-subtle); margin-top: 2px;
  animation: dayBodyIn 0.25s ease;
}

@keyframes dayBodyIn {
  from { opacity: 0; transform: translateY(-4px); }
  to   { opacity: 1; transform: translateY(0); }
}

/* Rendered markdown styles inside day-body */
.day-body :global(.si-h2) {
  font-family: 'Georgia', 'Songti SC', serif;
  font-size: 1rem; font-weight: 700; color: var(--text-primary);
  margin: 10px 0 4px; line-height: 1.2;
}
.day-body :global(.si-h3) {
  font-size: 0.9rem; font-weight: 700; color: var(--text-primary);
  margin: 8px 0 3px;
}
.day-body :global(.si-p) {
  margin: 1px 0; line-height: 1.55;
}
.day-body :global(.si-li) {
  position: relative;
  padding-left: 16px;
  margin: 2px 0;
  line-height: 1.55;
}
.day-body :global(.si-li)::before {
  content: '·';
  position: absolute; left: 4px; top: 0;
  color: var(--text-tertiary); font-weight: 700;
}
.day-card--ai .day-body :global(.si-li)::before { color: var(--accent-amber); }
.day-card--vla .day-body :global(.si-li)::before { color: var(--accent-cyan); }


.day-body :global(.si-hr) {
  border: none; border-top: 1px solid var(--border-subtle); margin-top: 2px;
  margin: 16px 0;
}
.day-body :global(br) { display: none; }
.day-body :global(strong) { color: var(--text-primary); font-weight: 700; }

/* ── Staleness notice ── */
.social-stale-notice {
  display: flex; flex-wrap: wrap; gap: 8px; margin-top: 12px;
}
.stale-tag {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.62rem; letter-spacing: 0.04em;
  padding: 3px 10px; border-radius: 4px;
  border: 1px solid var(--border);
  color: var(--text-tertiary);
  background: var(--surface-2);
}
.stale-tag--ai  { border-color: rgba(212,145,10,0.3); }
.stale-tag--vla { border-color: rgba(14,165,179,0.3); }

/* ── Empty-shell day card ── */
.day-card--empty { opacity: 0.65; }
.day-card--empty:hover { opacity: 0.85; }

.day-empty-badge {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.56rem; letter-spacing: 0.04em;
  padding: 1px 6px; border-radius: 3px;
  background: var(--surface-2); border: 1px solid var(--border);
  color: var(--text-tertiary);
}

.day-body :global(.si-empty-note) {
  font-style: italic; color: var(--text-tertiary);
  padding: 8px 0;
}

/* ── Empty state ── */
.feed-empty {
