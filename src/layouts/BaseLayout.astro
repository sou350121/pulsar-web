---
/**
 * BaseLayout.astro
 * Full HTML shell used by every page.
 * Props:
 *   title       — <title> tag content (appended with " | Pulsar")
 *   description — <meta name="description"> (defaults to site tagline)
 *   ogImage     — Open Graph image URL (optional)
 *   noIndex     — set true to add <meta name="robots" content="noindex">
 */
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  noIndex?: boolean;
}

const {
  title = 'Pulsar',
  description = 'AI Research Intelligence — 照見 (Zhàojiàn) pipeline monitoring, daily picks, and biweekly reflections.',
  ogImage = '/og-default.png',
  noIndex = false,
} = Astro.props;

const siteName = 'Pulsar';
const fullTitle = title === 'Pulsar' ? siteName : `${title} | ${siteName}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://pulsar.sou350121.github.io');
---

<!doctype html>
<html lang="zh-TW">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon (placeholder — replace with actual asset) -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={ogImage} />
    <meta property="og:site_name"   content={siteName} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={ogImage} />

    {noIndex && <meta name="robots" content="noindex, nofollow" />}

    <!--
      Theme initialisation — must run BEFORE first paint to avoid flash.
      Reads localStorage and applies the 'dark' class to <html> synchronously.
      Defaults to dark if no preference is stored.
    -->
    <script is:inline>
      (function() {
        var saved = localStorage.getItem('pulsar-theme');
        if (saved === 'light') {
          document.documentElement.classList.remove('dark');
        } else {
          /* dark by default — matches prototype behaviour */
          document.documentElement.classList.add('dark');
        }
      })();
    </script>
  </head>

  <body>
    <!-- Skip to content link — accessibility -->
    <a
      href="#main-content"
      class="sr-only"
      style="position:fixed;top:1rem;left:1rem;z-index:999;padding:0.5rem 1rem;background:var(--accent-amber);color:#fff;border-radius:6px;"
    >
      Skip to content
    </a>

    <Header />

    <main id="main-content">
      <slot />
    </main>

    <Footer />
  </body>
</html>
