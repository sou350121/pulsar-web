          <div class="health-list">
            {[
              { name: '<span data-tc>VLA 論文採集</span><span data-sc>VLA 论文采集</span>',    time: '09:00', ok: true  },
              { name: 'AI App <span data-tc>日報</span><span data-sc>日报</span>',     time: '07:00', ok: true  },
              { name: '<span data-tc>社交情報採集</span><span data-sc>社交情报采集</span>',    time: '09:30', ok: true  },
