---
/**
 * src/pages/vla-deepdive/index.astro
 * VLA Deep Dive — 統一文章庫 + 方法族趨勢金融終端看板 + SOTA 排行。
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadVLASOTA, loadVLATheory, loadVLAGitHubArticles, loadLatestFieldState, loadFieldStateHistory, COMPETITION_PAIRS } from '../../utils/data';
import type { FamilyTimeSeries } from '../../utils/data';

const theory   = loadVLATheory(50);
const sota     = loadVLASOTA(30);
const ghAll    = loadVLAGitHubArticles(100);
const fieldState = loadLatestFieldState();
const history  = loadFieldStateHistory();

const GITHUB_REPO         = 'https://github.com/sou350121/VLA-Handbook';
const GITHUB_THEORY_PATH  = `${GITHUB_REPO}/tree/main/theory`;
const GITHUB_SOTA_PATH    = 'https://sota.evomind-tech.com';

// 14-day cutoff
const cutoff = new Date(Date.now() - 14 * 86400000).toISOString().slice(0, 10);

// Deduplicate GitHub articles against theory articles (by title, case-insensitive)
const theoryTitles = new Set(theory.map(a => a.title.toLowerCase().trim()));
const dedupedGh = ghAll.filter(a => !theoryTitles.has(a.title.toLowerCase().trim()));

// Unified combined list (single data source)
const allCombined = [
  ...theory.map(a => ({
    title:    a.title,
    date:     a.date,
    html_url: a.html_url || a.url,
    topic:    a.target_dir?.replace('theory/', '') ?? 'general',
    source:   'pipeline' as const,
  })),
  ...dedupedGh.map(a => ({
    title:    a.title,
    date:     a.date,
    html_url: a.html_url || a.url,
    topic:    a.topic,
    source:   'github' as const,
  })),
].sort((a, b) => b.date.localeCompare(a.date));

// Split into recent (cards) and older (topic-grouped list)
const recentAll = allCombined.filter(a => a.date >= cutoff);
const olderAll  = allCombined.filter(a => a.date < cutoff);
const byTopicAll: Record<string, typeof olderAll> = {};
for (const a of olderAll) { (byTopicAll[a.topic] ??= []).push(a); }
const topics = Object.keys(byTopicAll).sort();

function dotDate(iso: string) {
  const [y, m, d] = iso.split('-');
  return `${y}.${m}.${d}`;
}

function vddRecency(dateStr: string): string {
  const now  = new Date();
  const d    = new Date(dateStr + 'T00:00:00+08:00');
  const diff = Math.floor((now.getTime() - d.getTime()) / 86400000);
  if (diff <= 0)  return '今天';
  if (diff === 1) return '昨天';
  return `${diff} 天前`;
}

// Group SOTA by benchmark
const sotaByBenchmark: Record<string, typeof sota> = {};
for (const s of sota) { (sotaByBenchmark[s.benchmark] ??= []).push(s); }
const benchmarks = Object.keys(sotaByBenchmark).sort();

// Method family display names
const FAMILY_NAMES: Record<string, string> = {
  diffusion_policy:   'Diffusion Policy',
  flow_matching:      'Flow Matching',
  rl_finetuning:      'RL Fine-tuning',
  instruction_tuning: 'Instr. Tuning',
  world_model:        'World Model',
  tactile:            'Tactile',
  dexterous_hand:     'Dexterous Hand',
  cross_embodiment:   'Cross-Embodiment',
};

// Short names for gauge/competition
const FAMILY_SHORT: Record<string, string> = {
  diffusion_policy:   'Diffusion Pol.',
  flow_matching:      'Flow Matching',
  rl_finetuning:      'RL Fine-tune',
  instruction_tuning: 'Instr. Tuning',
  world_model:        'World Model',
  tactile:            'Tactile',
  dexterous_hand:     'Dext. Hand',
  cross_embodiment:   'Cross-Embod.',
};

// Build saturated benchmark set from field-state (prefix match: BENCHMARK/SPLIT → BENCHMARK)
const saturatedBenchmarks = new Set<string>();
if (fieldState?.benchmark_health) {
  for (const bh of fieldState.benchmark_health) {
    if (bh.status === 'saturated') {
      saturatedBenchmarks.add(bh.benchmark.split('/')[0]);
    }
  }
}

// --- Financial terminal helpers ---

// Build SVG sparkline bars for a family's share history
function buildSparkBars(shares: number[]): { x: number; y: number; h: number; up: boolean }[] {
  if (shares.length < 2) return [];
  const min = Math.min(...shares);
  const max = Math.max(...shares);
  const range = max - min || 0.001; // avoid division by zero
  const barW = 8;
  const gap = 4;
  const svgH = 36;
  const padding = 2;
  const usableH = svgH - padding * 2;

  return shares.map((s, i) => {
    const norm = (s - min) / range; // 0..1
    const h = Math.max(2, norm * usableH);
    const y = svgH - padding - h;
    const up = i === 0 ? true : s >= shares[i - 1];
    return { x: i * (barW + gap), y, h, up };
  });
}

// MA line points for sparkline
function buildMALine(shares: number[], window: number = 3): { x: number; y: number }[] {
  if (shares.length < window) return [];
  const min = Math.min(...shares);
  const max = Math.max(...shares);
  const range = max - min || 0.001;
  const barW = 8;
  const gap = 4;
  const svgH = 36;
  const padding = 2;
  const usableH = svgH - padding * 2;

  const points: { x: number; y: number }[] = [];
  for (let i = 0; i < shares.length; i++) {
    const start = Math.max(0, i - window + 1);
    const slice = shares.slice(start, i + 1);
    const avg = slice.reduce((a, b) => a + b, 0) / slice.length;
    const norm = (avg - min) / range;
    const y = svgH - padding - norm * usableH;
    points.push({ x: i * (barW + gap) + barW / 2, y });
  }
  return points;
}

// Sparkline SVG width
function sparkWidth(n: number): number {
  return n * 8 + (n - 1) * 4;
}

// Status dot and label
function statusInfo(accel: number, status: string): { dot: string; label: string; cls: string } {
  if (status === 'accelerating' || accel >= 1.5) return { dot: '◉', label: 'SURGE', cls: 'fin-surge' };
  if (accel >= 1.15) return { dot: '●', label: 'ACCEL', cls: 'fin-accel-dot' };
  if (!(accel > 0.85)) return { dot: '●', label: 'DECEL', cls: 'fin-decel-dot' };
  return { dot: '●', label: 'STABLE', cls: 'fin-stable-dot' };
}

// Format share as percentage
function fmtPct(v: number): string {
  return (v * 100).toFixed(1) + '%';
}

// Format delta (pp change)
function fmtDelta(v: number): string {
  const pp = v * 100;
  return (pp >= 0 ? '+' : '') + pp.toFixed(1);
}

// Momentum gauge: position of thumb (0..100), center = 50 (accel=1.0)
// Maps accel range [0.5, 2.0] → [0, 100]
function gaugePos(accel: number): number {
  const clamped = Math.max(0.5, Math.min(2.0, accel));
  return ((clamped - 0.5) / 1.5) * 100;
}

// Gauge thumb color class
function gaugeColorCls(accel: number): string {
  if (accel > 1.5)  return 'fin-gauge-glow';
  if (accel > 1.2)  return 'fin-gauge-up';
  if (accel < 0.8)  return 'fin-gauge-down';
  return 'fin-gauge-neutral';
}


// Helpers to avoid <= in JSX templates (Astro compiler treats < as tag)
function accelCls(val: number): string {
  if (val >= 1.15) return 'fin-up';
  if (val >= 0.86) return 'fin-flat';  // > 0.85
  return 'fin-down';
}

function isDecel(val: number): boolean {
  return val >= 0 && val < 0.71; // <= 0.7
}

// Sort families by latest share desc (already done in history loader)
const sortedFamilies = history?.families ?? [];
// Sort by accel desc for gauge
const sortedByAccel = [...sortedFamilies].sort((a, b) => b.latest.accel - a.latest.accel);

// Competition pairs data
const pairsData = history ? COMPETITION_PAIRS.map(pair => {
  const a = history.families.find(f => f.family === pair.familyA);
  const b = history.families.find(f => f.family === pair.familyB);
  if (!a || !b) return null;
  const total = a.latest.share + b.latest.share;
  const pctA = total > 0 ? (a.latest.share / total) * 100 : 50;
  const ratio = b.latest.share > 0 ? (a.latest.share / b.latest.share).toFixed(2) : '—';
  return { ...pair, a, b, pctA, ratio };
}).filter(Boolean) : [];

const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="VLA 深度追蹤"
  description="Vision-Language-Action 理論深挖與 SOTA 排行 — VLA-Handbook 庫"
>
  <div class="vdd-page page-container">

    <!-- ── Breadcrumb ── -->
    <nav class="dd-breadcrumb" aria-label="麵包屑">
      <a href={`${base}/`} class="bc-link"><span data-tc>首頁</span><span data-sc>首页</span></a>
      <span class="bc-sep">›</span>
      <span class="bc-current"><span data-tc>VLA 深度追蹤</span><span data-sc>VLA 深度追踪</span></span>
    </nav>

    <!-- ── Masthead (slim) ── -->
    <header class="vdd-masthead">
      <div class="vdd-overline"><span data-tc>VLA 線 · DEEP DIVE ARCHIVE</span><span data-sc>VLA 线 · DEEP DIVE ARCHIVE</span></div>
      <h1 class="vdd-title"><span data-tc>VLA 深度追蹤</span><span data-sc>VLA 深度追踪</span></h1>
      <div class="vdd-accent-bar"></div>
      <p class="vdd-desc"><span data-tc>Vision-Language-Action：讓機器人看→想→做的端到端模型</span><span data-sc>Vision-Language-Action：让机器人看→想→做的端到端模型</span></p>

      <!-- GitHub CTA row -->
      <div class="vdd-cta-row">
        <a href={GITHUB_THEORY_PATH} target="_blank" rel="noopener noreferrer" class="vdd-github-btn">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
            <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38
              0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13
              -.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87
              2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95
              0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12
              0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27
              1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12
              .51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95
              .29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2
              0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
          </svg>
          <span data-tc>VLA-Handbook 庫</span><span data-sc>VLA-Handbook 库</span>
          <span class="vdd-github-sub"><span data-tc>theory/ 目錄</span><span data-sc>theory/ 目录</span></span>
          <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M2 6h8M6 2l4 4-4 4"/>
          </svg>
        </a>
        <a href={GITHUB_SOTA_PATH} target="_blank" rel="noopener noreferrer" class="vdd-github-secondary">
          Evo-SOTA 排行榜 →
        </a>
        <div class="vdd-stats-row">
          <span class="vdd-stat">
            <span class="vdd-stat-num">{allCombined.length}</span>
            <span class="vdd-stat-lbl"><span data-tc>理論文章</span><span data-sc>理论文章</span></span>
          </span>
          <span class="vdd-stat-sep">·</span>
          <span class="vdd-stat">
            <span class="vdd-stat-num vdd-stat-num--cyan">{sota.length}</span>
            <span class="vdd-stat-lbl"><span data-tc>SOTA 記錄</span><span data-sc>SOTA 记录</span></span>
          </span>
        </div>
      </div>
    </header>

    <!-- ══════════════════════════════════════════
         FINANCIAL TERMINAL: Method Family Trends
    ══════════════════════════════════════════ -->
    {history && (
      <section class="fin-panel" aria-label="方法族趨勢看板">
        <!-- Gradient top bar via ::before -->

        <!-- Header -->
        <div class="fin-header">
          <div class="fin-header-left">
            <h2 class="fin-title">METHOD FAMILY TRENDS</h2>
            <span class="fin-meta">
              {history.latestDate} · {history.totalPapers} papers · {history.dates.length}d window
            </span>
          </div>
          <span class={`fin-confidence fin-confidence--${history.confidence}`}>
            confidence: {history.confidence}
          </span>
        </div>

        <!-- A: Ticker Table -->
        <div class="fin-ticker-header">
          <span class="fin-th fin-th-name">FAMILY</span>
          <span class="fin-th fin-th-chart">{history.dates.length}D CHART</span>
          <span class="fin-th fin-th-share">SHARE</span>
          <span class="fin-th fin-th-delta">&Delta;</span>
          <span class="fin-th fin-th-accel">MOM</span>
          <span class="fin-th fin-th-vol">VOL</span>
          <span class="fin-th fin-th-status">ST</span>
        </div>
        <div class="fin-ticker">
          {sortedFamilies.map(fam => {
            const bars = buildSparkBars(fam.shares);
            const maLine = buildMALine(fam.shares);
            const maPath = maLine.length > 1
              ? 'M' + maLine.map(p => `${p.x.toFixed(1)},${p.y.toFixed(1)}`).join('L')
              : '';
            const svgW = sparkWidth(fam.shares.length);
            const si = statusInfo(fam.latest.accel, fam.latest.status);
            const deltaCls = fam.delta >= 0 ? 'fin-up' : 'fin-down';
            const accelClsVal = accelCls(fam.latest.accel);
            return (
              <div class="fin-row">
                <span class="fin-name">{FAMILY_NAMES[fam.family] ?? fam.family}</span>
                <svg class="fin-spark" viewBox={`0 0 ${svgW} 36`} width={svgW} height="36" aria-hidden="true">
                  {bars.map(b => (
                    <rect
                      x={b.x} y={b.y} width="8" height={b.h} rx="1"
                      fill={b.up ? 'var(--fin-up)' : 'var(--fin-down)'}
                      opacity="0.85"
                    />
                  ))}
                  {maPath && (
                    <path d={maPath} fill="none" stroke="var(--text-tertiary)" stroke-width="1"
                      stroke-dasharray="3,2" opacity="0.5" />
                  )}
                </svg>
                <span class="fin-share">{fmtPct(fam.latest.share)}</span>
                <span class={`fin-delta ${deltaCls}`}>{fmtDelta(fam.delta)}</span>
                <span class={`fin-accel ${accelClsVal}`}>{fam.latest.accel.toFixed(2)}</span>
                <span class="fin-vol">{fam.latest.count}</span>
                <span class={`fin-status-dot ${si.cls}`} title={si.label}>{si.dot}</span>
              </div>
            );
          })}
        </div>

        <!-- B: Momentum Gauge -->
        <div class="fin-gauge-panel">
          <h3 class="fin-sub-title">MOMENTUM GAUGE</h3>
          <div class="fin-gauge-axis">
            <span class="fin-gauge-label-left">decel</span>
            <span class="fin-gauge-label-center">1.0</span>
            <span class="fin-gauge-label-right">accel</span>
          </div>
          {sortedByAccel.map(fam => {
            const pos = gaugePos(fam.latest.accel);
            const centerPos = gaugePos(1.0);
            const colorCls = gaugeColorCls(fam.latest.accel);
            const isAccel = fam.latest.accel >= 1.0;
            const fillLeft = isAccel ? centerPos : pos;
            const fillWidth = isAccel ? pos - centerPos : centerPos - pos;
            return (
              <div class="fin-gauge-row">
                <span class="fin-gauge-name">{FAMILY_SHORT[fam.family] ?? fam.family}</span>
                <div class="fin-gauge-track">
                  <div class="fin-gauge-center-line" style={`left:${centerPos}%`}></div>
                  <div
                    class={`fin-gauge-fill ${isAccel ? 'fin-gauge-fill-right' : 'fin-gauge-fill-left'}`}
                    style={`left:${fillLeft}%;width:${Math.max(fillWidth, 0.5)}%`}
                  ></div>
                  <div class={`fin-gauge-thumb ${colorCls}`} style={`left:${pos}%`}></div>
                </div>
                <span class={`fin-gauge-val ${accelCls(fam.latest.accel)}`}>
                  {fam.latest.accel.toFixed(2)}
                </span>
                {fam.latest.accel >= 1.5 && <span class="fin-gauge-tag fin-up">ACCEL</span>}
                {isDecel(fam.latest.accel) && <span class="fin-gauge-tag fin-down">DECEL</span>}
              </div>
            );
          })}
        </div>

        <!-- C: Competition Pairs -->
        {pairsData.length > 0 && (
          <div class="fin-competition">
            <h3 class="fin-sub-title">COMPETITION PAIRS</h3>
            {pairsData.map(pair => pair && (
              <div class="fin-pair">
                <div class="fin-pair-label">{pair.label}</div>
                <div class="fin-pair-names">
                  <span class="fin-pair-name-left">{FAMILY_SHORT[pair.familyA] ?? pair.familyA}</span>
                  <span class="fin-pair-vs">vs</span>
                  <span class="fin-pair-name-right">{FAMILY_SHORT[pair.familyB] ?? pair.familyB}</span>
                </div>
                <div class="fin-pair-bar">
                  <div class="fin-pair-left" style={`width:${pair.pctA}%`}>
                    <span class="fin-pair-pct">{pair.pctA.toFixed(0)}%</span>
                  </div>
                  <div class="fin-pair-right" style={`width:${100 - pair.pctA}%`}>
                    <span class="fin-pair-pct">{(100 - pair.pctA).toFixed(0)}%</span>
                  </div>
                </div>
                <div class="fin-pair-stats">
                  <span class="fin-pair-stat">{fmtPct(pair.a.latest.share)} · x{pair.a.latest.accel.toFixed(2)}</span>
                  <span class="fin-pair-ratio">ratio {pair.ratio}</span>
                  <span class="fin-pair-stat">{fmtPct(pair.b.latest.share)} · x{pair.b.latest.accel.toFixed(2)}</span>
                </div>
              </div>
            ))}
          </div>
        )}
      </section>
    )}

    <!-- ══════════════════════════════════════════
         UNIFIED: Theory Articles (merged)
    ══════════════════════════════════════════ -->
    <section class="vdd-section" aria-label="VLA 理論文章庫">
      <div class="vdd-section-header">
        <h2 class="vdd-section-title"><span data-tc>📐 理論文章庫</span><span data-sc>📐 理论文章库</span></h2>
        <a href={GITHUB_THEORY_PATH} target="_blank" rel="noopener noreferrer" class="vdd-section-link">
          <span data-tc>查看 GitHub 全庫</span><span data-sc>查看 GitHub 全库</span> →
        </a>
      </div>

      {allCombined.length === 0 ? (
        <p class="vdd-empty"><span data-tc>尚無理論文章資料</span><span data-sc>尚无理论文章资料</span></p>
      ) : (
        <>
          {/* --- Recent cards with NEW badge --- */}
          {recentAll.length > 0 && (
            <div class="vdd-subsection">
              <div class="vdd-subsection-label">
                <span class="vdd-sublabel"><span data-tc>最近 2 週</span><span data-sc>最近 2 周</span></span>
                <span class="vdd-sublabel-count">{recentAll.length} 篇</span>
              </div>
              <div class="vdd-card-grid">
                {recentAll.map((article) => (
                  <article class="vdd-card">
                    <div class="vdd-card-top">
                      <time class="vdd-card-date">{dotDate(article.date)}</time>
                      <span class="vdd-card-recency">{vddRecency(article.date)}</span>
                      <span class="vdd-card-tag vdd-card-tag--cyan">
                        {article.topic.replace(/-/g, ' ')}
                      </span>
                    </div>
                    <h3 class="vdd-card-title">{article.title}</h3>
                    <a
                      href={article.html_url || article.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="vdd-card-cta"
                    >
                      <span data-tc>在 GitHub 閱讀</span><span data-sc>在 GitHub 阅读</span>
                      <svg width="11" height="11" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                        <path d="M2 6h8M6 2l4 4-4 4"/>
                      </svg>
                    </a>
                  </article>
                ))}
              </div>
            </div>
          )}

          {/* --- Older articles grouped by topic --- */}
          {olderAll.length > 0 && (
            <div class="vdd-subsection">
              {recentAll.length > 0 && (
                <div class="vdd-subsection-label">
                  <span class="vdd-sublabel">更多文章 · 全部在 GitHub</span>
                  <span class="vdd-sublabel-count">{olderAll.length} 篇</span>
                </div>
              )}
              <div class="vdd-topics">
                {topics.map(topic => (
                  <div class="vdd-topic-group">
                    <div class="vdd-topic-label">
                      {topic.replace(/-/g, ' ')} &nbsp;·&nbsp; {byTopicAll[topic].length} 篇
                    </div>
                    <div class="vdd-art-list">
                      {byTopicAll[topic].map((article, i) => (
                        <a
                          href={article.html_url || article.url}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="vdd-art-row"
                          style={`animation-delay:${i * 0.03}s`}
                        >
                          <time class="vdd-art-date">{dotDate(article.date)}</time>
                          <span class="vdd-art-title">{article.title}</span>
                          <span class="vdd-art-ext" aria-label="在 GitHub 閱讀">
                            <svg width="11" height="11" viewBox="0 0 12 12" fill="none"
                              stroke="currentColor" stroke-width="2" stroke-linecap="round">
                              <path d="M5 2H2a1 1 0 00-1 1v7a1 1 0 001 1h7a1 1 0 001-1V7"/>
                              <path d="M8 1h3v3M11 1L6 6"/>
                            </svg>
                          </span>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          )}
        </>
      )}
    </section>

    <!-- ══════════════════════════════════════════
         SOTA Leaderboard
    ══════════════════════════════════════════ -->
    <section class="vdd-section" aria-label="SOTA 排行">
      <div class="vdd-section-header">
        <h2 class="vdd-section-title">🏆 SOTA 排行</h2>
        <a href={GITHUB_SOTA_PATH} target="_blank" rel="noopener noreferrer" class="vdd-section-link">
          Evo-SOTA 完整榜 →
        </a>
      </div>

      {sota.length === 0 ? (
        <p class="vdd-empty"><span data-tc>尚無 SOTA 數據</span><span data-sc>尚无 SOTA 数据</span></p>
      ) : (
        <div class="vdd-sota-groups">
          {benchmarks.map(bench => {
            const entries = sotaByBenchmark[bench].sort((a, b) => b.value - a.value);
            const top = entries[0];
            const isSaturated = saturatedBenchmarks.has(bench);
            return (
              <div class="sota-bench-block">
                <div class="sota-bench-header">
                  <div class="sota-bench-left">
                    <span class="sota-bench-name">
                      {top.leaderboard_url
                        ? <a href={top.leaderboard_url} target="_blank" rel="noopener noreferrer">{bench}</a>
                        : bench
                      }
                    </span>
                    {top.split && <span class="sota-bench-split">{top.split}</span>}
                    {isSaturated && <span class="sota-saturated-badge">飽和</span>}
                  </div>
                  <span class="sota-bench-metric">{top.metric}</span>
                </div>
                <div class="sota-table-wrap">
                  <table class="sota-table">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Model</th>
                        <th>Score</th>
                        <th>vs Prev</th>
                        <th>Date</th>
                        <th>Paper</th>
                      </tr>
                    </thead>
                    <tbody>
                      {entries.map((e, rank) => (
                        <tr class:list={['sota-row', rank === 0 && 'sota-row--top']}>
                          <td class="sota-rank">{rank + 1}</td>
                          <td class="sota-model">{e.model}</td>
                          <td class="sota-score">{e.value}</td>
                          <td class="sota-baseline">{e.baseline ?? '—'}</td>
                          <td class="sota-date">{e.date}</td>
                          <td class="sota-paper">
                            {e.paper_url
                              ? <a href={e.paper_url} target="_blank" rel="noopener noreferrer">arxiv →</a>
                              : '—'
                            }
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </section>

    <!-- ── Cross-domain navigation ── -->
    <nav class="xdomain-nav">
      <a href={`${base}/ai-deepdive/`} class="xdomain-link">
        <span data-tc>AI Agent 領域的工程實戰文章庫</span><span data-sc>AI Agent 领域的工程实战文章库</span>
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M3 8h10M9 4l4 4-4 4"/>
        </svg>
      </a>
    </nav>

  </div>
</BaseLayout>

