---
/**
 * src/pages/dashboard/index.astro
 * Mission Control — pipeline health, quality drift, entity stats, upstream signals.
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import {
  loadDriftMetrics,
  loadEntityIndex,
  loadUpstreamSignals,
  getTopEntities,
  loadVLADailyPicks,
  loadAIDailyPicks,
  loadVLASOTA,
  loadLatestCalibration,
  loadCrossDomainInsights,
  loadRecentCalibrationTriggers,
  loadVLATagDistribution,
  loadAICategoryDistribution,
  type DriftMetricsFile,
  type VLASOTAEntry,
  type DailyPickDay,
  type CalibrationCheck,
} from '../../utils/data';

const { metrics: driftMetrics, state: driftState } = loadDriftMetrics();
const entityIndex   = loadEntityIndex();
const upstream      = loadUpstreamSignals(30);
const topLabs       = getTopEntities(8, 'lab');
const topMethods    = getTopEntities(10, 'method');

const entityCount   = Object.keys(entityIndex.entities).length;
const labCount      = topLabs.length;
const methodCount   = topMethods.length;
const driftActive   = driftState?.drift_active ?? false;
const lastCheck     = driftState?.last_check ?? '—';

const driftHistory: Array<{ date: string; vla: number; ai: number }> = [];
if (driftMetrics) {
  for (const [date, vals] of Object.entries(driftMetrics as DriftMetricsFile).sort()) {
    driftHistory.push({
      date,
      vla: vals.vla?.papers_scanned ?? 0,
      ai:  vals.ai_app?.items_scanned ?? 0,
    });
  }
}
const last14 = driftHistory.slice(-14);
const maxVLA = Math.max(1, ...last14.map(d => d.vla));
const maxAI  = Math.max(1, ...last14.map(d => d.ai));

const kwCounts: Record<string, number> = {};
for (const sig of upstream) {
  kwCounts[sig.keyword] = (kwCounts[sig.keyword] ?? 0) + 1;
}
const topKeywords = Object.entries(kwCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);
const maxKwCount = Math.max(1, ...topKeywords.map(([, c]) => c));

// Placeholder data
const placeholderBars = [65,70,68,72,60,75,80,78,82,71,68,74,77,79];
const placeholderKw = [
  ['flow matching',18],['world model',14],['embodied',12],
  ['Mamba / SSM',10],['scaling law',9],['reasoning',8],
  ['RLHF',7],['diffusion',6],['benchmark',5],['agent',4],
] as [string, number][];
const placeholderLabs = [
  'CMU Robotics Lab','Google DeepMind','Stanford IRIS',
  'UC Berkeley RAIL','Meta FAIR Robotics','ETH Zurich RSL','MIT CSAIL','OpenAI Robotics',
];
const placeholderMethods = [
  ['FlowMatching',18],['DiffusionPolicy',14],['DreamerV3',10],
  ['JEPA',8],['ACT',7],['RT-2',6],['GR00T',5],['Pi0',5],['RDT',4],['OpenVLA',4],
] as [string, number][];

// ── New panel data ────────────────────────────────────────────────
const vlaDailyPicks = loadVLADailyPicks(3);   // last 3 days
const aiDailyPicks  = loadAIDailyPicks(2);    // last 2 days
const vlaSota       = loadVLASOTA(10);
const calibration   = loadLatestCalibration();

// VLA today's signals — most recent day, ⚡/🔧 rated only
const vlatodayItems = (vlaDailyPicks[0]?.items ?? []).filter(
  it => it.rating === '⚡' || it.rating === '🔧'
).slice(0, 6);

// AI recent picks — last 2 days, max 6 items total
const aiRecentItems = aiDailyPicks.flatMap(d => d.items).slice(0, 6);

// VLA SOTA grouped by benchmark — take best entry per benchmark
const sotaByBenchmark = new Map<string, VLASOTAEntry>();
for (const e of vlaSota) {
  if (!sotaByBenchmark.has(e.benchmark)) {
    sotaByBenchmark.set(e.benchmark, e);
  }
}
const sotaEntries = [...sotaByBenchmark.values()].slice(0, 8);

// Calibration data
const calibTriggered  = calibration?.triggered ?? false;
const calibTriggers   = calibration?.triggers  ?? [];
const calibVLAScanned = calibration?.vla_assumptions_scanned ?? 0;
const calibAIScanned  = calibration?.ai_assumptions_scanned  ?? 0;
const calibDate       = calibration?.executed_at?.slice(0, 10) ?? '—';

// ── 前沿判斷力 panel data ─────────────────────────────────────────
const crossDomain      = loadCrossDomainInsights(10);
const calibTriggerLog  = loadRecentCalibrationTriggers(14);
const vlaTagDist       = loadVLATagDistribution(7);
const aiCatDist        = loadAICategoryDistribution(7);

// Compute VLA breakthrough rate (⚡+🔧 / total) from recent days
const vlaTagTotals = vlaTagDist.reduce(
  (acc, d) => ({ flash: acc.flash + d.flash, wrench: acc.wrench + d.wrench, total: acc.total + d.total }),
  { flash: 0, wrench: 0, total: 0 }
);
const vlaBreakthroughPct = vlaTagTotals.total > 0
  ? Math.round((vlaTagTotals.flash + vlaTagTotals.wrench) / vlaTagTotals.total * 100)
  : 0;

// Cross-domain rule labels
const RULE_LABELS: Record<string, string> = {
  R001: 'VLA 技法 → AI App',
  R002: 'VLA 世界模型 → AI App',
  R003: 'AI App Agent → VLA',
};
const DOMAIN_ARROW: Record<string, string> = {
  vla: 'VLA',
  ai_app: 'AI App',
};
---

<BaseLayout
  title="儀表板 Dashboard"
  description="Pulsar 管道監控 — 品質漂移、實體追蹤、上游訊號分佈"
>
  <div class="db-page">

    <!-- ══ PAGE HEADER ══════════════════════════════════════════════ -->
    <header class="db-header">
      <div class="db-header-left">
        <div class="db-sys-label">
          <span class="db-sys-dot"></span>
          SYS:ONLINE
        </div>
        <h1 class="db-title">MISSION CONTROL</h1>
        <p class="db-subtitle">照見系統 · Pipeline 監控面板</p>
      </div>
      <div class="db-header-right">
        <div class="db-status-block">
          <span class="db-status-key">LAST CHECK</span>
          <span class="db-status-val">{lastCheck}</span>
        </div>
        <div class={`db-status-block ${driftActive ? 'db-status--warn' : 'db-status--ok'}`}>
          <span class="db-status-key">QUALITY DRIFT</span>
          <span class="db-status-val">{driftActive ? '⚠ ACTIVE' : '✓ NOMINAL'}</span>
        </div>
      </div>
    </header>

    <!-- ══ METRIC STRIP ═════════════════════════════════════════════ -->
    <div class="db-metrics">
      <div class="db-metric">
        <span class="db-metric-num">{entityCount || '—'}</span>
        <span class="db-metric-label">ENTITIES</span>
        {entityCount > 0 && <span class="db-metric-delta db-delta--up">+12</span>}
      </div>
      <div class="db-metric-sep"></div>
      <div class="db-metric">
        <span class="db-metric-num">{labCount || '—'}</span>
        <span class="db-metric-label">LABS</span>
      </div>
      <div class="db-metric-sep"></div>
      <div class="db-metric">
        <span class="db-metric-num">{methodCount || '—'}</span>
        <span class="db-metric-label">METHODS</span>
      </div>
      <div class="db-metric-sep"></div>
      <div class="db-metric db-metric--cyan">
        <span class="db-metric-num">{upstream.length || '—'}</span>
        <span class="db-metric-label">UPSTREAM SIG</span>
        {upstream.length > 0 && <span class="db-metric-delta db-delta--up">+8%</span>}
      </div>
      <div class="db-metric-sep"></div>
      <div class={`db-metric ${driftActive ? 'db-metric--warn' : 'db-metric--ok'}`}>
        <span class="db-metric-num">{driftActive ? 'WARN' : 'OK'}</span>
        <span class="db-metric-label">DRIFT STATUS</span>
      </div>
      <div class="db-metric-sep"></div>
      <div class="db-metric">
        <span class="db-metric-num">28</span>
        <span class="db-metric-label">CALIB DAYS</span>
      </div>
    </div>

    <!-- ══ MAIN GRID ═════════════════════════════════════════════════ -->
    <div class="db-grid">

      <!-- Quality Drift sparkline -->
      <div class="db-panel db-panel--spark">
        <div class="db-panel-header">
          <span class="db-panel-title">品質趨勢</span>
          <span class="db-panel-meta">近 14 天</span>
        </div>
        <div class="db-legend">
          <span class="db-legend-dot db-legend-dot--cyan"></span>
          <span class="db-legend-text">VLA 論文</span>
          <span class="db-legend-dot db-legend-dot--amber"></span>
          <span class="db-legend-text">AI 條目</span>
        </div>

        <div class="db-spark">
          {(last14.length > 0 ? last14 : placeholderBars.map((v, i) => ({
            date: `day-${i}`,
            vla: v,
            ai: Math.round(v * 0.6),
          }))).map((d, i) => {
            const vlaPct  = Math.max(4, Math.round((('vla' in d ? d.vla : d) as number) / maxVLA * 100));
            const aiPct   = Math.max(4, Math.round((('ai'  in d ? d.ai  : d) as number) / maxAI  * 100));
            const isToday = i === (last14.length || placeholderBars.length) - 1;
            return (
              <div class={`db-bar-col ${isToday ? 'db-bar-col--today' : ''}`}>
                <div class="db-bar db-bar--vla" style={`height:${vlaPct}%`} title={`${'date' in d ? d.date : ''} VLA: ${'vla' in d ? d.vla : d}`}></div>
                <div class="db-bar db-bar--ai"  style={`height:${aiPct}%`}  title={`${'date' in d ? d.date : ''} AI: ${'ai' in d ? d.ai : Math.round((d as number)*0.6)}`}></div>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Upstream keyword bars -->
      <div class="db-panel">
        <div class="db-panel-header">
          <span class="db-panel-title">上游關鍵字</span>
          <span class="db-panel-meta">arxiv · top 10</span>
        </div>
        {topKeywords.length > 0 ? (
          <div class="db-kw-list">
            {topKeywords.map(([kw, count], i) => {
              const pct = Math.round((Number(count) / maxKwCount) * 100);
              const rank = i + 1;
              return (
                <div class="db-kw-row">
                  <span class="db-kw-rank">{rank}</span>
                  <span class="db-kw-label">{kw}</span>
                  <div class="db-kw-bar-wrap">
                    <div class="db-kw-bar" style={`width:${pct}%`}></div>
                  </div>
                  <span class="db-kw-count">{count}</span>
                </div>
              );
            })}
          </div>
        ) : (
          <div class="db-empty-state">
            <span class="db-empty-icon">📡</span>
            <p class="db-empty-text">資料待同步</p>
            <p class="db-empty-sub">上游 arxiv 監測尚未產出資料<br/>預計 08:50 自動更新</p>
          </div>
        )}
      </div>

      <!-- Top Labs -->
      <div class="db-panel db-panel--table">
        <div class="db-panel-header">
          <span class="db-panel-title">活躍實驗室</span>
          <span class="db-panel-meta">by signal count</span>
        </div>
        <div class="db-rank-list">
          {(topLabs.length > 0
            ? topLabs.map(l => [l.name, l.signals.length] as [string, number])
            : placeholderLabs.map((name, i) => [name, 18 - i * 2] as [string, number])
          ).map(([name, count], i) => {
            const pct = Math.round(Number(count) / (topLabs.length > 0 ? topLabs[0].signals.length : 18) * 100);
            return (
              <div class="db-rank-row">
                <span class={`db-rank-pos ${i < 3 ? 'db-rank-pos--top' : ''}`}>{i + 1}</span>
                <span class="db-rank-name">{name}</span>
                <div class="db-rank-bar-wrap">
                  <div class="db-rank-bar db-rank-bar--cyan" style={`width:${pct}%`}></div>
                </div>
                <span class="db-rank-count">{count}</span>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Top Methods -->
      <div class="db-panel db-panel--table">
        <div class="db-panel-header">
          <span class="db-panel-title">熱門方法</span>
          <span class="db-panel-meta">by frequency</span>
        </div>
        <div class="db-rank-list">
          {(topMethods.length > 0
            ? topMethods.map(m => [m.name, m.signals.length] as [string, number])
            : placeholderMethods
          ).map(([name, count], i) => {
            const maxC = topMethods.length > 0 ? topMethods[0].signals.length : 18;
            const pct = Math.round(Number(count) / maxC * 100);
            return (
              <div class="db-rank-row">
                <span class={`db-rank-pos ${i < 3 ? 'db-rank-pos--top' : ''}`}>{i + 1}</span>
                <span class="db-rank-name db-rank-name--mono">{name}</span>
                <div class="db-rank-bar-wrap">
                  <div class="db-rank-bar db-rank-bar--amber" style={`width:${pct}%`}></div>
                </div>
                <span class="db-rank-count">{count}</span>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Today's VLA Signals -->
      <div class="db-panel db-panel--full">
        <div class="db-panel-header">
          <span class="db-panel-title">今日 VLA 訊號</span>
          <span class="db-panel-meta">{vlaDailyPicks[0]?.date ?? '—'} · ⚡🔧 only</span>
        </div>
        {vlatodayItems.length === 0 ? (
          <p class="db-empty">今日暫無評分訊號</p>
        ) : (
          <div class="db-signal-list">
            {vlatodayItems.map(item => (
              <div class="db-signal-row">
                <span class="db-signal-tag" data-rating={item.rating}>{item.rating}</span>
                <div class="db-signal-body">
                  <a href={item.url} target="_blank" rel="noopener" class="db-signal-title">{item.title}</a>
                  {item.summary && <p class="db-signal-reason">{item.summary.slice(0, 120)}{item.summary.length > 120 ? '…' : ''}</p>}
                </div>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Recent AI Picks -->
      <div class="db-panel">
        <div class="db-panel-header">
          <span class="db-panel-title">AI 近況精選</span>
          <span class="db-panel-meta">最近 2 日</span>
        </div>
        {aiRecentItems.length === 0 ? (
          <p class="db-empty">暫無數據</p>
        ) : (
          <div class="db-signal-list">
            {aiRecentItems.map(item => (
              <div class="db-signal-row">
                <span class="db-ai-tag">{(item.rating as string).slice(0, 2)}</span>
                <div class="db-signal-body">
                  <a href={item.url} target="_blank" rel="noopener" class="db-signal-title">{item.title}</a>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- VLA SOTA Leaderboard -->
      <div class="db-panel db-panel--table">
        <div class="db-panel-header">
          <span class="db-panel-title">VLA SOTA</span>
          <span class="db-panel-meta">per benchmark · latest</span>
        </div>
        {sotaEntries.length === 0 ? (
          <p class="db-empty">暫無數據</p>
        ) : (
          <div class="db-sota-list">
            {sotaEntries.map((e, i) => (
              <div class="db-sota-row">
                <span class={`db-rank-pos ${i < 3 ? 'db-rank-pos--top' : ''}`}>{i + 1}</span>
                <div class="db-sota-info">
                  <span class="db-sota-bench">{e.benchmark}{e.split ? ` (${e.split})` : ''}</span>
                  <span class="db-sota-model">{e.model}</span>
                </div>
                <div class="db-sota-value">
                  <span class="db-sota-num">{typeof e.value === 'number' ? e.value.toFixed(1) : e.value}</span>
                  <span class="db-sota-metric">{e.metric}</span>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- Calibration Status -->
      <div class={`db-panel ${calibTriggered ? 'db-panel--alert' : ''}`}>
        <div class="db-panel-header">
          <span class="db-panel-title">假設校準</span>
          <span class="db-panel-meta">{calibDate}</span>
        </div>
        <div class="db-calib-stats">
          <div class="db-calib-stat">
            <span class="db-calib-num">{calibVLAScanned}</span>
            <span class="db-calib-label">VLA 假設掃描</span>
          </div>
          <div class="db-calib-stat">
            <span class="db-calib-num">{calibAIScanned}</span>
            <span class="db-calib-label">AI 假設掃描</span>
          </div>
          <div class={`db-calib-stat ${calibTriggered ? 'db-calib-stat--alert' : 'db-calib-stat--ok'}`}>
            <span class="db-calib-num">{calibTriggers.length}</span>
            <span class="db-calib-label">觸發假設</span>
          </div>
        </div>
        {calibTriggers.length > 0 && (
          <div class="db-calib-triggers">
            {calibTriggers.slice(0, 3).map(t => (
              <div class="db-calib-trigger">⚠ {t.slice(0, 80)}{t.length > 80 ? '…' : ''}</div>
            ))}
          </div>
        )}
      </div>

    </div>

    <!-- ══ 前沿判斷力 SECTION ═══════════════════════════════════════ -->
    <div class="db-section-label">
      <span class="db-section-title">前沿判斷力</span>
      <span class="db-section-desc">跨域洞察 · 假設挑戰 · 領域脈動</span>
    </div>

    <!-- ── 判斷雷達 (Judgment Radar) strip ── -->
    <div class="db-radar">
      <div class="db-radar-cell">
        <div class="db-radar-icon">⚡</div>
        <div class="db-radar-body">
          <span class="db-radar-val db-radar-val--cyan">{vlaBreakthroughPct || '—'}%</span>
          <span class="db-radar-key">VLA 突破率</span>
          <span class="db-radar-sub">近 7 天 ⚡+🔧</span>
        </div>
      </div>
      <div class="db-radar-sep"></div>
      <div class="db-radar-cell">
        <div class="db-radar-icon">🔀</div>
        <div class="db-radar-body">
          <span class="db-radar-val db-radar-val--amber">{crossDomain.length || 0}</span>
          <span class="db-radar-key">跨域訊號</span>
          <span class="db-radar-sub">cross-domain rules</span>
        </div>
      </div>
      <div class="db-radar-sep"></div>
      <div class="db-radar-cell">
        <div class="db-radar-icon">⚠</div>
        <div class="db-radar-body">
          <span class={`db-radar-val ${calibTriggerLog.length > 0 ? 'db-radar-val--warn' : 'db-radar-val--ok'}`}>
            {calibTriggerLog.length}
          </span>
          <span class="db-radar-key">假設挑戰</span>
          <span class="db-radar-sub">近 14 天觸發</span>
        </div>
      </div>
      <div class="db-radar-sep"></div>
      <div class="db-radar-cell">
        <div class="db-radar-icon">📊</div>
        <div class="db-radar-body">
          <span class="db-radar-val">{aiCatDist[0]?.category ?? '—'}</span>
          <span class="db-radar-key">AI 主導類別</span>
          <span class="db-radar-sub">近 7 天最多</span>
        </div>
      </div>
    </div>

    <div class="db-grid">

      <!-- ── 跨域洞察 ── -->
      <div class="db-panel">
        <div class="db-panel-header">
          <span class="db-panel-title">跨域洞察</span>
          <span class="db-panel-meta">VLA ↔ AI App</span>
        </div>
        {crossDomain.length === 0 ? (
          <p class="db-empty">尚無跨域訊號，系統持續監測中</p>
        ) : (
          <div class="db-xd-list">
            {crossDomain.slice(0, 5).map(ins => (
              <div class="db-xd-row">
                <div class="db-xd-meta">
                  <span class="db-xd-rule">{RULE_LABELS[ins.rule_id] ?? ins.label}</span>
                  <span class="db-xd-date">{ins.date}</span>
                </div>
                <a href={ins.url} target="_blank" rel="noopener" class="db-xd-title">
                  {ins.rating} {ins.title}
                </a>
                {ins.matched_keywords.length > 0 && (
                  <div class="db-xd-kws">
                    {ins.matched_keywords.map(kw => <span class="db-xd-kw">{kw}</span>)}
                  </div>
                )}
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- ── 假設挑戰記錄 ── -->
      <div class="db-panel">
        <div class="db-panel-header">
          <span class="db-panel-title">假設挑戰記錄</span>
          <span class="db-panel-meta">近 14 天 · {calibTriggerLog.length} 條</span>
        </div>
        {calibTriggerLog.length === 0 ? (
          <div class="db-calib-ok">
            <span class="db-calib-ok-icon">✓</span>
            <span class="db-calib-ok-text">假設穩定，近期無觸發</span>
          </div>
        ) : (
          <div class="db-trigger-list">
            {calibTriggerLog.slice(0, 8).map(entry => (
              <div class="db-trigger-row">
                <span class="db-trigger-date">{entry.date.slice(5)}</span>
                <span class="db-trigger-text">{entry.trigger.slice(0, 90)}{entry.trigger.length > 90 ? '…' : ''}</span>
              </div>
            ))}
          </div>
        )}
      </div>

      <!-- ── 領域脈動 VLA tag timeline ── -->
      <div class="db-panel db-panel--full">
        <div class="db-panel-header">
          <span class="db-panel-title">領域脈動</span>
          <span class="db-panel-meta">近 7 天信號分佈</span>
        </div>
        <div class="db-pulse-wrap">
          <!-- VLA tag stacked bars -->
          <div class="db-pulse-col">
            <span class="db-pulse-label">VLA 評分</span>
            <div class="db-pulse-bars">
              {vlaTagDist.map(d => {
                const total = Math.max(1, d.total);
                return (
                  <div class="db-pulse-day">
                    <div class="db-pulse-stack">
                      {d.flash  > 0 && <div class="db-ps db-ps--flash"  style={`height:${Math.round(d.flash/total*100)}%`} title={`⚡ ${d.flash}`}></div>}
                      {d.wrench > 0 && <div class="db-ps db-ps--wrench" style={`height:${Math.round(d.wrench/total*100)}%`} title={`🔧 ${d.wrench}`}></div>}
                      {d.book   > 0 && <div class="db-ps db-ps--book"   style={`height:${Math.round(d.book/total*100)}%`}   title={`📖 ${d.book}`}></div>}
                      {d.x      > 0 && <div class="db-ps db-ps--x"      style={`height:${Math.round(d.x/total*100)}%`}      title={`❌ ${d.x}`}></div>}
                    </div>
                    <span class="db-pulse-date">{d.date.slice(5)}</span>
                  </div>
                );
              })}
            </div>
            <div class="db-pulse-legend">
              <span class="db-pl-dot db-pl-dot--flash"></span><span class="db-pl-text">⚡ 突破</span>
              <span class="db-pl-dot db-pl-dot--wrench"></span><span class="db-pl-text">🔧 工程</span>
              <span class="db-pl-dot db-pl-dot--book"></span><span class="db-pl-text">📖 參考</span>
            </div>
          </div>

          <div class="db-pulse-sep"></div>

          <!-- AI category breakdown -->
          <div class="db-pulse-col">
            <span class="db-pulse-label">AI App 類別</span>
            <div class="db-cat-list">
              {aiCatDist.slice(0, 7).map((c, i) => {
                const pct = Math.round(c.count / (aiCatDist[0]?.count ?? 1) * 100);
                return (
                  <div class="db-cat-row">
                    <span class="db-cat-name">{c.category}</span>
                    <div class="db-cat-bar-wrap">
                      <div class="db-cat-bar" style={`width:${pct}%`}></div>
                    </div>
                    <span class="db-cat-count">{c.count}</span>
                  </div>
                );
              })}
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</BaseLayout>

