                {driftOk ? '正常' : '注意'}
              </div>
            </div>
          </div>
        </div>

        <!-- Entity activity (real data) -->
        <div class="dash-card">
          <div class="dash-card-header">
            <span class="dash-card-title"><span data-tc>實體活躍度</span><span data-sc>实体活跃度</span></span>
