---
/**
 * ThemeToggle.astro
 * Sun/moon button. Reads/writes localStorage key 'pulsar-theme'.
 * Toggles .dark class on <html>; CSS variables do the rest.
 */
---

<button
  id="theme-toggle"
  type="button"
  class="theme-toggle"
  aria-label="切換深色模式"
  title="Toggle colour theme"
>
  <span id="theme-icon">◑</span>
</button>

<script is:inline>
  (function() {
    var btn  = document.getElementById('theme-toggle');
    var icon = document.getElementById('theme-icon');

    /* Sync icon with current theme on mount */
    function syncIcon() {
      if (icon) {
        icon.textContent = document.documentElement.classList.contains('dark') ? '☀' : '◑';
      }
    }
    syncIcon();

    btn && btn.addEventListener('click', function() {
      var isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('pulsar-theme', isDark ? 'dark' : 'light');
      syncIcon();
      if (btn) btn.setAttribute('aria-label', isDark ? '切換淺色模式' : '切換深色模式');
    });
  })();
</script>
