---
/**
 * src/pages/reports/[date].astro
 * Dynamic route — individual biweekly report view.
 * Generates one page per date found via loadBiweeklyReports().
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import { loadBiweeklyReports } from '../../utils/data';

// getStaticPaths — required for Astro static output
export async function getStaticPaths() {
  const reports = loadBiweeklyReports(60, false);
  return reports.map(r => ({
    params: { date: r.date },
    props:  { report: r },
  }));
}

const { report } = Astro.props;
const { date, content } = report;
const base = import.meta.env.BASE_URL;

// Load all reports for prev/next navigation
const allReports = loadBiweeklyReports(60, false);
const allDates = [...new Set(allReports.map(r => r.date))].sort();
const idx = allDates.indexOf(date);
const prevDate = idx > 0 ? allDates[idx - 1] : null;
const nextDate = idx < allDates.length - 1 ? allDates[idx + 1] : null;

// Format ISO date as Chinese: "2026年2月25日"
function formatDateZh(iso: string): string {
  const [year, month, day] = iso.split('-').map(Number);
  return `${year}年${month}月${day}日`;
}

// Format ISO date as numeric with dots: "2026.02.25"
function formatDateNumeric(iso: string): string {
  const [y, m, d] = iso.split('-');
  return `${y}.${m}.${d}`;
}

// Compute a biweekly period label: e.g. "2026.02.12 – 02.25"
function formatPeriod(iso: string): string {
  const end   = new Date(iso);
  const start = new Date(end);
  start.setDate(start.getDate() - 13);
  const sm = String(start.getMonth() + 1).padStart(2, '0');
  const sd = String(start.getDate()).padStart(2, '0');
  const em = String(end.getMonth() + 1).padStart(2, '0');
  const ed = String(end.getDate()).padStart(2, '0');
  const ey = end.getFullYear();
  return `${ey}.${sm}.${sd} – ${em}.${ed}`;
}
---

<BaseLayout
  title={`雙週報告 ${date} — PULSAR`}
  description={`PULSAR 雙週報告 ${formatDateZh(date)} — VLA 進展、AI 應用、社交情報與校準分析`}
>
  <div class="report-page page-container">

    <!-- ── Breadcrumb ── -->
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href={base} class="breadcrumb-link">首頁</a>
      <span class="breadcrumb-sep">/</span>
      <a href={`${base}/reports`} class="breadcrumb-link">雙週報告</a>
      <span class="breadcrumb-sep">/</span>
      <span class="breadcrumb-current">{date}</span>
    </nav>

    <!-- ── Page header ── -->
    <header class="report-header fade-in-1">
      <div class="report-overline">
        <span class="overline-badge">雙週報告</span>
        <span class="overline-sep">|</span>
        <span class="overline-period">{formatPeriod(date)}</span>
      </div>

      <h1 class="report-title">
        深度分析 · {formatDateZh(date)}
      </h1>

      <div class="report-meta-row">
        <span class="meta-tag meta-tag--ai">AI App線</span>
        <span class="meta-tag meta-tag--vla">VLA線</span>
        <span class="meta-tag meta-tag--default">社交情報</span>
        <span class="meta-tag meta-tag--default">校準</span>
      </div>

      <hr class="report-rule" />
    </header>

    <!-- ── Detail breadcrumb (replaces domain-nav; reports span both domains) ── -->
    <nav class="detail-breadcrumb" aria-label="麵包屑">
      <a href={`${base}`} class="bc-link">首頁</a>
      <span class="bc-sep">›</span>
      <a href={`${base}reports`} class="bc-link">雙週報告</a>
      <span class="bc-sep">›</span>
      <span class="bc-current">{date}</span>
    </nav>

    <!-- ── Report body ── -->
    <article class="report-article">
      {content
        ? <pre class="report-pre">{content}</pre>
        : (
          <div class="report-empty">
            <span class="empty-icon">▣</span>
            <p class="empty-title">CONTENT PENDING</p>
            <p class="empty-sub">報告內容尚未同步 — pipeline 自動生成中</p>
          </div>
        )
      }
    </article>

    <!-- ── Prev / next report pagination ── -->
    <div class="report-pagination">
      {prevDate ? (
        <a href={`${base}reports/${prevDate}`} class="rpag-btn rpag-btn--prev">
          ← {prevDate}
        </a>
      ) : <span />}
      <a href={`${base}reports`} class="rpag-btn rpag-btn--list">報告列表</a>
      {nextDate ? (
        <a href={`${base}reports/${nextDate}`} class="rpag-btn rpag-btn--next">
          {nextDate} →
        </a>
      ) : <span />}
    </div>

    <!-- ── Back link ── -->
    <div class="back-row">
      <a href={`${base}reports`} class="back-link">
        <span class="back-arrow">←</span> 返回報告列表
      </a>
    </div>

  </div>
</BaseLayout>

<style>
/* ============================================================
   REPORT DETAIL PAGE
   Scoped CSS: only affects this page
============================================================ */

/* ── Page wrapper ── */
.report-page {
  padding-top: 60px;
  padding-bottom: 80px;
}

/* ── Breadcrumb ── */
.breadcrumb {
  margin-bottom: 2rem;
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.72rem;
  color: var(--text-tertiary);
  display: flex;
  align-items: center;
  gap: 0.25rem;
  flex-wrap: wrap;
}

.breadcrumb-link {
  color: var(--text-tertiary);
  text-decoration: none;
  transition: color 0.2s;
}

.breadcrumb-link:hover {
  color: var(--text-secondary);
  opacity: 1;
}

.breadcrumb-sep {
  color: var(--border);
  margin: 0 0.2rem;
}

.breadcrumb-current {
  color: var(--text-secondary);
  font-weight: 600;
}

/* ── Page header ── */
.report-header {
  margin-bottom: 28px;
}

.report-overline {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 14px;
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.62rem;
  letter-spacing: 0.16em;
  text-transform: uppercase;
}

.overline-badge {
  color: var(--accent-amber);
  background: var(--accent-amber-bg);
  border: 1px solid rgba(212,145,10,0.25);
  padding: 2px 8px;
  border-radius: 3px;
  font-weight: 600;
}

.overline-sep {
  color: var(--border);
  opacity: 0.5;
}

.overline-period {
  color: var(--text-tertiary);
  letter-spacing: 0.06em;
}

.report-title {
  /* Override global h1 with serif style matching reports/index */
  font-family: 'Georgia', 'Songti SC', 'SimSun', serif !important;
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 700;
  letter-spacing: -0.02em;
  line-height: 1.15;
  color: var(--text-primary);
  margin-bottom: 16px;
}

.report-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 24px;
}

.meta-tag {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.58rem;
  font-weight: 600;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  padding: 2px 8px;
  border-radius: 3px;
  border: 1px solid;
}

.meta-tag--ai {
  color: var(--accent-amber);
  background: var(--accent-amber-bg);
  border-color: rgba(212,145,10,0.3);
}

.meta-tag--vla {
  color: var(--accent-cyan);
  background: var(--accent-cyan-bg);
  border-color: rgba(14,165,179,0.3);
}

.meta-tag--default {
  color: var(--text-tertiary);
  background: transparent;
  border-color: var(--border);
}

.report-rule {
  border: none;
  border-top: 1px solid var(--border);
  position: relative;
}

.report-rule::before {
  content: '';
  position: absolute;
  top: -1px;
  left: 0;
  width: 60px;
  height: 1px;
  background: var(--accent-amber);
}

/* ── Detail breadcrumb (replaces domain-nav on report detail pages) ── */
.detail-breadcrumb {
  display: flex;
  align-items: center;
  gap: 0.25rem;
  flex-wrap: wrap;
  margin-bottom: 32px;
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.72rem;
  color: var(--text-tertiary);
  border-bottom: 1px solid var(--border);
  padding-bottom: 12px;
}

.bc-link {
  color: var(--text-tertiary);
  text-decoration: none;
  transition: color 0.2s;
}

.bc-link:hover {
  color: var(--accent-amber);
  opacity: 1;
}

.bc-sep {
  color: var(--border);
  margin: 0 0.2rem;
}

.bc-current {
  color: var(--text-secondary);
  font-weight: 600;
}

/* ── Prev / next pagination ── */
.report-pagination {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
  margin: 32px 0 16px;
  flex-wrap: wrap;
}

.rpag-btn {
  font-family: 'Menlo', 'Consolas', monospace;
  font-size: 0.68rem;
  letter-spacing: 0.06em;
  padding: 6px 14px;
  border: 1px solid var(--border);
  border-radius: 6px;
  text-decoration: none;
  color: var(--text-secondary);
  background: var(--surface);
  transition: border-color 0.15s, color 0.15s;
}

.rpag-btn:hover {
  border-color: var(--accent-amber);
  color: var(--accent-amber);
  opacity: 1;
}

.rpag-btn--list {
  border-style: dashed;
}

/* ── Report article ── */
.report-article {
  max-width: 720px;
  margin-bottom: 48px;
}

/* Monospace pre — used when no markdown renderer is available */
.report-pre {
  white-space: pre-wrap;
  word-break: break-word;
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.8rem;
  line-height: 1.75;
  color: var(--text-secondary);
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 24px 28px;
  overflow-x: auto;
}

/* Prose styles — used if content is rendered as HTML via set:html */
.report-body {
  max-width: 720px;
  line-height: 1.8;
  font-size: 0.92rem;
  color: var(--text-secondary);
  font-family: 'PingFang SC', 'Microsoft YaHei', 'Hiragino Sans GB', sans-serif;
}

.report-body h1,
.report-body h2,
.report-body h3,
.report-body h4 {
  font-family: 'Georgia', 'Songti SC', 'SimSun', serif;
  color: var(--text-primary);
  margin-top: 2em;
  margin-bottom: 0.6em;
  line-height: 1.25;
}

.report-body h1 { font-size: 1.4rem; }
.report-body h2 { font-size: 1.2rem; }
.report-body h3 { font-size: 1.05rem; }

.report-body p  { margin-bottom: 1em; }

.report-body a {
  color: var(--accent-amber);
  text-decoration: none;
  border-bottom: 1px dotted var(--accent-amber);
}

.report-body a:hover {
  opacity: 0.8;
}

.report-body ul,
.report-body ol {
  padding-left: 1.4em;
  margin-bottom: 1em;
}

.report-body li {
  margin-bottom: 0.35em;
}

.report-body code {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.82em;
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: 1px 5px;
}

.report-body blockquote {
  border-left: 3px solid var(--accent-amber);
  padding-left: 16px;
  margin: 1.2em 0;
  color: var(--text-tertiary);
  font-style: italic;
}

.report-body hr {
  border: none;
  border-top: 1px solid var(--border);
  margin: 2em 0;
}

/* ── Empty state ── */
.report-empty {
  padding: 60px 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12px;
  text-align: center;
}

.empty-icon {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 2rem;
  color: var(--border);
  margin-bottom: 8px;
}

.empty-title {
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.72rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: var(--text-tertiary);
}

.empty-sub {
  font-family: 'PingFang SC', 'Microsoft YaHei', 'Hiragino Sans GB', sans-serif;
  font-size: 0.85rem;
  color: var(--text-tertiary);
  max-width: 340px;
  line-height: 1.7;
}

/* ── Back link ── */
.back-row {
  padding-top: 20px;
  border-top: 1px solid var(--border-subtle);
}

.back-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: 'Menlo', 'Consolas', 'Courier New', monospace;
  font-size: 0.7rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  color: var(--text-tertiary);
  text-decoration: none;
  transition: color 0.2s;
}

.back-link:hover {
  color: var(--accent-amber);
  opacity: 1;
}

.back-arrow {
  display: inline-block;
  transition: transform 0.2s;
}

.back-link:hover .back-arrow {
  transform: translateX(-3px);
}

/* ── Responsive ── */
@media (max-width: 640px) {
  .report-title {
    font-size: clamp(1.4rem, 7vw, 2rem);
  }

  .report-pre {
    padding: 16px 16px;
    font-size: 0.75rem;
  }

  .report-pagination {
    gap: 8px;
  }

  .rpag-btn {
    font-size: 0.63rem;
    padding: 5px 10px;
  }
}
</style>
